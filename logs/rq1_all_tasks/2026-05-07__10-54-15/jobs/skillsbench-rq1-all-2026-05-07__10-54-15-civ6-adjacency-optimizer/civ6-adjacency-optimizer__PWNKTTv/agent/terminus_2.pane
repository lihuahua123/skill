[?2004l [?2004h> # Calculate adjacency bonuses for each tile
[?2004lt[?2004h> def get_tile_value(tile):
[?2004l  [?2004h>     """Get base value for adjacency calculations"""
[?2004l[?2004h>     value = 0
[?2004l[?2004h>     bonus_sources = []
[?2004l[?2004h>     
[?2004l[?2004h>     terrain = tile.get('terrain', '')
[?2004l[?2004h>     feature = tile.get('feature', '')
[?2004l,[?2004h>     has_river = tile.get('has_river', False)
[?2004l[?2004h>     
[?2004l[?2004h>     # Mountains for Campus/Holy Site
[?2004l[?2004h>     if terrain == 'TERRAIN_GRASS_MOUNTAIN':
[?2004l[?2004h>         value += 1
[?2004l[?2004h>         bonus_sources.append('mountain')
[?2004l[?2004h>     
[?2004l[?2004h>     # Geothermal Fissure for Campus
[?2004l[?2004h>     if feature == 'FEATURE_GEOTHERMAL_FISSURE':
