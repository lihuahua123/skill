def _normalize_coords(coords) -> List[Tuple[int, int]]:
    """Normalize coordinates to a list of (x, y) tuples.

    Supports:
        [x, y]              -> [(x, y)]
        [[x1, y1], [x2, y2]] -> [(x1, y1), (x2, y2)]
    """
