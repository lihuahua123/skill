[?2004l[?2004h> import sqlite3
[?2004l[?2004h> import os
[?2004l[?2004h> import json
[?2004l[?2004h> from collections import defaultdict
[?2004l[?2004h> 
[?2004l[?2004h> # Hex grid utilities for offset coordinates (odd-r)
[?2004l[?2004h> def get_hex_neighbors(x, y):
[?2004l[?2004h>     """Get 6 neighbors in odd-r offset coordinates"""
[?2004l[?2004h>     if y % 2 == 1:  # odd row
[?2004l[?2004h>         return [
[?2004l[?2004h>             (x+1, y),   # E
[?2004l[?2004h>             (x+1, y-1), # NE
[?2004l[?2004h>             (x+1, y+1), # SE
[?2004l[?2004h>             (x-1, y),   # W
[?2004l[?2004h>             (x, y-1),   # NW
[?2004l[?2004h>             (x, y+1),   # SW
[?2004l[?2004h>         ]
[?2004l[?2004h>     else:  # even row
[?2004l[?2004h>         return [
[?2004l[?2004h>             (x+1, y),   # E
[?2004l[?2004h>             (x, y-1),   # NE
[?2004l[?2004h>             (x, y+1),   # SE
[?2004l[?2004h>             (x-1, y),   # W
[?2004l[?2004h>             (x-1, y-1), # NW
[?2004l[?2004h>             (x-1, y+1), # SW
[?2004l[?2004h>         ]
[?2004l[?2004h> 
[?2004l[?2004h> def hex_distance(x1, y1, x2, y2):
[?2004l[?2004h>     """Calculate hex distance between two points"""
[?2004l[?2004h>     # Convert to cube coordinates
[?2004l[?2004h>     def to_cube(x, y):
[?2004l[?2004h>         z = -x - y
[?2004l[?2004h>         if y % 2 == 1:  # odd-r
[?2004l[?2004h>             x_cube = x - (y - 1) // 2
[?2004l[?2004h>         else:  # even-r
[?2004l[?2004h>             x_cube = x - y // 2
[?2004l[?2004h>         return x_cube, y, z
[?2004l[?2004h>     cx1, cy1, cz1 = to_cube(x1, y1)
[?2004l[?2004h>     cx2, cy2, cz2 = to_cube(x2, y2)
[?2004l[?2004h>     return max(abs(cx1 - cx2), abs(cy1 - cy2), abs(cz1 - cz2))
[?2004l[?2004h> 
[?2004l[?2004h> def get_tiles_in_range(cx, cy, max_dist):
[?2004l[?2004h>     """Get all tiles within range of a center"""
[?2004l[?2004h>     result = []
[?2004l[?2004h>     for dy in range(-max_dist, max_dist + 1):
[?2004l[?2004h>         for dx in range(-max_dist, max_dist + 1):
[?2004l[?2004h>             x, y = cx + dx, cy + dy
[?2004l[?2004h>             if hex_distance(cx, cy, x, y) <= max_dist:
[?2004l[?2004h>                 result.append((x, y))
[?2004l[?2004h>     return result
[?2004l[?2004h> 
[?2004l[?2004h> # Load map
[?2004l[?2004h> dbpath = None
[?2004l[?2004h> for f in os.listdir('/data/maps'):
[?2004l[?2004h>     fp = '/data/maps/' + f
[?2004l[?2004h>     if os.path.getsize(fp) > 0:
[?2004l[?2004h>         dbpath = fp
[?2004l[?2004h>         break
[?2004l[?2004h> 
[?2004l[?2004h> conn = sqlite3.connect(dbpath)
[?2004l[?2004h> cursor = conn.cursor()
[?2004l[?2004h> cursor.execute("SELECT * FROM Map LIMIT 1")
[?2004l[?2004h> _, width, height = cursor.fetchone()[0], cursor.fetchone()[1], cursor.fetchone()[2]
[?2004l[?2004h> 
[?2004l[?2004h> # Load plots
