[?2004ll[?2004h>         bonus_sources.append('geothermal')
[?2004l[?2004h>     
[?2004lch[?2004h>     # Reef for Campus
[?2004l[?2004h>     if feature == 'FEATURE_REEF':
[?2004l[?2004h>         value += 2
[?2004lt([?2004h>         bonus_sources.append('reef')
[?2004l[?2004h>     
[?2004l[?2004h>     # Woods for Holy Site
[?2004l[?2004h>     if feature == 'FEATURE_FOREST':
[?2004lb[?2004h>         value += 0.5  # Floor separately
[?2004lr[?2004h>         bonus_sources.append('forest')
[?2004l[?2004h>     
[?2004l[?2004h>     # Rainforest for Campus
[?2004ly[?2004h>     if feature in ['FEATURE_JUNGLE', 'FEATURE_RAINFOREST']:
[?2004l[?2004h>         value += 0.5  # Floor separately
[?2004l[?2004h>         bonus_sources.append('rainforest')
