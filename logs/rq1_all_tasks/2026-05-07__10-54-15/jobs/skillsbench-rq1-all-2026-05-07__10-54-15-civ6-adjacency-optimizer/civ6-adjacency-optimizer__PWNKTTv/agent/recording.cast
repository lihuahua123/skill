[459.520033, "o", "\u001b[?2004h> "]
[459.520108, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[459.520222, "o", "    terrain = tile.get('terrain', '')\r\n\u001b[?2004l\r"]
[459.520288, "o", "\u001b[?2004h> "]
[459.520386, "o", "    feature = tile.get('feature', '')\r\n\u001b[?2004l\r,\u001b[?2004h> "]
[459.520629, "o", "    has_river = tile.get('has_river', False)\r\n\u001b[?2004l\r\u001b[?2004h"]
[459.520692, "o", ">     \r\n\u001b[?2004l\r"]
[459.520764, "o", "\u001b[?2004h> "]
[459.520841, "o", "    # Mountains for Campus/Holy Site\r\n\u001b[?2004l\r\u001b[?2004h"]
[459.520906, "o", "> "]
[459.521014, "o", "    if terrain == 'TERRAIN_GRASS_MOUNTAIN':\r\n\u001b[?2004l\r\u001b[?2004h> "]
[459.521128, "o", "        value += 1\r\n\u001b[?2004l\r\u001b[?2004h"]
[459.521208, "o", "> "]
