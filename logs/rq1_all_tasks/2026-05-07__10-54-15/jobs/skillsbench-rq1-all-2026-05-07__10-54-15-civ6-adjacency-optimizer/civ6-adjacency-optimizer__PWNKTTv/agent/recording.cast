[459.529745, "o", "> "]
[459.529907, "o", "        if tile.get('feature') == 'FEATURE_GEOTHERMAL_FISSURE':\r\n\u001b[?2004l\r\u001b[?2004h"]
[459.529969, "o", "> "]
[459.530034, "o", "            continue\r\n\u001b[?2004l\r"]
[459.530083, "o", "\u001b[?2004h> "]
