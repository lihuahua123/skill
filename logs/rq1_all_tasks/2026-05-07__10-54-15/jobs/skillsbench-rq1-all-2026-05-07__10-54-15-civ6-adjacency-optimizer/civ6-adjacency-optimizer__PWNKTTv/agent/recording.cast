[314.479149, "i", "cat > /tmp/full_map.py << 'ENDSCRIPT'\nimport sqlite3\nimport os\nimport json\n\ndbpath = None\nfor f in os.listdir('/data/maps'):\n    fp = '/data/maps/' + f\n    if os.path.getsize(fp) > 0:\n        dbpath = fp\n        break\n\nconn = sqlite3.connect(dbpath)\ncursor = conn.cursor()\n\n# Get dimensions\ncursor.execute(\"SELECT * FROM Map LIMIT 1\")\nmap_row = cursor.fetchone()\n_, width, height = map_row[0], map_row[1], map_row[2]\n\n# Extract all plots\ncursor.execute(\"SELECT * FROM Plots ORDER BY ID\")\nplots = {}\nfor row in cursor.fetchall():\n    pid, terrain, continent, impassable = row\n    x = pid % width\n    y = pid // width\n    plots[pid] = {'x': x, 'y': y, 'terrain': terrain, 'continent': continent, 'impassable': bool(impassable)}\n\n# Extract features\ncursor.execute(\"SELECT * FROM PlotFeatures\")\nfor row in cursor.fetchall():\n    pid, feature = row\n    if pid in plots:\n        plots[pid]['feature'] = feature\n\n# Extract rivers (bidirectional)\nrivers = set()\ncursor.execute(\"SELECT * FROM PlotRivers\")\nfor row in cursor.fetchall():\n    pid = row[0]\n    is_ne, is_w, is_nw = bool(row[1]), bool(row[2]), bool(row[3])\n    if pid in plots:\n        plots[pid]['river_directions'] = {'NE': is_ne, 'W': is_w, 'NW': is_nw}\n        if is_ne: rivers.add((pid, 'NE'))\n        if is_w: rivers.add((pid, 'W'))\n        if is_nw: rivers.add((pid, 'NW'))\n\n# Extract resources\ncursor.execute(\"SELECT * FROM PlotResources\")\nfor row in cursor.fetchall():\n    print(\"Resource:\", row)\n\n# Find all land tiles\nland_tiles = [p for p in plots.values() if p['terrain'] not in ['TERRAIN_OCEAN']]\nprint(f\"\\nTotal land tiles: {len(land_tiles)}\")\n\n# Print land tiles with their details\nprint(\"\\nLand tiles details:\")\nfor t in sorted(land_tiles, key=lambda p: (p['y'], p['x'])):\n    feat = t.get('feature', 'NONE')\n    print(f\"  ({t['x']}, {t['y']}): {t['terrain']}, feature={feat}, river={t.get('river_directions', {})}\")\nENDSCRIPT\n"]
[314.479376, "o", "cat > /tmp/full_map.py << 'ENDSCRIPT'\r\n\u001b[?2004l\r"]
