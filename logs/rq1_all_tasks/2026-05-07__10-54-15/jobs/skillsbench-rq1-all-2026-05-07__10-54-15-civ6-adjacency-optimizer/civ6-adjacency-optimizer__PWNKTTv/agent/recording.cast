[459.5244, "o", "        value += 2  # Binary\r\n\u001b[?2004l\r\u001b[?2004h"]
[459.524467, "o", "> "]
[459.524567, "o", "        bonus_sources.append('river')\r\n\u001b[?2004l\r\u001b[?2004h"]
[459.524625, "o", ">     "]
[459.524681, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
