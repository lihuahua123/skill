[459.538728, "o", "> "]
[459.538806, "o", "        top_industrial = industrial_scores[0]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[459.538896, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[459.538959, "o", "    # Simple greedy: pick top 3 districts (excluding unique conflicts)\r\n\u001b[?2004l\r\u001b[?2004h"]
[459.539026, "o", "> "]
[459.539092, "o", "    all_top = []\r\n\u001b[?2004l\r\u001b[?2004h> "]
