[459.537931, "o", ">     # Score this center\r\n\u001b[?2004l\r"]
[459.537969, "o", "\u001b[?2004h> "]
[459.538006, "o", "    if campus_scores:\r\n\u001b[?2004l\r"]
[459.538128, "o", "\u001b[?2004h> "]
