[459.523415, "o", "> "]
[459.523623, "o", "    if feature in ['FEATURE_JUNGLE', 'FEATURE_RAINFOREST']:\r\n\u001b[?2004l\r"]
[459.523663, "o", "\u001b[?2004h> "]
