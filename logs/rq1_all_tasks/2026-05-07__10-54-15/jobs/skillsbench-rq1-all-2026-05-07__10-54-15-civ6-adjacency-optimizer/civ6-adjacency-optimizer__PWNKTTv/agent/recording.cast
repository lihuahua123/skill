[459.531997, "o", "> "]
[459.532033, "o", "    industrial_scores = []\r\n\u001b[?2004l\r\u001b[?2004h"]
[459.532116, "o", ">     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[459.532176, "o", "    for dx, dy in valid_districts:\r\n\u001b[?2004l\r\u001b[?2004h"]
