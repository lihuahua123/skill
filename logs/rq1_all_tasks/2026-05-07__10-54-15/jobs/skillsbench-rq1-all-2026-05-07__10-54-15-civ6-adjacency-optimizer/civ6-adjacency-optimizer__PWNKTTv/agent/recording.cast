[459.539255, "o", "        all_top.append(('CAMPUS', top_campus[0], top_campus[1]))\r\n\u001b[?2004l\r\u001b[?2004h"]
[459.539321, "o", "> "]
[459.539388, "o", "    if commercial_scores:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[459.539498, "o", "        all_top.append(('COMMERCIAL_HUB', top_commercial[0], top_commercial[1]))\r\n\u001b[?2004l\r\u001b[?2004h"]
[459.539553, "o", "> "]
[459.539621, "o", "    if industrial_scores:\r\n\u001b[?2004l\r\u001b[?2004h"]
[459.539685, "o", "> "]
[459.539772, "o", "        all_top.append(('INDUSTRIAL_ZONE', top_industrial[0], top_industrial[1]))\r\n\u001b[?2004l\r\u001b[?2004h"]
[459.539834, "o", ">     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[459.539906, "o", "    # Sort by bonus and take top 3\r\n\u001b[?2004l\r\u001b[?2004h"]
[459.539944, "o", "> "]
[459.540016, "o", "    all_top.sort(key=lambda x: -x[2])\r\n\u001b[?2004l\r\u001b[?2004h"]
[459.540073, "o", "> "]
[459.540116, "o", "    top3 = all_top[:3]\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r"]
[459.540154, "o", "\u001b[?2004h> "]
[459.540288, "o", "    # Calculate total score (need to account for +0.5 district adjacency)\r\n\u001b[?2004l\r\u001b[?2004h"]
[459.540351, "o", "> "]
[459.540419, "o", "    total = sum(x[2] for x in top3)\r\n\u001b[?2004l\r\u001b[?2004h> "]
