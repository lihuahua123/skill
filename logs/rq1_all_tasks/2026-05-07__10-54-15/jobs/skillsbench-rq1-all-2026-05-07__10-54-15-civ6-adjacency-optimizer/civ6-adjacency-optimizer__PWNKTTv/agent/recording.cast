[267.118087, "i", "cat > /tmp/explore_map.py << 'ENDSCRIPT'\nimport sqlite3\nimport os\nimport json\n\n# Find the correct map file\ndbpath = None\nfor f in os.listdir('/data/maps'):\n    fp = '/data/maps/' + f\n    if os.path.getsize(fp) > 0:\n        dbpath = fp\n        break\n\nprint(f\"Using: {dbpath}\")\nconn = sqlite3.connect(dbpath)\ncursor = conn.cursor()\n\n# Get Map table\ncursor.execute(\"SELECT * FROM Map LIMIT 1\")\nprint(\"Map:\", cursor.fetchall())\n\n# Get Plots\ncursor.execute(\"SELECT * FROM Plots LIMIT 5\")\nprint(\"\\nPlots:\")\nfor row in cursor.fetchall():\n    print(row)\n\n# Get PlotFeatures\ncursor.execute(\"SELECT * FROM PlotFeatures LIMIT 5\")\nprint(\"\\nPlotFeatures:\")\nfor row in cursor.fetchall():\n    print(row)\n\n# Get PlotRivers sample\ncursor.execute(\"SELECT * FROM PlotRivers LIMIT 5\")\nprint(\"\\nPlotRivers:\")\nfor row in cursor.fetchall():\n    print(row)\n\n# Get PlotResources sample\ncursor.execute(\"SELECT * FROM PlotResources LIMIT 5\")\nprint(\"\\nPlotResources:\")\nfor row in cursor.fetchall():\n    print(row)\nENDSCRIPT\n"]
