[901.41127, "o", "103:    data_dir: Optional[Path] = None,\r\n109:    2. Map file reference: {\"map_file\": \"maps/foo.Civ6Map\"}\r\n113:        data_dir: Base directory for resolving map_file paths\r\n116:    if \"map_file\" in scenario and data_dir:\r\n117:        map_path = data_dir / scenario[\"map_file\"]\r\n196:    data_dir: Optional[Path] = None,\r\n205:        data_dir: Base directory for resolving map_file paths\r\n218:    tiles = build_tiles_dict(scenario, data_dir)\r\n452:    # Determine data_dir from scenario_path\r\n453:    # Scenario is at /data/scenario_XX/scenario.json, so data_dir is /data\r\n454:    data_dir = scenario_path.parent.parent\r\n456:    result = evaluate_solution(scenario, solution, ground_truth, data_dir)\r\n"]
