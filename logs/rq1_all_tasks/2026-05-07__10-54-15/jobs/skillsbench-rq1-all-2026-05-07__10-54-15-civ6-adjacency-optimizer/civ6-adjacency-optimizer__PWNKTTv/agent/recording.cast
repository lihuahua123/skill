[459.532498, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h> "]
[459.53257, "o", "        # Get neighbor info\r\n\u001b[?2004l\r\u001b[?2004h> "]
[459.532661, "o", "        neighbor_tiles = [plots.get(n, {}) for n in neighbors]\r\n\u001b[?2004l\r\u001b[?2004h"]
[459.532718, "o", ">         \r\n\u001b[?2004l\r"]
[459.532802, "o", "\u001b[?2004h> "]
[459.532882, "o", "        # Campus: +2 geothermal/reef, +1 mountain, +0.5 rainforest\r\n\u001b[?2004l\r\u001b[?2004h"]
[459.532937, "o", "> "]
[459.533006, "o", "        campus_bonus = 0\r\n\u001b[?2004l\r\u001b[?2004h> "]
[459.533062, "o", "        for nt in neighbor_tiles:\r\n\u001b[?2004l\r\u001b[?2004h"]
[459.533118, "o", "> "]
[459.533207, "o", "            if nt.get('feature') == 'FEATURE_GEOTHERMAL_FISSURE':\r\n\u001b[?2004l\r\u001b[?2004h"]
[459.53327, "o", "> "]
[459.533337, "o", "                campus_bonus += 2\r\n\u001b[?2004l\r"]
[459.533404, "o", "\u001b[?2004h> "]
[459.533442, "o", "            elif nt.get('feature') == 'FEATURE_REEF':\r\n\u001b[?2004l\r"]
[459.533507, "o", "\u001b[?2004h> "]
[459.53354, "o", "                campus_bonus += 2\r\n\u001b[?2004l\r"]
[459.533579, "o", "\u001b[?2004h> "]
[459.533697, "o", "            elif nt.get('terrain') == 'TERRAIN_GRASS_MOUNTAIN':\r\n\u001b[?2004l\r\u001b[?2004h"]
[459.533754, "o", "> "]
[459.533806, "o", "                campus_bonus += 1\r\n\u001b[?2004l\r\u001b[?2004h"]
[459.53388, "o", "> "]
[459.533973, "o", "            elif nt.get('feature') in ['FEATURE_JUNGLE', 'FEATURE_RAINFOREST']:\r\n\u001b[?2004l\r"]
[459.534042, "o", "\u001b[?2004h> "]
[459.534109, "o", "                campus_bonus += 0.5\r\n\u001b[?2004l\r"]
[459.534176, "o", "\u001b[?2004h> "]
[459.534231, "o", "        campus_scores.append(((dx, dy), campus_bonus))\r\n\u001b[?2004l\r\u001b[?2004h"]
[459.534285, "o", ">         \r\n\u001b[?2004l\r"]
[459.53435, "o", "\u001b[?2004h> "]
[459.53443, "o", "        # Holy Site: +2 natural wonder, +1 mountain, +0.5 woods\r\n\u001b[?2004l\r\u001b[?2004h"]
[459.534485, "o", "> "]
[459.534552, "o", "        holysite_bonus = 0\r\n\u001b[?2004l\r\u001b[?2004h"]
[459.534619, "o", "> "]
[459.534683, "o", "        for nt in neighbor_tiles:\r\n\u001b[?2004l\r\u001b[?2004h> "]
