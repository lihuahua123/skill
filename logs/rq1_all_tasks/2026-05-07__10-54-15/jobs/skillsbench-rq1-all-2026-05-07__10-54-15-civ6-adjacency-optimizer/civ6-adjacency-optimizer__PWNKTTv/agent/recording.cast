[81.565878, "i", "python3 << 'EOF'\nimport sqlite3\nconn = sqlite3.connect('/data/maps/e2e_test_case_0 Civ6Map')\ncursor = conn.cursor()\n\n# Get total plots count to understand dimensions\ncursor.execute(\"SELECT COUNT(*) FROM Plots\")\nprint(\"Total plots:\", cursor.fetchone()[0])\n\n# Get some sample plots\ncursor.execute(\"SELECT * FROM Plots LIMIT 10\")\nprint(\"\\nSample plots:\")\nfor row in cursor.fetchall():\n    print(row)\n\n# Get plot features schema\ncursor.execute(\"PRAGMA table_info(PlotFeatures)\")\nprint(\"\\nPlotFeatures schema:\")\nfor row in cursor.fetchall():\n    print(row)\nEOF\n"]
