[459.519488, "o", "def get_tile_value(tile):\r\n\u001b[?2004l\r  "]
[459.51956, "o", "\u001b[?2004h> "]
[459.519769, "o", "    \"\"\"Get base value for adjacency calculations\"\"\"\r\n\u001b[?2004l\r"]
[459.519834, "o", "\u001b[?2004h> "]
[459.519887, "o", "    value = 0\r\n\u001b[?2004l\r\u001b[?2004h> "]
