[459.526393, "o", "> \r\n\u001b[?2004l\r \u001b[?2004h"]
[459.52643, "o", "> "]
[459.526624, "o", "print(f\"Valid city centers on main landmass: {len(valid_centers)}\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[459.526694, "o", "> \r\n\u001b[?2004l\re\u001b[?2004h> "]
[459.52685, "o", "# Analyze each center and find best district placements\r\n\u001b[?2004l\r\u001b[?2004h"]
[459.526916, "o", "> "]
[459.526964, "o", "best_solution = None\r\n\u001b[?2004l\r\u001b[?2004h"]
[459.527026, "o", "> "]
[459.527078, "o", "best_score = 0\r\n\u001b[?2004l\r\u001b[?2004h"]
[459.527129, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
[459.527167, "o", "> "]
[459.527258, "o", "for cx, cy in valid_centers:\r\n\u001b[?2004l\r"]
[459.527292, "o", "\u001b[?2004h> "]
[459.527429, "o", "    # Get all tiles within 3 range\r\n\u001b[?2004l\r"]
[459.527464, "o", "\u001b[?2004h> "]
[459.527641, "o", "    reachable = get_tiles_in_range(cx, cy, 3)\r\n\u001b[?2004l\r"]
[459.527722, "o", "\u001b[?2004h> "]
