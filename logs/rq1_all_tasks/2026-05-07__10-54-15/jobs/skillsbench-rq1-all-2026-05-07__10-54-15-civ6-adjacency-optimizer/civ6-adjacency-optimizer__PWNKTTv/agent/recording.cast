[459.508136, "i", "cat > /tmp/optimizer2.py << 'ENDSCRIPT'\nimport sqlite3\nimport os\nfrom collections import defaultdict\n\n# Hex grid utilities\ndef get_hex_neighbors(x, y):\n    if y % 2 == 1:\n        return [(x+1, y), (x+1, y-1), (x+1, y+1), (x-1, y), (x, y-1), (x, y+1)]\n    else:\n        return [(x+1, y), (x, y-1), (x, y+1), (x-1, y), (x-1, y-1), (x-1, y+1)]\n\ndef hex_distance(x1, y1, x2, y2):\n    def to_cube(x, y):\n        if y % 2 == 1:\n            x_cube = x - (y - 1) // 2\n        else:\n            x_cube = x - y // 2\n        return x_cube, y, -x_cube - y\n    cx1, cy1, cz1 = to_cube(x1, y1)\n    cx2, cy2, cz2 = to_cube(x2, y2)\n    return max(abs(cx1 - cx2), abs(cy1 - cy2), abs(cz1 - cz2))\n\ndef get_tiles_in_range(cx, cy, max_dist):\n    result = []\n    for dy in range(-max_dist, max_dist + 1):\n        for dx in range(-max_dist, max_dist + 1):\n            x, y = cx + dx, cy + dy\n            if hex_distance(cx, cy, x, y) <= max_dist:\n                result.append((x, y))\n    return result\n\n# Load map\ndbpath = None\nfor f in os.listdir('/data/maps'):\n    fp = '/data/maps/' + f\n    if os.path.getsize(fp) > 0:\n        dbpath = fp\n        break\n\nconn = sqlite3.connect(dbpath)\ncursor = conn.cursor()\ncursor.execute(\"SELECT * FROM Map LIMIT 1\")\nmap_row = cursor.fetchone()\n_, width, height = map_row[0], map_row[1], map_row[2]\n\n# Load plots\ncursor.execute(\"SELECT * FROM Plots ORDER BY ID\")\nplots = {}\nfor row in cursor.fetchall():\n    pid, terrain, continent, impassable = row\n    x, y = pid % width, pid // width\n    plots[(x, y)] = {'terrain': terrain, 'impassable': bool(impassable)}\n\n# Load features\ncursor.execute(\"SELECT * FROM PlotFeatures\")\nfor row in cursor.fetchall():\n    pid, feature = row\n    x, y = pid % width, pid // width\n    if (x, y) in plots:\n        plots[(x, y)]['feature'] = feature\n\n# Load rivers\ncursor.execute(\"SELECT * FROM PlotRivers\")\nfor row in cursor.fetchall():\n    pid = row[0]\n    x, y = pid % width, pid // width\n    if (x, y) in plots:\n        plots[(x, y)]['has_river'] = True\n\nprint(f\"Map: {width}x{height}\")\n\n# Find main landmass tiles (focus on central area)\nmain_tiles = [(x, y) for (x, y) in plots.items() if 18 <= x <= 28 and 10 <= y <= 18]\nprint(f\"Main landmass tiles: {len(main_tiles)}\")\n\n# Calculate adjacency bonuses for each tile\ndef get_tile_value(tile):\n    \"\"\"Get base value for adjacency calculations\"\"\"\n    value = 0\n    bonus_sources = []\n    \n    terrain = tile.get('terrain', '')\n    feature = tile.get('feature', '')\n    has_river = tile.get('has_river', False)\n    \n    # Mountains for Campus/Holy Site\n    if terrain == 'TERRAIN_GRASS_MOUNTAIN':\n        value += 1\n        bonus_sources.append('mountain')\n    \n    # Geothermal Fissure for Campus\n    if feature == 'FEATURE_GEOTHERMAL_FISSURE':\n        value += 2\n        bonus_sources.append('geothermal')\n    \n    # Reef for Campus\n    if feature == 'FEATURE_REEF':\n        value += 2\n        bonus_sources.append('reef')\n    \n    # Woods for Holy Site\n    if feature == 'FEATURE_FOREST':\n        value += 0.5  # Floor separately\n        bonus_sources.append('forest')\n    \n    # Rainforest for Campus\n    if feature in ['FEATURE_JUNGLE', 'FEATURE_RAINFOREST']:\n        value += 0.5  # Floor separately\n        bonus_sources.append('rainforest')\n    \n    # River for Commercial Hub\n    if has_river:\n        value += 2  # Binary\n        bonus_sources.append('river')\n    \n    return value, bonus_sources\n\n# Find valid city centers on main landmass\nvalid_centers = []\nfor (x, y) in main_tiles:\n    tile = plots[(x, y)]\n    if tile['terrain'] not in ['TERRAIN_OCEAN'] and not tile['impassable']:\n        if tile['terrain'] != 'TERRAIN_GRASS_MOUNTAIN':\n            if tile.get('feature') != 'FEATURE_GEOTHERMAL_FISSURE':\n                valid_centers.append((x, y))\n\nprint(f\"Valid city centers on main landmass: {len(valid_centers)}\")\n\n# Analyze each center and find best district placements\nbest_solution = None\nbest_score = 0\n\nfor cx, cy in valid_centers:\n    # Get all tiles within 3 range\n    reachable = get_tiles_in_range(cx, cy, 3)\n    reachable_tiles = {t: plots.get(t, {}) for t in reacha"]
[459.508299, "i", "ble if t in plots}\n    \n    # Find valid district placements\n    valid_districts = []\n    for (x, y), tile in reachable_tiles.items():\n        # Can't place on city center\n        if (x, y) == (cx, cy):\n            continue\n        # Can't place on mountains\n        if tile['terrain'] == 'TERRAIN_GRASS_MOUNTAIN':\n            continue\n        # Can't place on geothermal fissure\n        if tile.get('feature') == 'FEATURE_GEOTHERMAL_FISSURE':\n            continue\n        # Can't place on coast if not harbor\n        # All other tiles are valid\n        valid_districts.append((x, y))\n    \n    # Calculate adjacency for each district type\n    # Need to consider which districts get +0.5 from each other\n    \n    # For now, let's calculate base adjacency for each possible placement\n    campus_scores = []\n    holysite_scores = []\n    theater_scores = []\n    commercial_scores = []\n    industrial_scores = []\n    \n    for dx, dy in valid_districts:\n        tile = plots[(dx, dy)]\n        neighbors = get_hex_neighbors(dx, dy)\n        \n        # Get neighbor info\n        neighbor_tiles = [plots.get(n, {}) for n in neighbors]\n        \n        # Campus: +2 geothermal/reef, +1 mountain, +0.5 rainforest\n        campus_bonus = 0\n        for nt in neighbor_tiles:\n            if nt.get('feature') == 'FEATURE_GEOTHERMAL_FISSURE':\n                campus_bonus += 2\n            elif nt.get('feature') == 'FEATURE_REEF':\n                campus_bonus += 2\n            elif nt.get('terrain') == 'TERRAIN_GRASS_MOUNTAIN':\n                campus_bonus += 1\n            elif nt.get('feature') in ['FEATURE_JUNGLE', 'FEATURE_RAINFOREST']:\n                campus_bonus += 0.5\n        campus_scores.append(((dx, dy), campus_bonus))\n        \n        # Holy Site: +2 natural wonder, +1 mountain, +0.5 woods\n        holysite_bonus = 0\n        for nt in neighbor_tiles:\n            if nt.get('terrain') == 'TERRAIN_GRASS_MOUNTAIN':\n                holysite_bonus += 1\n            elif nt.get('feature') == 'FEATURE_FOREST':\n                holysite_bonus += 0.5\n        holysite_scores.append(((dx, dy), holysite_bonus))\n        \n        # Commercial Hub: +2 river, +2 harbor\n        commercial_bonus = 0\n        if tile.get('has_river'):\n            commercial_bonus += 2\n        for nt in neighbor_tiles:\n            if nt.get('terrain') == 'TERRAIN_COAST':\n                commercial_bonus += 2  # Harbor adjacency\n                break\n        commercial_scores.append(((dx, dy), commercial_bonus))\n        \n        # Industrial Zone: +1 district, +0.5 from features\n        industrial_bonus = 0\n        for nt in neighbor_tiles:\n            if nt.get('feature') == 'FEATURE_FOREST':\n                industrial_bonus += 0.5\n        industrial_scores.append(((dx, dy), industrial_bonus))\n    \n    # Find top placements for each type\n    campus_scores.sort(key=lambda x: -x[1])\n    holysite_scores.sort(key=lambda x: -x[1])\n    commercial_scores.sort(key=lambda x: -x[1])\n    industrial_scores.sort(key=lambda x: -x[1])\n    \n    # Score this center\n    if campus_scores:\n        top_campus = campus_scores[0]\n    if holysite_scores:\n        top_holysite = holysite_scores[0]\n    if commercial_scores:\n        top_commercial = commercial_scores[0]\n    if industrial_scores:\n        top_industrial = industrial_scores[0]\n    \n    # Simple greedy: pick top 3 districts (excluding unique conflicts)\n    all_top = []\n    if campus_scores:\n        all_top.append(('CAMPUS', top_campus[0], top_campus[1]))\n    if commercial_scores:\n        all_top.append(('COMMERCIAL_HUB', top_commercial[0], top_commercial[1]))\n    if industrial_scores:\n        all_top.append(('INDUSTRIAL_ZONE', top_industrial[0], top_industrial[1]))\n    \n    # Sort by bonus and take top 3\n    all_top.sort(key=lambda x: -x[2])\n    top3 = all_top[:3]\n    \n    # Calculate total score (need to account for +0.5 district adjacency)\n    total = sum(x[2] for x in top3)\n    # Add district-to-district bonuses (floor separately for 0.5 sources)\n    district_positions = [x[1] for x in top3]\n    district_bonus = 0\n    for i, pos1 in enumerate(district_p"]
[459.508417, "i", "ositions):\n        for pos2 in district_positions[i+1:]:\n            if pos2 in get_hex_neighbors(pos1[0], pos1[1]):\n                district_bonus += 0.5  # Each adjacent district pair = +0.5\n    \n    # Floor the 0.5 bonuses separately\n    total_with_district = total + district_bonus\n    \n    if total_with_district > best_score:\n        best_score = total_with_district\n        best_solution = {\n            'center': (cx, cy),\n            'districts': top3,\n            'raw_total': total,\n            'district_bonus': district_bonus,\n            'final_total': total_with_district\n        }\n\nprint(f\"\\nBest solution:\")\nprint(f\"City Center: {best_solution['center']}\")\nprint(f\"Districts: {best_solution['districts']}\")\nprint(f\"Raw total: {best_solution['raw_total']}\")\nprint(f\"District bonus: {best_solution['district_bonus']}\")\nprint(f\"Final total: {best_solution['final_total']}\")\nENDSCRIPT\n"]
