[459.521699, "o", "> "]
[459.521749, "o", "        value += 2\r\n\u001b[?2004l\rl\u001b[?2004h"]
[459.521783, "o", "> "]
[459.521941, "o", "        bonus_sources.append('geothermal')\r\n\u001b[?2004l\r"]
[459.521998, "o", "\u001b[?2004h>     \r\n\u001b[?2004l\rch"]
[459.522028, "o", "\u001b[?2004h> "]
[459.522091, "o", "    # Reef for Campus\r\n\u001b[?2004l\r"]
[459.52214, "o", "\u001b[?2004h> "]
[459.522228, "o", "    if feature == 'FEATURE_REEF':\r\n\u001b[?2004l\r"]
[459.522284, "o", "\u001b[?2004h> "]
[459.522336, "o", "        value += 2\r\n\u001b[?2004l\rt(\u001b[?2004h> "]
[459.522481, "o", "        bonus_sources.append('reef')\r\n\u001b[?2004l\r"]
[459.522538, "o", "\u001b[?2004h>     \r\n\u001b[?2004l\r"]
[459.522592, "o", "\u001b[?2004h> "]
[459.522652, "o", "    # Woods for Holy Site\r\n\u001b[?2004l\r"]
[459.522704, "o", "\u001b[?2004h> "]
[459.522825, "o", "    if feature == 'FEATURE_FOREST':\r\n\u001b[?2004l\rb\u001b[?2004h"]
[459.522886, "o", "> "]
[459.522991, "o", "        value += 0.5  # Floor separately\r\n\u001b[?2004l\rr\u001b[?2004h"]
[459.52304, "o", "> "]
[459.523169, "o", "        bonus_sources.append('forest')\r\n\u001b[?2004l\r"]
[459.523228, "o", "\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h"]
[459.523288, "o", "> "]
