[1297.626459, "o", "\u001b[31m\u001b[1m______________________________________________________ TestEvaluation.test_evaluate_scenario[scenario_3] _______________________________________________________\u001b[0m\r\n\r\nself = <test_outputs.TestEvaluation object at 0x7f0973b50910>, scenario_id = 'scenario_3'\r\n\r\n"]
[1297.626578, "o", "    @pytest.mark.parametrize(\"scenario_id\", SCENARIOS)\r\n    def test_evaluate_scenario(self, scenario_id):\r\n        \"\"\"\r\n"]
[1297.626615, "o", "        Evaluate solution for a scenario.\r\n    \r\n        Checks:\r\n        1. Solution is valid (placements legal)\r\n        2. Adjacency calculation is correct\r\n"]
[1297.626647, "o", "    \r\n        Writes score to file for reward calculation.\r\n        \"\"\"\r\n        from evaluate import evaluate_solution\r\n"]
[1297.626837, "o", "    \r\n        paths = get_paths(scenario_id)\r\n    \r\n        # Load files\r\n        if not paths[\"solution\"].exists():\r\n            # Write 0 score and fail\r\n            SCORE_DIR.mkdir(parents=True, exist_ok=True)\r\n            (SCORE_DIR / f\"{scenario_id}.txt\").write_text(\"0.0\")\r\n            pytest.fail(f\"Solution file not found: {paths['solution']}\")\r\n    \r\n        with open(paths[\"solution\"]) as f:\r\n            solution = json.load(f)\r\n        with open(paths[\"scenario\"]) as f:\r\n            scenario = json.load(f)\r\n        with open(paths[\"ground_truth\"]) as f:\r\n            ground_truth = json.load(f)\r\n    \r\n        # Run evaluation ONCE\r\n"]
[1297.626868, "o", "        result = evaluate_solution(scenario, solution, ground_truth, DATA_DIR)\r\n    \r\n        # Write score to file (0 if invalid)\r\n        score = result.score if result.valid else 0.0\r\n        SCORE_DIR.mkdir(parents=True, exist_ok=True)\r\n        (SCORE_DIR / f\"{scenario_id}.txt\").write_text(str(score))\r\n"]
[1297.626998, "o", "    \r\n        # Assert validity\r\n>       assert result.valid, f\"Invalid solution: {result.errors}\"\r\n\u001b[1m\u001b[31mE       AssertionError: Invalid solution: ['Total adjacency mismatch: submitted=20, calculated=17']\u001b[0m\r\n\u001b[1m\u001b[31mE       assert False\u001b[0m\r\n\u001b[1m\u001b[31mE        +  where False = EvaluationResult(valid=False, total_adjacency=17, optimal_adjacency=20, score=0.0, errors=['Total adjacency mismatch: submitted=20, calculated=17'], warnings=['Adjacency info for INDUSTRIAL_ZONE: submitted=9, calculated=8', 'Adjacency info for COMMERCIAL_HUB: submitted=5, calculated=3'], per_district={'CAMPUS@(21,14)': {'bonus': 6, 'breakdown': {'FEATURE_GEOTHERMAL_FISSURE': {'count': 1, 'bonus': 2, 'count_required': 1, 'bonus_per': 2, 'sources': ['FEATURE_GEOTHERMAL_FISSURE@(21,13)']}, 'FEATURE_REEF': {'count': 1, 'bonus': 2, 'count_required': 1, 'bonus_per': 2, 'sources': ['FEATURE_REEF@(20,14)']}, 'MOUNTAIN': {'count': 1, 'bonus': 1, 'count_required': 1, 'bonus_per': 1, 'sources': ['Mountain@(21,15)']}, 'FEATURE_JUNGLE': {'count': 2, 'bonus': 1, 'count_required': 2, 'bonus_per': 1, 'sources': ['FEATURE_JUNGLE@(20,13)', 'FEATURE_JUNGLE@(20,15)']}}}, 'INDUSTRIAL_ZONE@(23,16)': {'bonus': 8, 'breakdown': {'AQUEDUCT+BATH+DAM+CANAL': {'count': 3, 'bonus': 6, 'count_required': 1, 'bonus_per': 2, 'sources': ['DAM@(24,16)', 'AQUEDUCT@(23,15)', 'CANAL@(22,16)']}, 'DISTRICT': {'count': 5, 'bonus': 2, 'count_required': 2, 'bonus_per': 1, 'sources': ['District(DAM)@(24,16)', 'District(AQUEDUCT)@(23,15)', 'District(CITY_CENTER)@(22,15)', 'District(CANAL)@(22,16)', 'District(NEIGHBORHOOD)@(22,17)']}}}, 'AQUEDUCT@(23,15)': {'bonus': 0, 'breakdown': {}}, 'DAM@(24,16)': {'bonus': 0, 'breakdown': {}}, 'CANAL@(22,16)': {'bonus': 0, 'breakdown': {}}, 'COMMERCIAL_HUB@(23,14)': {'bonus': 3, 'breakdown': {'RIVER': {'count': 1, 'bonus': 2, 'sources': ['OnRiver']}, 'DISTRICT': {'count': 2, 'bonus': 1, 'count_required': 2, 'bonus_per': 1, '