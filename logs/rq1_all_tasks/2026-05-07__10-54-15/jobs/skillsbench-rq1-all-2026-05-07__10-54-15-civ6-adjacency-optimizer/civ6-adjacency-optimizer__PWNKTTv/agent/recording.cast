[559.092207, "o", "        if i < j and pos2 in get_hex_neighbors(pos1[0], pos1[1]):\r\n\u001b[?2004l\r"]
[559.092234, "o", "\u001b[?2004h> "]
[559.092297, "o", "            district_adj += 0.5\r\n\u001b[?2004l\r\u001b[?2004h> "]
[559.092382, "o", "            print(f\"Adjacent: {pos1} <-> {pos2}\")\r\n\u001b[?2004l\r\u001b[?2004h"]
