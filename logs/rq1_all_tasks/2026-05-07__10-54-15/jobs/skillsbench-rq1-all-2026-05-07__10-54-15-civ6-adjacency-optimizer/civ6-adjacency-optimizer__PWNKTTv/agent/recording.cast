[1172.218329, "i", "python3 -c \"\nimport sqlite3\nconn = sqlite3.connect('/tmp/map.db')\ncursor = conn.cursor()\ncursor.execute('SELECT * FROM Map LIMIT 1')\nrow = cursor.fetchone()\nwidth = row[1]\nheight = row[2]\nprint(f'Map size: {width}x{height}')\n\ncursor.execute('SELECT ID FROM PlotRivers')\nriver_ids = [r[0] for r in cursor.fetchall()]\nprint(f'River tiles: {len(river_ids)}')\n\n# Convert to coordinates\nriver_coords = []\nfor rid in river_ids:\n    x = rid % width\n    y = rid // width\n    river_coords.append((x, y))\n    \nprint('River coordinates:')\nfor coord in sorted(river_coords):\n    print(f'  {coord}')\n\n# Check if (23, 14) is on/near a river\ntarget = (23, 14)\nprint(f'\\nIs {target} a river tile:', target in river_coords)\n\"\n"]
