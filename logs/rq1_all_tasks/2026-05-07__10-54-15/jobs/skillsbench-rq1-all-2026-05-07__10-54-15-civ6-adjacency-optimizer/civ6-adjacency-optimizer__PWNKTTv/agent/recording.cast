[561.102309, "o", "Key tiles:\r\n  (21, 14): terrain=TERRAIN_GRASS, feature=None, river=None\r\n  (21, 13): terrain=TERRAIN_GRASS, feature=FEATURE_GEOTHERMAL_FISSURE, river=True\r\n  (21, 11): terrain=TERRAIN_COAST, feature=None, river=None\r\n  (21, 15): terrain=TERRAIN_GRASS_MOUNTAIN, feature=None, river=None\r\n  (20, 14): terrain=TERRAIN_COAST, feature=FEATURE_REEF, river=None\r\n"]
[561.102437, "o", "  (22, 14): terrain=TERRAIN_GRASS, feature=None, river=True\r\n  (22, 17): terrain=TERRAIN_PLAINS, feature=FEATURE_FLOODPLAINS_PLAINS, river=True\r\n  (23, 12): terrain=TERRAIN_GRASS, feature=None, river=None\r\nCAMPUS at (21, 14): geo=1, reef=1, mtn=1, rain=2 -> 5\r\nCOMM_HUB at (22, 17): river=True, harbor=True -> 4\r\n"]
[561.102474, "o", "IND_ZONE at (23, 12): forests=3 -> 0\r\n\r\nTotal: 5 + 4 + 0 = 9\r\n"]
