[459.530441, "o", "\u001b[?2004h> "]
[459.530533, "o", "        valid_districts.append((x, y))\r\n\u001b[?2004l\r"]
[459.530604, "o", "\u001b[?2004h> "]
[459.530674, "o", "    \r\n\u001b[?2004l\r \u001b[?2004h> "]
[459.530803, "o", "    # Calculate adjacency for each district type\r\n\u001b[?2004l\r\u001b[?2004h"]
[459.530874, "o", "> "]
[459.531055, "o", "    # Need to consider which districts get +0.5 from each other\r\n\u001b[?2004l\r"]
