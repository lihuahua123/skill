[1037.028547, "i", "python3 -c \"\nimport json\nwith open('/tmp/scenario_clean.json') as f:\n    data = json.load(f)\ntiles = data['tiles']\n\n# Count terrain types\nterrains = {}\nfeatures = {}\nfor tile in tiles:\n    t = tile.get('terrain', 'UNKNOWN')\n    terrains[t] = terrains.get(t, 0) + 1\n    f = tile.get('feature')\n    if f:\n        features[f] = features.get(f, 0) + 1\n\nprint('Terrain counts:', terrains)\nprint('Feature counts:', features)\n\n# Find tiles with mountains, geothermal, volcanic soil, forests\nspecial = []\nfor tile in tiles:\n    if tile.get('terrain') == 'MOUNTAIN':\n        special.append(('MOUNTAIN', tile['x'], tile['y']))\n    if tile.get('feature') in ['FEATURE_GEOTHERMAL_FISSURE', 'FEATURE_VOLCANIC_SOIL']:\n        special.append((tile.get('feature'), tile['x'], tile['y']))\n    if tile.get('is_hills'):\n        special.append(('HILLS', tile['x'], tile['y']))\n\nprint('\\nSpecial tiles:', special[:30])\n\"\n"]
