[525.044854, "i", "cat > /tmp/verify.py << 'ENDSCRIPT'\nimport sqlite3\nimport os\nimport math\n\n# Hex grid utilities\ndef get_hex_neighbors(x, y):\n    if y % 2 == 1:\n        return [(x+1, y), (x+1, y-1), (x+1, y+1), (x-1, y), (x, y-1), (x, y+1)]\n    else:\n        return [(x+1, y), (x, y-1), (x, y+1), (x-1, y), (x-1, y-1), (x-1, y+1)]\n\ndef hex_distance(x1, y1, x2, y2):\n    def to_cube(x, y):\n        if y % 2 == 1:\n            x_cube = x - (y - 1) // 2\n        else:\n            x_cube = x - y // 2\n        return x_cube, y, -x_cube - y\n    cx1, cy1, cz1 = to_cube(x1, y1)\n    cx2, cy2, cz2 = to_cube(x2, y2)\n    return max(abs(cx1 - cx2), abs(cy1 - cy2), abs(cz1 - cz2))\n\n# Load map\ndbpath = None\nfor f in os.listdir('/data/maps'):\n    fp = '/data/maps/' + f\n    if os.path.getsize(fp) > 0:\n        dbpath = fp\n        break\n\nconn = sqlite3.connect(dbpath)\ncursor = conn.cursor()\ncursor.execute(\"SELECT * FROM Map LIMIT 1\")\n_, width, height = cursor.fetchone()[0], cursor.fetchone()[1], cursor.fetchone()[2]\n\n# Load plots\ncursor.execute(\"SELECT * FROM Plots ORDER BY ID\")\nplots = {}\nfor row in cursor.fetchall():\n    pid, terrain, continent, impassable = row\n    x, y = pid % width, pid // width\n    plots[(x, y)] = {'terrain': terrain, 'impassable': bool(impassable)}\n\n# Load features\ncursor.execute(\"SELECT * FROM PlotFeatures\")\nfor row in cursor.fetchall():\n    pid, feature = row\n    x, y = pid % width, pid // width\n    if (x, y) in plots:\n        plots[(x, y)]['feature'] = feature\n\n# Load rivers\ncursor.execute(\"SELECT * FROM PlotRivers\")\nfor row in cursor.fetchall():\n    pid = row[0]\n    x, y = pid % width, pid // width\n    if (x, y) in plots:\n        plots[(x, y)]['has_river'] = True\n\nprint(\"Map details for key tiles:\")\nkey_tiles = [(21, 14), (21, 13), (21, 11), (21, 15), (20, 14), (22, 14), (22, 17), (23, 12)]\nfor t in key_tiles:\n    if t in plots:\n        tile = plots[t]\n        print(f\"  {t}: terrain={tile.get('terrain')}, feature={tile.get('feature')}, river={tile.get('has_river')}\")\n\n# Verify the solution\ncity_center = (22, 14)\ndistricts = {\n    'CAMPUS': (21, 14),\n    'COMMERCIAL_HUB': (22, 17),\n    'INDUSTRIAL_ZONE': (23, 12)\n}\n\nprint(f\"\\nVerifying solution with city center at {city_center}\")\n\ndef calculate_campus_adjacency(pos):\n    \"\"\"Calculate Campus adjacency bonus with proper floor separately\"\"\"\n    neighbors = get_hex_neighbors(pos[0], pos[1])\n    geothermal_count = 0\n    reef_count = 0\n    mountain_count = 0\n    rainforest_count = 0\n    \n    for n in neighbors:\n        if n in plots:\n            tile = plots[n]\n            if tile.get('feature') == 'FEATURE_GEOTHERMAL_FISSURE':\n                geothermal_count += 1\n            elif tile.get('feature') == 'FEATURE_REEF':\n                reef_count += 1\n            elif tile.get('terrain') == 'TERRAIN_GRASS_MOUNTAIN':\n                mountain_count += 1\n            elif tile.get('feature') in ['FEATURE_JUNGLE', 'FEATURE_RAINFOREST']:\n                rainforest_count += 1\n    \n    # +2 each geothermal/reef, +1 each mountain, +0.5 each rainforest (floored separately)\n    bonus = geothermal_count * 2 + reef_count * 2 + mountain_count * 1\n    bonus += sum(math.floor(0.5) for _ in range(rainforest_count))  # 0 each\n    \n    print(f\"  Campus at {pos}: geothermal={geothermal_count}, reef={reef_count}, mountain={mountain_count}, rainforest={rainforest_count}\")\n    print(f\"    geothermal*2={geothermal_count*2}, reef*2={reef_count*2}, mountain*1={mountain_count*1}, rainforest floor(0.5)*N={sum(math.floor(0.5) for _ in range(rainforest_count))}\")\n    return bonus\n\ndef calculate_commercial_adjacency(pos):\n    \"\"\"Calculate Commercial Hub adjacency bonus\"\"\"\n    tile = plots.get(pos, {})\n    has_river = tile.get('has_river', False)\n    \n    neighbors = get_hex_neighbors(pos[0], pos[1])\n    has_harbor = False\n    \n    # Check for harbor (coastal tile adjacent to city center or district)\n    # Harbor gives +2 to Commercial Hub\n    for n in neighbors:\n        if n in plots:\n            nt = plots[n]\n            if nt.get('terrain') == 'TERRAIN_COAST':\n                has_harbor = True\n                break\n    \n"]
[525.044912, "i", "    bonus = 2 if has_river else 0\n    bonus += 2 if has_harbor else 0\n    \n    print(f\"  Commercial Hub at {pos}: river={has_river}, harbor={has_harbor}\")\n    print(f\"    river*2={2 if has_river else 0}, harbor*2={2 if has_harbor else 0}\")\n    return bonus\n\ndef calculate_industrial_adjacency(pos):\n    \"\"\"Calculate Industrial Zone adjacency bonus with floor separately\"\"\"\n    neighbors = get_hex_neighbors(pos[0], pos[1])\n    forest_count = 0\n    quarry_count = 0\n    mine_count = 0\n    resource_count = 0\n    \n    for n in neighbors:\n        if n in plots:\n            tile = plots[n]\n            feat = tile.get('feature', '')\n            terrain = tile.get('terrain', '')\n            # Check for strategic resources (mines) - not in our map\n            # Check for bonus resources - not in our map\n            if feat == 'FEATURE_FOREST':\n                forest_count += 1\n    \n    # +1 per district (floor separately, so floor(1/2) = 0 for each)\n    # +0.5 per forest (floor separately)\n    bonus = 0\n    bonus += sum(math.floor(0.5) for _ in range(forest_count))  # 0 each\n    \n    print(f\"  Industrial Zone at {pos}: forests={forest_count}\")\n    print(f\"    forest floor(0.5)*N={sum(math.floor(0.5) for _ in range(forest_count))}\")\n    return bonus\n\n# Calculate base adjacency for each district\ncampus_bonus = calculate_campus_adjacency(districts['CAMPUS'])\ncommercial_bonus = calculate_commercial_adjacency(districts['COMMERCIAL_HUB'])\nindustrial_bonus = calculate_industrial_adjacency(districts['INDUSTRIAL_ZONE'])\n\nprint(f\"\\nBase adjacency: Campus={campus_bonus}, Commercial={commercial_bonus}, Industrial={industrial_bonus}\")\n\n# Add district-to-district adjacency (+0.5 each, floored separately)\ndistrict_positions = list(districts.values())\ndistrict_adj_bonus = 0\nfor i, pos1 in enumerate(district_positions):\n    for j, pos2 in enumerate(district_positions):\n        if i < j:\n            neighbors = get_hex_neighbors(pos1[0], pos1[1])\n            if pos2 in neighbors:\n                district_adj_bonus += 0.5\n                print(f\"  Districts {pos1} and {pos2} are adjacent, adding 0.5\")\n\n# Floor the district bonus separately (each +0.5 becomes floor(0.5) = 0)\nprint(f\"\\nDistrict adjacency bonus (before flooring): {district_adj_bonus}\")\nprint(f\"District adjacency bonus (after flooring each): {math.floor(district_adj_bonus) if district_adj_bonus < 1 else sum(math.floor(0.5) for _ in range(int(district_adj_bonus * 2)))}\")\n\n# Calculate total\nbase_total = campus_bonus + commercial_bonus + industrial_bonus\n# The +0.5 per district is already floored to 0\ntotal = base_total\n\nprint(f\"\\nFinal total: {total}\")\nENDSCRIPT\n"]
[525.045341, "o", "cat > /tmp/verify.py << 'ENDSCRIPT'\r\n\u001b[?2004l\r\u001b[?2004h> import sqlite3\r\n"]
[525.045492, "o", "\u001b[?2004l\r\u001b[?2004h> import os\r\n\u001b[?2004l\r\u001b[?2004h> "]
[525.045616, "o", "import math\r\n\u001b[?2004l\r \u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Hex grid utilities\r\n\u001b[?2004l\r"]
[525.045719, "o", "\u001b[?2004h> "]
[525.045852, "o", "def get_hex_neighbors(x, y):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[525.045964, "o", "    if y % 2 == 1:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[525.046305, "o", "        return [(x+1, y), (x+1, y-1), (x+1, y+1), (x-1, y), (x, y-1), (x, y+1)]\r\n\u001b[?2004l\r\u001b[?2004h"]
[525.046338, "o", "> "]
[525.046356, "o", "    else:\r\n\u001b[?2004l\r"]
[525.046375, "o", "\u001b[?2004h"]
[525.046395, "o", "> "]
[525.046749, "o", "        return [(x+1, y), (x, y-1), (x, y+1), (x-1, y), (x-1, y-1), (x-1, y+1)]\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[525.046797, "o", "\u001b[?2004h> "]
[525.046944, "o", "def hex_distance(x1, y1, x2, y2):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[525.047061, "o", "    def to_cube(x, y):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[525.047209, "o", "        if y % 2 == 1:\r\n\u001b[?2004l\r\u001b[?2004h"]
[525.047243, "o", "> "]
[525.047462, "o", "            x_cube = x - (y - 1) // 2\r\n\u001b[?2004l\res"]
[525.047558, "o", "\u001b[?2004h> "]
[525.047595, "o", "        else:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[525.047728, "o", "            x_cube = x - y // 2\r\n\u001b[?2004l\r\u001b[?2004h"]
[525.047849, "o", "> "]
[525.047924, "o", "        return x_cube, y, -x_cube - y\r\n\u001b[?2004l\r"]
[525.047992, "o", "\u001b[?2004h> "]
[525.048098, "o", "    cx1, cy1, cz1 = to_cube(x1, y1)\r\n\u001b[?2004l\r\u001b[?2004h"]
[525.048179, "o", "> "]
[525.048258, "o", "    cx2, cy2, cz2 = to_cube(x2, y2)\r\n\u001b[?2004l\r "]
[525.048313, "o", "\u001b[?2004h> "]
[525.048498, "o", "    return max(abs(cx1 - cx2), abs(cy1 - cy2), abs(cz1 - cz2))\r\n\u001b[?2004l\r\u001b[?2004h"]
[525.048563, "o", "> \r\n\u001b[?2004l\r \u001b[?2004h> "]
[525.04862, "o", "# Load map\r\n\u001b[?2004l\r\u001b[?2004h> "]
[525.048678, "o", "dbpath = None\r\n\u001b[?2004l\r"]
[525.048735, "o", "\u001b[?2004h> "]
[525.048875, "o", "for f in os.listdir('/data/maps'):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[525.04899, "o", "    fp = '/data/maps/' + f\r\n\u001b[?2004l\r"]
[525.04907, "o", "\u001b[?2004h> "]
[525.049181, "o", "    if os.path.getsize(fp) > 0:\r\n\u001b[?2004l\r\u001b[?2004h"]
[525.049332, "o", ">         dbpath = fp\r\n\u001b[?2004l\r"]
[525.049411, "o", "\u001b[?2004h>         break\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r \u001b[?2004h"]
[525.049493, "o", "> "]
[525.049586, "o", "conn = sqlite3.connect(dbpath)\r\n\u001b[?2004l\r\u001b[?2004h"]
[525.049693, "o", "> "]
[525.050709, "o", "cursor = conn.cursor()\r\n\u001b[?2004l\r\u001b[?2004h> cursor.execute(\"SELECT * FROM Map LIMIT 1\")\r\n\u001b[?2004l\r\u001b[?2004h> _, width, height = cursor.fetchone()[0], cursor.fetchone()[1], cursor.fetchone()[2]\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\rl\u001b[?2004h> # Load plots\r\n\u001b[?2004l\r \u001b[?2004h> cursor.execute(\"SELECT * FROM Plots ORDER BY ID\")\r\n\u001b[?2004l\r\u001b[?2004h> plots = {}\r\n\u001b[?2004l\ro"]
[525.050804, "o", "\u001b[?2004h> "]
[525.050896, "o", "for row in cursor.fetchall():\r\n\u001b[?2004l\r\u001b[?2004h> "]
[525.051075, "o", "    pid, terrain, continent, impassable = row\r\n\u001b[?2004l\r"]
[525.05115, "o", "\u001b[?2004h> "]
[525.051267, "o", "    x, y = pid % width, pid // width\r\n\u001b[?2004l\r"]
[525.051345, "o", "\u001b[?2004h> "]
[525.051599, "o", "    plots[(x, y)] = {'terrain': terrain, 'impassable': bool(impassable)}\r\n\u001b[?2004l\r"]
[525.051639, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r \u001b[?2004h> "]
[525.051726, "o", "# Load features\r\n\u001b[?2004l\r\u001b[?2004h"]
[525.051794, "o", "> "]
[525.05186, "o", "cursor.execute(\"SELECT * FROM PlotFeatures\")\r\n\u001b[?2004l\r"]
[525.051931, "o", "\u001b[?2004h> "]
[525.052037, "o", "for row in cursor.fetchall():\r\n\u001b[?2004l\r\u001b[?2004h> "]
[525.052131, "o", "    pid, feature = row\r\n\u001b[?2004l\r\u001b[?2004h"]
[525.052197, "o", "> "]
[525.052282, "o", "    x, y = pid % width, pid // width\r\n\u001b[?2004l\r\u001b[?2004h> "]
[525.052415, "o", "    if (x, y) in plots:\r\n\u001b[?2004l\r[\u001b[?2004h> "]
[525.052632, "o", "        plots[(x, y)]['feature'] = feature\r\n\u001b[?2004l\r\u001b[?2004h"]
[525.052719, "o", "> \r\n\u001b[?2004l\rl\u001b[?2004h> "]
[525.052809, "o", "# Load rivers\r\n\u001b[?2004l\r\u001b[?2004h> "]
[525.052958, "o", "cursor.execute(\"SELECT * FROM PlotRivers\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[525.053084, "o", "for row in cursor.fetchall():\r\n\u001b[?2004l\rpu\u001b[?2004h> "]
[525.053153, "o", "    pid = row[0]\r\n\u001b[?2004l\r"]
[525.053189, "o", "\u001b[?2004h> "]
[525.053315, "o", "    x, y = pid % width, pid // width\r\n\u001b[?2004l\r\u001b[?2004h"]
[525.053383, "o", "> "]
[525.05345, "o", "    if (x, y) in plots:\r\n\u001b[?2004l\r}\u001b[?2004h"]
[525.053517, "o", "> "]
[525.053609, "o", "        plots[(x, y)]['has_river'] = True\r\n\u001b[?2004l\r"]
[525.053675, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r+\u001b[?2004h> "]
[525.053807, "o", "print(\"Map details for key tiles:\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[525.053872, "o", "> "]
[525.054204, "o", "key_tiles = [(21, 14), (21, 13), (21, 11), (21, 15), (20, 14), (22, 14), (22, 17), (23, 12)]\r\n\u001b[?2004l\r"]
[525.054265, "o", "\u001b[?2004h> "]
[525.054324, "o", "for t in key_tiles:\r\n\u001b[?2004l\r"]
[525.054407, "o", "\u001b[?2004h> "]
[525.054439, "o", "    if t in plots:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[525.054516, "o", "        tile = plots[t]\r\n\u001b[?2004l\rs\u001b[?2004h"]
[525.054581, "o", "> "]
[525.055002, "o", "        print(f\"  {t}: terrain={tile.get('terrain')}, feature={tile.get('feature')}, river={tile.get('has_river')}\")\r\n\u001b[?2004l\r"]
[525.05504, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r \u001b[?2004h"]
[525.055111, "o", "> "]
[525.055183, "o", "# Verify the solution\r\n\u001b[?2004l\r\u001b[?2004h> "]
[525.055244, "o", "city_center = (22, 14)\r\n\u001b[?2004l\r"]
[525.055278, "o", "\u001b[?2004h> "]
[525.055353, "o", "districts = {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[525.055465, "o", "    'CAMPUS': (21, 14),\r\n\u001b[?2004l\r"]
[525.055532, "o", "\u001b[?2004h> "]
[525.055603, "o", "    'COMMERCIAL_HUB': (22, 17),\r\n\u001b[?2004l\r"]
[525.055636, "o", "\u001b[?2004h> "]
[525.055729, "o", "    'INDUSTRIAL_ZONE': (23, 12)\r\n\u001b[?2004l\r"]
[525.05576, "o", "\u001b[?2004h> }\r\n\u001b[?2004l\r"]
[525.055846, "o", "\u001b[?2004h> \r\n\u001b[?2004l\re\u001b[?2004h> "]
[525.056073, "o", "print(f\"\\nVerifying solution with city center at {city_center}\")\r\n\u001b[?2004l\r"]
[525.056111, "o", "\u001b[?2004h> \r\n\u001b[?2004l\rj"]
[525.056195, "o", "\u001b[?2004h> "]
[525.056255, "o", "def calculate_campus_adjacency(pos):\r\n\u001b[?2004l\r"]
[525.056325, "o", "\u001b[?2004h> "]
[525.056563, "o", "    \"\"\"Calculate Campus adjacency bonus with proper floor separately\"\"\"\r\n\u001b[?2004l\r"]
[525.056599, "o", "\u001b[?2004h> "]
[525.056804, "o", "    neighbors = get_hex_neighbors(pos[0], pos[1])\r\n\u001b[?2004l\r"]
[525.056845, "o", "\u001b[?2004h> "]
[525.056948, "o", "    geothermal_count = 0\r\n\u001b[?2004l\r\u001b[?2004h> "]
[525.057022, "o", "    reef_count = 0\r\n\u001b[?2004l\r\u001b[?2004h"]
[525.057081, "o", "> "]
[525.057134, "o", "    mountain_count = 0\r\n\u001b[?2004l\r\u001b[?2004h"]
[525.057203, "o", "> "]
[525.057243, "o", "    rainforest_count = 0\r\n\u001b[?2004l\r"]
[525.057314, "o", "\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[525.05738, "o", "    for n in neighbors:\r\n\u001b[?2004l\r"]
[525.057415, "o", "\u001b[?2004h> "]
[525.057479, "o", "        if n in plots:\r\n\u001b[?2004l\r"]
[525.057546, "o", "\u001b[?2004h> "]
[525.057617, "o", "            tile = plots[n]\r\n\u001b[?2004l\r"]
[525.057653, "o", "\u001b[?2004h> "]
[525.057904, "o", "            if tile.get('feature') == 'FEATURE_GEOTHERMAL_FISSURE':\r\n\u001b[?2004l\r"]
[525.057941, "o", "\u001b[?2004h> "]
[525.058049, "o", "                geothermal_count += 1\r\n\u001b[?2004l\r\u001b[?2004h> "]
[525.058144, "o", "            elif tile.get('feature') == 'FEATURE_REEF':\r\n\u001b[?2004l\r\u001b[?2004h> "]
[525.058208, "o", "                reef_count += 1\r\n\u001b[?2004l\r\u001b[?2004h> "]
[525.058328, "o", "            elif tile.get('terrain') == 'TERRAIN_GRASS_MOUNTAIN':\r\n\u001b[?2004l\r"]
[525.058359, "o", "\u001b[?2004h> "]
[525.058437, "o", "                mountain_count += 1\r\n\u001b[?2004l\r\u001b[?2004h> "]
[525.058569, "o", "            elif tile.get('feature') in ['FEATURE_JUNGLE', 'FEATURE_RAINFOREST']:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[525.058649, "o", "                rainforest_count += 1\r\n\u001b[?2004l\r\u001b[?2004h> "]
[525.058714, "o", "    \r\n\u001b[?2004l\r"]
[525.058763, "o", "\u001b[?2004h> "]
[525.058838, "o", "    # +2 each geothermal/reef, +1 each mountain, +0.5 each rainforest (floored separately)\r\n\u001b[?2004l\r\u001b[?2004h"]
[525.058865, "o", "> "]
[525.058962, "o", "    bonus = geothermal_count * 2 + reef_count * 2 + mountain_count * 1\r\n\u001b[?2004l\r\u001b[?2004h"]
[525.058991, "o", "> "]
[525.059091, "o", "    bonus += sum(math.floor(0.5) for _ in range(rainforest_count))  # 0 each\r\n\u001b[?2004l\r\u001b[?2004h"]
[525.059115, "o", ">     \r\n\u001b[?2004l\r"]
[525.059178, "o", "\u001b[?2004h> "]
[525.059356, "o", "    print(f\"  Campus at {pos}: geothermal={geothermal_count}, reef={reef_count}, mountain={mountain_count}, rainforest={rainforest_count}\")\r\n\u001b[?2004l\r"]
[525.059383, "o", "\u001b[?2004h> "]
[525.059653, "o", "    print(f\"    geothermal*2={geothermal_count*2}, reef*2={reef_count*2}, mountain*1={mountain_count*1}, rainforest floor(0.5)*N={sum(math.floor(0.5) for _ in range(rainforest_count))}\")\r\n\u001b[?2004l\r"]
[525.059678, "o", "\u001b[?2004h> "]
[525.059727, "o", "    return bonus\r\n\u001b[?2004l\r\u001b[?2004h> "]
[525.059798, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[525.059861, "o", "def calculate_commercial_adjacency(pos):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[525.05994, "o", "    \"\"\"Calculate Commercial Hub adjacency bonus\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[525.060021, "o", "    tile = plots.get(pos, {})\r\n\u001b[?2004l\r"]
[525.060047, "o", "\u001b[?2004h> "]
[525.06013, "o", "    has_river = tile.get('has_river', False)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[525.060157, "o", "    \r\n\u001b[?2004l\r"]
[525.060218, "o", "\u001b[?2004h> "]
[525.060286, "o", "    neighbors = get_hex_neighbors(pos[0], pos[1])\r\n\u001b[?2004l\r\u001b[?2004h> "]
[525.060341, "o", "    has_harbor = False\r\n\u001b[?2004l\r\u001b[?2004h> "]
[525.060376, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[525.060511, "o", "    # Check for harbor (coastal tile adjacent to city center or district)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[525.060591, "o", "    # Harbor gives +2 to Commercial Hub\r\n\u001b[?2004l\r\u001b[?2004h> "]
[525.060645, "o", "    for n in neighbors:\r\n\u001b[?2004l\r\u001b[?2004h"]
[525.060704, "o", "> "]
[525.060738, "o", "        if n in plots:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[525.060811, "o", "            nt = plots[n]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[525.060913, "o", "            if nt.get('terrain') == 'TERRAIN_COAST':\r\n\u001b[?2004l\r"]
[525.060944, "o", "\u001b[?2004h> "]
[525.061033, "o", "                has_harbor = True\r\n\u001b[?2004l\r\u001b[?2004h> "]
[525.061095, "o", "                break\r\n\u001b[?2004l\r\u001b[?2004h"]
[525.061112, "o", ">     \r\n\u001b[?2004l\r"]
[525.061186, "o", "\u001b[?2004h"]
[525.061224, "o", ">     bonus = 2 if has_river else 0\r\n\u001b[?2004l\r"]
[525.061316, "o", "\u001b[?2004h> "]
[525.06139, "o", "    bonus += 2 if has_harbor else 0\r\n\u001b[?2004l\r\u001b[?2004h"]
[525.061424, "o", ">     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[525.061555, "o", "    print(f\"  Commercial Hub at {pos}: river={has_river}, harbor={has_harbor}\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[525.061583, "o", "> "]
[525.061727, "o", "    print(f\"    river*2={2 if has_river else 0}, harbor*2={2 if has_harbor else 0}\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[525.061796, "o", "> "]
[525.061826, "o", "    return bonus\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[525.061893, "o", "\u001b[?2004h> "]
[525.061958, "o", "def calculate_industrial_adjacency(pos):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[525.062085, "o", "    \"\"\"Calculate Industrial Zone adjacency bonus with floor separately\"\"\"\r\n\u001b[?2004l\r"]
[525.062113, "o", "\u001b[?2004h> "]
[525.062215, "o", "    neighbors = get_hex_neighbors(pos[0], pos[1])\r\n\u001b[?2004l\r\u001b[?2004h"]
[525.062244, "o", "> "]
[525.062315, "o", "    forest_count = 0\r\n\u001b[?2004l\r\u001b[?2004h> "]
[525.062344, "o", "    quarry_count = 0\r\n\u001b[?2004l\r"]
[525.062407, "o", "\u001b[?2004h>     mine_count = 0\r\n\u001b[?2004l\r"]
[525.062434, "o", "\u001b[?2004h> "]
[525.062494, "o", "    resource_count = 0\r\n\u001b[?2004l\r"]
[525.06252, "o", "\u001b[?2004h>     \r\n\u001b[?2004l\r"]
[525.062586, "o", "\u001b[?2004h> "]
[525.062613, "o", "    for n in neighbors:\r\n\u001b[?2004l\r"]
[525.062678, "o", "\u001b[?2004h> "]
[525.062705, "o", "        if n in plots:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[525.062773, "o", "            tile = plots[n]\r\n\u001b[?2004l\r"]
[525.062808, "o", "\u001b[?2004h> "]
[525.062892, "o", "            feat = tile.get('feature', '')\r\n\u001b[?2004l\r\u001b[?2004h"]
[525.06292, "o", "> "]
[525.063006, "o", "            terrain = tile.get('terrain', '')\r\n\u001b[?2004l\r\u001b[?2004h"]
[525.063034, "o", "> "]
[525.063155, "o", "            # Check for strategic resources (mines) - not in our map\r\n\u001b[?2004l\r\u001b[?2004h"]
[525.063183, "o", "> "]
[525.063285, "o", "            # Check for bonus resources - not in our map\r\n\u001b[?2004l\r\u001b[?2004h"]
[525.063314, "o", "> "]
[525.063384, "o", "            if feat == 'FEATURE_FOREST':\r\n\u001b[?2004l\r"]
[525.063413, "o", "\u001b[?2004h> "]
[525.063487, "o", "                forest_count += 1\r\n\u001b[?2004l\r"]
[525.063549, "o", "\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[525.063675, "o", "    # +1 per district (floor separately, so floor(1/2) = 0 for each)\r\n\u001b[?2004l\r\u001b[?2004h"]
[525.063702, "o", "> "]
[525.063788, "o", "    # +0.5 per forest (floor separately)\r\n\u001b[?2004l\r\u001b[?2004h"]
[525.063819, "o", "> "]
[525.063888, "o", "    bonus = 0\r\n\u001b[?2004l\r\u001b[?2004h> "]
[525.063992, "o", "    bonus += sum(math.floor(0.5) for _ in range(forest_count))  # 0 each\r\n\u001b[?2004l\r\u001b[?2004h"]
[525.064019, "o", ">     \r\n\u001b[?2004l\r"]
[525.064088, "o", "\u001b[?2004h> "]
[525.064184, "o", "    print(f\"  Industrial Zone at {pos}: forests={forest_count}\")\r\n\u001b[?2004l\r"]
[525.06421, "o", "\u001b[?2004h> "]
[525.06436, "o", "    print(f\"    forest floor(0.5)*N={sum(math.floor(0.5) for _ in range(forest_count))}\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[525.064384, "o", "> "]
[525.064459, "o", "    return bonus\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[525.064554, "o", "# Calculate base adjacency for each district\r\n\u001b[?2004l\r\u001b[?2004h"]
[525.064581, "o", "> "]
[525.064696, "o", "campus_bonus = calculate_campus_adjacency(districts['CAMPUS'])\r\n\u001b[?2004l\r\u001b[?2004h"]
[525.064759, "o", "> "]
[525.064897, "o", "commercial_bonus = calculate_commercial_adjacency(districts['COMMERCIAL_HUB'])\r\n\u001b[?2004l\r"]
[525.064921, "o", "\u001b[?2004h> "]
[525.065067, "o", "industrial_bonus = calculate_industrial_adjacency(districts['INDUSTRIAL_ZONE'])\r\n\u001b[?2004l\r\u001b[?2004h"]
[525.065094, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[525.065283, "o", "print(f\"\\nBase adjacency: Campus={campus_bonus}, Commercial={commercial_bonus}, Industrial={industrial_bonus}\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[525.065311, "o", "> \r\n\u001b[?2004l\r"]
[525.065385, "o", "\u001b[?2004h> "]
[525.065486, "o", "# Add district-to-district adjacency (+0.5 each, floored separately)\r\n\u001b[?2004l\r"]
[525.065512, "o", "\u001b[?2004h> "]
[525.065604, "o", "district_positions = list(districts.values())\r\n\u001b[?2004l\r\u001b[?2004h"]
[525.065632, "o", "> "]
[525.065712, "o", "district_adj_bonus = 0\r\n\u001b[?2004l\r\u001b[?2004h"]
[525.065797, "o", "> "]
[525.065866, "o", "for i, pos1 in enumerate(district_positions):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[525.065922, "o", "    for j, pos2 in enumerate(district_positions):\r\n\u001b[?2004l\r"]
[525.065947, "o", "\u001b[?2004h> "]
[525.066008, "o", "        if i < j:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[525.066124, "o", "            neighbors = get_hex_neighbors(pos1[0], pos1[1])\r\n\u001b[?2004l\r\u001b[?2004h"]
[525.06615, "o", "> "]
[525.066214, "o", "            if pos2 in neighbors:\r\n\u001b[?2004l\r"]
[525.066242, "o", "\u001b[?2004h> "]
[525.066336, "o", "                district_adj_bonus += 0.5\r\n\u001b[?2004l\r\u001b[?2004h"]
[525.066363, "o", "> "]
[525.066497, "o", "                print(f\"  Districts {pos1} and {pos2} are adjacent, adding 0.5\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[525.066524, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[525.066656, "o", "# Floor the district bonus separately (each +0.5 becomes floor(0.5) = 0)\r\n\u001b[?2004l\r"]
[525.066685, "o", "\u001b[?2004h> "]
[525.066825, "o", "print(f\"\\nDistrict adjacency bonus (before flooring): {district_adj_bonus}\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[525.066883, "o", "> "]
[525.067131, "o", "print(f\"District adjacency bonus (after flooring each): {math.floor(district_adj_bonus) if district_adj_bonus < 1 else sum(math.floor(0.5) for _ in range(int(district_adj_bonus * 2)))}\")\r\n\u001b[?2004l\r"]
[525.067202, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[525.067234, "o", "> # Calculate total\r\n\u001b[?2004l\r\u001b[?2004h"]
[525.067303, "o", "> "]
[525.067381, "o", "base_total = campus_bonus + commercial_bonus + industrial_bonus\r\n\u001b[?2004l\r\u001b[?2004h"]
[525.067409, "o", "> "]
[525.067507, "o", "# The +0.5 per district is already floored to 0\r\n\u001b[?2004l\r\u001b[?2004h"]
[525.067534, "o", "> "]
[525.067611, "o", "total = base_total\r\n\u001b[?2004l\r"]
[525.067691, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[525.067747, "o", "print(f\"\\nFinal total: {total}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[525.067818, "o", "ENDSCRIPT\r\n\u001b[?2004l\r"]
[525.068838, "o", "\u001b[?2004hroot@0d3c1addd3d3:/data/maps# "]
[527.048617, "i", "python3 /tmp/verify.py\n"]
[527.048849, "o", "python3 /tmp/verify.py\r\n\u001b[?2004l\r"]
[527.065784, "o", "Traceback (most recent call last):\r\n  File \"/tmp/verify.py\", line 34, in <module>\r\n"]
[527.065914, "o", "    _, width, height = cursor.fetchone()[0], cursor.fetchone()[1], cursor.fetchone()[2]\r\n                                             ~~~~~~~~~~~~~~~~~^^^\r\nTypeError: 'NoneType' object is not subscriptable\r\n"]
[527.068798, "o", "\u001b[?2004hroot@0d3c1addd3d3:/data/maps# "]
[559.083531, "i", "cat > /tmp/verify.py << 'ENDSCRIPT'\nimport sqlite3\nimport os\nimport math\n\ndef get_hex_neighbors(x, y):\n    if y % 2 == 1:\n        return [(x+1, y), (x+1, y-1), (x+1, y+1), (x-1, y), (x, y-1), (x, y+1)]\n    else:\n        return [(x+1, y), (x, y-1), (x, y+1), (x-1, y), (x-1, y-1), (x-1, y+1)]\n\ndbpath = None\nfor f in os.listdir('/data/maps'):\n    fp = '/data/maps/' + f\n    if os.path.getsize(fp) > 0:\n        dbpath = fp\n        break\n\nconn = sqlite3.connect(dbpath)\ncursor = conn.cursor()\ncursor.execute(\"SELECT * FROM Map LIMIT 1\")\nmap_row = cursor.fetchone()\n_, width, height = map_row[0], map_row[1], map_row[2]\n\ncursor.execute(\"SELECT * FROM Plots ORDER BY ID\")\nplots = {}\nfor row in cursor.fetchall():\n    pid, terrain, continent, impassable = row\n    x, y = pid % width, pid // width\n    plots[(x, y)] = {'terrain': terrain, 'impassable': bool(impassable)}\n\ncursor.execute(\"SELECT * FROM PlotFeatures\")\nfor row in cursor.fetchall():\n    pid, feature = row\n    x, y = pid % width, pid // width\n    if (x, y) in plots:\n        plots[(x, y)]['feature'] = feature\n\ncursor.execute(\"SELECT * FROM PlotRivers\")\nfor row in cursor.fetchall():\n    pid = row[0]\n    x, y = pid % width, pid // width\n    if (x, y) in plots:\n        plots[(x, y)]['has_river'] = True\n\nprint(\"Key tiles:\")\nfor t in [(21, 14), (21, 13), (21, 11), (21, 15), (20, 14), (22, 14), (22, 17), (23, 12)]:\n    if t in plots:\n        tile = plots[t]\n        print(f\"  {t}: terrain={tile.get('terrain')}, feature={tile.get('feature')}, river={tile.get('has_river')}\")\n\ncity_center = (22, 14)\ndistricts = {'CAMPUS': (21, 14), 'COMMERCIAL_HUB': (22, 17), 'INDUSTRIAL_ZONE': (23, 12)}\n\ndef calc_campus(pos):\n    n = get_hex_neighbors(pos[0], pos[1])\n    geo = sum(1 for x in n if x in plots and plots[x].get('feature') == 'FEATURE_GEOTHERMAL_FISSURE')\n    reef = sum(1 for x in n if x in plots and plots[x].get('feature') == 'FEATURE_REEF')\n    mtn = sum(1 for x in n if x in plots and plots[x].get('terrain') == 'TERRAIN_GRASS_MOUNTAIN')\n    rain = sum(1 for x in n if x in plots and plots[x].get('feature') in ['FEATURE_JUNGLE', 'FEATURE_RAINFOREST'])\n    bonus = geo*2 + reef*2 + mtn*1 + sum(math.floor(0.5) for _ in range(rain))\n    print(f\"CAMPUS at {pos}: geo={geo}, reef={reef}, mtn={mtn}, rain={rain} -> {bonus}\")\n    return bonus\n\ndef calc_commercial(pos):\n    tile = plots.get(pos, {})\n    has_river = tile.get('has_river', False)\n    n = get_hex_neighbors(pos[0], pos[1])\n    has_harbor = any(x in plots and plots[x].get('terrain') == 'TERRAIN_COAST' for x in n)\n    bonus = (2 if has_river else 0) + (2 if has_harbor else 0)\n    print(f\"COMM_HUB at {pos}: river={has_river}, harbor={has_harbor} -> {bonus}\")\n    return bonus\n\ndef calc_industrial(pos):\n    n = get_hex_neighbors(pos[0], pos[1])\n    forest = sum(1 for x in n if x in plots and plots[x].get('feature') == 'FEATURE_FOREST')\n    bonus = sum(math.floor(0.5) for _ in range(forest))\n    print(f\"IND_ZONE at {pos}: forests={forest} -> {bonus}\")\n    return bonus\n\ncampus_bonus = calc_campus(districts['CAMPUS'])\ncommercial_bonus = calc_commercial(districts['COMMERCIAL_HUB'])\nindustrial_bonus = calc_industrial(districts['INDUSTRIAL_ZONE'])\n\n# Check district adjacency\ndistrict_adj = 0\nfor i, pos1 in enumerate(list(districts.values())):\n    for j, pos2 in enumerate(list(districts.values())):\n        if i < j and pos2 in get_hex_neighbors(pos1[0], pos1[1]):\n            district_adj += 0.5\n            print(f\"Adjacent: {pos1} <-> {pos2}\")\n\ntotal = campus_bonus + commercial_bonus + industrial_bonus\nprint(f\"\\nTotal: {campus_bonus} + {commercial_bonus} + {industrial_bonus} = {total}\")\nENDSCRIPT\n"]
