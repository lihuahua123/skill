[252.813295, "i", "cat > /tmp/parse_map.py << 'ENDSCRIPT'\nimport sqlite3\nimport json\nconn = sqlite3.connect('/data/maps/e2e_test_case_0 Civ6Map')\ncursor = conn.cursor()\n\n# Get map dimensions from Map table\ncursor.execute(\"SELECT * FROM Map LIMIT 1\")\nprint(\"Map:\")\nfor row in cursor.fetchall():\n    print(row)\n\n# Get Plots data\ncursor.execute(\"SELECT * FROM Plots LIMIT 20\")\nprint(\"\\nPlots:\")\nfor row in cursor.fetchall():\n    print(row)\n\n# Get PlotFeatures\ncursor.execute(\"PRAGMA table_info(PlotFeatures)\")\nprint(\"\\nPlotFeatures schema:\")\nfor row in cursor.fetchall():\n    print(row)\n\n# Get PlotRivers\ncursor.execute(\"PRAGMA table_info(PlotRivers)\")\nprint(\"\\nPlotRivers schema:\")\nfor row in cursor.fetchall():\n    print(row)\n\n# Get PlotResources\ncursor.execute(\"PRAGMA table_info(PlotResources)\")\nprint(\"\\nPlotResources schema:\")\nfor row in cursor.fetchall():\n    print(row)\nENDSCRIPT\n"]
