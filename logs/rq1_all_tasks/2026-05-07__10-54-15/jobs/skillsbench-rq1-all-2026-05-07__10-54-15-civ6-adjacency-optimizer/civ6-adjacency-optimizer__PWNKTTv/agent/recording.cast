[459.536405, "o", "\u001b[?2004h> "]
[459.536496, "o", "        # Industrial Zone: +1 district, +0.5 from features\r\n\u001b[?2004l\r\u001b[?2004h"]
[459.536551, "o", "> "]
[459.536622, "o", "        industrial_bonus = 0\r\n\u001b[?2004l\r\u001b[?2004h"]
[459.536676, "o", "> "]
[459.536745, "o", "        for nt in neighbor_tiles:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[459.536885, "o", "            if nt.get('feature') == 'FEATURE_FOREST':\r\n\u001b[?2004l\r\u001b[?2004h"]
[459.536947, "o", "> "]
[459.537018, "o", "                industrial_bonus += 0.5\r\n\u001b[?2004l\r"]
[459.537087, "o", "\u001b[?2004h> "]
