[459.527991, "o", ">     \r\n\u001b[?2004l\r\u001b[?2004h"]
[459.528064, "o", "> "]
[459.528184, "o", "    # Find valid district placements\r\n\u001b[?2004l\r\u001b[?2004h"]
[459.528217, "o", "> "]
[459.528305, "o", "    valid_districts = []\r\n\u001b[?2004l\re\u001b[?2004h"]
[459.528393, "o", "> "]
