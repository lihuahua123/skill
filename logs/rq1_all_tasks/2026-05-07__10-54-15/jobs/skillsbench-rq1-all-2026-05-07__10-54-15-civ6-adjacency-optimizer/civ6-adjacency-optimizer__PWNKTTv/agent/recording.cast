[287.477357, "i", "cat > /tmp/extract_map.py << 'ENDSCRIPT'\nimport sqlite3\nimport os\nimport json\n\n# Find the correct map file\ndbpath = None\nfor f in os.listdir('/data/maps'):\n    fp = '/data/maps/' + f\n    if os.path.getsize(fp) > 0:\n        dbpath = fp\n        break\n\nconn = sqlite3.connect(dbpath)\ncursor = conn.cursor()\n\n# Get dimensions\ncursor.execute(\"SELECT * FROM Map LIMIT 1\")\nmap_row = cursor.fetchone()\nmap_name, width, height = map_row[0], map_row[1], map_row[2]\nprint(f\"Map: {map_name}, Width: {width}, Height: {height}\")\n\n# Extract all plots\ncursor.execute(\"SELECT * FROM Plots ORDER BY ID\")\nplots = {}\nfor row in cursor.fetchall():\n    pid, terrain, continent, impassable = row\n    x = pid % width\n    y = pid // width\n    plots[pid] = {'x': x, 'y': y, 'terrain': terrain, 'continent': continent, 'impassable': impassable}\n\n# Extract features\ncursor.execute(\"SELECT * FROM PlotFeatures\")\nfeatures = {}\nfor row in cursor.fetchall():\n    pid, feature = row\n    if pid in plots:\n        plots[pid]['feature'] = feature\n\n# Extract rivers (PlotRivers has different structure)\ncursor.execute(\"PRAGMA table_info(PlotRivers)\")\nprint(\"\\nPlotRivers columns:\")\nfor row in cursor.fetchall():\n    print(row)\n\ncursor.execute(\"SELECT * FROM PlotRivers LIMIT 5\")\nprint(\"\\nPlotRivers sample:\")\nfor row in cursor.fetchall():\n    print(row)\n\n# Extract resources\ncursor.execute(\"SELECT * FROM PlotResources LIMIT 5\")\nprint(\"\\nPlotResources sample:\")\nfor row in cursor.fetchall():\n    print(row)\n\nprint(f\"\\nTotal plots: {len(plots)}\")\n\n# Count terrain types\nterrain_counts = {}\nfor p in plots.values():\n    t = p['terrain']\n    terrain_counts[t] = terrain_counts.get(t, 0) + 1\nprint(\"Terrain distribution:\", terrain_counts)\n\n# Count features\nfeature_counts = {}\nfor p in plots.values():\n    if 'feature' in p:\n        f = p['feature']\n        feature_counts[f] = feature_counts.get(f, 0) + 1\nprint(\"Feature distribution:\", feature_counts)\nENDSCRIPT\n"]
