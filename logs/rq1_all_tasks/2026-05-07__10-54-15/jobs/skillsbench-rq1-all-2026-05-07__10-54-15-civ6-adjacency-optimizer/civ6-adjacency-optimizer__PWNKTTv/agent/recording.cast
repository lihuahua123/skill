[673.88139, "o", "cat /output/scenario_3.json\r\n\u001b[?2004l\r"]
[673.882457, "o", "{\r\n  \"city_center\": [\r\n    22,\r\n    14\r\n  ],\r\n  \"placements\": {\r\n    \"CAMPUS\": [\r\n      21,\r\n      14\r\n    ],\r\n    \"COMMERCIAL_HUB\": [\r\n      22,\r\n      17\r\n    ],\r\n    \"INDUSTRIAL_ZONE\": [\r\n      23,\r\n      12\r\n    ]\r\n  },\r\n  \"adjacency_bonuses\": {\r\n    \"CAMPUS\": 5,\r\n    \"COMMERCIAL_HUB\": 4,\r\n    \"INDUSTRIAL_ZONE\": 0\r\n  },\r\n  \"total_adjacency\": 9\r\n}"]
[673.882761, "o", "\u001b[?2004hroot@0d3c1addd3d3:/data/maps# "]
[705.887906, "i", "cat > /tmp/optimize_full.py << 'ENDSCRIPT'\nimport sqlite3\nimport os\nimport math\n\ndef get_hex_neighbors(x, y):\n    if y % 2 == 1:\n        return [(x+1, y), (x+1, y-1), (x+1, y+1), (x-1, y), (x, y-1), (x, y+1)]\n    else:\n        return [(x+1, y), (x, y-1), (x, y+1), (x-1, y), (x-1, y-1), (x-1, y+1)]\n\ndef hex_distance(x1, y1, x2, y2):\n    def to_cube(x, y):\n        if y % 2 == 1:\n            x_cube = x - (y - 1) // 2\n        else:\n            x_cube = x - y // 2\n        return x_cube, y, -x_cube - y\n    cx1, cy1, cz1 = to_cube(x1, y1)\n    cx2, cy2, cz2 = to_cube(x2, y2)\n    return max(abs(cx1 - cx2), abs(cy1 - cy2), abs(cz1 - cz2))\n\ndbpath = None\nfor f in os.listdir('/data/maps'):\n    fp = '/data/maps/' + f\n    if os.path.getsize(fp) > 0:\n        dbpath = fp\n        break\n\nconn = sqlite3.connect(dbpath)\ncursor = conn.cursor()\ncursor.execute(\"SELECT * FROM Map LIMIT 1\")\nmap_row = cursor.fetchone()\n_, width, height = map_row[0], map_row[1], map_row[2]\n\ncursor.execute(\"SELECT * FROM Plots ORDER BY ID\")\nplots = {}\nfor row in cursor.fetchall():\n    pid, terrain, continent, impassable = row\n    x, y = pid % width, pid // width\n    plots[(x, y)] = {'terrain': terrain, 'impassable': bool(impassable)}\n\ncursor.execute(\"SELECT * FROM PlotFeatures\")\nfor row in cursor.fetchall():\n    pid, feature = row\n    x, y = pid % width, pid // width\n    if (x, y) in plots:\n        plots[(x, y)]['feature'] = feature\n\ncursor.execute(\"SELECT * FROM PlotRivers\")\nfor row in cursor.fetchall():\n    pid = row[0]\n    x, y = pid % width, pid // width\n    if (x, y) in plots:\n        plots[(x, y)]['has_river'] = True\n\ndef calc_campus(x, y):\n    n = get_hex_neighbors(x, y)\n    geo = sum(1 for t in n if t in plots and plots[t].get('feature') == 'FEATURE_GEOTHERMAL_FISSURE')\n    reef = sum(1 for t in n if t in plots and plots[t].get('feature') == 'FEATURE_REEF')\n    mtn = sum(1 for t in n if t in plots and plots[t].get('terrain') == 'TERRAIN_GRASS_MOUNTAIN')\n    rain = sum(1 for t in n if t in plots and plots[t].get('feature') in ['FEATURE_JUNGLE', 'FEATURE_RAINFOREST'])\n    return geo*2 + reef*2 + mtn*1 + sum(math.floor(0.5) for _ in range(rain))\n\ndef calc_commercial(x, y):\n    tile = plots.get((x, y), {})\n    has_river = tile.get('has_river', False)\n    n = get_hex_neighbors(x, y)\n    has_harbor = any(t in plots and plots[t].get('terrain') == 'TERRAIN_COAST' for t in n)\n    return (2 if has_river else 0) + (2 if has_harbor else 0)\n\ndef calc_industrial(x, y):\n    n = get_hex_neighbors(x, y)\n    forest = sum(1 for t in n if t in plots and plots[t].get('feature') == 'FEATURE_FOREST')\n    return sum(math.floor(0.5) for _ in range(forest))\n\ndef calc_theater(x, y):\n    n = get_hex_neighbors(x, y)\n    entertainment = sum(1 for t in n if t in plots and plots[t].get('terrain') == 'TERRAIN_COAST')\n    return sum(math.floor(0.5) for _ in range(entertainment))\n\n# Main landmass valid tiles\nvalid_tiles = [(x, y) for (x, y) in plots if 19 <= x <= 27 and 11 <= y <= 17]\nvalid_tiles = [t for t in valid_tiles if plots[t]['terrain'] not in ['TERRAIN_OCEAN', 'TERRAIN_GRASS_MOUNTAIN']]\nvalid_tiles = [t for t in valid_tiles if plots[t].get('feature') != 'FEATURE_GEOTHERMAL_FISSURE']\n\nbest = (0, None)\nfor cc in valid_tiles:\n    # Find all valid district placements within 3 range\n    reachable = []\n    for t in valid_tiles:\n        if hex_distance(cc[0], cc[1], t[0], t[1]) <= 3 and t != cc:\n            reachable.append(t)\n    \n    # Score each\n    scores = []\n    for t in reachable:\n        c = calc_campus(t[0], t[1])\n        o = calc_commercial(t[0], t[1])\n        i = calc_industrial(t[0], t[1])\n        scores.append(('CAMPUS', t, c))\n        scores.append(('COMMERCIAL_HUB', t, o))\n        scores.append(('INDUSTRIAL_ZONE', t, i))\n    \n    scores.sort(key=lambda x: -x[2])\n    \n    # Try combinations\n    chosen = []\n    used_types = set()\n    used_tiles = set()\n    for s in scores:\n        if s[0] not in used_types and s[1] not in used_tiles:\n            chosen.append(s)\n            used_types.add(s[0])\n            used_tiles.add(s[1])\n            if len(chosen) >= 3:\n                "]
[705.888056, "i", "break\n    \n    total = sum(s[2] for s in chosen)\n    if total > best[0]:\n        best = (total, cc, chosen)\n\nprint(f\"Best: {best[0]} at {best[1]}\")\nfor s in best[2]:\n    print(f\"  {s[0]} at {s[1]}: {s[2]}\")\nENDSCRIPT\n"]
