[1057.591076, "i", "python3 -c \"\nimport json\nwith open('/tmp/scenario_clean.json') as f:\n    data = json.load(f)\ntiles = data['tiles']\n\n# Build tile lookup\ntile_map = {}\nfor t in tiles:\n    tile_map[(t['x'], t['y'])] = t\n\n# Find all land tiles (non-ocean, non-coast, non-mountain)\nland_tiles = []\nfor t in tiles:\n    if t['terrain'] not in ['OCEAN', 'COAST', 'MOUNTAIN']:\n        land_tiles.append((t['x'], t['y'], t.get('terrain'), t.get('feature'), t.get('is_hills')))\n\nprint('Land tiles:')\nfor lt in sorted(land_tiles):\n    print(f'  ({lt[0]}, {lt[1]}): {lt[2]} hills={lt[4]} feature={lt[3]}')\n\"\n"]
