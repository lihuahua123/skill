[289.502526, "o", "\r\nPlotRivers columns:\r\n"]
[289.502622, "o", "(0, 'ID', 'INTEGER', 1, None, 1)\r\n(1, 'IsNEOfRiver', 'BOOLEAN', 0, None, 0)\r\n(2, 'IsWOfRiver', 'BOOLEAN', 0, None, 0)\r\n(3, 'IsNWOfRiver', 'BOOLEAN', 0, None, 0)\r\n(4, 'EFlowDirection', 'INTEGER', 0, None, 0)\r\n(5, 'SEFlowDirection', 'INTEGER', 0, None, 0)\r\n(6, 'SWFlowDirection', 'INTEGER', 0, None, 0)\r\n"]
[289.5027, "o", "\r\nPlotRivers sample:\r\n(313, 1, 0, 0, -1, -1, 5)\r\n(575, 0, 0, 1, -1, 4, -1)\r\n(593, 0, 1, 1, 3, 4, -1)\r\n(638, 0, 1, 1, 3, 4, -1)\r\n(639, 0, 1, 0, 0, -1, -1)\r\n\r\nPlotResources sample:\r\n\r\nTotal plots: 1144\r\n"]
