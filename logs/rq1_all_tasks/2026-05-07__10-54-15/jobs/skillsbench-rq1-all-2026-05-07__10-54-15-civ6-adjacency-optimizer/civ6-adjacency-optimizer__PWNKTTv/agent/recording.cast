[459.540791, "o", "    district_bonus = 0\r\n\u001b[?2004l\r\u001b[?2004h> "]
[459.540889, "o", "    for i, pos1 in enumerate(district_positions):\r\n\u001b[?2004l\r\u001b[?2004h"]
[459.540926, "o", "> "]
[459.54101, "o", "        for pos2 in district_positions[i+1:]:\r\n\u001b[?2004l\r\u001b[?2004h"]
[459.541067, "o", "> "]
[459.541151, "o", "            if pos2 in get_hex_neighbors(pos1[0], pos1[1]):\r\n\u001b[?2004l\r\u001b[?2004h"]
[459.541205, "o", "> "]
[459.54131, "o", "                district_bonus += 0.5  # Each adjacent district pair = +0.5\r\n\u001b[?2004l\r\u001b[?2004h"]
[459.541365, "o", ">     \r\n\u001b[?2004l\r"]
[459.541433, "o", "\u001b[?2004h> "]
[459.541497, "o", "    # Floor the 0.5 bonuses separately\r\n\u001b[?2004l\r\u001b[?2004h"]
[459.541645, "o", ">     total_with_district = total + district_bonus\r\n\u001b[?2004l\r\u001b[?2004h> "]
[459.541703, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[459.541791, "o", "    if total_with_district > best_score:\r\n\u001b[?2004l\r\u001b[?2004h"]
[459.541847, "o", "> "]
[459.541916, "o", "        best_score = total_with_district\r\n\u001b[?2004l\r\u001b[?2004h> "]
[459.541984, "o", "        best_solution = {\r\n\u001b[?2004l\r"]
[459.542051, "o", "\u001b[?2004h> "]
[459.542115, "o", "            'center': (cx, cy),\r\n\u001b[?2004l\r\u001b[?2004h> "]
[459.542172, "o", "            'districts': top3,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[459.542244, "o", "            'raw_total': total,\r\n\u001b[?2004l\r\u001b[?2004h"]
[459.542282, "o", "> "]
[459.542363, "o", "            'district_bonus': district_bonus,\r\n\u001b[?2004l\r\u001b[?2004h"]
[459.542426, "o", "> "]
[459.542479, "o", "            'final_total': total_with_district\r\n\u001b[?2004l\r"]
[459.542514, "o", "\u001b[?2004h> "]
[459.542583, "o", "        }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[459.542648, "o", "\u001b[?2004h> "]
[459.542704, "o", "print(f\"\\nBest solution:\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[459.542768, "o", "> "]
[459.542834, "o", "print(f\"City Center: {best_solution['center']}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[459.542936, "o", "print(f\"Districts: {best_solution['districts']}\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[459.542994, "o", "> "]
[459.543065, "o", "print(f\"Raw total: {best_solution['raw_total']}\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[459.543122, "o", "> "]
[459.543209, "o", "print(f\"District bonus: {best_solution['district_bonus']}\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[459.543264, "o", "> "]
[459.543344, "o", "print(f\"Final total: {best_solution['final_total']}\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[459.543408, "o", "> ENDSCRIPT\r\n\u001b[?2004l\r"]
