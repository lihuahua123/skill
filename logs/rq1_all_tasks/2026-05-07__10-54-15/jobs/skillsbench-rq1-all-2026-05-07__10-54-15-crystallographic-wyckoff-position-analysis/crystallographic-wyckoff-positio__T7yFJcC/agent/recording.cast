[416.573151, "o", "# generated using pymatgen\r\ndata_FeS2\r\n_symmetry_space_group_name_H-M   'P 1'\r\n_cell_length_a   5.39682380\r\n_cell_length_b   5.39682380\r\n_cell_length_c   5.39682380\r\n_cell_angle_alpha   90.00000000\r\n_cell_angle_beta   90.00000000\r\n_cell_angle_gamma   90.00000000\r\n_symmetry_Int_Tables_number   1\r\n_chemical_formula_structural   FeS2\r\n_chemical_formula_sum   'Fe4 S8'\r\n_cell_volume   157.18630942\r\n_cell_formula_units_Z   4\r\nloop_\r\n _symmetry_equiv_pos_site_id\r\n _symmetry_equiv_pos_as_xyz\r\n  1  'x, y, z'\r\nloop_\r\n _atom_type_symbol\r\n _atom_type_oxidation_number\r\n  Fe4+  4.0\r\n  S2-  -2.0\r\nloop_\r\n _atom_site_type_symbol\r\n _atom_site_label\r\n _atom_site_symmetry_multiplicity\r\n _atom_site_fract_x\r\n _atom_site_fract_y\r\n _atom_site_fract_z\r\n _atom_site_occupancy\r\n  Fe4+  Fe0  1  0.00000000  0.50000000  0.50000000  1\r\n  Fe4+  Fe1  1  0.50000000  0.50000000  0.00000000  1\r\n  Fe4+  Fe2  1  0.50000000  0.00000000  0.50000000  1\r\n  Fe4+  Fe3  1  0.00000000  0.00000000  0.00000000  1\r\n  S2-  S4  1  0.38538014  0.11461986  0.88538014  1\r\n  S2-  S5  1  0.11461986  0.88538014  0.38538014  1\r\n  S2-  S6  1  0.88538014  0.38538014  0.11461986  1\r\n  S2-  S7  1  0.61461986  0.61461986  0.61461986  1\r\n  S2-  S8  1  0.38538014  0.38538014  0.38538014  1\r\n  S2-  S9  1  0.11461986  0.61461986  0.88538014  1\r\n  S2-  S10  1  0.88538014  0.11461986  0.61461986  1\r\n  S2-  S11  1  0.61461986  0.88538014  0.11461986  1\r\n"]
