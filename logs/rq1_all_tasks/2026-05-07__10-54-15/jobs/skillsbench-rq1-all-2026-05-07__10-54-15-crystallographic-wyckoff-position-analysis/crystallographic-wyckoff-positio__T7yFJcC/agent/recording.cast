[556.767641, "i", "cat > /root/workspace/solution.py << 'EOF'\nimport numpy as np\nfrom fractions import Fraction\nfrom pymatgen.core import Structure\nfrom pymatgen.symmetry.analyzer import SpacegroupAnalyzer\n\ndef analyze_wyckoff_position_multiplicities_and_coordinates(filepath: str) -> dict:\n    \"\"\"\n    Analyze Wyckoff position multiplicities and calculate approximate coordinates\n    for the first atom of each Wyckoff position.\n    \"\"\"\n    # Read structure from CIF file\n    struct = Structure.from_file(filepath)\n    \n    # Use SpacegroupAnalyzer to get the correct symmetry\n    # Increase symprec for numerical precision issues\n    sga = SpacegroupAnalyzer(struct, symprec=0.01)\n    \n    # Get the symmetry-reduced structure with site information\n    symm_struct = sga.get_symmetrized_structure()\n    \n    # Get primitive structure to find unique Wyckoff positions\n    prim_struct = sga.get_primitive_structure()\n    \n    # Analyze Wyckoff positions using symmetry\n    wyckoff_multiplicity_dict = {}\n    wyckoff_coordinates_dict = {}\n    \n    # Group atoms by their symmetry-equivalent positions\n    wyckoff_dict = {}  # key: wyckoff letter, value: list of (coords, site)\n    \n    for site in prim_struct:\n        # Get the Wyckoff letter and multiplicity from the structure\n        # Using pymatgen's structure analysis\n        label = site.label\n        species = site.specie.symbol\n        \n        # Get fractional coordinates\n        frac_coords = site.frac_coords\n        \n        # Determine Wyckoff position by analyzing the site symmetry\n        # We need to find the site symmetry and match it to Wyckoff positions\n        \n        # Get space group info\n        spg = sga.get_space_group_info()\n        \n        # Create a mapping of coordinates to wyckoff positions based on\n        # the symmetry operations\n    \n    # Alternative approach: Use the structure's site properties\n    # and analyze the symmetry\n    \n    # For each unique site in the symmetrized structure, get wyckoff info\n    for i, (idx, equi_idx) in enumerate(symm_struct.equivalent_sites):\n        site = symm_struct[i]\n        # The site symm is already calculated\n    \n    # Let's use a different approach - analyze the structure using spglib\n    # Get the dataset from spglib which contains Wyckoff information\n    import spglib\n    \n    # Convert pymatgen structure to spglib cell format\n    lattice = struct.lattice.matrix\n    positions = [site.frac_coords for site in struct]\n    species = [str(site.specie) for site in struct]\n    \n    cell = (lattice, positions, species)\n    \n    # Get symmetry dataset with full information\n    dataset = spglib.get_symmetry_dataset(cell, symprec=0.01)\n    \n    if dataset is None:\n        raise ValueError(\"Could not get symmetry information\")\n    \n    # Get space group number and symbol\n    international = dataset['international']\n    hall_number = dataset['hall_number']\n    \n    # Get Wyckoff positions from spglib\n    wyckoffs = dataset['wyckoffs']\n    \n    # Group atoms by Wyckoff letter\n    wyckoff_dict = {}\n    for i, wyckoff_letter in enumerate(wyckoffs):\n        if wyckoff_letter not in wyckoff_dict:\n            wyckoff_dict[wyckoff_letter] = []\n        wyckoff_dict[wyckoff_letter].append(i)\n    \n    # Count multiplicities (number of atoms per Wyckoff position)\n    for letter, indices in wyckoff_dict.items():\n        wyckoff_multiplicity_dict[letter] = len(indices)\n    \n    # Get coordinates for the first atom of each Wyckoff position\n    for letter, indices in wyckoff_dict.items():\n        first_idx = indices[0]\n        coords = positions[first_idx]\n        # Convert to fractions with denominator <= 12\n        frac_coords = []\n        for coord in coords:\n            # Round to nearest fraction with denominator <= 12\n            f = Fraction(coord).limit_denominator(12)\n            # Handle rounding for display (e.g., 11/12 is close to 1)\n            # If denominator is small enough, round to nearest 1/denominator\n            if f.denominator <= 12:\n                # Check if rounding to nearest fraction gives a better result\n                for d in "]
[556.76778, "i", "range(1, 13):\n                    rounded = round(coord * d) / d\n                    if abs(rounded - coord) < 0.01:\n                        frac_coords.append(str(Fraction(rounded).limit_denominator(12)))\n                        break\n                else:\n                    frac_coords.append(str(f))\n            else:\n                frac_coords.append(str(f))\n        wyckoff_coordinates_dict[letter] = frac_coords\n    \n    # Sort by wyckoff letter (a, b, c, ...)\n    wyckoff_multiplicity_dict = dict(sorted(wyckoff_multiplicity_dict.items()))\n    wyckoff_coordinates_dict = dict(sorted(wyckoff_coordinates_dict.items()))\n    \n    return {\n        \"wyckoff_multiplicity_dict\": wyckoff_multiplicity_dict,\n        \"wyckoff_coordinates_dict\": wyckoff_coordinates_dict\n    }\n\nif __name__ == \"__main__\":\n    result = analyze_wyckoff_position_multiplicities_and_coordinates(\"/root/cif_files/FeS2_mp-226.cif\")\n    print(result)\nEOF\n"]
