[75.752944, "i", "python3 << 'EOF'\nfrom pymatgen.core import Structure\nfrom pymatgen.symmetry.analyzer import SpacegroupAnalyzer\nfrom fractions import Fraction\n\nstruct = Structure.from_file(\"/root/cif_files/FeS2_mp-226.cif\")\nsga = SpacegroupAnalyzer(struct)\ndataset = sga.get_symmetry_dataset()\n\nprint(\"Wyckoffs:\", dataset.wyckoffs)\nprint(\"Std positions:\", dataset.std_positions)\n\n# Get unique Wyckoff positions\nunique_wyckoffs = list(dict.fromkeys(dataset.wyckoffs))\nprint(\"Unique Wyckoffs:\", unique_wyckoffs)\n\n# For each unique Wyckoff, find the first atom\nwyckoff_coords = {}\nfor wyck in unique_wyckoffs:\n    idx = dataset.wyckoffs.index(wyck)\n    coords = dataset.std_positions[idx]\n    wyckoff_coords[wyck] = coords\n    print(f\"Wyckoff {wyck}: {coords}\")\n    \n# Test fraction conversion\ntest_val = 0.38538014\nprint(f\"\\nFraction test: {test_val}\")\nfor d in range(1, 13):\n    f = Fraction(test_val).limit_denominator(d)\n    print(f\"  Denom {d}: {f} = {float(f):.10f}\")\nEOF\n"]
