[838.623533, "o", "from fractions import Fraction\r\nfrom typing import Any\r\nimport numpy as np\r\n\r\ndef rationalize(x: float, max_denom: int = 12) -> str:\r\n    \"\"\"Convert float to rational string with max denominator.\"\"\"\r\n    f = Fraction(x).limit_denominator(max_denom)\r\n    return str(f)\r\n\r\ndef analyze_wyckoff_position_multiplicities_and_coordinates(filepath: str) -> dict[str, Any]:\r\n    \"\"\"Analyze Wyckoff positions from a CIF file.\"\"\"\r\n    from pymatgen.core import Structure\r\n    from pymatgen.symmetry.analyzer import SpacegroupAnalyzer\r\n    \r\n    # Load structure from CIF\r\n    structure = Structure.from_file(filepath)\r\n    \r\n    # Get spacegroup analyzer\r\n    sym_analyzer = SpacegroupAnalyzer(structure)\r\n    \r\n    # Get symmetry dataset\r\n    symmetry_data = sym_analyzer.get_symmetry_dataset()\r\n    if symmetry_data is None:\r\n        raise ValueError(\"Could not get symmetry information\")\r\n    \r\n    # Get wyckoff letters from symmetry dataset\r\n    wyckoffs = symmetry_data.wyckoffs\r\n    \r\n    # Count multiplicities for each Wyckoff letter\r\n    wyckoff_counts = {}\r\n    wyckoff_first_coords = {}\r\n    \r\n    for idx, label in enumerate(wyckoffs):\r\n        if label not in wyckoff_counts:\r\n            wyckoff_counts[label] = 0\r\n            wyckoff_first_coords[label] = structure[idx].frac_coords\r\n        wyckoff_counts[label] += 1\r\n    \r\n    wyckoff_multiplicity_dict = {}\r\n    wyckoff_coordinates_dict = {}\r\n    \r\n    for label in sorted(wyckoff_counts.keys()):\r\n        wyckoff_multiplicity_dict[label] = wyckoff_counts[label]\r\n        coords = wyckoff_first_coords[label]\r\n"]
[838.623686, "o", "        wyckoff_coordinates_dict[label] = [rationalize(c) for c in coords]\r\n    \r\n    return {\r\n        'wyckoff_multiplicity_dict': wyckoff_multiplicity_dict,\r\n        'wyckoff_coordinates_dict': wyckoff_coordinates_dict\r\n    }\r\n\r\nif __name__ == \"__main__\":\r\n    result = analyze_wyckoff_position_multiplicities_and_coordinates(\"/root/cif_files/FeS2_mp-226.cif\")\r\n    print(result)\r\n"]
[838.623738, "o", "\u001b[?2004hroot@561ccb8d5e18:~/workspace# "]
