[123.343466, "i", "python3 << 'EOF'\nimport sys\nsys.path.insert(0, '/root/workspace')\nfrom solution import analyze_wyckoff_position_multiplicities_and_coordinates\n\n# Test with a few more files\nfiles = [\n    \"/root/cif_files/Al2O3_mp-7048.cif\",\n    \"/root/cif_files/C_mp-169.cif\",\n    \"/root/cif_files/SiO2_mp-6945.cif\"\n]\n\nfor f in files:\n    print(f\"\\n=== {f} ===\")\n    result = analyze_wyckoff_position_multiplicities_and_coordinates(f)\n    print(result)\nEOF\n"]
