[?2004l[?2004h> from pymatgen.core import Structure
[?2004l[?2004h> from pymatgen.symmetry.analyzer import SpacegroupAnalyzer
[?2004l[?2004h> from fractions import Fraction
[?2004l[?2004h> from typing import Dict, Any
[?2004l[?2004h> import sympy
[?2004l[?2004h> 
[?2004l[?2004h> def to_fraction_string(value: float, max_denominator: int = 12) -> str:
[?2004l[?2004h>     """Convert a float to a fraction string with denominator <= max_denominator."""
[?2004l[?2004h>     frac = Fraction(value).limit_denominator(max_denominator)
[?2004l[?2004h>     if frac.numerator == 0:
[?2004l[?2004h>         return "0"
[?2004l[?2004h>     if frac.denominator == 1:
[?2004l[?2004h>         return str(frac.numerator)
[?2004l[?2004h>     return f"{frac.numerator}/{frac.denominator}"
[?2004l[?2004h> 
[?2004l[?2004h> def analyze_wyckoff_position_multiplicities_and_coordinates(filepath: str) -> Dict[str, Any]:
[?2004l[?2004h>     """
[?2004l[?2004h>     Analyze Wyckoff position multiplicities and calculate approximate coordinates
[?2004l[?2004h>     for the first atom of each Wyckoff position.
[?2004l[?2004h>     
[?2004l[?2004h>     Args:
[?2004l[?2004h>         filepath: Path to the CIF file
[?2004l[?2004h>         
[?2004l[?2004h>     Returns:
[?2004l[?2004h>         Dictionary with 'wyckoff_multiplicity_dict' and 'wyckoff_coordinates_dict'
[?2004l[?2004h>     """
[?2004l[?2004h>     # Load structure from CIF
[?2004l[?2004h>     structure = Structure.from_file(filepath)
[?2004l[?2004h>     
[?2004l[?2004h>     # Get symmetry analyzer and dataset
[?2004l[?2004h>     analyzer = SpacegroupAnalyzer(structure)
[?2004l[?2004h>     sym_dataset = analyzer.get_symmetry_dataset()
[?2004l[?2004h>     
[?2004l[?2004h>     wyckoffs = sym_dataset['wyckoffs']
[?2004l[?2004h>     frac_coords = structure.frac_coords
[?2004l[?2004h>     
[?2004l[?2004h>     # Group Wyckoff positions and their indices
[?2004l[?2004h>     wyckoff_dict = {}
[?2004l[?2004h>     for idx, wpos in enumerate(wyckoffs):
[?2004l[?2004h>         if wpos not in wyckoff_dict:
[?2004l[?2004h>             wyckoff_dict[wpos] = idx
[?2004l[?2004h>     
[?2004l[?2004h>     # Calculate multiplicities and get first atom coordinates for each position
[?2004l[?2004h>     multiplicity_dict = {}
[?2004l[?2004h>     coordinates_dict = {}
[?2004l[?2004h>     
[?2004l[?2004h>     for wpos, first_idx in wyckoff_dict.items():
[?2004l[?2004h>         # Count multiplicity by counting occurrences
