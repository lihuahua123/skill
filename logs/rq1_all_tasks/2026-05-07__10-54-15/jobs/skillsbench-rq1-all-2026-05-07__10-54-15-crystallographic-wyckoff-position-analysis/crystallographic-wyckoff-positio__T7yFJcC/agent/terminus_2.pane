[?2004l[?2004h> from fractions import Fraction
[?2004l[?2004h> from pymatgen.core import Structure
[?2004l[?2004h> from pymatgen.symmetry.analyzer import SpacegroupAnalyzer
[?2004l[?2004h> from typing import Dict, Any
[?2004l[?2004h> 
[?2004l[?2004h> def decimal_to_rational_str(value: float, max_denom: int = 12) -> str:
[?2004l[?2004h>     """Convert a decimal to a rational string with denominators <= max_denom."""
[?2004l[?2004h>     # Handle very small values as 0
[?2004l[?2004h>     if abs(value) < 1e-6:
[?2004l[?2004h>         return "0"
[?2004l[?2004h>     # Handle 1 as 1
[?2004l[?2004h>     if abs(value - 1.0) < 1e-6:
[?2004l[?2004h>         return "1"
[?2004l[?2004h>     
[?2004l[?2004h>     frac = Fraction(value).limit_denominator(max_denom)
[?2004l[?2004h>     return str(frac)
[?2004l[?2004h> 
[?2004l[?2004h> def analyze_wyckoff_position_multiplicities_and_coordinates(filepath: str) -> Dict[str, Any]:
[?2004l[?2004h>     """
[?2004l[?2004h>     Analyze Wyckoff position multiplicities and calculate approximate coordinates
[?2004l[?2004h>     for the first atom of each Wyckoff position.
[?2004l[?2004h>     """
[?2004l[?2004h>     # Load structure from CIF file
[?2004l[?2004h>     structure = Structure.from_file(filepath)
[?2004l[?2004h>     
[?2004l[?2004h>     # Use SpacegroupAnalyzer to get symmetry information
[?2004l[?2004h>     sga = SpacegroupAnalyzer(structure)
[?2004l[?2004h>     symmetry_dataset = sga.get_symmetry_dataset()
[?2004l[?2004h>     
[?2004l[?2004h>     # Extract Wyckoff positions and coordinates
[?2004l[?2004h>     wyckoffs = symmetry_dataset['wyckoffs']
[?2004l[?2004h>     std_positions = symmetry_dataset['std_positions']
[?2004l[?2004h>     
[?2004l[?2004h>     # Find unique Wyckoff positions and track first occurrence
[?2004l[?2004h>     seen_wyckoffs = {}
[?2004l[?2004h>     for i, w in enumerate(wyckoffs):
[?2004l[?2004h>         if w not in seen_wyckoffs:
[?2004l[?2004h>             seen_wyckoffs[w] = i
[?2004l[?2004h>     
[?2004l[?2004h>     # Count multiplicities
[?2004l[?2004h>     wyckoff_multiplicity_dict = {}
[?2004l[?2004h>     for w in wyckoffs:
[?2004l[?2004h>         wyckoff_multiplicity_dict[w] = wyckoff_multiplicity_dict.get(w, 0) + 1
[?2004l[?2004h>     
[?2004l[?2004h>     # Get coordinates for first atom of each unique Wyckoff position
[?2004l[?2004h>     wyckoff_coordinates_dict = {}
[?2004l[?2004h>     for w, idx in seen_wyckoffs.items():
[?2004l[?2004h>         coords = std_positions[idx]
[?2004l[?2004h>         # Convert to rational strings
[?2004l[?2004h>         coord_strs = [decimal_to_rational_str(c) for c in coords]
[?2004l[?2004h>         wyckoff_coordinates_dict[w] = coord_strs
[?2004l[?2004h>     
[?2004l[?2004h>     # Sort by Wyckoff letter for consistent output
[?2004l[?2004h>     sorted_multiplicities = dict(sorted(wyckoff_multiplicity_dict.items()))
[?2004l[?2004h>     sorted_coordinates = dict(sorted(wyckoff_coordinates_dict.items()))
[?2004l[?2004h>     
[?2004l[?2004h>     return {
[?2004l[?2004h>         "wyckoff_multiplicity_dict": sorted_multiplicities,
[?2004l[?2004h>         "wyckoff_coordinates_dict": sorted_coordinates
[?2004l[?2004h>     }
[?2004l[?2004h> 
