[?2004hroot@561ccb8d5e18:~# cat > /root/workspace/solution.py << 'EOF'
[?2004l[?2004h> """
[?2004l[?2004h> CIF file analyzer for Wyckoff position multiplicities and coordinates.
[?2004l[?2004h> """
[?2004l[?2004h> from fractions import Fraction
[?2004l[?2004h> from typing import Dict, Any
[?2004l[?2004h> import numpy as np
[?2004l[?2004h> 
[?2004l[?2004h> from pymatgen.core import Structure
[?2004l[?2004h> from pymatgen.symmetry.analyzer import SpacegroupAnalyzer
[?2004l[?2004h> 
[?2004l[?2004h> 
[?2004l[?2004h> def _round_to_fraction(value: float, max_denominator: int = 12) -> str:
[?2004l[?2004h>     """
[?2004l[?2004h>     Round a float value to the closest fraction with denominator <= max_denominator.
[?2004l[?2004h>     Returns the fraction as a string.
[?2004l[?2004h>     """
[?2004l[?2004h>     frac = Fraction(value).limit_denominator(max_denominator)
[?2004l[?2004h>     # Handle the case where the value is very close to 0 or 1
[?2004l[?2004h>     if abs(value - round(value)) < 1e-6:
[?2004l[?2004h>         return str(int(round(value)))
[?2004l[?2004h>     return str(frac)
[?2004l[?2004h> 
[?2004l[?2004h> 
[?2004l[?2004h> def _normalize_fraction_string(frac_str: str) -> str:
[?2004l[?2004h>     """
[?2004l[?2004h>     Normalize a fraction string to ensure consistent formatting.
[?2004l[?2004h>     E.g., '0' becomes '0', '-1/2' stays '-1/2'.
[?2004l[?2004h>     """
[?2004l[?2004h>     return frac_str
[?2004l[?2004h> 
[?2004l[?2004h> 
[?2004l[?2004h> def analyze_wyckoff_position_multiplicities_and_coordinates(filepath: str) -> Dict[str, Dict[str, Any]]:
[?2004l[?2004h>     """
[?2004l[?2004h>     Analyze Wyckoff position multiplicities and calculate approximate coordinates
[?2004l[?2004h>     for the first atom of each Wyckoff position in a CIF file.
[?2004l[?2004h>     
[?2004l[?2004h>     Args:
[?2004l[?2004h>         filepath: Path to the CIF file.
[?2004l[?2004h>         
[?2004l[?2004h>     Returns:
[?2004l[?2004h>         A dictionary with two keys:
[?2004l[?2004h>         - 'wyckoff_multiplicity_dict': Dict mapping Wyckoff letters to their multiplicities
[?2004l[?2004h>         - 'wyckoff_coordinates_dict': Dict mapping Wyckoff letters to lists of coordinate strings
[?2004l[?2004h>           (x, y, z) for the first atom of each position, rounded to fractions with denominators <= 12
[?2004l[?2004h>     """
[?2004l[?2004h>     # Load structure from CIF file
[?2004l[?2004h>     struct = Structure.from_file(filepath)
[?2004l[?2004h>     
[?2004l[?2004h>     # Get symmetry analysis
[?2004l[?2004h>     sga = SpacegroupAnalyzer(struct)
[?2004l[?2004h>     dataset = sga.get_symmetry_dataset()
[?2004l[?2004h>     
[?2004l[?2004h>     wyckoffs = list(dataset.wyckoffs)
[?2004l[?2004h>     std_positions = dataset.std_positions
[?2004l[?2004h>     
[?2004l[?2004h>     # Get unique Wyckoff positions in order of appearance
[?2004l[?2004h>     unique_wyckoffs = list(dict.fromkeys(wyckoffs))
[?2004l[?2004h>     
[?2004l[?2004h>     # Calculate multiplicities for each unique Wyckoff position
[?2004l[?2004h>     wyckoff_multiplicity_dict = {}
[?2004l[?2004h>     for wyck in unique_wyckoffs:
[?2004l[?2004h>         wyckoff_multiplicity_dict[wyck] = wyckoffs.count(wyck)
[?2004l[?2004h>     
[?2004l[?2004h>     # Get coordinates for the first atom of each unique Wyckoff position
[?2004l[?2004h>     wyckoff_coordinates_dict = {}
[?2004l[?2004h>     for wyck in unique_wyckoffs:
[?2004l[?2004h>         # Find index of first occurrence of this Wyckoff position
