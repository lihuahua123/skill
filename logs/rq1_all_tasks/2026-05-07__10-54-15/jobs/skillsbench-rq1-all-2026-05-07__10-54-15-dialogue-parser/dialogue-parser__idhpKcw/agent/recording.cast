[104.111535, "i", "hape = \"rounded\"\n            color = \"lightgray\"\n        \n        # Escape text for DOT\n        text = node.text.replace('\"', '\\\\\"').replace('\\n', '\\\\n')\n        speaker = node.speaker if node.speaker else \"\"\n        label = f\"{speaker}: {text}\" if speaker else text\n        \n        lines.append(f'  \"{node_id}\" [label=\"{label}\", shape={shape}, style=rounded, fillcolor={color}];')\n    \n    # Add edges\n    for edge in graph.edges:\n        edge_text = edge.get('text', '') if isinstance(edge, dict) else getattr(edge, 'text', '')\n        if edge_text:\n            lines.append(f'  \"{edge[\"source\"]}\" -> \"{edge[\"target\"]}\" [label=\"{edge_text}\"];')\n        else:\n            lines.append(f'  \"{edge[\"source\"]}\" -> \"{edge[\"target\"]}\";')\n    \n    lines.append('}')\n    return '\\n'.join(lines)\n\n\ndef main():\n    # Read script\n    with open('/app/script.txt', 'r') as f:\n        script_text = f.read()\n    \n    # Parse script\n    graph = parse_script(script_text)\n    \n    # Export to JSON\n    json_data = graph.to_dict()\n    wit"]
