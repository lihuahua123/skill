[104.11777, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[104.117832, "o", "def generate_dot(graph: Graph) -> str:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[104.117943, "o", "    \"\"\"Generate DOT format visualization of the graph.\"\"\"\r\n\u001b[?2004l\r"]
[104.117988, "o", "\u001b[?2004h> "]
[104.118092, "o", "    lines = ['digraph dialogue {', '  rankdir=TB;', '  node [shape=box];']\r\n\u001b[?2004l\r"]
[104.118135, "o", "\u001b[?2004h> "]
[104.118178, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[104.118252, "o", "    for node_id, node in graph.nodes.items():\r\n\u001b[?2004l\r"]
[104.118298, "o", "\u001b[?2004h> "]
[104.118337, "o", "        if node.type == \"choice\":\r\n\u001b[?2004l\r"]
[104.118368, "o", "\u001b[?2004h> "]
[104.118427, "o", "            shape = \"diamond\"\r\n\u001b[?2004l\r"]
[104.11847, "o", "\u001b[?2004h> "]
[104.118513, "o", "            color = \"lightblue\"\r\n\u001b[?2004l\r"]
[104.118546, "o", "\u001b[?2004h> "]
[104.118595, "o", "        else:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[104.118711, "o", "            shape = \"rounded\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[104.118773, "o", "            color = \"lightgray\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[104.11881, "o", "> "]
[104.118852, "o", "        \r\n\u001b[?2004l\r"]
[104.118894, "o", "\u001b[?2004h> "]
[104.118947, "o", "        # Escape text for DOT\r\n\u001b[?2004l\r"]
[104.118991, "o", "\u001b[?2004h> "]
[104.119066, "o", "        text = node.text.replace('\"', '\\\\\"').replace('\\n', '\\\\n')\r\n\u001b[?2004l\r"]
[104.119098, "o", "\u001b[?2004h> "]
[104.119194, "o", "        speaker = node.speaker if node.speaker else \"\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[104.119218, "o", "> "]
[104.119315, "o", "        label = f\"{speaker}: {text}\" if speaker else text\r\n\u001b[?2004l\r"]
[104.11935, "o", "\u001b[?2004h> "]
[104.119388, "o", "        \r\n\u001b[?2004l\r"]
[104.11943, "o", "\u001b[?2004h> "]
[104.119578, "o", "        lines.append(f'  \"{node_id}\" [label=\"{label}\", shape={shape}, style=rounded, fillcolor={color}];')\r\n\u001b[?2004l\r"]
[104.119626, "o", "\u001b[?2004h>     \r\n"]
[104.119683, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[104.11974, "o", "    # Add edges\r\n\u001b[?2004l\r\u001b[?2004h> "]
[104.119807, "o", "    for edge in graph.edges:\r\n\u001b[?2004l\r"]
[104.119864, "o", "\u001b[?2004h> "]
[104.119953, "o", "        edge_text = edge.get('text', '') if isinstance(edge, dict) else getattr(edge, 'text', '')\r\n\u001b[?2004l\r\u001b[?2004h"]
[104.119972, "o", "> "]
[104.120066, "o", "        if edge_text:\r\n\u001b[?2004l\r"]
[104.120113, "o", "\u001b[?2004h> "]
[104.120214, "o", "            lines.append(f'  \"{edge[\"source\"]}\" -> \"{edge[\"target\"]}\" [label=\"{edge_text}\"];')\r\n\u001b[?2004l\r\u001b[?2004h> "]
[104.120254, "o", "        else:\r\n\u001b[?2004l\r"]
[104.120267, "o", "\u001b[?2004h> "]
[104.120405, "o", "            lines.append(f'  \"{edge[\"source\"]}\" -> \"{edge[\"target\"]}\";')\r\n\u001b[?2004l\r"]
[104.120447, "o", "\u001b[?2004h>     \r\n\u001b[?2004l\r"]
[104.120483, "o", "\u001b[?2004h> "]
[104.12052, "o", "    lines.append('}')\r\n\u001b[?2004l\r\u001b[?2004h> "]
[104.12057, "o", "    return '\\n'.join(lines)\r\n\u001b[?2004l\r"]
[104.120622, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[104.120677, "o", "> "]
[104.120729, "o", "def main():\r\n\u001b[?2004l\r\u001b[?2004h> "]
[104.120769, "o", "    # Read script\r\n\u001b[?2004l\r\u001b[?2004h> "]
[104.120814, "o", "    with open('/app/script.txt', 'r') as f:\r\n\u001b[?2004l\r"]
[104.120842, "o", "\u001b[?2004h> "]
