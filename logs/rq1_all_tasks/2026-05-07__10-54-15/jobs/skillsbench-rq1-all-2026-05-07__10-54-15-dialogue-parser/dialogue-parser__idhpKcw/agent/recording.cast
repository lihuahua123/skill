[104.120935, "o", ">     \r\n"]
[104.120964, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[104.121006, "o", "    # Parse script\r\n\u001b[?2004l\r"]
[104.121045, "o", "\u001b[?2004h> "]
[104.121101, "o", "    graph = parse_script(script_text)\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[104.121142, "o", "    # Export to JSON\r\n\u001b[?2004l\r"]
[104.121164, "o", "\u001b[?2004h> "]
[104.121221, "o", "    json_data = graph.to_dict()\r\n\u001b[?2004l\r\u001b[?2004h"]
[104.121264, "o", "> "]
[104.121318, "o", "    with open('/app/dialogue.json', 'w') as f:\r\n\u001b[?2004l\r\u001b[?2004h"]
[104.121349, "o", "> "]
[104.121374, "o", "        import json\r\n\u001b[?2004l\r"]
[104.121419, "o", "\u001b[?2004h> "]
[104.121464, "o", "        json.dump(json_data, f, indent=2)\r\n\u001b[?2004l\r\u001b[?2004h"]
[104.121506, "o", ">     \r\n\u001b[?2004l\r"]
[104.121559, "o", "\u001b[?2004h> "]
[104.121598, "o", "    # Generate DOT visualization\r\n\u001b[?2004l\r\u001b[?2004h> "]
[104.121662, "o", "    dot_content = generate_dot(graph)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[104.121756, "o", "    with open('/app/dialogue.dot', 'w') as f:\r\n\u001b[?2004l\r"]
[104.121786, "o", "\u001b[?2004h> "]
[104.121818, "o", "        f.write(dot_content)\r\n\u001b[?2004l\r"]
[104.12187, "o", "\u001b[?2004h> "]
[104.121909, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[104.121993, "o", "    print(f\"Parsed {len(graph.nodes)} nodes and {len(graph.edges)} edges\")\r\n\u001b[?2004l\r"]
[104.122024, "o", "\u001b[?2004h> "]
[104.122127, "o", "    print(\"Output written to /app/dialogue.json and /app/dialogue.dot\")\r\n\u001b[?2004l\r"]
[104.122173, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[104.122213, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[104.122264, "o", "if __name__ == '__main__':\r\n\u001b[?2004l\r"]
[104.122306, "o", "\u001b[?2004h> "]
[104.12236, "o", "    main()\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
