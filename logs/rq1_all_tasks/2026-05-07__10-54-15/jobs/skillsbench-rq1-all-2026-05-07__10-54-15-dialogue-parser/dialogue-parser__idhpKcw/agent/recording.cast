[104.11597, "o", "\u001b[?2004h> "]
[104.116067, "o", "            choice_node_id = f\"{current_node_id}_choice\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[104.116077, "o", "> "]
[104.116117, "o", "            \r\n\u001b[?2004l\r"]
[104.116145, "o", "\u001b[?2004h> "]
