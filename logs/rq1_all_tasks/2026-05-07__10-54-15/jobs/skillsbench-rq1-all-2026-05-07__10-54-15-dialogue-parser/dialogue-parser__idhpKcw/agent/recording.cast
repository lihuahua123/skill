[177.682858, "o", "        else:\r\n\u001b[?2004l\r"]
[177.682919, "o", "\u001b[?2004h> "]
[177.682977, "o", "            shape = \"rounded\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[177.683039, "o", "            color = \"lightgray\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[177.683083, "o", "> "]
[177.683134, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h> "]
[177.683179, "o", "        # Escape text for DOT\r\n\u001b[?2004l\r\u001b[?2004h"]
[177.683219, "o", "> "]
[177.683318, "o", "        text = node.text.replace('\"', '\\\\\"').replace('\\n', '\\\\n')\r\n\u001b[?2004l\r\u001b[?2004h"]
[177.683355, "o", "> "]
[177.683436, "o", "        speaker = node.speaker if node.speaker else \"\"\r\n\u001b[?2004l\r"]
[177.683475, "o", "\u001b[?2004h> "]
[177.683567, "o", "        label = f\"{speaker}: {text}\" if speaker else text\r\n\u001b[?2004l\r\u001b[?2004h"]
[177.683612, "o", "> "]
[177.683656, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h> "]
[177.683806, "o", "        lines.append(f'  \"{node_id}\" [label=\"{label}\", shape={shape}, style=rounded, fillcolor={color}];')\r\n\u001b[?2004l\r"]
[177.683849, "o", "\u001b[?2004h> "]
[177.683886, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[177.683931, "o", "    # Add edges\r\n\u001b[?2004l\r"]
[177.683966, "o", "\u001b[?2004h> "]
[177.684015, "o", "    for edge in graph.edges:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[177.684069, "o", "        if edge.text:\r\n\u001b[?2004l\r"]
[177.684101, "o", "\u001b[?2004h> "]
[177.684189, "o", "            edge_text = edge.text.replace('\"', '\\\\\"')\r\n\u001b[?2004l\r\u001b[?2004h"]
[177.68423, "o", "> "]
[177.684361, "o", "            lines.append(f'  \"{edge.source}\" -> \"{edge.target}\" [label=\"{edge_text}\"];')\r\n\u001b[?2004l\r\u001b[?2004h"]
[177.684399, "o", "> "]
[177.684446, "o", "        else:\r\n\u001b[?2004l\r"]
[177.68448, "o", "\u001b[?2004h> "]
[177.684572, "o", "            lines.append(f'  \"{edge.source}\" -> \"{edge.target}\";')\r\n\u001b[?2004l\r\u001b[?2004h"]
[177.684607, "o", ">     \r\n\u001b[?2004l\r"]
[177.684651, "o", "\u001b[?2004h> "]
[177.684696, "o", "    lines.append('}')\r\n\u001b[?2004l\r"]
[177.684731, "o", "\u001b[?2004h> "]
[177.684752, "o", "    return '\\n'.join(lines)\r\n\u001b[?2004l\r"]
[177.684805, "o", "\u001b[?2004h> "]
[177.684849, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[177.684869, "o", "def main():\r\n\u001b[?2004l\r"]
[177.684911, "o", "\u001b[?2004h> "]
[177.684952, "o", "    # Read script\r\n\u001b[?2004l\r"]
[177.684995, "o", "\u001b[?2004h> "]
[177.685052, "o", "    with open('/app/script.txt', 'r') as f:\r\n\u001b[?2004l\r\u001b[?2004h"]
[177.685094, "o", "> "]
[177.685143, "o", "        script_text = f.read()\r\n\u001b[?2004l\r"]
[177.685186, "o", "\u001b[?2004h> "]
[177.685222, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[177.685255, "o", "    # Parse script"]
[177.685291, "o", "\r\n\u001b[?2004l\r\u001b[?2004h"]
[177.685324, "o", "> "]
[177.685375, "o", "    graph = parse_script(script_text)\r\n\u001b[?2004l\r"]
[177.685417, "o", "\u001b[?2004h> "]
[177.685462, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[177.685503, "o", "    # Export to JSON\r\n\u001b[?2004l\r"]
[177.685539, "o", "\u001b[?2004h> "]
[177.685589, "o", "    json_data = graph.to_dict()\r\n\u001b[?2004l\r"]
[177.685633, "o", "\u001b[?2004h> "]
[177.685707, "o", "    with open('/app/dialogue.json', 'w') as f:\r\n\u001b[?2004l\r\u001b[?2004h"]
[177.68574, "o", "> "]
[177.685774, "o", "        import json\r\n\u001b[?2004l\r"]
[177.685815, "o", "\u001b[?2004h> "]
[177.685886, "o", "        json.dump(json_data, f, indent=2)\r\n\u001b[?2004l\r\u001b[?2004h"]
[177.68591, "o", "> "]
[177.685936, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[177.685964, "o", "> "]
[177.686025, "o", "    # Generate DOT visualization\r\n\u001b[?2004l\r"]
[177.686057, "o", "\u001b[?2004h> "]
[177.686133, "o", "    dot_content = generate_dot(graph)\r\n\u001b[?2004l\r"]
[177.686174, "o", "\u001b[?2004h> "]
[177.686247, "o", "    with open('/app/dialogue.dot', 'w') as f:\r\n\u001b[?2004l\r\u001b[?2004h"]
[177.686283, "o", "> "]
[177.686336, "o", "        f.write(dot_content)\r\n\u001b[?2004l\r\u001b[?2004h"]
[177.686377, "o", "> "]
[177.686422, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[177.686534, "o", "    print(f\"Parsed {len(graph.nodes)} nodes and {len(graph.edges)} edges\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[177.686567, "o", "> "]
[177.686723, "o", "    print(\"Output written to /app/dialogue.json and /app/dialogue.dot\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[177.686773, "o", "> \r\n\u001b[?2004l\r"]
[177.686817, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[177.686865, "o", "if __name__ == '__main__':\r\n\u001b[?2004l\r\u001b[?2004h"]
[177.68689, "o", "> "]
[177.68693, "o", "    main()\r\n\u001b[?2004l\r"]
[177.686966, "o", "\u001b[?2004h> "]
[177.687002, "o", "EOF\r\n\u001b[?2004l\r"]
