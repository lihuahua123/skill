[104.116395, "o", "\u001b[?2004h> "]
[104.116493, "o", "                graph.nodes[choice_node_id].text += \"\\n\" + full_choice\r\n\u001b[?2004l\r"]
[104.116525, "o", "\u001b[?2004h> "]
[104.116565, "o", "            else:\r\n\u001b[?2004l\r"]
