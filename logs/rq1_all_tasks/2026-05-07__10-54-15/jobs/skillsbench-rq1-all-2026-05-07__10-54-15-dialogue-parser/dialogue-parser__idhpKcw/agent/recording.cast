[186.08623, "o", "{\r\n  \"nodes\": [\r\n    {\r\n      \"id\": \"Start\",\r\n      \"text\": \"The tavern door creaks open. Smoke and laughter fill the air.\",\r\n      \"speaker\": \"Narrator\",\r\n      \"type\": \"line\"\r\n    },\r\n    {\r\n      \"id\": \"TavernEntry\",\r\n      \"text\": \"Three figures catch your eye: a hooded stranger, a boisterous merchant, and the barkeep.\",\r\n      \"speaker\": \"Narrator\",\r\n      \"type\": \"line\"\r\n    },\r\n    {\r\n      \"id\": \"TavernChoice\",\r\n      \"text\": \"1. Approach the hooded stranger.\\n2. Sit next to the merchant.\\n3. Order a drink from the barkeep.\\n4. [Observe] Study the room from the shadows.\",\r\n      \"speaker\": null,\r\n      \"type\": \"choice\"\r\n    },\r\n    {\r\n      \"id\": \"ObserveRoom\",\r\n      \"text\": \"You notice the stranger slipping a note to the barkeep. The merchant counts gold nervously.\",\r\n      \"speaker\": \"Narrator\",\r\n      \"type\": \"line\"\r\n    },\r\n    {\r\n      \"id\": \"ObserveChoice\",\r\n      \"text\": \"1. Intercept the note.\\n2. Pickpocket the merchant.\\n3. Pretend you saw nothing.\",\r\n      \"speaker\": null,\r\n      \"type\": \""]
[186.086271, "o", "choice\"\r\n    },\r\n    {\r\n      \"id\": \"InterceptNote\",\r\n      \"text\": \"You dare?!\",\r\n      \"speaker\": \"Stranger\",\r\n      \"type\": \"line\"\r\n    },\r\n    {\r\n      \"id\": \"PickpocketAttempt\",\r\n      \"text\": \"1. [Sleight of Hand] Swiftly grab the pouch.\\n2. [Distraction] Bump into him accidentally.\\n3. Abandon the attempt.\",\r\n      \"speaker\": null,\r\n      \"type\": \"choice\"\r\n    },\r\n    {\r\n      \"id\": \"PickpocketSuccess\",\r\n      \"text\": \"50 gold pieces heavier, you slip away. The merchant hasn't noticed... yet.\",\r\n      \"speaker\": \"Narrator\",\r\n      \"type\": \"line\"\r\n    },\r\n    {\r\n      \"id\": \"PickpocketDistract\",\r\n      \"text\": \"Watch it, friend!\",\r\n      \"speaker\": \"Merchant\",\r\n      \"type\": \"line\"\r\n    },\r\n    {\r\n      \"id\": \"MerchantAnnoyed\",\r\n      \"text\": \"1. Apologize profusely.\\n2. [Intimidate] You watch where YOU'RE going.\\n3. Use the distraction to grab the gold.\",\r\n      \"speaker\": null,\r\n      \"type\": \"choice\"\r\n    },\r\n    {\r\n      \"id\": \"MerchantCalm\",\r\n      \"text\": \"Hmph. Buy me a drink and we're even.\",\r\n "]
[186.086425, "o", "     \"speaker\": \"Merchant\",\r\n      \"type\": \"line\"\r\n    },\r\n    {\r\n      \"id\": \"MerchantFight\",\r\n      \"text\": \"Why you little\\u2014!\",\r\n      \"speaker\": \"Merchant\",\r\n      \"type\": \"line\"\r\n    },\r\n    {\r\n      \"id\": \"PickpocketAfter\",\r\n      \"text\": \"But where to spend your ill-gotten gains?\",\r\n      \"speaker\": \"Narrator\",\r\n      \"type\": \"line\"\r\n    },\r\n"]
