[131.911473, "o", "> \r\n\u001b[?2004l\r "]
[131.911485, "o", "\u001b[?2004h> "]
[131.91169, "o", "def parse_script(text: str) -> Graph:"]
[131.911793, "o", "\r\n\u001b[?2004l\r"]
[131.911826, "o", "\u001b[?2004h>     \"\"\"\r\n\u001b[?2004l\r"]
[131.911916, "o", "\u001b[?2004h> "]
[131.912044, "o", "    Parse dialogue script text into a Graph object.\r\n\u001b[?2004l\r"]
[131.912101, "o", "\u001b[?2004h> "]
[131.912117, "o", "    \"\"\"\r\n\u001b[?2004l\r"]
[131.912142, "o", "\u001b[?2004h> "]
[131.91222, "o", "    graph = Graph()\r\n\u001b[?2004l\r"]
[131.912287, "o", "\u001b[?2004h> "]
[131.912415, "o", "    lines = text.strip().split('\\n')\r\n\u001b[?2004l\r\u001b[?2004h"]
[131.912466, "o", "> "]
[131.912518, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[131.912569, "o", "    current_node_id = None\r\n\u001b[?2004l\r\u001b[?2004h"]
[131.912602, "o", "> "]
[131.912669, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[131.912718, "o", "    for line in lines:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[131.912822, "o", "        line = line.strip()\r\n\u001b[?2004l\r"]
[131.912865, "o", "\u001b[?2004h> "]
[131.91294, "o", "        if not line:\r\n\u001b[?2004l\r\u001b[?2004h"]
[131.912986, "o", "> "]
[131.913048, "o", "            continue\r\n\u001b[?2004l\r\u001b[?2004h"]
[131.913092, "o", "> "]
[131.913147, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h> "]
[131.913208, "o", "        # Check if this is a node header [NodeID]\r\n\u001b[?2004l\r"]
[131.91325, "o", "\u001b[?2004h> "]
[131.913305, "o", "        header_match = re.match(r'\\[(\\w+)\\]', line)\r\n\u001b[?2004l\r\u001b[?2004h"]
[131.913334, "o", "> "]
[131.913364, "o", "        if header_match:\r\n\u001b[?2004l\r"]
[131.9134, "o", "\u001b[?2004h> "]
[131.913455, "o", "            current_node_id = header_match.group(1)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[131.913503, "o", "            continue\r\n\u001b[?2004l\r\u001b[?2004h> "]
[131.91354, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h"]
[131.913573, "o", "> "]
[131.913656, "o", "        # Check if this is a regular dialogue line with -> target\r\n\u001b[?2004l\r\u001b[?2004h"]
[131.913703, "o", "> "]
[131.913783, "o", "        dialogue_match = re.match(r'^([^:]+):\\s*(.+?)\\s*->\\s*(\\w+)$', line)\r\n\u001b[?2004l\r"]
[131.91382, "o", "\u001b[?2004h> "]
[131.913861, "o", "        if dialogue_match:\r\n\u001b[?2004l\r"]
[131.9139, "o", "\u001b[?2004h> "]
[131.913939, "o", "            speaker = dialogue_match.group(1).strip()\r\n\u001b[?2004l\r\u001b[?2004h"]
[131.913966, "o", "> "]
[131.914044, "o", "            dialogue_text = dialogue_match.group(2).strip()\r\n\u001b[?2004l\r"]
[131.914083, "o", "\u001b[?2004h> "]
[131.914137, "o", "            target = dialogue_match.group(3).strip()\r\n\u001b[?2004l\r\u001b[?2004h"]
[131.914175, "o", "> "]
[131.914212, "o", "            \r\n\u001b[?2004l\r\u001b[?2004h> "]
[131.914267, "o", "            # Create current node if not exists\r\n\u001b[?2004l\r\u001b[?2004h> "]
[131.914359, "o", "            if current_node_id not in graph.nodes:\r\n\u001b[?2004l\r"]
[131.914418, "o", "\u001b[?2004h> "]
[131.914544, "o", "                graph.add_node(Node(id=current_node_id, speaker=speaker, text=dialogue_text, type=\"line\"))\r\n\u001b[?2004l\r"]
[131.914586, "o", "\u001b[?2004h> "]
[131.914623, "o", "            \r\n\u001b[?2004l\r\u001b[?2004h> "]
[131.914753, "o", "            # Add edge to target\r\n\u001b[?2004l\r\u001b[?2004h> "]
[131.914842, "o", "            graph.add_edge(Edge(source=current_node_id, target=target, text=\"\"))\r\n\u001b[?2004l\r"]
[131.914881, "o", "\u001b[?2004h> "]
[131.91492, "o", "            continue\r\n\u001b[?2004l\r"]
[131.914972, "o", "\u001b[?2004h> "]
[131.91501, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h> "]
[131.915118, "o", "        # Check if this is a choice line with optional [Skill]\r\n\u001b[?2004l\r\u001b[?2004h"]
[131.915148, "o", "> "]
[131.915305, "o", "        choice_match = re.match(r'^(\\d+)\\.\\s*(?:\\[(\\w+)\\]\\s*)?(.+?)\\s*->\\s*(\\w+)$', line)\r\n\u001b[?2004l\r"]
[131.915339, "o", "\u001b[?2004h> "]
[131.915388, "o", "        if choice_match:\r\n\u001b[?2004l\r\u001b[?2004h"]
[131.915418, "o", "> "]
[131.915497, "o", "            choice_num = choice_match.group(1)\r\n\u001b[?2004l\r"]
[131.915535, "o", "\u001b[?2004h> "]
[131.915634, "o", "            skill = choice_match.group(2)  # Optional skill\r\n\u001b[?2004l\r"]
[131.915679, "o", "\u001b[?2004h> "]
[131.915767, "o", "            choice_text = choice_match.group(3).strip()\r\n\u001b[?2004l\r"]
[131.915798, "o", "\u001b[?2004h> "]
[131.915895, "o", "            target = choice_match.group(4).strip()\r\n\u001b[?2004l\r"]
[131.915936, "o", "\u001b[?2004h> "]
[131.915977, "o", "            \r\n\u001b[?2004l\r\u001b[?2004h"]
[131.916015, "o", "> "]
[131.916062, "o", "            # Build full choice text\r\n\u001b[?2004l\r"]
[131.916098, "o", "\u001b[?2004h> "]
[131.91613, "o", "            if skill:\r\n\u001b[?2004l\r"]
[131.916163, "o", "\u001b[?2004h> "]
[131.916306, "o", "                full_choice = f\"{choice_num}. [{skill}] {choice_text}\"\r\n\u001b[?2004l\r"]
[131.916339, "o", "\u001b[?2004h> "]
[131.916379, "o", "            else:\r\n\u001b[?2004l\r"]
[131.916419, "o", "\u001b[?2004h> "]
[131.916542, "o", "                full_choice = f\"{choice_num}. {choice_text}\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[131.916572, "o", "> "]
[131.916612, "o", "            \r\n\u001b[?2004l\r"]
[131.916665, "o", "\u001b[?2004h> "]
[131.916704, "o", "            # Create or update choice node\r\n\u001b[?2004l\r"]
[131.916724, "o", "\u001b[?2004h> "]
[131.916904, "o", "            choice_node_id = f\"{current_node_id}_choice\"\r\n\u001b[?2004l\r\u001b[?2004h>             \r\n\u001b[?2004l\r"]
[131.916975, "o", "\u001b[?2004h> "]
[131.917032, "o", "            if choice_node_id in graph.nodes:\r\n\u001b[?2004l\r\u001b[?2004h"]
[131.917079, "o", "> "]
[131.91715, "o", "                # Append to existing choice text\r\n\u001b[?2004l\r"]
[131.917193, "o", "\u001b[?2004h> "]
[131.917292, "o", "                graph.nodes[choice_node_id].text += \"\\n\" + full_choice\r\n\u001b[?2004l\r"]
[131.917337, "o", "\u001b[?2004h> "]
[131.917358, "o", "            else:\r\n\u001b[?2004l\r"]
[131.91742, "o", "\u001b[?2004h> "]
[131.917472, "o", "                # Create new choice node\r\n\u001b[?2004l\r\u001b[?2004h"]
[131.917505, "o", "> "]
[131.917658, "o", "                graph.add_node(Node(id=choice_node_id, speaker=None, text=full_choice, type=\"choice\"))\r\n\u001b[?2004l\r\u001b[?2004h"]
[131.917705, "o", "> "]
[131.917791, "o", "                # Add edge from main node to choice node\r\n\u001b[?2004l\r\u001b[?2004h"]
[131.917826, "o", "> "]
[131.917964, "o", "                graph.add_edge(Edge(source=current_node_id, target=choice_node_id, text=\"\"))\r\n\u001b[?2004l\r\u001b[?2004h"]
[131.917997, "o", "> "]
[131.918036, "o", "            \r\n\u001b[?2004l\r"]
[131.918061, "o", "\u001b[?2004h> "]
[131.918136, "o", "            # Add edge from choice node to target\r\n\u001b[?2004l\r\u001b[?2004h"]
[131.918151, "o", "> "]
[131.918295, "o", "            graph.add_edge(Edge(source=choice_node_id, target=target, text=full_choice))\r\n\u001b[?2004l\r"]
[131.91838, "o", "\u001b[?2004h> "]
[131.918437, "o", "            continue\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r"]
[131.918472, "o", "\u001b[?2004h>     return graph\r\n\u001b[?2004l\r"]
[131.918508, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[131.918555, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[131.918598, "o", "\u001b[?2004h> "]
[131.918661, "o", "def generate_dot(graph: Graph) -> str:\r\n\u001b[?2004l\r"]
[131.91871, "o", "\u001b[?2004h"]
[131.918752, "o", "> "]
[131.918861, "o", "    \"\"\"Generate DOT format visualization of the graph.\"\"\"\r\n\u001b[?2004l\r"]
[131.918897, "o", "\u001b[?2004h> "]
[131.919008, "o", "    lines = ['digraph dialogue {', '  rankdir=TB;', '  node [shape=box];']\r\n\u001b[?2004l\r"]
[131.919052, "o", "\u001b[?2004h> "]
[131.919089, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[131.919165, "o", "    for node_id, node in graph.nodes.items():\r\n\u001b[?2004l\r\u001b[?2004h"]
[131.919208, "o", "> "]
[131.919263, "o", "        if node.type == \"choice\":\r\n\u001b[?2004l\r\u001b[?2004h"]
[131.91931, "o", "> "]
[131.919354, "o", "            shape = \"diamond\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[131.919402, "o", "> "]
[131.919452, "o", "            color = \"lightblue\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[131.919493, "o", "> "]
[131.919522, "o", "        else:\r\n\u001b[?2004l\r\u001b[?2004h"]
[131.919568, "o", "> "]
[131.919604, "o", "            shape = \"rounded\"\r\n\u001b[?2004l\r"]
[131.91965, "o", "\u001b[?2004h> "]
[131.919694, "o", "            color = \"lightgray\"\r\n\u001b[?2004l\r"]
[131.919745, "o", "\u001b[?2004h> "]
[131.91979, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h> "]
[131.919844, "o", "        # Escape text for DOT\r\n\u001b[?2004l\r\u001b[?2004h"]
[131.919879, "o", "> "]
[131.919982, "o", "        text = node.text.replace('\"', '\\\\\"').replace('\\n', '\\\\n')\r\n\u001b[?2004l\r\u001b[?2004h"]
[131.920017, "o", "> "]
[131.920099, "o", "        speaker = node.speaker if node.speaker else \"\"\r\n\u001b[?2004l\r"]
[131.920144, "o", "\u001b[?2004h> "]
[131.920225, "o", "        label = f\"{speaker}: {text}\" if speaker else text\r\n\u001b[?2004l\r"]
[131.92027, "o", "\u001b[?2004h> "]
[131.92032, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h> "]
[131.920478, "o", "        lines.append(f'  \"{node_id}\" [label=\"{label}\", shape={shape}, style=rounded, fillcolor={color}];')\r\n\u001b[?2004l\r\u001b[?2004h"]
[131.920525, "o", "> "]
[131.92057, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[131.920616, "o", "    # Add edges\r\n\u001b[?2004l\r\u001b[?2004h"]
[131.920672, "o", "> "]
[131.920726, "o", "    for edge in graph.edges:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[131.92077, "o", "        if edge.text:\r\n\u001b[?2004l\r"]
[131.920816, "o", "\u001b[?2004h> "]
[131.920874, "o", "            edge_text = edge.text.replace('\"', '\\\\\"')\r\n\u001b[?2004l\r"]
[131.920919, "o", "\u001b[?2004h> "]
[131.921051, "o", "            lines.append(f'  \"{edge.source}\" -> \"{edge.target}\" [label=\"{edge_text}\"];')\r\n\u001b[?2004l\r\u001b[?2004h"]
[131.921087, "o", "> "]
[131.921126, "o", "        else:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[131.921244, "o", "            lines.append(f'  \"{edge.source}\" -> \"{edge.target}\";')\r\n\u001b[?2004l\r\u001b[?2004h"]
[131.921297, "o", ">     \r\n\u001b[?2004l\r"]
[131.921342, "o", "\u001b[?2004h> "]
[131.921379, "o", "    lines.append('}')\r\n\u001b[?2004l\r"]
[131.921422, "o", "\u001b[?2004h> "]
[131.921455, "o", "    return '\\n'.join(lines)\r\n\u001b[?2004l\r"]
[131.921474, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[131.921525, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[131.921569, "o", "def main():\r\n\u001b[?2004l\r\u001b[?2004h"]
[131.921612, "o", "> "]
[131.921664, "o", "    # Read script\r\n\u001b[?2004l\r"]
[131.921708, "o", "\u001b[?2004h> "]
[131.921758, "o", "    with open('/app/script.txt', 'r') as f:\r\n\u001b[?2004l\r\u001b[?2004h"]
[131.921803, "o", "> "]
[131.921851, "o", "        script_text = f.read()\r\n\u001b[?2004l\r\u001b[?2004h"]
[131.921895, "o", "> "]
[131.921949, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[131.921992, "o", "    # Parse script\r\n\u001b[?2004l\r\u001b[?2004h"]
[131.922036, "o", "> "]
[131.922076, "o", "    graph = parse_script(script_text)\r\n\u001b[?2004l\r"]
[131.922124, "o", "\u001b[?2004h> "]
[131.922162, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[131.922206, "o", "    # Export to JSON\r\n\u001b[?2004l\r"]
[131.922242, "o", "\u001b[?2004h> "]
[131.922287, "o", "    json_data = graph.to_dict()\r\n\u001b[?2004l\r\u001b[?2004h"]
[131.922334, "o", "> "]
[131.922401, "o", "    with open('/app/dialogue.json', 'w') as f:\r\n\u001b[?2004l\r\u001b[?2004h"]
[131.922446, "o", "> "]
[131.922466, "o", "        import json\r\n\u001b[?2004l\r"]
[131.922518, "o", "\u001b[?2004h"]
[131.922564, "o", "> "]
[131.922601, "o", "        json.dump(json_data, f, indent=2)\r\n\u001b[?2004l\r"]
[131.922658, "o", "\u001b[?2004h>     \r\n\u001b[?2004l\r"]
[131.922709, "o", "\u001b[?2004h> "]
[131.922745, "o", "    # Generate DOT visualization\r\n\u001b[?2004l\r"]
[131.922789, "o", "\u001b[?2004h> "]
[131.922848, "o", "    dot_content = generate_dot(graph)\r\n\u001b[?2004l\r\u001b[?2004h"]
[131.922891, "o", "> "]
[131.92296, "o", "    with open('/app/dialogue.dot', 'w') as f:\r\n\u001b[?2004l\r\u001b[?2004h"]
[131.923006, "o", "> "]
[131.923053, "o", "        f.write(dot_content)\r\n\u001b[?2004l\r\u001b[?2004h"]
[131.923098, "o", ">     \r\n\u001b[?2004l\r\u001b[?2004h"]
[131.92314, "o", "> "]
[131.923242, "o", "    print(f\"Parsed {len(graph.nodes)} nodes and {len(graph.edges)} edges\")\r\n\u001b[?2004l\r"]
[131.923285, "o", "\u001b[?2004h> "]
[131.923391, "o", "    print(\"Output written to /app/dialogue.json and /app/dialogue.dot\")\r\n\u001b[?2004l\r"]
[131.923446, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n"]
[131.923482, "o", "\u001b[?2004l\r"]
[131.923515, "o", "\u001b[?2004h> "]
[131.92355, "o", "if __name__ == '__main__':\r\n\u001b[?2004l\r"]
[131.923598, "o", "\u001b[?2004h> "]
[131.923653, "o", "    main()\r\n\u001b[?2004l\r"]
[131.923683, "o", "\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
[131.924745, "o", "\u001b[?2004hroot@0588585e24cd:/app# "]
[132.410983, "i", "python3 /app/solution.py\n"]
[132.411298, "o", "python3 /app/solution.py\r\n\u001b[?2004l\r"]
[132.443024, "o", "Parsed 204 nodes and 379 edges\r\nOutput written to /app/dialogue.json and /app/dialogue.dot\r\n"]
[132.446765, "o", "\u001b[?2004hroot@0588585e24cd:/app# "]
[142.5273, "i", "head -50 /app/dialogue.json\n"]
[142.527489, "o", "head -50 /app/dialogue.json\r\n\u001b[?2004l\r"]
[142.529415, "o", "{\r\n  \"nodes\": [\r\n    {\r\n      \"id\": \"Start\",\r\n      \"text\": \"The tavern door creaks open. Smoke and laughter fill the air.\",\r\n      \"speaker\": \"Narrator\",\r\n      \"type\": \"line\"\r\n    },\r\n    {\r\n      \"id\": \"TavernEntry\",\r\n      \"text\": \"Three figures catch your eye: a hooded stranger, a boisterous merchant, and the barkeep.\",\r\n      \"speaker\": \"Narrator\",\r\n      \"type\": \"line\"\r\n    },\r\n    {\r\n      \"id\": \"TavernChoice_choice\",\r\n      \"text\": \"1. Approach the hooded stranger.\\n2. Sit next to the merchant.\\n3. Order a drink from the barkeep.\\n4. [Observe] Study the room from the shadows.\",\r\n      \"speaker\": null,\r\n      \"type\": \"choice\"\r\n    },\r\n    {\r\n      \"id\": \"ObserveRoom\",\r\n      \"text\": \"You notice the stranger slipping a note to the barkeep. The merchant counts gold nervously.\",\r\n      \"speaker\": \"Narrator\",\r\n      \"type\": \"line\"\r\n    },\r\n    {\r\n      \"id\": \"ObserveChoice_choice\",\r\n      \"text\": \"1. Intercept the note.\\n2. Pickpocket the merchant.\\n3. Pretend you saw nothing.\",\r\n      \"speaker\": null,\r\n "]
[142.529464, "o", "     \"type\": \"choice\"\r\n    },\r\n    {\r\n      \"id\": \"InterceptNote\",\r\n      \"text\": \"You dare?!\",\r\n      \"speaker\": \"Stranger\",\r\n      \"type\": \"line\"\r\n    },\r\n    {\r\n      \"id\": \"PickpocketAttempt_choice\",\r\n      \"text\": \"1. [Sleight of Hand] Swiftly grab the pouch.\\n2. [Distraction] Bump into him accidentally.\\n3. Abandon the attempt.\",\r\n      \"speaker\": null,\r\n      \"type\": \"choice\"\r\n    },\r\n    {\r\n      \"id\": \"PickpocketSuccess\",\r\n      \"text\": \"50 gold pieces heavier, you slip away. The merchant hasn't noticed... yet.\",\r\n      \"speaker\": \"Narrator\",\r\n      \"type\": \"line\"\r\n    },\r\n"]
[142.529911, "o", "\u001b[?2004hroot@0588585e24cd:/app# "]
[142.62784, "i", "head -30 /app/dialogue.dot\n"]
[142.628002, "o", "head -30 /app/dialogue.dot\r\n\u001b[?2004l\r"]
[142.628921, "o", "digraph dialogue {\r\n  rankdir=TB;\r\n  node [shape=box];\r\n  \"Start\" [label=\"Narrator: The tavern door creaks open. Smoke and laughter fill the air.\", shape=rounded, style=rounded, fillcolor=lightgray];\r\n  \"TavernEntry\" [label=\"Narrator: Three figures catch your eye: a hooded stranger, a boisterous merchant, and the barkeep.\", shape=rounded, style=rounded, fillcolor=lightgray];\r\n  \"TavernChoice_choice\" [label=\"1. Approach the hooded stranger.\\n2. Sit next to the merchant.\\n3. Order a drink from the barkeep.\\n4. [Observe] Study the room from the shadows.\", shape=diamond, style=rounded, fillcolor=lightblue];\r\n  \"ObserveRoom\" [label=\"Narrator: You notice the stranger slipping a note to the barkeep. The merchant counts gold nervously.\", shape=rounded, style=rounded, fillcolor=lightgray];\r\n  \"ObserveChoice_choice\" [label=\"1. Intercept the note.\\n2. Pickpocket the merchant.\\n3. Pretend you saw nothing.\", shape=diamond, style=rounded, fillcolor=lightblue];\r\n  \"InterceptNote\" [label=\"Stranger: You dare?!\", shape=rounded"]
[142.62907, "o", ", style=rounded, fillcolor=lightgray];\r\n  \"PickpocketAttempt_choice\" [label=\"1. [Sleight of Hand] Swiftly grab the pouch.\\n2. [Distraction] Bump into him accidentally.\\n3. Abandon the attempt.\", shape=diamond, style=rounded, fillcolor=lightblue];\r\n  \"PickpocketSuccess\" [label=\"Narrator: 50 gold pieces heavier, you slip away. The merchant hasn't noticed... yet.\", shape=rounded, style=rounded, fillcolor=lightgray];\r\n  \"PickpocketDistract\" [label=\"Merchant: Watch it, friend!\", shape=rounded, style=rounded, fillcolor=lightgray];\r\n  \"MerchantAnnoyed_choice\" [label=\"1. Apologize profusely.\\n2. [Intimidate] You watch where YOU'RE going.\\n3. Use the distraction to grab the gold.\", shape=diamond, style=rounded, fillcolor=lightblue];\r\n  \"MerchantCalm\" [label=\"Merchant: Hmph. Buy me a drink and we're even.\", shape=rounded, style=rounded, fillcolor=lightgray];\r\n  \"MerchantFight\" [label=\"Merchant: Why you little—!\", shape=rounded, style=rounded, fillcolor=lightgray];\r\n  \"PickpocketAfter\" [label=\"Narrator: But where to s"]
[142.629104, "o", "pend your ill-gotten gains?\", shape=rounded, style=rounded, fillcolor=lightgray];\r\n  \"PickpocketChoice_choice\" [label=\"1. Buy information from the barkeep.\\n2. Leave before anyone notices.\\n3. Approach the stranger with newfound confidence.\", shape=diamond, style=rounded, fillcolor=lightblue];\r\n  \"StrangerApproach\" [label=\"Stranger: You have the look of someone seeking something.\", shape=rounded, style=rounded, fillcolor=lightgray];\r\n  \"StrangerGreet_choice\" [label=\"1. I seek the Crimson Blade.\\n2. I'm looking for work.\\n3. Who are you?\\n4. [Insight] Something tells me you're not what you seem.\", shape=diamond, style=rounded, fillcolor=lightblue];\r\n  \"CrimsonQuestStart\" [label=\"Stranger: The Crimson Blade? Many seek it. Few survive.\", shape=rounded, style=rounded, fillcolor=lightgray];\r\n  \"CrimsonWarning_choice\" [label=\"1. I'm not like the others.\\n2. What happened to them?\\n3. Perhaps I should reconsider...\", shape=diamond, style=rounded, fillcolor=lightblue];\r\n  \"CrimsonAccept\" [label=\"Stranger: Then you'll"]
[142.629125, "o", " need a map. I have one... for a price.\", shape=rounded, style=rounded, fillcolor=lightgray];\r\n  \"CrimsonPrice_choice\" [label=\"1. How much?\\n2. [Persuade] Surely we can come to an arrangement.\\n3. I'll find my own way.\", shape=diamond, style=rounded, fillcolor=lightblue];\r\n  \"CrimsonNegotiate\" [label=\"Stranger: 100 gold, or a favor to be named later.\", shape=rounded, style=rounded, fillcolor=lightgray];\r\n  \"CrimsonDeal_choice\" [label=\"1. I'll pay the gold.\\n2. I'll owe you a favor.\\n3. [Barter] 50 gold and a minor favor.\", shape=diamond, style=rounded, fillcolor=lightblue];\r\n  \"CrimsonGoldPath\" [label=\"Stranger: Wise choice. No strings attached.\", shape=rounded, style=rounded, fillcolor=lightgray];\r\n  \"CrimsonFavorPath\" [label=\"Stranger: Remember, I always collect.\", shape=rounded, style=rounded, fillcolor=lightgray];\r\n  \"CrimsonCompromise\" [label=\"Stranger: You drive a hard bargain. Agreed.\", shape=rounded, style=rounded, fillcolor=lightgray];\r\n  \"CrimsonDiscount\" [label=\"Stranger: Your silver tongue amuses "]
[142.629138, "o", "me. 75 gold, final offer.\", shape=rounded, style=rounded, fillcolor=lightgray];\r\n  \"CrimsonDiscountDeal_choice\" [label=\"1. Deal.\\n2. Still too rich for my blood.\", shape=diamond, style=rounded, fillcolor=lightblue];\r\n"]
