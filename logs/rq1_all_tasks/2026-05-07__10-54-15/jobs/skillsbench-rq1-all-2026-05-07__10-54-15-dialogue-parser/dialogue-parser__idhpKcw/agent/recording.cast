[210.345926, "o", "digraph dialogue {\r\n  rankdir=TB;\r\n  node [shape=box];\r\n  \"Start\" [label=\"Narrator: The tavern door creaks open. Smoke and laughter fill the air.\", shape=rounded, style=rounded, fillcolor=lightgray];\r\n  \"TavernEntry\" [label=\"Narrator: Three figures catch your eye: a hooded stranger, a boisterous merchant, and the barkeep.\", shape=rounded, style=rounded, fillcolor=lightgray];\r\n  \"TavernChoice\" [label=\"1. Approach the hooded stranger.\\n2. Sit next to the merchant.\\n3. Order a drink from the barkeep.\\n4. [Observe] Study the room from the shadows.\", shape=diamond, style=rounded, fillcolor=lightblue];\r\n  \"ObserveRoom\" [label=\"Narrator: You notice the stranger slipping a note to the barkeep. The merchant counts gold nervously.\", shape=rounded, style=rounded, fillcolor=lightgray];\r\n  \"ObserveChoice\" [label=\"1. Intercept the note.\\n2. Pickpocket the merchant.\\n3. Pretend you saw nothing.\", shape=diamond, style=rounded, fillcolor=lightblue];\r\n  \"InterceptNote\" [label=\"Stranger: You dare?!\", shape=rounded, style=rounde"]
[210.346086, "o", "d, fillcolor=lightgray];\r\n  \"PickpocketAttempt\" [label=\"1. [Sleight of Hand] Swiftly grab the pouch.\\n2. [Distraction] Bump into him accidentally.\\n3. Abandon the attempt.\", shape=diamond, style=rounded, fillcolor=lightblue];\r\n  \"PickpocketSuccess\" [label=\"Narrator: 50 gold pieces heavier, you slip away. The merchant hasn't noticed... yet.\", shape=rounded, style=rounded, fillcolor=lightgray];\r\n  \"PickpocketDistract\" [label=\"Merchant: Watch it, friend!\", shape=rounded, style=rounded, fillcolor=lightgray];\r\n  \"MerchantAnnoyed\" [label=\"1. Apologize profusely.\\n2. [Intimidate] You watch where YOU'RE going.\\n3. Use the distraction to grab the gold.\", shape=diamond, style=rounded, fillcolor=lightblue];\r\n  \"MerchantCalm\" [label=\"Merchant: Hmph. Buy me a drink and we're even.\", shape=rounded, style=rounded, fillcolor=lightgray];\r\n  \"MerchantFight\" [label=\"Merchant: Why you little—!\", shape=rounded, style=rounded, fillcolor=lightgray];\r\n  \"PickpocketAfter\" [label=\"Narrator: But where to spend your ill-gotten gains?\""]
[210.346158, "o", ", shape=rounded, style=rounded, fillcolor=lightgray];\r\n  \"PickpocketChoice\" [label=\"1. Buy information from the barkeep.\\n2. Leave before anyone notices.\\n3. Approach the stranger with newfound confidence.\", shape=diamond, style=rounded, fillcolor=lightblue];\r\n  \"StrangerApproach\" [label=\"Stranger: You have the look of someone seeking something.\", shape=rounded, style=rounded, fillcolor=lightgray];\r\n  \"StrangerGreet\" [label=\"1. I seek the Crimson Blade.\\n2. I'm looking for work.\\n3. Who are you?\\n4. [Insight] Something tells me you're not what you seem.\", shape=diamond, style=rounded, fillcolor=lightblue];\r\n  \"CrimsonQuestStart\" [label=\"Stranger: The Crimson Blade? Many seek it. Few survive.\", shape=rounded, style=rounded, fillcolor=lightgray];\r\n...\r\n"]
[210.347926, "o", "  \"BarFight\" -> \"BarFightChoice\";\r\n  \"BarFightChoice\" -> \"BarFightWin\" [label=\"1. [Fight] Join the brawl!\"];\r\n  \"BarFightChoice\" -> \"TavernExit\" [label=\"2. [Flee] Slip out the back!\"];\r\n  \"BarFightChoice\" -> \"BarFightHide\" [label=\"3. [Hide] Duck under a table!\"];\r\n  \"BarFightWin\" -> \"BarFightAfter\";\r\n  \"BarFightHide\" -> \"BarFightAfter\";\r\n  \"BarFightAfter\" -> \"TavernExit\";\r\n"]
[210.34797, "o", "  \"TavernExit\" -> \"End\";\r\n  \"JourneyBegin\" -> \"End\";\r\n}"]
