[77.394412, "i", "cat > /app/solution.py << 'EOF'\nimport re\nfrom dialogue_graph import Graph, Node, Edge\n\ndef parse_script(text: str) -> Graph:\n    \"\"\"\n    Parse dialogue script text into a Graph object.\n    \"\"\"\n    graph = Graph()\n    lines = text.strip().split('\\n')\n    \n    current_node_id = None\n    \n    for line in lines:\n        line = line.strip()\n        if not line:\n            continue\n        \n        # Check if this is a node header [NodeID]\n        header_match = re.match(r'\\[(\\w+)\\]', line)\n        if header_match:\n            current_node_id = header_match.group(1)\n            continue\n        \n        # Check if this is a regular dialogue line with -> target\n        dialogue_match = re.match(r'^([^:]+):\\s*(.+?)\\s*->\\s*(\\w+)$', line)\n        if dialogue_match:\n            speaker = dialogue_match.group(1).strip()\n            dialogue_text = dialogue_match.group(2).strip()\n            target = dialogue_match.group(3).strip()\n            \n            # Create current node if not exists\n            if current_node_"]
[77.394547, "i", "id not in graph.nodes:\n                graph.add_node(Node(id=current_node_id, speaker=speaker, text=dialogue_text, type=\"line\"))\n            \n            # Add edge to target\n            graph.add_edge(Edge(source=current_node_id, target=target, text=\"\"))\n            continue\n        \n        # Check if this is a choice line with optional [Skill]\n        choice_match = re.match(r'^(\\d+)\\.\\s*(?:\\[(\\w+)\\]\\s*)?(.+?)\\s*->\\s*(\\w+)$', line)\n        if choice_match:\n            choice_num = choice_match.group(1)\n            skill = choice_match.group(2)  # Optional skill\n            choice_text = choice_match.group(3).strip()\n            target = choice_match.group(4).strip()\n            \n            # Build full choice text\n            if skill:\n                full_choice = f\"{choice_num}. [{skill}] {choice_text}\"\n            else:\n                full_choice = f\"{choice_num}. {choice_text}\"\n            \n            # Create or update choice node\n            choice_node_id = f\"{current_node_id}_choice\"\n          "]
[77.394692, "o", "cat > /app/solution.py << 'EOF'\r\n\u001b[?2004l\r"]
[77.394747, "i", "  \n            if choice_node_id in graph.nodes:\n                # Append to existing choice text\n                graph.nodes[choice_node_id].text += \"\\n\" + full_choice\n            else:\n                # Create new choice node\n                graph.add_node(Node(id=choice_node_id, speaker=None, text=full_choice, type=\"choice\"))\n                # Add edge from main node to choice node\n                graph.add_edge(Edge(source=current_node_id, target=choice_node_id, text=\"\"))\n            \n            # Add edge from choice node to target\n            graph.add_edge(Edge(source=choice_node_id, target=target, text=full_choice))\n            continue\n    \n    return graph\n\n\ndef main():\n    # Read script\n    with open('/app/script.txt', 'r') as f:\n        script_text = f.read()\n    \n    # Parse script\n    graph = parse_script(script_text)\n    \n    # Export to JSON\n    json_data = graph.to_dict()\n    with open('/app/dialogue.json', 'w') as f:\n        import json\n        json.dump(json_data, f, indent=2)\n    \n    # G"]
[77.394802, "o", "\u001b[?2004h> import re\r\n\u001b[?2004l\r\u001b[?2004h> "]
[77.394823, "i", "enerate DOT visualization\n    dot_content = graph.to_dot()\n    with open('/app/dialogue.dot', 'w') as f:\n        f.write(dot_content)\n    \n    print(f\"Parsed {len(graph.nodes)} nodes and {len(graph.edges)} edges\")\n    print(\"Output written to /app/dialogue.json and /app/dialogue.dot\")\n\n\nif __name__ == '__main__':\n    main()\nEOF\n"]
