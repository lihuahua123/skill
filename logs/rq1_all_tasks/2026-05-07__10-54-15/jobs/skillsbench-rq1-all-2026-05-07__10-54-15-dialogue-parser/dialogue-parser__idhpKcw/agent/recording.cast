[177.674346, "i", "cat > /app/solution.py << 'EOF'\nimport re\nfrom dialogue_graph import Graph, Node, Edge\n\ndef parse_script(text: str) -> Graph:\n    \"\"\"\n    Parse dialogue script text into a Graph object.\n    \"\"\"\n    graph = Graph()\n    lines = text.strip().split('\\n')\n    \n    current_node_id = None\n    \n    for line in lines:\n        line = line.strip()\n        if not line:\n            continue\n        \n        # Check if this is a node header [NodeID]\n        header_match = re.match(r'\\[(\\w+)\\]', line)\n        if header_match:\n            current_node_id = header_match.group(1)\n            continue\n        \n        # Check if this is a regular dialogue line with -> target\n        dialogue_match = re.match(r'^([^:]+):\\s*(.+?)\\s*->\\s*(\\w+)$', line)\n        if dialogue_match:\n            speaker = dialogue_match.group(1).strip()\n            dialogue_text = dialogue_match.group(2).strip()\n            target = dialogue_match.group(3).strip()\n            \n            # Create current node if not exists\n            if current_node_"]
[177.674542, "i", "id not in graph.nodes:\n                graph.add_node(Node(id=current_node_id, speaker=speaker, text=dialogue_text, type=\"line\"))\n            \n            # Add edge to target\n            graph.add_edge(Edge(source=current_node_id, target=target, text=\"\"))\n            continue\n        \n        # Check if this is a choice line with optional [Skill]\n        choice_match = re.match(r'^(\\d+)\\.\\s*(?:\\[(\\w+)\\]\\s*)?(.+?)\\s*->\\s*(\\w+)$', line)\n        if choice_match:\n            choice_num = choice_match.group(1)\n            skill = choice_match.group(2)  # Optional skill\n            choice_text = choice_match.group(3).strip()\n            target = choice_match.group(4).strip()\n            \n            # Build full choice text\n            if skill:\n                full_choice = f\"{choice_num}. [{skill}] {choice_text}\"\n            else:\n                full_choice = f\"{choice_num}. {choice_text}\"\n            \n            if current_node_id in graph.nodes:\n                # Append to existing node's choice text\n       "]
[177.674628, "o", "cat > /app/solution.py << 'EOF'\r\n\u001b[?2004l\r\u001b[?2004h> import re\r\n\u001b[?2004l\r\u001b[?2004h> "]
[177.674745, "i", "         existing = graph.nodes[current_node_id]\n                if existing.text:\n                    existing.text += \"\\n\" + full_choice\n                else:\n                    existing.text = full_choice\n                existing.type = \"choice\"\n            else:\n                # Create new choice node\n                graph.add_node(Node(id=current_node_id, speaker=None, text=full_choice, type=\"choice\"))\n            \n            # Add edge from choice node to target\n            graph.add_edge(Edge(source=current_node_id, target=target, text=full_choice))\n            continue\n    \n    return graph\n\n\ndef generate_dot(graph: Graph) -> str:\n    \"\"\"Generate DOT format visualization of the graph.\"\"\"\n    lines = ['digraph dialogue {', '  rankdir=TB;', '  node [shape=box];']\n    \n    for node_id, node in graph.nodes.items():\n        if node.type == \"choice\":\n            shape = \"diamond\"\n            color = \"lightblue\"\n        else:\n            shape = \"rounded\"\n            color = \"lightgray\"\n        \n        #"]
[177.674863, "o", "from dialogue_graph import Graph, Node, Edge\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def parse_script(text: str) -> Graph:\r\n\u001b[?2004l\r"]
[177.674884, "i", " Escape text for DOT\n        text = node.text.replace('\"', '\\\\\"').replace('\\n', '\\\\n')\n        speaker = node.speaker if node.speaker else \"\"\n        label = f\"{speaker}: {text}\" if speaker else text\n        \n        lines.append(f'  \"{node_id}\" [label=\"{label}\", shape={shape}, style=rounded, fillcolor={color}];')\n    \n    # Add edges\n    for edge in graph.edges:\n        if edge.text:\n            edge_text = edge.text.replace('\"', '\\\\\"')\n            lines.append(f'  \"{edge.source}\" -> \"{edge.target}\" [label=\"{edge_text}\"];')\n        else:\n            lines.append(f'  \"{edge.source}\" -> \"{edge.target}\";')\n    \n    lines.append('}')\n    return '\\n'.join(lines)\n\n\ndef main():\n    # Read script\n    with open('/app/script.txt', 'r') as f:\n        script_text = f.read()\n    \n    # Parse script\n    graph = parse_script(script_text)\n    \n    # Export to JSON\n    json_data = graph.to_dict()\n    with open('/app/dialogue.json', 'w') as f:\n        import json\n        json.dump(json_data, f, indent=2)\n    \n    # Generate D"]
[177.674895, "o", "\u001b[?2004h>     \"\"\"\r\n\u001b[?2004l\r"]
[177.674903, "i", "OT visualization\n    dot_content = generate_dot(graph)\n    with open('/app/dialogue.dot', 'w') as f:\n        f.write(dot_content)\n    \n    print(f\"Parsed {len(graph.nodes)} nodes and {len(graph.edges)} edges\")\n    print(\"Output written to /app/dialogue.json and /app/dialogue.dot\")\n\n\nif __name__ == '__main__':\n    main()\nEOF\n"]
[177.675042, "o", " Escape text for DOT\r\n        text = node.text.replace('\"', '\\\\\"').replace('\\n', '\\\\n')\r\n        speaker = node.speaker if node.speaker else \"\"\r\n        label = f\"{speaker}: {text}\" if speaker else text\r\n        \r\n        lines.append(f'  \"{node_id}\" [label=\"{label}\", shape={shape}, style=rounded, fillcolor={color}];')\r\n    \r\n    # Add edges\r\n    for edge in graph.edges:\r\n        if edge.text:\r\n            edge_text = edge.text.replace('\"', '\\\\\"')\r\n            lines.append(f'  \"{edge.source}\" -> \"{edge.target}\" [label=\"{edge_text}\"];')\r\n        else:\r\n            lines.append(f'  \"{edge.source}\" -> \"{edge.target}\";')\r\n    \r\n    lines.append('}')\r\n    return '\\n'.join(lines)\r\n\r\n\r\ndef main():\r\n    # Read script\r\n    with open('/app/script.txt', 'r') as f:\r\n        script_text = f.read()\r\n    \r\n    # Parse script\r\n    graph = parse_script(script_text)\r\n    \r\n    # Export to JSON\r\n    json_data = graph.to_dict()\r\n    with open('/app/dialogue.json', 'w') as f:\r\n        import json\r\n        json.dump(json_data, f, "]
