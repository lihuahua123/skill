[?2004l[?2004h>         
[?2004l[?2004h>         # Clamp acceleration to physical limits
[?2004l[?2004h>         acceleration_cmd = max(self.max_deceleration, min(self.max_acceleration, acceleration_cmd))
[?2004l[?2004h>         
[?2004l[?2004h>         return acceleration_cmd, mode, distance_error
[?2004l[?2004h>     
