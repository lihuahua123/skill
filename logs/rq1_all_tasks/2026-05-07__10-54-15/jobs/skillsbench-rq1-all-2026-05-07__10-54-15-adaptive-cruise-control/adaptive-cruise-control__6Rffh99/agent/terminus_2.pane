[?2004l[?2004h> def generate_report(df, config, tuning):
[?2004l[?2004h>     set_speed = config['acc_settings']['set_speed']
[?2004l[?2004h>     speeds = pd.to_numeric(df['ego_speed'], errors='coerce').fillna(0)
