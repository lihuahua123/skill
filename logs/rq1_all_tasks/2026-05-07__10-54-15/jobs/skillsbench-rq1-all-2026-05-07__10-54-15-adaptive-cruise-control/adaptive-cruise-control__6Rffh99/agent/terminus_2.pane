   194	
   195	    def test_speed_control(self):
   196	        """Speed control: rise time, overshoot, and steady-state error."""
   197	        import pandas as pd
   198	
   199	        simulation_data = pd.read_csv('/root/simulation_results.csv')
   200	        cruise = simulation_data[simulation_data['time'] <= 30.0]
   201	
   202	        # Rise time < 10s (time from 3 to 27 m/s)
   203	        t10_series = cruise[cruise['ego_speed'] >= 3.0]['time']
   204	        t90_series = cruise[cruise['ego_speed'] >= 27.0]['time']
   205	        assert len(t10_series) > 0 and len(t90_series) > 0, "Speed thresholds not reached"
   206	        t10 = t10_series.min()
   207	        t90 = t90_series.min()
   208	        assert t90 - t10 < 10.0
   209	
   210	        # Overshoot < 5% (max speed < 31.5 m/s)
   211	        assert cruise['ego_speed'].max() < 31.5
   212	
   213	        # Steady-state error < 0.5 m/s (at t=25-30s)
   214	        ss = simulation_data[(simulation_data['time'] >= 25.0) & (simulation_data['time'] <= 30.0)]
   215	        assert abs(30.0 - ss['ego_speed'].mean()) < 0.5
