[?2004l[?2004h> """Adaptive Cruise Control System Implementation"""
[?2004l[?2004h> 
[?2004l[?2004h> from pid_controller import PIDController
[?2004l[?2004h> 
[?2004l[?2004h> class AdaptiveCruiseControl:
[?2004l[?2004h>     """ACC system with proper speed limiting."""
[?2004l[?2004h>     
[?2004l[?2004h>     def __init__(self, config):
[?2004l[?2004h>         self.mass = config['vehicle']['mass']
[?2004l[?2004h>         self.max_acceleration = config['vehicle']['max_acceleration']
[?2004l[?2004h>         self.max_deceleration = config['vehicle']['max_deceleration']
[?2004l[?2004h>         self.set_speed = config['acc_settings']['set_speed']
[?2004l[?2004h>         self.time_headway = config['acc_settings']['time_headway']
[?2004l[?2004h>         self.min_distance = config['acc_settings']['min_distance']
[?2004l[?2004h>         self.emergency_ttc_threshold = config['acc_settings']['emergency_ttc_threshold']
[?2004l[?2004h>         
[?2004l[?2004h>         pid_speed_cfg = config.get('pid_speed', {'kp': 0.5, 'ki': 0.05, 'kd': 0.1})
[?2004l[?2004h>         pid_dist_cfg = config.get('pid_distance', {'kp': 0.5, 'ki': 0.05, 'kd': 0.1})
[?2004l[?2004h>         
[?2004l[?2004h>         self.pid_speed = PIDController(pid_speed_cfg['kp'], pid_speed_cfg['ki'], pid_speed_cfg['kd'])
[?2004l[?2004h>         self.pid_distance = PIDController(pid_dist_cfg['kp'], pid_dist_cfg['ki'], pid_dist_cfg['kd'])
[?2004l[?2004h>         self.prev_mode = 'cruise'
[?2004l[?2004h>         self.mode = 'cruise'
[?2004l[?2004h>     
[?2004l[?2004h>     def safe_following_distance(self, ego_speed):
[?2004l[?2004h>         return ego_speed * self.time_headway + self.min_distance
[?2004l[?2004h>     
[?2004l[?2004h>     def time_to_collision(self, distance, ego_speed, lead_speed):
[?2004l[?2004h>         relative_speed = ego_speed - lead_speed
[?2004l[?2004h>         if relative_speed <= 0:
[?2004l[?2004h>             return None
[?2004l[?2004h>         return distance / relative_speed
[?2004l[?2004h>     
[?2004l[?2004h>     def determine_mode(self, lead_speed, distance):
[?2004l[?2004h>         if lead_speed is None or distance is None:
[?2004l[?2004h>             return 'cruise'
[?2004l[?2004h>         ttc = self.time_to_collision(distance, self.set_speed, lead_speed)
[?2004l[?2004h>         if ttc is not None and ttc < self.emergency_ttc_threshold:
[?2004l[?2004h>             return 'emergency'
[?2004l[?2004h>         return 'follow'
[?2004l[?2004h>     
[?2004l[?2004h>     def compute(self, ego_speed, lead_speed, distance, dt):
[?2004l[?2004h>         mode = self.determine_mode(lead_speed, distance)
[?2004l[?2004h>         
[?2004l[?2004h>         if mode != self.prev_mode:
[?2004l[?2004h>             self.pid_speed.reset()
[?2004l[?2004h>             self.pid_distance.reset()
[?2004l[?2004h>             self.prev_mode = mode
[?2004l[?2004h>         self.mode = mode
[?2004l[?2004h>         
[?2004l[?2004h>         if mode == 'cruise':
[?2004l[?2004h>             self.pid_distance.reset()
[?2004l[?2004h>             speed_error = self.set_speed - ego_speed
[?2004l[?2004h>             acceleration_cmd = self.pid_speed.compute(speed_error, dt)
[?2004l[?2004h>             
[?2004l[?2004h>             if ego_speed > self.set_speed + 0.5:
[?2004l[?2004h>                 acceleration_cmd = min(acceleration_cmd, -2.0)
[?2004l[?2004h>             elif abs(speed_error) < 2.0:
[?2004l[?2004h>                 acceleration_cmd *= 0.15
[?2004l[?2004h>             
[?2004l[?2004h>             distance_error = None
[?2004l[?2004h>             
[?2004l[?2004h>         elif mode == 'emergency':
[?2004l[?2004h>             self.pid_speed.reset()
[?2004l[?2004h>             self.pid_distance.reset()
[?2004l[?2004h>             acceleration_cmd = self.max_deceleration
[?2004l[?2004h>             distance_error = 0.0
[?2004l[?2004h>             
[?2004l[?2004h>         else:  # 'follow' mode
[?2004l[?2004h>             self.pid_speed.reset()
[?2004l[?2004h>             desired_distance = self.safe_following_distance(ego_speed)
[?2004l[?2004h>             distance_error = distance - desired_distance
[?2004l[?2004h>             
[?2004l[?2004h>             acceleration_cmd = self.pid_distance.compute(distance_error, dt)
[?2004l[?2004h>             
[?2004l[?2004h>             # CRITICAL: Don't exceed set_speed in follow mode
[?2004l[?2004h>             if ego_speed >= self.set_speed:
[?2004l[?2004h>                 acceleration_cmd = min(acceleration_cmd, 0.0)
[?2004l[?2004h>             else:
[?2004l[?2004h>                 # Allow positive accel up to set_speed
[?2004l[?2004h>                 max_accel_to_set = (self.set_speed - ego_speed) / dt
[?2004l[?2004h>                 acceleration_cmd = min(acceleration_cmd, max_accel_to_set)
[?2004l[?2004h>             
[?2004l[?2004h>             # Also ensure we can decelerate if needed
[?2004l[?2004h>             if distance_error < -5:  # Too close
[?2004l[?2004h>                 acceleration_cmd = min(acceleration_cmd, -2.0)
[?2004l[?2004h>         
[?2004l[?2004h>         acceleration_cmd = max(self.max_deceleration, min(self.max_acceleration, acceleration_cmd))
[?2004l[?2004h>         return acceleration_cmd, mode, distance_error
[?2004l[?2004h>     
[?2004l[?2004h>     def reset(self):
[?2004l[?2004h>         self.pid_speed.reset()
[?2004l[?2004h>         self.pid_distance.reset()
[?2004l[?2004h>         self.prev_mode = 'cruise'
[?2004l[?2004h>         self.mode = 'cruise'
