   218	class TestDistanceControl:
   219	    """Performance targets: Distance control (t=30-60s, follow mode)."""
   220	
   221	    def test_distance_control(self):
   222	        """Distance control: steady-state error and minimum distance constraints."""
   223	        import pandas as pd
   224	
   225	        simulation_data = pd.read_csv('/root/simulation_results.csv')
   226	
   227	        # Steady-state error < 2m from safe distance (at t=50-60s)
   228	        follow = simulation_data[(simulation_data['time'] >= 50.0) & (simulation_data['time'] <= 60.0)]
   229	        follow = follow[follow['mode'] == 'follow']
   230	        follow = follow[follow['distance_error'].notna() & (follow['distance_error'] != '')]
   231	        if len(follow) >= 5:
   232	            errors = pd.to_numeric(follow['distance_error'], errors='coerce').abs()
   233	            assert errors.mean() < 2.0
   234	
   235	        # Distance never drops below 90% of safe distance
   236	        follow = simulation_data[(simulation_data['time'] >= 30.0) & (simulation_data['time'] <= 60.0)]
   237	        follow = follow[follow['mode'] == 'follow']
   238	        follow = follow[follow['distance'].notna() & (follow['distance'] != '')]
   239	        if len(follow) >= 5:
   240	            distances = pd.to_numeric(follow['distance'], errors='coerce')
   241	            safe_distances = follow['ego_speed'] * 1.5 + 10.0
   242	            min_allowed = safe_distances * 0.9
   243	            assert (distances >= min_allowed).all()
