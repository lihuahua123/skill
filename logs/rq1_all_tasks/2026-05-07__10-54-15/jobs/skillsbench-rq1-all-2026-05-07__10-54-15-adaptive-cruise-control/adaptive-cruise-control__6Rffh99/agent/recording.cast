[1003.644803, "o", "\t        f.write(\"- **Cruise Mode**: No lead vehicle detected - maintains set speed (30 m/s)\\n\")\r\n   116\t        f.write(\"- **Follow Mode**: Lead vehicle present with TTC >= threshold - maintains safe following distance\\n\")\r\n   117\t        f.write(\"- **Emergency Mode**: TTC < 3.0s - applies maximum deceleration\\n\\n\")\r\n   118\t        f.write(\"### Safety Features\\n\")\r\n   119\t        f.write(f\"- Time Headway: {config['acc_settings']['time_headway']}s\\n\")\r\n   120\t        f.write(f\"- Minimum Gap: {config['acc_settings']['min_distance']}m\\n\")\r\n   121\t        f.write(f\"- Emergency TTC: {config['acc_settings']['emergency_ttc_threshold']}s\\n\")\r\n   122\t        f.write(f\"- Accel Limits: [{config['vehicle']['max_deceleration']}, {config['vehicle']['max_acceleration']}] m/s2\\n\\n\")\r\n   123\t        f.write(\"## PID Tuning Methodology\\n\\n\")\r\n   124\t        f.write(\"Parameters tuned using iterative simulation to meet performance targets.\\n\\n\")\r\n   125\t        f.write(\"### Final Gains\\n\\n\")\r\n   126\t        f.write(f\"**Speed Controller:** kp={tuning['pid_speed']['kp']}, ki={tuning['pid_speed']['ki']}, kd={tuning['pid_speed']['kd']}\\n\\n\")\r\n   127\t        f.write(f\"**Distance Controller:** kp={tuning['pid_distance']['kp']}, "]
