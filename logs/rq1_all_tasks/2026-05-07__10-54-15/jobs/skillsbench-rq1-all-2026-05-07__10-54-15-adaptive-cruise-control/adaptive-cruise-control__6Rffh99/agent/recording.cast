[743.912979, "o", "\u001b[?2004h> "]
[743.913064, "o", "    else:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[743.913154, "o", "        ss_error = abs(speeds.iloc[-150:].mean() - set_speed)\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r"]
[743.913221, "o", "\u001b[?2004h> "]
[743.913313, "o", "    # Distance SS error: use stable follow period (middle 50% of follow mode)\r\n\u001b[?2004l\r"]
[743.913354, "o", "\u001b[?2004h> "]
[743.913431, "o", "    follow_df = df[df['mode'] == 'follow'].copy()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[743.913593, "o", "    follow_df['dist_err_num'] = pd.to_numeric(follow_df['distance_error'], errors='coerce')\r\n\u001b[?2004l\r"]
[743.913627, "o", "\u001b[?2004h> "]
[743.913757, "o", "    follow_df['dist_num'] = pd.to_numeric(follow_df['distance'], errors='coerce')\r\n\u001b[?2004l\r\u001b[?2004h"]
[743.913799, "o", ">     \r\n\u001b[?2004l\r\u001b[?2004h"]
[743.913839, "o", "> "]
[743.913949, "o", "    # Use middle 50% of follow data for SS error\r\n\u001b[?2004l\r\u001b[?2004h> "]
[743.914017, "o", "    mid_start = len(follow_df) // 4\r\n\u001b[?2004l\r\u001b[?2004h> "]
[743.914095, "o", "    mid_end = 3 * len(follow_df) // 4\r\n\u001b[?2004l\r\u001b[?2004h> "]
[743.914181, "o", "    stable_follow = follow_df.iloc[mid_start:mid_end]\r\n\u001b[?2004l\r\u001b[?2004h"]
[743.914247, "o", "> "]
[743.914305, "o", "    dist_ss_err = stable_follow['dist_err_num'].abs().mean()\r\n\u001b[?2004l\r\u001b[?2004h"]
[743.914333, "o", ">     \r\n\u001b[?2004l\r\u001b[?2004h"]
[743.914369, "o", "> "]
[743.914465, "o", "    dists = follow_df['dist_num'].dropna()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[743.914566, "o", "    min_dist = dists.min() if len(dists) > 0 else None\r\n\u001b[?2004l\r"]
[743.91463, "o", "\u001b[?2004h>     \r\n\u001b[?2004l\r"]
[743.914689, "o", "\u001b[?2004h> "]
[743.91473, "o", "    with open('acc_report.md', 'w') as f:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[743.914799, "o", "        f.write(\"# ACC Simulation Report\\n\\n\")\r\n\u001b[?2004l\r"]
[743.914857, "o", "\u001b[?2004h> "]
[743.914922, "o", "        f.write(\"## System Design\\n\\n\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[743.914994, "o", "> "]
[743.915027, "o", "        f.write(\"### ACC Architecture\\n\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[743.91518, "o", "        f.write(\"The ACC system implements a hierarchical control architecture with three modes:\\n\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[743.915333, "o", "        f.write(\"- **Cruise Mode**: No lead vehicle detected - maintains set speed (30 m/s)\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[743.915538, "o", "        f.write(\"- **Follow Mode**: Lead vehicle present with TTC >= threshold - maintains safe following distance\\n\")\r\n\u001b[?2004l\r"]
[743.915574, "o", "\u001b[?2004h> "]
[743.915724, "o", "        f.write(\"- **Emergency Mode**: TTC < 3.0s - applies maximum deceleration\\n\\n\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[743.915791, "o", "> "]
[743.915873, "o", "        f.write(\"### Safety Features\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[743.915962, "o", "        f.write(f\"- Time Headway: {config['acc_settings']['time_headway']}s\\n\")\r\n\u001b[?2004l\r"]
[743.916037, "o", "\u001b[?2004h> "]
[743.916112, "o", "        f.write(f\"- Minimum Gap: {config['acc_settings']['min_distance']}m\\n\")\r\n\u001b[?2004l\r"]
[743.916184, "o", "\u001b[?2004h> "]
[743.9163, "o", "        f.write(f\"- Emergency TTC: {config['acc_settings']['emergency_ttc_threshold']}s\\n\")\r\n\u001b[?2004l\r"]
[743.916336, "o", "\u001b[?2004h> "]
[743.916552, "o", "        f.write(f\"- Accel Limits: [{config['vehicle']['max_deceleration']}, {config['vehicle']['max_acceleration']}] m/s2\\n\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[743.916637, "o", "        f.write(\"## PID Tuning Methodology\\n\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[743.916793, "o", "        f.write(\"Parameters tuned using iterative simulation to meet performance targets.\\n\\n\")\r\n\u001b[?2004l\r"]
[743.916855, "o", "\u001b[?2004h> "]
[743.916895, "o", "        f.write(\"### Final Gains\\n\\n\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[743.916964, "o", "> "]
[743.91713, "o", "        f.write(f\"**Speed Controller:** kp={tuning['pid_speed']['kp']}, ki={tuning['pid_speed']['ki']}, kd={tuning['pid_speed']['kd']}\\n\\n\")\r\n\u001b[?2004l\r"]
[743.917179, "o", "\u001b[?2004h> "]
[743.917387, "o", "        f.write(f\"**Distance Controller:** kp={tuning['pid_distance']['kp']}, ki={tuning['pid_distance']['ki']}, kd={tuning['pid_distance']['kd']}\\n\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[743.917497, "o", "        f.write(\"## Simulation Results\\n\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[743.917593, "o", "        f.write(\"### Performance Metrics\\n\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[743.917702, "o", "        f.write(\"| Metric | Target | Achieved | Status |\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[743.917814, "o", "        f.write(\"|--------|--------|----------|--------|\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[743.91794, "o", "        rt_status = 'PASS' if (rise_time and rise_time < 10) else 'FAIL'\r\n\u001b[?2004l\r\u001b[?2004h> "]
[743.91807, "o", "        f.write(f\"| Rise Time | <10s | {rise_time:.2f}s | {rt_status} |\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[743.918176, "o", "        os_status = 'PASS' if overshoot < 5 else 'FAIL'\r\n\u001b[?2004l\r\u001b[?2004h> "]
[743.918318, "o", "        f.write(f\"| Overshoot | <5% | {overshoot:.2f}% | {os_status} |\\n\")\r\n\u001b[?2004l\r"]
[743.918364, "o", "\u001b[?2004h> "]
[743.918447, "o", "        ss_status = 'PASS' if ss_error < 0.5 else 'FAIL'\r\n\u001b[?2004l\r\u001b[?2004h> "]
[743.918597, "o", "        f.write(f\"| Speed SS Error | <0.5m/s | {ss_error:.3f}m/s | {ss_status} |\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[743.918692, "o", "        ds_status = 'PASS' if dist_ss_err < 2 else 'FAIL'\r\n\u001b[?2004l\r"]
[743.918738, "o", "\u001b[?2004h> "]
[743.918854, "o", "        f.write(f\"| Dist SS Error | <2m | {dist_ss_err:.2f}m | {ds_status} |\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[743.918977, "o", "        md_status = 'PASS' if (min_dist and min_dist > 5) else 'FAIL'\r\n\u001b[?2004l\r\u001b[?2004h> "]
[743.919111, "o", "        f.write(f\"| Min Distance | >5m | {min_dist:.2f}m | {md_status} |\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[743.919209, "o", "        f.write(\"\\n### Simulation Summary\\n\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[743.919312, "o", "        f.write(f\"- Duration: 150s, Timestep: 0.1s\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[743.919407, "o", "        f.write(f\"- Rows in output: {len(df)}\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[743.919525, "o", "        f.write(f\"- Max speed: {max_speed:.2f} m/s\\n\")\r\n\u001b[?2004l\r"]
[743.919563, "o", "\u001b[?2004h> "]
[743.919772, "o", "        f.write(f\"- Modes: cruise={len(df[df['mode']=='cruise'])}, follow={len(follow_df)}, emergency={len(df[df['mode']=='emergency'])}\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[743.919846, "o", "    print(\"Report saved to acc_report.md\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[743.919912, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[743.919975, "o", "if __name__ == '__main__':\r\n\u001b[?2004l\r\u001b[?2004h> "]
[743.920036, "o", "    run_simulation()\r\n\u001b[?2004l\r\u001b[?2004h"]
[743.920063, "o", "> SIMEOF\r\n\u001b[?2004l\r"]
