[178.115029, "o", "\u001b[?2004hroot@bfb65fae2dcc:~# "]
[240.358533, "i", "cat > acc_system.py << 'EOF'\n\"\"\"Adaptive Cruise Control System Implementation\"\"\"\n\nfrom pid_controller import PIDController\n\nclass AdaptiveCruiseControl:\n    \"\"\"ACC system that maintains speed and safe following distance.\"\"\"\n    \n    def __init__(self, config):\n        self.mass = config['vehicle']['mass']\n        self.max_acceleration = config['vehicle']['max_acceleration']\n        self.max_deceleration = config['vehicle']['max_deceleration']\n        self.set_speed = config['acc_settings']['set_speed']\n        self.time_headway = config['acc_settings']['time_headway']\n        self.min_distance = config['acc_settings']['min_distance']\n        self.emergency_ttc_threshold = config['acc_settings']['emergency_ttc_threshold']\n        \n        pid_speed_cfg = config.get('pid_speed', {'kp': 0.5, 'ki': 0.05, 'kd': 0.1})\n        pid_dist_cfg = config.get('pid_distance', {'kp': 0.5, 'ki': 0.05, 'kd': 0.1})\n        \n        self.pid_speed = PIDController(pid_speed_cfg['kp'], pid_speed_cfg['ki'], pid_speed_cfg['kd'])\n        self.pid_distance = PIDController(pid_dist_cfg['kp'], pid_dist_cfg['ki'], pid_dist_cfg['kd'])\n        self.prev_mode = 'cruise'\n        self.mode = 'cruise'\n    \n    def safe_following_distance(self, ego_speed):\n        return ego_speed * self.time_headway + self.min_distance\n    \n    def time_to_collision(self, distance, ego_speed, lead_speed):\n        relative_speed = ego_speed - lead_speed\n        if relative_speed <= 0:\n            return None\n        return distance / relative_speed\n    \n    def determine_mode(self, lead_speed, distance):\n        if lead_speed is None or distance is None:\n            return 'cruise'\n        return 'follow'\n    \n    def compute(self, ego_speed, lead_speed, distance, dt):\n        mode = self.determine_mode(lead_speed, distance)\n        \n        # Reset on mode change\n        if mode != self.prev_mode:\n            self.pid_speed.reset()\n            self.pid_distance.reset()\n            self.prev_mode = mode\n        self.mode = mode\n        \n        if mode == 'cruise':\n            # Cruise mode: maintain set speed\n            speed_error = self.set_speed - ego_speed\n            acceleration_cmd = self.pid_speed.compute(speed_error, dt)\n            distance_error = None\n            \n        else:  # 'follow' mode\n            # Follow mode: maintain safe distance\n            desired_distance = self.safe_following_distance(ego_speed)\n            distance_error = desired_distance - distance\n            \n            # PID on distance error\n            acc_from_distance = self.pid_distance.compute(distance_error, dt)\n            \n            # Speed correction to stay near set_speed\n            speed_error = self.set_speed - ego_speed\n            speed_correction = 0.3 * speed_error\n            \n            acceleration_cmd = acc_from_distance + speed_correction\n        \n        # Clamp acceleration to physical limits\n        acceleration_cmd = max(self.max_deceleration, min(self.max_acceleration, acceleration_cmd))\n        \n        return acceleration_cmd, mode, distance_error\n    \n    def reset(self):\n        self.pid_speed.reset()\n        self.pid_distance.reset()\n        self.prev_mode = 'cruise'\n        self.mode = 'cruise'\nEOF\n"]
