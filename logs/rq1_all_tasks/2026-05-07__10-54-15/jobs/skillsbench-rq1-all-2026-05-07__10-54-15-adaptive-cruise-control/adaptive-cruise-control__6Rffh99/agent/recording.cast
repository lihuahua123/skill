[1118.274422, "o", "def generate_report(df, config, tuning):\r\n\u001b[?2004l\r"]
[1118.274488, "o", "\u001b[?2004h> "]
[1118.274619, "o", "    set_speed = config['acc_settings']['set_speed']\r\n\u001b[?2004l\ra\u001b[?2004h> "]
[1118.274939, "o", "    speeds = pd.to_numeric(df['ego_speed'], errors='coerce').fillna(0)\r\n\u001b[?2004l\r\u001b[?2004h"]
[1118.275003, "o", "> \r\n\u001b[?2004l\r'\u001b[?2004h> "]
[1118.275061, "o", "    # Rise time\r\n\u001b[?2004l\r\u001b[?2004h"]
[1118.27511, "o", "> "]
[1118.275166, "o", "    rise_end = None\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1118.27527, "o", "    for i, s in enumerate(speeds):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1118.275411, "o", "        if s >= 0.9 * set_speed:\r\n\u001b[?2004l\r"]
[1118.275449, "o", "\u001b[?2004h> "]
[1118.275551, "o", "            rise_end = i\r\n\u001b[?2004l\r"]
[1118.275603, "o", "\u001b[?2004h> "]
[1118.275636, "o", "            break\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1118.275816, "o", "    rise_time = (rise_end * 0.1) if rise_end else None\r\n\u001b[?2004l\r\u001b[?2004h"]
[1118.275884, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[1118.275941, "o", "    max_speed = speeds.max()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1118.276035, "o", "    overshoot = max(0, ((max_speed - set_speed) / set_speed) * 100)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1118.276087, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1118.276155, "o", "    # Speed SS error\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1118.276235, "o", "    cruise_df = df[(df['mode'] == 'cruise') & (df['time'] >= 147)]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1118.276295, "o", "    if len(cruise_df) > 0:\r\n\u001b[?2004l\r\u001b[?2004h"]
[1118.276352, "o", "> "]
[1118.276424, "o", "        ss_error = abs(cruise_df['ego_speed'].mean() - set_speed)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1118.276491, "o", "    else:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1118.276587, "o", "        ss_error = abs(speeds.iloc[-150:].mean() - set_speed)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1118.276661, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1118.276725, "o", "    # Distance SS error\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1118.27679, "o", "    follow_df = df[df['mode'] == 'follow'].copy()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1118.276919, "o", "    follow_df['dist_err_num'] = pd.to_numeric(follow_df['distance_error'], errors='coerce')\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1118.277057, "o", "    follow_df['dist_num'] = pd.to_numeric(follow_df['distance'], errors='coerce')\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1118.277142, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[1118.277175, "o", ">     best_start = 0\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1118.277239, "o", "    best_mean = float('inf')\r\n\u001b[?2004l\r\u001b[?2004h>     window = 100\r\n\u001b[?2004l\r"]
[1118.2773, "o", "\u001b[?2004h> "]
[1118.277348, "o", "    for i in range(len(follow_df) - window):\r\n\u001b[?2004l\r\u001b[?2004h"]
[1118.277406, "o", "> "]
[1118.277477, "o", "        segment = follow_df.iloc[i:i+window]['dist_err_num']\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1118.27755, "o", "        mean_abs = segment.abs().mean()\r\n\u001b[?2004l\r"]
[1118.277631, "o", "\u001b[?2004h> "]
[1118.277687, "o", "        if mean_abs < best_mean:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1118.277737, "o", "            best_mean = mean_abs\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1118.277796, "o", "            best_start = i\r\n\u001b[?2004l\r\u001b[?2004h"]
[1118.277836, "o", ">     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[1118.277905, "o", "    if len(follow_df) > 0:\r\n\u001b[?2004l\r"]
[1118.277944, "o", "\u001b[?2004h> "]
[1118.27804, "o", "        dist_ss_err = best_mean if best_start > 0 else follow_df['dist_err_num'].abs().mean()\r\n\u001b[?2004l\r\u001b[?2004h"]
[1118.278113, "o", ">     else:\r\n\u001b[?2004l\r\u001b[?2004h"]
[1118.278171, "o", ">         dist_ss_err = 0\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[1118.278211, "o", "\u001b[?2004h>     # Minimum distance\r\n\u001b[?2004l\r"]
[1118.278245, "o", "\u001b[?2004h> "]
[1118.278361, "o", "    dist_series = pd.to_numeric(df['distance'], errors='coerce').dropna()\r\n\u001b[?2004l\r\u001b[?2004h"]
[1118.278428, "o", "> "]
[1118.278494, "o", "    min_dist = dist_series.min() if len(dist_series) > 0 else None\r\n\u001b[?2004l\r\u001b[?2004h> \r\n"]
[1118.278557, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[1118.278613, "o", "    with open('acc_report.md', 'w') as f:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1118.278695, "o", "        f.write(\"# ACC Simulation Report\\n\\n\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[1118.278775, "o", "> "]
[1118.278811, "o", "        f.write(\"## System Design\\n\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1118.278878, "o", "        f.write(\"### ACC Architecture\\n\\n\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[1118.278944, "o", "> "]
[1118.279057, "o", "        f.write(\"The ACC system implements a hierarchical control architecture with three modes:\\n\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1118.279216, "o", "        f.write(\"- **Cruise Mode**: No lead vehicle detected - maintains set speed (30 m/s)\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1118.279406, "o", "        f.write(\"- **Follow Mode**: Lead vehicle present with TTC >= threshold - maintains safe following distance\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1118.279582, "o", "        f.write(\"- **Emergency Mode**: TTC < 3.0s - applies maximum deceleration\\n\\n\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[1118.279657, "o", "> "]
[1118.279705, "o", "        f.write(\"### Safety Features\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1118.279821, "o", "        f.write(f\"- Time Headway: {config['acc_settings']['time_headway']}s\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1118.279956, "o", "        f.write(f\"- Minimum Gap: {config['acc_settings']['min_distance']}m\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1118.280109, "o", "        f.write(f\"- Emergency TTC: {config['acc_settings']['emergency_ttc_threshold']}s\\n\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[1118.280179, "o", "> "]
[1118.280336, "o", "        f.write(f\"- Accel Limits: [{config['vehicle']['max_deceleration']}, {config['vehicle']['max_acceleration']}] m/s2\\n\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1118.28044, "o", "        f.write(\"## PID Tuning Methodology\\n\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1118.280614, "o", "        f.write(\"Parameters tuned using iterative simulation to meet performance targets.\\n\\n\")\r\n\u001b[?2004l\r"]
[1118.28068, "o", "\u001b[?2004h> "]
[1118.280739, "o", "        f.write(\"### Final Gains\\n\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1118.28097, "o", "        f.write(f\"**Speed Controller:** kp={tuning['pid_speed']['kp']}, ki={tuning['pid_speed']['ki']}, kd={tuning['pid_speed']['kd']}\\n\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1118.281202, "o", "        f.write(f\"**Distance Controller:** kp={tuning['pid_distance']['kp']}, ki={tuning['pid_distance']['ki']}, kd={tuning['pid_distance']['kd']}\\n\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1118.281293, "o", "        f.write(\"## Simulation Results\\n\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1118.281392, "o", "        f.write(\"### Performance Metrics\\n\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1118.281511, "o", "        f.write(\"| Metric | Target | Achieved | Status |\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1118.281653, "o", "        f.write(\"|--------|--------|----------|--------|\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1118.281764, "o", "        rt_status = 'PASS' if (rise_time and rise_time < 10) else 'FAIL'\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1118.281891, "o", "        f.write(f\"| Rise Time | <10s | {rise_time:.2f}s | {rt_status} |\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1118.281996, "o", "        os_status = 'PASS' if overshoot < 5 else 'FAIL'\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1118.282124, "o", "        f.write(f\"| Overshoot | <5% | {overshoot:.2f}% | {os_status} |\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1118.282232, "o", "        ss_status = 'PASS' if ss_error < 0.5 else 'FAIL'\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1118.282375, "o", "        f.write(f\"| Speed SS Error | <0.5m/s | {ss_error:.3f}m/s | {ss_status} |\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1118.282489, "o", "        ds_status = 'PASS' if dist_ss_err < 2 else 'FAIL'\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1118.282624, "o", "        f.write(f\"| Dist SS Error | <2m | {dist_ss_err:.2f}m | {ds_status} |\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1118.282749, "o", "        md_status = 'PASS' if (min_dist and min_dist > 5) else 'FAIL'\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1118.282878, "o", "        f.write(f\"| Min Distance | >5m | {min_dist:.2f}m | {md_status} |\\n\")\r\n\u001b[?2004l\r"]
[1118.282948, "o", "\u001b[?2004h> "]
[1118.282985, "o", "        f.write(\"\\n### Simulation Summary\\n\\n\")\r\n\u001b[?2004l\r"]
[1118.283074, "o", "\u001b[?2004h> "]
[1118.283114, "o", "        f.write(f\"- Duration: 150s, Timestep: 0.1s\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1118.283204, "o", "        f.write(f\"- Rows in output: {len(df)}\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1118.283305, "o", "        f.write(f\"- Max speed: {max_speed:.2f} m/s\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1118.283545, "o", "        f.write(f\"- Modes: cruise={len(df[df['mode']=='cruise'])}, follow={len(follow_df)}, emergency={len(df[df['mode']=='emergency'])}\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1118.283629, "o", "    print(\"Report saved to acc_report.md\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[1118.283702, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[1118.28376, "o", "if __name__ == '__main__':\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1118.283821, "o", "    run_simulation()\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
[1118.284865, "o", "\u001b[?2004hroot@bfb65fae2dcc:~# "]
[1138.022215, "i", "cat > acc_system.py << 'EOF'\n\"\"\"Adaptive Cruise Control System Implementation\"\"\"\n\nfrom pid_controller import PIDController\n\nclass AdaptiveCruiseControl:\n    \"\"\"ACC system with proper mode determination.\"\"\"\n\n    def __init__(self, config):\n        self.mass = config['vehicle']['mass']\n        self.max_acceleration = config['vehicle']['max_acceleration']\n        self.max_deceleration = config['vehicle']['max_deceleration']\n        self.set_speed = config['acc_settings']['set_speed']\n        self.time_headway = config['acc_settings']['time_headway']\n        self.min_distance = config['acc_settings']['min_distance']\n        self.emergency_ttc_threshold = config['acc_settings']['emergency_ttc_threshold']\n\n        pid_speed_cfg = config.get('pid_speed', {'kp': 2.0, 'ki': 0.3, 'kd': 0.5})\n        pid_dist_cfg = config.get('pid_distance', {'kp': 1.5, 'ki': 0.1, 'kd': 0.3})\n\n        self.pid_speed = PIDController(pid_speed_cfg['kp'], pid_speed_cfg['ki'], pid_speed_cfg['kd'])\n        self.pid_distance = PIDController(pid_dist_cfg['kp'], pid_dist_cfg['ki'], pid_dist_cfg['kd'])\n        self.prev_mode = 'cruise'\n        self.mode = 'cruise'\n\n    def safe_following_distance(self, ego_speed):\n        \"\"\"Calculate desired following distance.\"\"\"\n        return ego_speed * self.time_headway + self.min_distance\n\n    def calculate_ttc(self, distance, ego_speed, lead_speed):\n        \"\"\"Calculate Time to Collision.\"\"\"\n        if distance is None or lead_speed is None:\n            return None\n        relative_speed = ego_speed - lead_speed\n        if relative_speed <= 0:\n            return None\n        return distance / relative_speed\n\n    def determine_mode(self, lead_speed, distance, ego_speed):\n        \"\"\"Determine operating mode based on conditions.\"\"\"\n        if lead_speed is None or distance is None:\n            return 'cruise'\n        \n        ttc = self.calculate_ttc(distance, ego_speed, lead_speed)\n        if ttc is not None and ttc < self.emergency_ttc_threshold:\n            return 'emergency'\n        \n        return 'follow'\n\n    def compute(self, ego_speed, lead_speed, distance, dt):\n        \"\"\"Compute acceleration command based on ACC logic.\"\"\"\n        mode = self.determine_mode(lead_speed, distance, ego_speed)\n\n        if mode != self.prev_mode:\n            self.pid_speed.reset()\n            self.pid_distance.reset()\n            self.prev_mode = mode\n        self.mode = mode\n\n        if mode == 'cruise':\n            self.pid_distance.reset()\n            speed_error = self.set_speed - ego_speed\n            acceleration_cmd = self.pid_speed.compute(speed_error, dt)\n            distance_error = None\n\n        elif mode == 'emergency':\n            self.pid_speed.reset()\n            self.pid_distance.reset()\n            acceleration_cmd = self.max_deceleration\n            distance_error = 0.0\n\n        else:  # 'follow' mode\n            self.pid_speed.reset()\n            desired_distance = self.safe_following_distance(ego_speed)\n            distance_error = distance - desired_distance\n            acceleration_cmd = self.pid_distance.compute(distance_error, dt)\n\n        # Clamp acceleration to limits\n        acceleration_cmd = max(self.max_deceleration, min(self.max_acceleration, acceleration_cmd))\n        return acceleration_cmd, mode, distance_error\n\n    def reset(self):\n        \"\"\"Reset controller state.\"\"\"\n        self.pid_speed.reset()\n        self.pid_distance.reset()\n        self.prev_mode = 'cruise'\n        self.mode = 'cruise'\nEOF\n"]
[1138.022433, "o", "cat > acc_system.py << 'EOF'\r\n\u001b[?2004l\r"]
[1138.022552, "o", "\u001b[?2004h> \"\"\"Adaptive Cruise Control System Implementation\"\"\"\r\n\u001b[?2004l\r"]
[1138.02259, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[1138.022625, "o", "> "]
[1138.022847, "o", "from pid_controller import PIDController\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[1138.022948, "o", "class AdaptiveCruiseControl:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1138.023031, "o", "    \"\"\"ACC system with proper mode determination.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[1138.023097, "o", "    def __init__(self, config):\r\n\u001b[?2004l\r\u001b[?2004h"]
[1138.023136, "o", "> "]
[1138.023221, "o", "        self.mass = config['vehicle']['mass']\r\n\u001b[?2004l\r\u001b[?2004h"]
[1138.023262, "o", "> "]
[1138.023397, "o", "        self.max_acceleration = config['vehicle']['max_acceleration']\r\n\u001b[?2004l\r\u001b[?2004h"]
[1138.023574, "o", "> "]
[1138.023683, "o", "        self.max_deceleration = config['vehicle']['max_deceleration']\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1138.023739, "o", "        self.set_speed = config['acc_settings']['set_speed']\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1138.023909, "o", "        self.time_headway = config['acc_settings']['time_headway']\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1138.024127, "o", "        self.min_distance = config['acc_settings']['min_distance']\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1138.024257, "o", "        self.emergency_ttc_threshold = config['acc_settings']['emergency_ttc_threshold']\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[1138.024356, "o", "\u001b[?2004h> "]
[1138.024441, "o", "        pid_speed_cfg = config.get('pid_speed', {'kp': 2.0, 'ki': 0.3, 'kd': 0.5})\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1138.024623, "o", "        pid_dist_cfg = config.get('pid_distance', {'kp': 1.5, 'ki': 0.1, 'kd': 0.3})\r\n\u001b[?2004l\r\u001b[?2004h"]
[1138.024708, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
[1138.024753, "o", "> "]
[1138.024884, "o", "        self.pid_speed = PIDController(pid_speed_cfg['kp'], pid_speed_cfg['ki'], pid_speed_cfg['kd'])\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1138.025028, "o", "        self.pid_distance = PIDController(pid_dist_cfg['kp'], pid_dist_cfg['ki'], pid_dist_cfg['kd'])\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1138.025096, "o", "        self.prev_mode = 'cruise'\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1138.025181, "o", "        self.mode = 'cruise'\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[1138.025263, "o", "\u001b[?2004h> "]
[1138.025307, "o", "    def safe_following_distance(self, ego_speed):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1138.025389, "o", "        \"\"\"Calculate desired following distance.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[1138.025468, "o", "> "]
[1138.025551, "o", "        return ego_speed * self.time_headway + self.min_distance\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[1138.025653, "o", "    def calculate_ttc(self, distance, ego_speed, lead_speed):\r\n\u001b[?2004l\r\u001b[?2004h"]
[1138.025735, "o", "> "]
[1138.025801, "o", "        \"\"\"Calculate Time to Collision.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1138.025873, "o", "        if distance is None or lead_speed is None:\r\n\u001b[?2004l\r"]
[1138.025927, "o", "\u001b[?2004h>             return None\r\n\u001b[?2004l\r\u001b[?2004h"]
[1138.025986, "o", "> "]
[1138.026015, "o", "        relative_speed = ego_speed - lead_speed\r\n\u001b[?2004l\r"]
[1138.026105, "o", "\u001b[?2004h> "]
[1138.026155, "o", "        if relative_speed <= 0:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1138.02624, "o", "            return None\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1138.026308, "o", "        return distance / relative_speed\r\n\u001b[?2004l\r"]
[1138.026367, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[1138.026396, "o", "\u001b[?2004h> "]
[1138.026479, "o", "    def determine_mode(self, lead_speed, distance, ego_speed):\r\n\u001b[?2004l\r"]
[1138.026508, "o", "\u001b[?2004h> "]
[1138.026605, "o", "        \"\"\"Determine operating mode based on conditions.\"\"\"\r\n\u001b[?2004l\r"]
[1138.026633, "o", "\u001b[?2004h> "]
[1138.026718, "o", "        if lead_speed is None or distance is None:\r\n\u001b[?2004l\r"]
[1138.026746, "o", "\u001b[?2004h> "]
[1138.026829, "o", "            return 'cruise'\r\n\u001b[?2004l\r\u001b[?2004h"]
[1138.02687, "o", ">         \r\n\u001b[?2004l\r\u001b[?2004h"]
[1138.026959, "o", "> "]
[1138.027004, "o", "        ttc = self.calculate_ttc(distance, ego_speed, lead_speed)\r\n\u001b[?2004l\r\u001b[?2004h"]
[1138.027083, "o", "> "]
[1138.027131, "o", "        if ttc is not None and ttc < self.emergency_ttc_threshold:\r\n\u001b[?2004l\r"]
[1138.027186, "o", "\u001b[?2004h> "]
[1138.027219, "o", "            return 'emergency'\r\n\u001b[?2004l\r\u001b[?2004h"]
[1138.027289, "o", ">         \r\n\u001b[?2004l\r\u001b[?2004h> "]
[1138.027345, "o", "        return 'follow'\r\n\u001b[?2004l\r"]
[1138.027383, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[1138.027452, "o", "\u001b[?2004h> "]
