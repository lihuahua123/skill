   def determine_mode(self, lead_speed, distance, ego_speed):\r\n\u001b[?2004l\r\u001b[?2004h>         if lead_speed is None or distance is None:\r\n\u001b[?2004l\r\u001b[?2004h>             return 'cruise', None\r\n\u001b[?2004l\r\u001b[?2004h>         ttc = self.calculate_ttc(distance, ego_speed, lead_speed)\r\n\u001b[?2004l\r\u001b[?2004h>         self.current_ttc = ttc\r\n\u001b[?2004l\r\u001b[?2004h>         if ttc is not None and ttc < self.emergency_ttc_threshold:\r\n\u001b[?2004l\r\u001b[?2004h>             return 'emergency', ttc\r\n\u001b[?2004l\r\u001b[?2004h>         return 'follow', ttc\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     def compute(self, ego_speed, lead_speed, distance, dt):\r\n\u001b[?2004l\r\u001b[?2004h>         mode, ttc = self.determine_mode(lead_speed, distance, ego_speed)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>         if mode != self.prev_mode:\r\n\u001b[?2004l\r\u001b[?2004h>             self.pid_speed.reset()\r\n\u001b[?2004l\r\u001b[?2004h>             self.pid_distance.reset()\r\n\u001b[?2004l\r\u001b[?2004h>             self.prev_mode = mode\r\n\u001b[?2004l\r\u001b[?2004h>         self.mode = mode\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>         if mode == 'cruise':\r\n\u001b[?2004l\r\u001b[?2004h>             self.pid_distance.reset()\r\n\u001b[?2004l\r\u001b[?2004h>             speed_error = self.set_speed - ego_speed\r\n\u001b[?2004l\r\u001b[?2004h>             acceleration_cmd = self.pid_speed.compute(speed_error, dt)\r\n\u001b[?2004l\r\u001b[?2004h>             if ego_speed >= self.set_speed:\r\n\u001b[?2004l\r\u001b[?2004h>                 acceleration_cmd = min(acceleration_cmd, 0)\r\n\u001b[?2004l\r\u001b[?2004h>             distance_error = None\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
