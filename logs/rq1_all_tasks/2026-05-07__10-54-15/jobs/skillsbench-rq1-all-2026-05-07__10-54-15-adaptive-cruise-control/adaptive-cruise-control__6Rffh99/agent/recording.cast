[1518.884384, "o", "\u001b[?2004h> "]
[1518.884546, "o", "    set_speed = config['acc_settings']['set_speed']\r\n\u001b[?2004l\r\u001b[?2004h"]
[1518.88458, "o", "> "]
[1518.884872, "o", "    speeds = pd.to_numeric(df['ego_speed'], errors='coerce').fillna(0)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1518.884915, "o", "\r\n\u001b[?2004l\rr\u001b[?2004h> "]
