[966.008707, "o", "vehicle:\r\n  mass: 1500  # kg\r\n  max_acceleration: 3.0  # m/s^2\r\n  max_deceleration: -8.0  # m/s^2\r\n  drag_coefficient: 0.3\r\n\r\nacc_settings:\r\n  set_speed: 30.0  # m/s (target cruise speed, ~108 km/h)\r\n  time_headway: 1.5  # seconds\r\n  min_distance: 10.0  # meters\r\n  emergency_ttc_threshold: 3.0  # seconds (trigger emergency braking when TTC < this)\r\n\r\npid_speed:\r\n  kp: 0.1\r\n  ki: 0.01\r\n  kd: 0.0\r\n\r\npid_distance:\r\n  kp: 0.1\r\n  ki: 0.01\r\n  kd: 0.0\r\n\r\nsimulation:\r\n  dt: 0.1  # seconds\r\n"]
