[1363.269898, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_safety\u001b[39;49;00m(\u001b[96mself\u001b[39;49;00m):\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"Safety: minimum distance, emergency mode, acceleration limits, speed.\"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[94mimport\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[04m\u001b[96mpandas\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[94mas\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[04m\u001b[96mpd\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        simulation_data = pd.read_csv(\u001b[33m'\u001b[39;49;00m\u001b[33m/root/simulation_results.csv\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n"]
[1363.27, "o", "    \u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Distance must never go below 5 meters\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        dist = simulation_data[simulation_data[\u001b[33m'\u001b[39;49;00m\u001b[33mdistance\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m].notna() & (simulation_data[\u001b[33m'\u001b[39;49;00m\u001b[33mdistance\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m] != \u001b[33m'\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m)]\u001b[90m\u001b[39;49;00m\r\n        \u001b[94mif\u001b[39;49;00m \u001b[96mlen\u001b[39;49;00m(dist) > \u001b[94m0\u001b[39;49;00m:\u001b[90m\u001b[39;49;00m\r\n            min_d = pd.to_numeric(dist[\u001b[33m'\u001b[39;49;00m\u001b[33mdistance\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m], errors=\u001b[33m'\u001b[39;49;00m\u001b[33mcoerce\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m).min()\u001b[90m\u001b[39;49;00m\r\n            \u001b[94massert\u001b[39;49;00m min_d >= \u001b[94m5.0\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Emergency mode must be triggered\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[94massert\u001b[39;49;00m \u001b[33m'\u001b[39;49;00m\u001b[33memergency\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m \u001b[95min\u001b[39;49;00m simulation_data[\u001b[33m'\u001b[39;49;00m\u001b[33mmode\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m].unique()\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# In emergency mode: TTC < 3.0 and acceleration must be negative\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        emergency = simulation_data[simulation_data[\u001b[33m'\u001b[39;49;00m\u001b[33mmode\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m] == \u001b[33m'\u001b[39;49;00m\u001b[33memergency\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m]\u001b[90m\u001b[39;49;00m\r\n        \u001b[94mif\u001b[39;49;00m \u001b[96mlen\u001b[39;49;00m(emergency) > \u001b[94m0\u001b[39;49;00m:\u001b[90m\u001b[39;49;00m\r\n            \u001b[94massert\u001b[39;49;00m \u001b[96mall\u001b[39;49;00m(emergency[\u001b[33m'\u001b[39;49;00m\u001b[33macceleration_cmd\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m] < \u001b[94m0\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n            ttc_data = emergency[emergency[\u001b[33m'\u001b[39;49;00m\u001b[33mttc\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m].notna() & (emergency[\u001b[33m'\u001b[39;49;00m\u001b[33mttc\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m] != \u001b[33m'\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m)]\u001b[90m\u001b[39;49;00m\r\n            \u001b[94mif\u001b[39;49;00m \u001b[96mlen\u001b[39;49;00m(ttc_data) > \u001b[94m0\u001b[39;49;00m:\u001b[90m\u001b[39;49;00m\r\n                ttc_values = pd.to_numeric(ttc_data[\u001b[33m'\u001b[39;49;00m\u001b[33mttc\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m], errors=\u001b[33m'\u001b[39;49;00m\u001b[33mcoerce\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m).dropna()\u001b[90m\u001b[39;49;00m\r\n                \u001b[94mif\u001b[39;49;00m \u001b[96mlen\u001b[39;49;00m(ttc_values) > \u001b[94m0\u001b[39;49;00m:\u001b[90m\u001b[39;49;00m\r\n"]
