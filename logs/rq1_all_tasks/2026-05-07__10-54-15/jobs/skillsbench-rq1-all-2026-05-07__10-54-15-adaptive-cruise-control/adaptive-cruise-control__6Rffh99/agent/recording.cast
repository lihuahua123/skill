[355.182164, "o", "\u001b[?2004hroot@bfb65fae2dcc:~# "]
[390.891941, "i", "cat > acc_system.py << 'EOF'\n\"\"\"Adaptive Cruise Control System Implementation\"\"\"\n\nfrom pid_controller import PIDController\n\nclass AdaptiveCruiseControl:\n    \"\"\"ACC system with proper distance control logic.\"\"\"\n    \n    def __init__(self, config):\n        self.mass = config['vehicle']['mass']\n        self.max_acceleration = config['vehicle']['max_acceleration']\n        self.max_deceleration = config['vehicle']['max_deceleration']\n        self.set_speed = config['acc_settings']['set_speed']\n        self.time_headway = config['acc_settings']['time_headway']\n        self.min_distance = config['acc_settings']['min_distance']\n        self.emergency_ttc_threshold = config['acc_settings']['emergency_ttc_threshold']\n        \n        pid_speed_cfg = config.get('pid_speed', {'kp': 0.5, 'ki': 0.05, 'kd': 0.1})\n        pid_dist_cfg = config.get('pid_distance', {'kp': 0.5, 'ki': 0.05, 'kd': 0.1})\n        \n        self.pid_speed = PIDController(pid_speed_cfg['kp'], pid_speed_cfg['ki'], pid_speed_cfg['kd'])\n        self.pid_distance = PIDController(pid_dist_cfg['kp'], pid_dist_cfg['ki'], pid_dist_cfg['kd'])\n        self.prev_mode = 'cruise'\n        self.mode = 'cruise'\n    \n    def safe_following_distance(self, ego_speed):\n        return ego_speed * self.time_headway + self.min_distance\n    \n    def time_to_collision(self, distance, ego_speed, lead_speed):\n        relative_speed = ego_speed - lead_speed\n        if relative_speed <= 0:\n            return None\n        return distance / relative_speed\n    \n    def determine_mode(self, lead_speed, distance):\n        if lead_speed is None or distance is None:\n            return 'cruise'\n        ttc = self.time_to_collision(distance, self.set_speed, lead_speed)\n        if ttc is not None and ttc < self.emergency_ttc_threshold:\n            return 'emergency'\n        return 'follow'\n    \n    def compute(self, ego_speed, lead_speed, distance, dt):\n        mode = self.determine_mode(lead_speed, distance)\n        \n        if mode != self.prev_mode:\n            self.pid_speed.reset()\n            self.pid_distance.reset()\n            self.prev_mode = mode\n        self.mode = mode\n        \n        if mode == 'cruise':\n            self.pid_distance.reset()\n            speed_error = self.set_speed - ego_speed\n            acceleration_cmd = self.pid_speed.compute(speed_error, dt)\n            \n            # Additional speed-based limiting\n            if ego_speed > self.set_speed:\n                # Need to slow down\n                decel_needed = ego_speed - self.set_speed\n                acc_limit = max(self.max_deceleration, -decel_needed * 2)\n                acceleration_cmd = min(acceleration_cmd, acc_limit)\n            elif ego_speed > self.set_speed - 2:\n                acceleration_cmd *= 0.1  # Dampen near target\n            \n            distance_error = None\n            \n        elif mode == 'emergency':\n            self.pid_speed.reset()\n            self.pid_distance.reset()\n            acceleration_cmd = self.max_deceleration\n            distance_error = 0.0\n            \n        else:  # 'follow' mode\n            self.pid_speed.reset()\n            desired_distance = self.safe_following_distance(ego_speed)\n            # FIXED: actual - desired (positive = too far = accelerate, negative = too close = decelerate)\n            distance_error = distance - desired_distance\n            \n            acceleration_cmd = self.pid_distance.compute(distance_error, dt)\n            \n            # Keep speed near set_speed\n            speed_error = self.set_speed - ego_speed\n            speed_correction = 0.2 * speed_error\n            acceleration_cmd += speed_correction\n        \n        acceleration_cmd = max(self.max_deceleration, min(self.max_acceleration, acceleration_cmd))\n        return acceleration_cmd, mode, distance_error\n    \n    def reset(self):\n        self.pid_speed.reset()\n        self.pid_distance.reset()\n        self.prev_mode = 'cruise'\n        self.mode = 'cruise'\nEOF\n"]
[390.892251, "o", "cat > acc_system.py << 'EOF'\r\n\u001b[?2004l\r"]
[390.892324, "o", "\u001b[?2004h> "]
[390.892463, "o", "\"\"\"Adaptive Cruise Control System Implementation\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[390.89264, "o", "from pid_controller import PIDController\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[390.89275, "o", "class AdaptiveCruiseControl:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[390.892793, "o", "    \"\"\"ACC system with proper distance control logic.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[390.892875, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[390.892923, "o", "    def __init__(self, config):\r\n\u001b[?2004l\r"]
[390.892946, "o", "\u001b[?2004h> "]
[390.893173, "o", "        self.mass = config['vehicle']['mass']\r\n\u001b[?2004l\r\u001b[?2004h> "]
[390.893311, "o", "        self.max_acceleration = config['vehicle']['max_acceleration']\r\n\u001b[?2004l\r\u001b[?2004h> "]
[390.893418, "o", "        self.max_deceleration = config['vehicle']['max_deceleration']\r\n\u001b[?2004l\r\u001b[?2004h> "]
[390.893535, "o", "        self.set_speed = config['acc_settings']['set_speed']"]
[390.893653, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[390.893819, "o", "        self.time_headway = config['acc_settings']['time_headway']\r\n\u001b[?2004l\r\u001b[?2004h> "]
[390.893961, "o", "        self.min_distance = config['acc_settings']['min_distance']\r\n\u001b[?2004l\r\u001b[?2004h> "]
[390.894154, "o", "        self.emergency_ttc_threshold = config['acc_settings']['emergency_ttc_threshold']\r\n\u001b[?2004l\r\u001b[?2004h"]
[390.894227, "o", ">         \r\n\u001b[?2004l\r\u001b[?2004h"]
[390.894268, "o", "> "]
[390.894378, "o", "        pid_speed_cfg = config.get('pid_speed', {'kp': 0.5, 'ki': 0.05, 'kd': 0.1})\r\n\u001b[?2004l\r\u001b[?2004h"]
[390.894447, "o", "> "]
[390.894561, "o", "        pid_dist_cfg = config.get('pid_distance', {'kp': 0.5, 'ki': 0.05, 'kd': 0.1})\r\n\u001b[?2004l\r\u001b[?2004h"]
[390.894623, "o", ">         \r\n\u001b[?2004l\r\u001b[?2004h> "]
[390.894818, "o", "        self.pid_speed = PIDController(pid_speed_cfg['kp'], pid_speed_cfg['ki'], pid_speed_cfg['kd'])\r\n\u001b[?2004l\r\u001b[?2004h"]
[390.894854, "o", "> "]
[390.895042, "o", "        self.pid_distance = PIDController(pid_dist_cfg['kp'], pid_dist_cfg['ki'], pid_dist_cfg['kd'])\r\n\u001b[?2004l\r"]
[390.895099, "o", "\u001b[?2004h> "]
[390.895164, "o", "        self.prev_mode = 'cruise'\r\n\u001b[?2004l\r\u001b[?2004h> "]
[390.895233, "o", "        self.mode = 'cruise'\r\n\u001b[?2004l\r"]
[390.895291, "o", "\u001b[?2004h> "]
[390.895353, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[390.895418, "o", "    def safe_following_distance(self, ego_speed):\r\n\u001b[?2004l\r\u001b[?2004h"]
[390.895472, "o", "> "]
[390.895612, "o", "        return ego_speed * self.time_headway + self.min_distance\r\n\u001b[?2004l\r\u001b[?2004h> "]
[390.8957, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[390.895804, "o", "    def time_to_collision(self, distance, ego_speed, lead_speed):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[390.895906, "o", "        relative_speed = ego_speed - lead_speed\r\n\u001b[?2004l\r"]
[390.896031, "o", "\u001b[?2004h> "]
[390.896121, "o", "        if relative_speed <= 0:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[390.896202, "o", "            return None\r\n\u001b[?2004l\r\u001b[?2004h> "]
[390.896284, "o", "        return distance / relative_speed\r\n\u001b[?2004l\r\u001b[?2004h"]
[390.896326, "o", ">     \r\n\u001b[?2004l\r"]
[390.896421, "o", "\u001b[?2004h> "]
[390.896485, "o", "    def determine_mode(self, lead_speed, distance):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[390.896581, "o", "        if lead_speed is None or distance is None:\r\n\u001b[?2004l\r\u001b[?2004h"]
[390.896664, "o", "> "]
[390.896737, "o", "            return 'cruise'\r\n\u001b[?2004l\r\u001b[?2004h> "]
[390.896831, "o", "        ttc = self.time_to_collision(distance, self.set_speed, lead_speed)\r\n\u001b[?2004l\r\u001b[?2004h"]
[390.896873, "o", "> "]
[390.896975, "o", "        if ttc is not None and ttc < self.emergency_ttc_threshold:\r\n\u001b[?2004l\r\u001b[?2004h"]
[390.897017, "o", "> "]
[390.897125, "o", "            return 'emergency'\r\n\u001b[?2004l\r\u001b[?2004h"]
[390.897182, "o", ">         return 'follow'\r\n\u001b[?2004l\r\u001b[?2004h> "]
[390.897202, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[390.897326, "o", "    def compute(self, ego_speed, lead_speed, distance, dt):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[390.897438, "o", "        mode = self.determine_mode(lead_speed, distance)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[390.897534, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h> "]
[390.897572, "o", "        if mode != self.prev_mode:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[390.897652, "o", "            self.pid_speed.reset()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[390.897718, "o", "            self.pid_distance.reset()\r\n\u001b[?2004l\r"]
[390.897749, "o", "\u001b[?2004h> "]
[390.897828, "o", "            self.prev_mode = mode\r\n\u001b[?2004l\r\u001b[?2004h> "]
[390.897884, "o", "        self.mode = mode\r\n\u001b[?2004l\r\u001b[?2004h"]
[390.897922, "o", ">         \r\n\u001b[?2004l\r\u001b[?2004h> "]
[390.897996, "o", "        if mode == 'cruise':\r\n\u001b[?2004l\r\u001b[?2004h> "]
[390.898067, "o", "            self.pid_distance.reset()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[390.898136, "o", "            speed_error = self.set_speed - ego_speed\r\n\u001b[?2004l\r\u001b[?2004h> "]
[390.89826, "o", "            acceleration_cmd = self.pid_speed.compute(speed_error, dt)\r\n\u001b[?2004l\r"]
[390.898317, "o", "\u001b[?2004h> "]
[390.898374, "o", "            \r\n\u001b[?2004l\r\u001b[?2004h> "]
[390.89841, "o", "            # Additional speed-based limiting\r\n\u001b[?2004l\r\u001b[?2004h> "]
[390.898486, "o", "            if ego_speed > self.set_speed:\r\n\u001b[?2004l\r"]
[390.898531, "o", "\u001b[?2004h> "]
[390.898625, "o", "                # Need to slow down\r\n\u001b[?2004l\r\u001b[?2004h> "]
[390.898679, "o", "                decel_needed = ego_speed - self.set_speed\r\n\u001b[?2004l\r\u001b[?2004h> "]
[390.898799, "o", "                acc_limit = max(self.max_deceleration, -decel_needed * 2)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[390.89891, "o", "                acceleration_cmd = min(acceleration_cmd, acc_limit)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[390.898995, "o", "            elif ego_speed > self.set_speed - 2:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[390.899099, "o", "                acceleration_cmd *= 0.1  # Dampen near target\r\n\u001b[?2004l\r\u001b[?2004h> "]
[390.899146, "o", "            \r\n\u001b[?2004l\r"]
[390.899201, "o", "\u001b[?2004h> "]
[390.89926, "o", "            distance_error = None\r\n\u001b[?2004l\r\u001b[?2004h"]
[390.899314, "o", ">             \r\n\u001b[?2004l\r\u001b[?2004h> "]
[390.899381, "o", "        elif mode == 'emergency':\r\n\u001b[?2004l\r\u001b[?2004h"]
[390.899433, "o", "> "]
[390.899508, "o", "            self.pid_speed.reset()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[390.899545, "o", "            self.pid_distance.reset()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[390.899638, "o", "            acceleration_cmd = self.max_deceleration\r\n\u001b[?2004l\r\u001b[?2004h> "]
[390.899717, "o", "            distance_error = 0.0\r\n\u001b[?2004l\r\u001b[?2004h> "]
[390.899774, "o", "            \r\n\u001b[?2004l\r\u001b[?2004h> "]
[390.899829, "o", "        else:  # 'follow' mode\r\n\u001b[?2004l\r"]
[390.899864, "o", "\u001b[?2004h> "]
[390.899944, "o", "            self.pid_speed.reset()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[390.900058, "o", "            desired_distance = self.safe_following_distance(ego_speed)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[390.900232, "o", "            # FIXED: actual - desired (positive = too far = accelerate, negative = too close = decelerate)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[390.900337, "o", "            distance_error = distance - desired_distance\r\n\u001b[?2004l\r\u001b[?2004h> "]
[390.900376, "o", "            \r\n\u001b[?2004l\r"]
[390.900441, "o", "\u001b[?2004h> "]
[390.900529, "o", "            acceleration_cmd = self.pid_distance.compute(distance_error, dt)\r\n\u001b[?2004l\r"]
[390.900585, "o", "\u001b[?2004h> "]
[390.900635, "o", "            \r\n\u001b[?2004l\r\u001b[?2004h> "]
[390.900667, "o", "            # Keep speed near set_speed\r\n\u001b[?2004l\r\u001b[?2004h"]
[390.900733, "o", "> "]
[390.900796, "o", "            speed_error = self.set_speed - ego_speed\r\n\u001b[?2004l\r\u001b[?2004h> "]
[390.900866, "o", "            speed_correction = 0.2 * speed_error\r\n\u001b[?2004l\r"]
[390.900913, "o", "\u001b[?2004h> "]
[390.900971, "o", "            acceleration_cmd += speed_correction\r\n\u001b[?2004l\r"]
[390.901001, "o", "\u001b[?2004h> "]
[390.901068, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h> "]
[390.901195, "o", "        acceleration_cmd = max(self.max_deceleration, min(self.max_acceleration, acceleration_cmd))\r\n\u001b[?2004l\r\u001b[?2004h> "]
[390.90129, "o", "        return acceleration_cmd, mode, distance_error\r\n\u001b[?2004l\r\u001b[?2004h> "]
[390.901326, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[390.901389, "o", "    def reset(self):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[390.901448, "o", "        self.pid_speed.reset()\r\n\u001b[?2004l\r"]
[390.90148, "o", "\u001b[?2004h> "]
[390.901559, "o", "        self.pid_distance.reset()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[390.901617, "o", "        self.prev_mode = 'cruise'\r\n\u001b[?2004l\r\u001b[?2004h> "]
[390.901691, "o", "        self.mode = 'cruise'\r\n\u001b[?2004l\r\u001b[?2004h> "]
[390.901756, "o", "EOF\r\n\u001b[?2004l\r"]
[390.90278, "o", "\u001b[?2004hroot@bfb65fae2dcc:~# "]
[391.38996, "i", "python3 simulation.py\n"]
[391.390322, "o", "python3 simulation.py\r\n\u001b[?2004l\r"]
[391.804383, "o", "Speed PID: {'kp': 1.0, 'ki': 0.2, 'kd': 0.3}\r\nDistance PID: {'kp': 0.5, 'ki': 0.05, 'kd': 0.1}\r\n"]
