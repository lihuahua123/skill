[1518.875936, "o", "> \r\n\u001b[?2004l\r \u001b[?2004h> "]
[1518.876092, "o", "    df = pd.read_csv('sensor_data.csv')\r\n\u001b[?2004l\r\u001b[?2004h"]
[1518.876159, "o", "> "]
[1518.876275, "o", "    dt = config['simulation']['dt']\r\n\u001b[?2004l\r\u001b[?2004h"]
[1518.87635, "o", "> "]
[1518.876487, "o", "    acc = AdaptiveCruiseControl(config)\r\n\u001b[?2004l\r'\u001b[?2004h> "]
[1518.87656, "o", "    acc.reset()\r\n\u001b[?2004l\rd\u001b[?2004h> "]
[1518.876636, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1518.876687, "o", "    ego_speed = 0.0\r\n\u001b[?2004l\r"]
[1518.876773, "o", "\u001b[?2004h> "]
[1518.876851, "o", "    distance = None\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1518.876916, "o", "    results = []\r\n\u001b[?2004l\rm\u001b[?2004h> "]
[1518.876956, "o", "\r\n\u001b[?2004l\r/\u001b[?2004h> "]
[1518.877149, "o", "    for idx, row in df.iterrows():\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1518.877278, "o", "        time = row['time']\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1518.877642, "o", "        sensor_lead_speed = row['lead_speed'] if pd.notna(row['lead_speed']) else None\r\n\u001b[?2004l\r\u001b[?2004h"]
[1518.877679, "o", "> "]
[1518.877981, "o", "        sensor_distance = row['distance'] if pd.notna(row['distance']) else None\r\n\u001b[?2004l\r\u001b[?2004h"]
[1518.878044, "o", "> "]
[1518.878117, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h> "]
[1518.878201, "o", "        lead_speed = sensor_lead_speed\r\n\u001b[?2004l\rp\u001b[?2004h"]
[1518.878267, "o", "> "]
[1518.878309, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h> "]
[1518.878621, "o", "        # Calculate distance based on physics using pre-acceleration ego_speed\r\n\u001b[?2004l\ron\u001b[?2004h> "]
[1518.878749, "o", "        if lead_speed is not None:\r\n\u001b[?2004l\re\u001b[?2004h"]
[1518.878826, "o", "> "]
[1518.878876, "o", "            if distance is None:\r\n\u001b[?2004l\r"]
[1518.878985, "o", "\u001b[?2004h> "]
[1518.879074, "o", "                distance = sensor_distance\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1518.879184, "o", "            else:\r\n\u001b[?2004l\r \u001b[?2004h> "]
[1518.879445, "o", "                relative_speed = ego_speed - lead_speed\r\n\u001b[?2004l\r"]
[1518.87961, "o", "\u001b[?2004h> "]
[1518.879704, "o", "                distance = distance - relative_speed * dt\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1518.879873, "o", "                distance = max(5.0, distance)\r\n\u001b[?2004l\re\u001b[?2004h"]
[1518.879965, "o", ">         else:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1518.880045, "o", "            distance = None\r\n\u001b[?2004l\r"]
[1518.880114, "o", "\u001b[?2004h> \r\n\u001b[?2004l\rn\u001b[?2004h"]
[1518.880169, "o", "> "]
[1518.880333, "o", "        # Calculate TTC before acceleration (using current ego_speed)\r\n\u001b[?2004l\r\u001b[?2004h"]
[1518.880382, "o", "> "]
[1518.880585, "o", "        ttc = calculate_ttc(distance, ego_speed, lead_speed)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1518.880653, "o", "        \r\n\u001b[?2004l\r"]
[1518.880709, "o", "\u001b[?2004h> "]
[1518.880925, "o", "        acc_cmd, mode, dist_error = acc.compute(ego_speed, lead_speed, distance, dt)\r\n\u001b[?2004l\r\u001b[?2004h"]
[1518.880994, "o", "> "]
[1518.881078, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h> "]
[1518.881223, "o", "        # Update ego speed after computing acceleration\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1518.881397, "o", "        ego_speed = ego_speed + acc_cmd * dt\r\n\u001b[?2004l\r\u001b[?2004h"]
[1518.881431, "o", "> "]
[1518.881542, "o", "        ego_speed = max(0, ego_speed)\r\n\u001b[?2004l\ro\u001b[?2004h"]
[1518.881595, "o", "> \r\n\u001b[?2004l\rr\u001b[?2004h> "]
[1518.881666, "o", "        result = {\r\n\u001b[?2004l\r"]
[1518.881732, "o", "\u001b[?2004h> "]
[1518.881822, "o", "            'time': time,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1518.882033, "o", "            'ego_speed': ego_speed,\r\n\u001b[?2004l\r\u001b[?2004h"]
[1518.882085, "o", "> "]
[1518.882191, "o", "            'acceleration_cmd': acc_cmd,\r\n\u001b[?2004l\r\u001b[?2004h"]
[1518.88224, "o", "> "]
[1518.882313, "o", "            'mode': mode,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1518.882572, "o", "            'distance_error': dist_error if dist_error is not None else '',\r\n\u001b[?2004l\r\u001b[?2004h"]
[1518.882607, "o", "> "]
[1518.882794, "o", "            'distance': distance if distance is not None else '',\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1518.882988, "o", "            'ttc': ttc if ttc is not None else ''\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1518.883039, "o", "        }\r\n\u001b[?2004l\r"]
[1518.883105, "o", "\u001b[?2004h> "]
[1518.883168, "o", "        results.append(result)\r\n\u001b[?2004l\r\\\u001b[?2004h> "]
[1518.883219, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1518.883338, "o", "    results_df = pd.DataFrame(results)\r\n\u001b[?2004l\r\u001b[?2004h"]
[1518.883392, "o", "> "]
[1518.88367, "o", "    results_df.to_csv('simulation_results.csv', index=False)\r\n\u001b[?2004l\r\u001b[?2004h"]
[1518.883732, "o", "> "]
