[1040.728217, "o", "\t        assert len(t10_series) > 0 and len(t90_series) > 0, \"Speed thresholds not reached\"\r\n   206\t        t10 = t10_series.min()\r\n   207\t        t90 = t90_series.min()\r\n   208\t        assert t90 - t10 < 10.0\r\n   209\t\r\n   210\t        # Overshoot < 5% (max speed < 31.5 m/s)\r\n   211\t        assert cruise['ego_speed'].max() < 31.5\r\n   212\t\r\n   213\t        # Steady-state error < 0.5 m/s (at t=25-30s)\r\n   214\t        ss = simulation_data[(simulation_data['time'] >= 25.0) & (simulation_data['time'] <= 30.0)]\r\n   215\t        assert abs(30.0 - ss['ego_speed'].mean()) < 0.5\r\n   216\t\r\n   217\t\r\n   218\t"]
