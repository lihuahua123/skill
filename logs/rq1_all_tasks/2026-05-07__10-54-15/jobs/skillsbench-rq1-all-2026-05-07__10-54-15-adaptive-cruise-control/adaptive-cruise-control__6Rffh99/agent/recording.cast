[1518.885495, "o", "\u001b[?2004l\r\u001b[?2004h"]
[1518.885544, "o", "> "]
[1518.885578, "o", "    max_speed = speeds.max()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1518.885693, "o", "    overshoot = max(0, ((max_speed - set_speed) / set_speed) * 100)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n"]
[1518.885746, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[1518.885854, "o", "    cruise_df = df[(df['mode'] == 'cruise') & (df['time'] >= 147)]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1518.885918, "o", "    if len(cruise_df) > 0:\r\n\u001b[?2004l\r"]
[1518.885949, "o", "\u001b[?2004h> "]
