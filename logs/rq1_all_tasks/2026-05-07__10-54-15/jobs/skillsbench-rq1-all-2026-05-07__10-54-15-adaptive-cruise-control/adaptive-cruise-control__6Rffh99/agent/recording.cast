[691.355745, "o", "grep ',follow,' simulation_results.csv | head -20 | tail -10\r\n\u001b[?2004l\r"]
[691.35732, "o", "31.0,28.01173036592476,-0.22147541422001882,follow,-4.800816861020138,47.25,14.055261682773969\r\n31.1,27.703389562277966,-3.0834080364679193,follow,-6.697595548887136,45.32,14.842521425988377\r\n31.2,27.695665572593455,-0.07723989684510713,follow,-4.115084343416953,47.44,18.857832502391425\r\n31.3,27.2317062017258,-4.639593708676564,follow,-8.183498358890184,43.36,11.841474332256364\r\n31.4,27.2517062017258,0.2,follow,-4.6475593025886965,46.2,13.04456026801086\r\n31.5,26.901302679599812,-3.5040352212598584,follow,-7.067559302588698,43.81,18.8730234902209\r\n31.6,26.596349189325064,-3.049534902747475,follow,-7.991954019399721,42.36,17.976962069927026\r\n31.7,26.36307894896704,-2.3327024035802366,follow,-7.654523783987592,42.24,37.6108910587724\r\n31.8,26.12984470199668,-2.332342469703576,follow,-7.424618423450561,42.12,23.272715031036533\r\n31.9,25.962214343225316,-1.6763035877136487,follow,-6.444767052995019,42.75,21.14019225668048\r\n"]
[691.357554, "o", "\u001b[?2004hroot@bfb65fae2dcc:~# "]
[691.651735, "i", "python3 -c \"\nimport pandas as pd\ndf = pd.read_csv('simulation_results.csv')\nfollow = df[df['mode']=='follow']\ndist = pd.to_numeric(follow['distance'], errors='coerce')\nerr = pd.to_numeric(follow['distance_error'], errors='coerce')\nprint('Distance stats in follow mode:')\nprint('Mean distance:', dist.mean())\nprint('Min distance:', dist.min())\nprint('Max distance:', dist.max())\nprint('Mean distance_error:', err.mean())\nprint('Last 100 rows dist_error mean:', err.iloc[-100:].mean())\n\"\n"]
[691.652039, "o", "python3 -c \"\r\n\u001b[?2004l\r"]
[691.65227, "o", "\u001b[?2004h> import pandas as pd\r\n\u001b[?2004l\r\u001b[?2004h> df = pd.read_csv('simulation_results.csv')\r\n\u001b[?2004l\r"]
[691.652312, "o", "\u001b[?2004h> "]
[691.652331, "o", "follow = df[df['mode']=='follow']\r\n\u001b[?2004l\r"]
[691.652493, "o", "\u001b[?2004h> "]
[691.652617, "o", "dist = pd.to_numeric(follow['distance'], errors='coerce')\r\n\u001b[?2004l\r\u001b[?2004h> "]
[691.652741, "o", "err = pd.to_numeric(follow['distance_error'], errors='coerce')\r\n\u001b[?2004l\r"]
[691.652799, "o", "\u001b[?2004h> "]
[691.652891, "o", "print('Distance stats in follow mode:')\r\n\u001b[?2004l\r\u001b[?2004h> print('Mean distance:', dist.mean())\r\n\u001b[?2004l\r\u001b[?2004h> "]
[691.653002, "o", "print('Min distance:', dist.min())\r\n\u001b[?2004l\r\u001b[?2004h> "]
[691.653064, "o", "print('Max distance:', dist.max())\r\n"]
[691.653155, "o", "\u001b[?2004l\r"]
[691.653186, "o", "\u001b[?2004h> "]
[691.653217, "o", "print('Mean distance_error:', err.mean())\r\n\u001b[?2004l\r"]
[691.653515, "o", "\u001b[?2004h> "]
