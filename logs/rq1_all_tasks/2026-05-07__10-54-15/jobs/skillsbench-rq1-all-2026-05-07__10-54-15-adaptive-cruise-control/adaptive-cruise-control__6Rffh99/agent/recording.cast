[1518.887583, "o", "    if len(follow_df) > 0:\r\n\u001b[?2004l\r"]
[1518.887635, "o", "\u001b[?2004h> "]
[1518.887672, "o", "        dist_ss_err = best_mean if best_start > 0 else follow_df['dist_err_num'].abs().mean()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1518.8877, "o", "    else:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1518.887789, "o", "        dist_ss_err = 0\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[1518.88785, "o", "\u001b[?2004h> "]
[1518.887944, "o", "    dist_series = pd.to_numeric(df['distance'], errors='coerce').dropna()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1518.888073, "o", "    min_dist = dist_series.min() if len(dist_series) > 0 else None\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1518.888133, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1518.888197, "o", "    with open('acc_report.md', 'w') as f:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1518.888298, "o", "        f.write(\"# ACC Simulation Report\\n\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1518.88839, "o", "        f.write(\"## System Design\\n\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1518.888493, "o", "        f.write(\"### ACC Architecture\\n\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1518.88867, "o", "        f.write(\"The ACC system implements a hierarchical control architecture with three modes:\\n\\n\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[1518.888716, "o", "> "]
[1518.888855, "o", "        f.write(\"- **Cruise Mode**: No lead vehicle detected - maintains set speed (30 m/s)\\n\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[1518.8889, "o", "> "]
[1518.889075, "o", "        f.write(\"- **Follow Mode**: Lead vehicle present with TTC >= threshold - maintains safe following distance\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1518.889252, "o", "        f.write(\"- **Emergency Mode**: TTC < 3.0s - applies maximum deceleration\\n\\n\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[1518.889288, "o", "> "]
[1518.889367, "o", "        f.write(\"### Safety Features\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1518.889516, "o", "        f.write(f\"- Time Headway: {config['acc_settings']['time_headway']}s\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1518.889663, "o", "        f.write(f\"- Minimum Gap: {config['acc_settings']['min_distance']}m\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1518.889827, "o", "        f.write(f\"- Emergency TTC: {config['acc_settings']['emergency_ttc_threshold']}s\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1518.890038, "o", "        f.write(f\"- Accel Limits: [{config['vehicle']['max_deceleration']}, {config['vehicle']['max_acceleration']}] m/s2\\n\\n\")\r\n\u001b[?2004l\r"]
[1518.890098, "o", "\u001b[?2004h> "]
[1518.890154, "o", "        f.write(\"## PID Tuning Methodology\\n\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1518.890316, "o", "        f.write(\"Parameters tuned using iterative simulation to meet performance targets.\\n\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1518.890411, "o", "        f.write(\"### Final Gains\\n\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1518.89064, "o", "        f.write(f\"**Speed Controller:** kp={tuning['pid_speed']['kp']}, ki={tuning['pid_speed']['ki']}, kd={tuning['pid_speed']['kd']}\\n\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1518.89089, "o", "        f.write(f\"**Distance Controller:** kp={tuning['pid_distance']['kp']}, ki={tuning['pid_distance']['ki']}, kd={tuning['pid_distance']['kd']}\\n\\n\")\r\n\u001b[?2004l\r"]
[1518.890925, "o", "\u001b[?2004h> "]
[1518.891, "o", "        f.write(\"## Simulation Results\\n\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1518.891098, "o", "        f.write(\"### Performance Metrics\\n\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1518.891217, "o", "        f.write(\"| Metric | Target | Achieved | Status |\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1518.891338, "o", "        f.write(\"|--------|--------|----------|--------|\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1518.891495, "o", "        rt_status = 'PASS' if (rise_time and rise_time < 10) else 'FAIL'\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1518.891642, "o", "        f.write(f\"| Rise Time | <10s | {rise_time:.2f}s | {rt_status} |\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1518.891757, "o", "        os_status = 'PASS' if overshoot < 5 else 'FAIL'\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1518.891896, "o", "        f.write(f\"| Overshoot | <5% | {overshoot:.2f}% | {os_status} |\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1518.892012, "o", "        ss_status = 'PASS' if ss_error < 0.5 else 'FAIL'\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1518.892164, "o", "        f.write(f\"| Speed SS Error | <0.5m/s | {ss_error:.3f}m/s | {ss_status} |\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1518.892283, "o", "        ds_status = 'PASS' if dist_ss_err < 2 else 'FAIL'\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1518.892431, "o", "        f.write(f\"| Dist SS Error | <2m | {dist_ss_err:.2f}m | {ds_status} |\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1518.892569, "o", "        md_status = 'PASS' if (min_dist and min_dist > 5) else 'FAIL'\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1518.892709, "o", "        f.write(f\"| Min Distance | >5m | {min_dist:.2f}m | {md_status} |\\n\")\r\n\u001b[?2004l\r"]
[1518.89277, "o", "\u001b[?2004h> "]
[1518.892822, "o", "        f.write(\"\\n### Simulation Summary\\n\\n\")\r\n\u001b[?2004l\r"]
[1518.89288, "o", "\u001b[?2004h> "]
[1518.892943, "o", "        f.write(f\"- Duration: 150s, Timestep: 0.1s\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1518.893048, "o", "        f.write(f\"- Rows in output: {len(df)}\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1518.893159, "o", "        f.write(f\"- Max speed: {max_speed:.2f} m/s\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1518.893387, "o", "        f.write(f\"- Modes: cruise={len(df[df['mode']=='cruise'])}, follow={len(follow_df)}, emergency={len(df[df['mode']=='emergency'])}\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1518.893493, "o", "    print(\"Report saved to acc_report.md\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[1518.893566, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
[1518.893625, "o", "> if __name__ == '__main__':\r\n\u001b[?2004l\r"]
[1518.893663, "o", "\u001b[?2004h>     run_simulation()\r\n\u001b[?2004l\r"]
[1518.893728, "o", "\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
