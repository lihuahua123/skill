[629.869779, "o", "\u001b[?2004hroot@bfb65fae2dcc:~# "]
[656.25381, "i", "cat > acc_system.py << 'EOF'\n\"\"\"Adaptive Cruise Control System Implementation\"\"\"\n\nfrom pid_controller import PIDController\n\nclass AdaptiveCruiseControl:\n    \"\"\"ACC system with tuned cruise and follow control.\"\"\"\n    \n    def __init__(self, config):\n        self.mass = config['vehicle']['mass']\n        self.max_acceleration = config['vehicle']['max_acceleration']\n        self.max_deceleration = config['vehicle']['max_deceleration']\n        self.set_speed = config['acc_settings']['set_speed']\n        self.time_headway = config['acc_settings']['time_headway']\n        self.min_distance = config['acc_settings']['min_distance']\n        self.emergency_ttc_threshold = config['acc_settings']['emergency_ttc_threshold']\n        \n        pid_speed_cfg = config.get('pid_speed', {'kp': 0.5, 'ki': 0.05, 'kd': 0.1})\n        pid_dist_cfg = config.get('pid_distance', {'kp': 0.5, 'ki': 0.05, 'kd': 0.1})\n        \n        self.pid_speed = PIDController(pid_speed_cfg['kp'], pid_speed_cfg['ki'], pid_speed_cfg['kd'])\n        self.pid_distance = PIDController(pid_dist_cfg['kp'], pid_dist_cfg['ki'], pid_dist_cfg['kd'])\n        self.prev_mode = 'cruise'\n        self.mode = 'cruise'\n    \n    def safe_following_distance(self, ego_speed):\n        return ego_speed * self.time_headway + self.min_distance\n    \n    def time_to_collision(self, distance, ego_speed, lead_speed):\n        relative_speed = ego_speed - lead_speed\n        if relative_speed <= 0:\n            return None\n        return distance / relative_speed\n    \n    def determine_mode(self, lead_speed, distance):\n        if lead_speed is None or distance is None:\n            return 'cruise'\n        ttc = self.time_to_collision(distance, self.set_speed, lead_speed)\n        if ttc is not None and ttc < self.emergency_ttc_threshold:\n            return 'emergency'\n        return 'follow'\n    \n    def compute(self, ego_speed, lead_speed, distance, dt):\n        mode = self.determine_mode(lead_speed, distance)\n        \n        if mode != self.prev_mode:\n            self.pid_speed.reset()\n            self.pid_distance.reset()\n            self.prev_mode = mode\n        self.mode = mode\n        \n        if mode == 'cruise':\n            self.pid_distance.reset()\n            speed_error = self.set_speed - ego_speed\n            \n            # Proportional-only control for smoother response\n            p_term = self.pid_speed.kp * speed_error\n            i_term = self.pid_speed.ki * self.pid_speed.integral\n            d_term = self.pid_speed.kd * (speed_error - self.pid_speed.prev_error) / dt\n            \n            acceleration_cmd = p_term + i_term + d_term\n            \n            # Progressive damping as approaching target\n            if ego_speed >= self.set_speed - 5:\n                damping = 0.1  # Heavy damping near target\n                acceleration_cmd *= damping\n            elif ego_speed >= self.set_speed - 10:\n                damping = 0.3\n                acceleration_cmd *= damping\n            elif ego_speed > self.set_speed:\n                acceleration_cmd = min(acceleration_cmd, -0.5)\n            \n            distance_error = None\n            \n        elif mode == 'emergency':\n            self.pid_speed.reset()\n            self.pid_distance.reset()\n            acceleration_cmd = self.max_deceleration\n            distance_error = 0.0\n            \n        else:  # 'follow' mode\n            self.pid_speed.reset()\n            desired_distance = self.safe_following_distance(ego_speed)\n            distance_error = distance - desired_distance\n            \n            acceleration_cmd = self.pid_distance.compute(distance_error, dt)\n            \n            # Speed limiting\n            if ego_speed >= self.set_speed:\n                acceleration_cmd = min(acceleration_cmd, 0.0)\n            elif ego_speed > self.set_speed - 3:\n                acceleration_cmd = min(acceleration_cmd, 0.2)\n            \n            # Emergency braking if too close\n            if distance < self.min_distance + 5:\n                acceleration_cmd = min(acceleration_cmd, -4.0)\n        \n        acceleration_cmd = max(sel"]
[656.253875, "i", "f.max_deceleration, min(self.max_acceleration, acceleration_cmd))\n        return acceleration_cmd, mode, distance_error\n    \n    def reset(self):\n        self.pid_speed.reset()\n        self.pid_distance.reset()\n        self.prev_mode = 'cruise'\n        self.mode = 'cruise'\nEOF\n"]
[656.254141, "o", "cat > acc_system.py << 'EOF'\r\n\u001b[?2004l\r"]
[656.254289, "o", "\u001b[?2004h> "]
[656.254497, "o", "\"\"\"Adaptive Cruise Control System Implementation\"\"\"\r\n\u001b[?2004l\r"]
[656.254563, "o", "\u001b[?2004h> \r\n\u001b[?2004l\ra"]
[656.254707, "o", "\u001b[?2004h> "]
[656.254836, "o", "from pid_controller import PIDController\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r \u001b[?2004h> "]
[656.255002, "o", "class AdaptiveCruiseControl:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[656.255232, "o", "    \"\"\"ACC system with tuned cruise and follow control.\"\"\"\r\n\u001b[?2004l\r"]
[656.25527, "o", "\u001b[?2004h>     \r\n\u001b[?2004l\r"]
[656.255289, "o", "\u001b[?2004h> "]
[656.25546, "o", "    def __init__(self, config):\r\n\u001b[?2004l\r\u001b[?2004h"]
[656.255614, "o", "> "]
[656.255685, "o", "        self.mass = config['vehicle']['mass']\r\n\u001b[?2004l\r\u001b[?2004h> "]
[656.255842, "o", "        self.max_acceleration = config['vehicle']['max_acceleration']\r\n\u001b[?2004l\r\u001b[?2004h> "]
[656.255994, "o", "        self.max_deceleration = config['vehicle']['max_deceleration']\r\n\u001b[?2004l\r"]
[656.256043, "o", "\u001b[?2004h> "]
[656.256188, "o", "        self.set_speed = config['acc_settings']['set_speed']\r\n\u001b[?2004l\r\u001b[?2004h> "]
[656.256334, "o", "        self.time_headway = config['acc_settings']['time_headway']\r\n\u001b[?2004l\r\u001b[?2004h> "]
[656.256485, "o", "        self.min_distance = config['acc_settings']['min_distance']\r\n\u001b[?2004l\r\u001b[?2004h"]
[656.256638, "o", "> "]
[656.256687, "o", "        self.emergency_ttc_threshold = config['acc_settings']['emergency_ttc_threshold']\r\n\u001b[?2004l\r\u001b[?2004h> "]
[656.256795, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h> "]
[656.256901, "o", "        pid_speed_cfg = config.get('pid_speed', {'kp': 0.5, 'ki': 0.05, 'kd': 0.1})\r\n\u001b[?2004l\r"]
[656.256931, "o", "\u001b[?2004h> "]
[656.257094, "o", "        pid_dist_cfg = config.get('pid_distance', {'kp': 0.5, 'ki': 0.05, 'kd': 0.1})\r\n\u001b[?2004l\r"]
[656.25713, "o", "\u001b[?2004h> "]
[656.257164, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h> "]
[656.257362, "o", "        self.pid_speed = PIDController(pid_speed_cfg['kp'], pid_speed_cfg['ki'], pid_speed_cfg['kd'])\r\n\u001b[?2004l\r"]
[656.2574, "o", "\u001b[?2004h> "]
[656.257599, "o", "        self.pid_distance = PIDController(pid_dist_cfg['kp'], pid_dist_cfg['ki'], pid_dist_cfg['kd'])\r\n\u001b[?2004l\r"]
[656.257659, "o", "\u001b[?2004h> "]
[656.257698, "o", "        self.prev_mode = 'cruise'\r\n\u001b[?2004l\r"]
[656.257777, "o", "\u001b[?2004h> "]
[656.257853, "o", "        self.mode = 'cruise'\r\n\u001b[?2004l\r\u001b[?2004h> "]
[656.257924, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[656.258009, "o", "    def safe_following_distance(self, ego_speed):\r\n\u001b[?2004l\r\u001b[?2004h"]
[656.258089, "o", "> "]
[656.258147, "o", "        return ego_speed * self.time_headway + self.min_distance\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r"]
[656.258223, "o", "\u001b[?2004h> "]
[656.25832, "o", "    def time_to_collision(self, distance, ego_speed, lead_speed):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[656.258437, "o", "        relative_speed = ego_speed - lead_speed\r\n\u001b[?2004l\r\u001b[?2004h> "]
[656.258541, "o", "        if relative_speed <= 0:"]
[656.258648, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[656.258739, "o", "            return None\r\n\u001b[?2004l\r\u001b[?2004h> "]
[656.258782, "o", "        return distance / relative_speed\r\n\u001b[?2004l\r"]
[656.258819, "o", "\u001b[?2004h> "]
[656.258861, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[656.259011, "o", "    def determine_mode(self, lead_speed, distance):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[656.259111, "o", "        if lead_speed is None or distance is None:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[656.259153, "o", "            return 'cruise'\r\n\u001b[?2004l\r\u001b[?2004h> "]
[656.259264, "o", "        ttc = self.time_to_collision(distance, self.set_speed, lead_speed)\r\n\u001b[?2004l\r"]
[656.259341, "o", "\u001b[?2004h> "]
[656.259423, "o", "        if ttc is not None and ttc < self.emergency_ttc_threshold:\r\n\u001b[?2004l\r"]
[656.259553, "o", "\u001b[?2004h> "]
[656.259593, "o", "            return 'emergency'\r\n\u001b[?2004l\r\u001b[?2004h>         return 'follow'\r\n\u001b[?2004l\r"]
[656.259695, "o", "\u001b[?2004h>     \r\n\u001b[?2004l\r"]
[656.259774, "o", "\u001b[?2004h> "]
[656.259817, "o", "    def compute(self, ego_speed, lead_speed, distance, dt):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[656.259951, "o", "        mode = self.determine_mode(lead_speed, distance)\r\n\u001b[?2004l\r\u001b[?2004h>         \r\n\u001b[?2004l\r"]
[656.260002, "o", "\u001b[?2004h> "]
[656.260105, "o", "        if mode != self.prev_mode:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[656.260204, "o", "            self.pid_speed.reset()\r\n\u001b[?2004l\r"]
[656.26032, "o", "\u001b[?2004h>             self.pid_distance.reset()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[656.260377, "o", "            self.prev_mode = mode\r\n\u001b[?2004l\r\u001b[?2004h> "]
[656.260416, "o", "        self.mode = mode\r\n\u001b[?2004l\r"]
[656.260454, "o", "\u001b[?2004h>         \r\n\u001b[?2004l\r\u001b[?2004h"]
[656.260484, "o", "> "]
[656.260594, "o", "        if mode == 'cruise':\r\n\u001b[?2004l\r\u001b[?2004h> "]
[656.260654, "o", "            self.pid_distance.reset()\r\n\u001b[?2004l\r"]
[656.260713, "o", "\u001b[?2004h> "]
[656.260788, "o", "            speed_error = self.set_speed - ego_speed\r\n\u001b[?2004l\r"]
[656.260848, "o", "\u001b[?2004h>             \r\n\u001b[?2004l\r\u001b[?2004h"]
[656.260912, "o", "> "]
[656.260967, "o", "            # Proportional-only control for smoother response\r\n\u001b[?2004l\r\u001b[?2004h"]
[656.260992, "o", "> "]
[656.261085, "o", "            p_term = self.pid_speed.kp * speed_error\r\n\u001b[?2004l\r"]
[656.261118, "o", "\u001b[?2004h> "]
[656.261233, "o", "            i_term = self.pid_speed.ki * self.pid_speed.integral\r\n\u001b[?2004l\r\u001b[?2004h> "]
[656.261387, "o", "            d_term = self.pid_speed.kd * (speed_error - self.pid_speed.prev_error) / dt\r\n\u001b[?2004l\r"]
[656.261424, "o", "\u001b[?2004h>             \r\n\u001b[?2004l\r"]
[656.261499, "o", "\u001b[?2004h> "]
[656.261538, "o", "            acceleration_cmd = p_term + i_term + d_term\r\n\u001b[?2004l\r"]
[656.26161, "o", "\u001b[?2004h> "]
[656.261638, "o", "            \r\n\u001b[?2004l\r\u001b[?2004h> "]
[656.261719, "o", "            # Progressive damping as approaching target\r\n\u001b[?2004l\r"]
[656.261764, "o", "\u001b[?2004h> "]
[656.26184, "o", "            if ego_speed >= self.set_speed - 5:\r\n\u001b[?2004l\r"]
[656.261872, "o", "\u001b[?2004h> "]
[656.261956, "o", "                damping = 0.1  # Heavy damping near target\r\n\u001b[?2004l\r"]
[656.262009, "o", "\u001b[?2004h> "]
[656.262059, "o", "                acceleration_cmd *= damping\r\n\u001b[?2004l\r"]
[656.26212, "o", "\u001b[?2004h> "]
[656.262179, "o", "            elif ego_speed >= self.set_speed - 10:\r\n\u001b[?2004l\r"]
[656.262211, "o", "\u001b[?2004h> "]
[656.262269, "o", "                damping = 0.3\r\n\u001b[?2004l\r\u001b[?2004h> "]
[656.262368, "o", "                acceleration_cmd *= damping\r\n\u001b[?2004l\r"]
[656.262401, "o", "\u001b[?2004h> "]
[656.262465, "o", "            elif ego_speed > self.set_speed:\r\n\u001b[?2004l\r"]
[656.262522, "o", "\u001b[?2004h> "]
[656.262626, "o", "                acceleration_cmd = min(acceleration_cmd, -0.5)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[656.26268, "o", "            \r\n\u001b[?2004l\r"]
[656.262739, "o", "\u001b[?2004h> "]
[656.262789, "o", "            distance_error = None\r\n\u001b[?2004l\r\u001b[?2004h> "]
[656.262854, "o", "            \r\n\u001b[?2004l\r"]
[656.262906, "o", "\u001b[?2004h> "]
[656.262956, "o", "        elif mode == 'emergency':\r\n\u001b[?2004l\r\u001b[?2004h> "]
[656.263006, "o", "            self.pid_speed.reset()\r\n\u001b[?2004l\r"]
[656.263038, "o", "\u001b[?2004h> "]
[656.263093, "o", "            self.pid_distance.reset()\r\n\u001b[?2004l\r"]
[656.263124, "o", "\u001b[?2004h> "]
[656.263225, "o", "            acceleration_cmd = self.max_deceleration\r\n\u001b[?2004l\r"]
[656.263275, "o", "\u001b[?2004h> "]
[656.263314, "o", "            distance_error = 0.0\r\n\u001b[?2004l\r\u001b[?2004h"]
[656.263353, "o", ">             \r\n\u001b[?2004l\r"]
[656.263438, "o", "\u001b[?2004h> "]
[656.263529, "o", "        else:  # 'follow' mode\r\n\u001b[?2004l\r\u001b[?2004h> "]
[656.263562, "o", "            self.pid_speed.reset()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[656.263698, "o", "            desired_distance = self.safe_following_distance(ego_speed)\r\n\u001b[?2004l\r\u001b[?2004h"]
[656.263723, "o", "> "]
[656.263811, "o", "            distance_error = distance - desired_distance\r\n\u001b[?2004l\r"]
[656.26386, "o", "\u001b[?2004h> "]
[656.263893, "o", "            \r\n\u001b[?2004l\r\u001b[?2004h> "]
[656.264032, "o", "            acceleration_cmd = self.pid_distance.compute(distance_error, dt)\r\n\u001b[?2004l\r\u001b[?2004h"]
[656.264065, "o", ">             \r\n\u001b[?2004l\r"]
[656.264141, "o", "\u001b[?2004h> "]
[656.26417, "o", "            # Speed limiting\r\n\u001b[?2004l\r\u001b[?2004h> "]
[656.264245, "o", "            if ego_speed >= self.set_speed:\r\n\u001b[?2004l\r"]
[656.264312, "o", "\u001b[?2004h> "]
[656.264388, "o", "                acceleration_cmd = min(acceleration_cmd, 0.0)\r\n\u001b[?2004l\r"]
[656.264443, "o", "\u001b[?2004h> "]
[656.264497, "o", "            elif ego_speed > self.set_speed - 3:\r\n\u001b[?2004l\r"]
[656.264548, "o", "\u001b[?2004h> "]
[656.264633, "o", "                acceleration_cmd = min(acceleration_cmd, 0.2)\r\n\u001b[?2004l\r"]
[656.264685, "o", "\u001b[?2004h>             \r\n\u001b[?2004l\r"]
[656.264718, "o", "\u001b[?2004h> "]
[656.264768, "o", "            # Emergency braking if too close\r\n\u001b[?2004l\r"]
[656.264803, "o", "\u001b[?2004h> "]
[656.264891, "o", "            if distance < self.min_distance + 5:\r\n\u001b[?2004l\r"]
[656.264925, "o", "\u001b[?2004h> "]
[656.265027, "o", "                acceleration_cmd = min(acceleration_cmd, -4.0)\r\n\u001b[?2004l\r"]
[656.265065, "o", "\u001b[?2004h>         \r\n\u001b[?2004l\r"]
[656.265127, "o", "\u001b[?2004h> "]
[656.265253, "o", "        acceleration_cmd = max(self.max_deceleration, min(self.max_acceleration, acceleration_cmd))\r\n\u001b[?2004l\r"]
[656.265315, "o", "\u001b[?2004h> "]
[656.265366, "o", "        return acceleration_cmd, mode, distance_error\r\n\u001b[?2004l\r"]
[656.265428, "o", "\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[656.265491, "o", "    def reset(self):\r\n\u001b[?2004l\r"]
[656.265522, "o", "\u001b[?2004h> "]
[656.265604, "o", "        self.pid_speed.reset()\r\n\u001b[?2004l\r\u001b[?2004h"]
[656.265665, "o", "> "]
[656.265715, "o", "        self.pid_distance.reset()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[656.265764, "o", "        self.prev_mode = 'cruise'\r\n\u001b[?2004l\r"]
[656.2658, "o", "\u001b[?2004h> "]
[656.265863, "o", "        self.mode = 'cruise'\r\n\u001b[?2004l\r\u001b[?2004h> "]
[656.265912, "o", "EOF\r\n\u001b[?2004l\r"]
[656.266899, "o", "\u001b[?2004hroot@bfb65fae2dcc:~# "]
[656.758003, "i", "cat > tuning_results.yaml << 'EOF'\npid_speed:\n  kp: 1.5\n  ki: 0.3\n  kd: 0.5\npid_distance:\n  kp: 0.3\n  ki: 0.02\n  kd: 0.05\nEOF\n"]
[656.758318, "o", "cat > tuning_results.yaml << 'EOF'\r\n\u001b[?2004l\r"]
[656.758416, "o", "\u001b[?2004h> "]
[656.758565, "o", "pid_speed:\r\n\u001b[?2004l\r\u001b[?2004h>   kp: 1.5\r\n\u001b[?2004l\r\u001b[?2004h>   ki: 0.3\r\n\u001b[?2004l\r\u001b[?2004h>   kd: 0.5\r\n\u001b[?2004l\r\u001b[?2004h"]
[656.758739, "o", "> pid_distance:\r\n\u001b[?2004l\r\u001b[?2004h>   kp: 0.3"]
[656.758794, "o", "\r\n\u001b[?2004l\r\u001b[?2004h>   ki: 0.02\r\n\u001b[?2004l\r\u001b[?2004h>   kd: 0.05\r\n\u001b[?2004l\r"]
[656.75892, "o", "\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
[656.760174, "o", "\u001b[?2004hroot@bfb65fae2dcc:~# "]
[657.055652, "i", "python3 simulation.py\n"]
[657.055919, "o", "python3 simulation.py\r\n\u001b[?2004l\r"]
[657.497312, "o", "Speed PID: {'kp': 1.5, 'ki': 0.3, 'kd': 0.5}\r\nDistance PID: {'kp': 0.3, 'ki': 0.02, 'kd': 0.05}\r\n"]
[657.561615, "o", "Saved 1501 rows to simulation_results.csv\r\n"]
[657.564246, "o", "Report saved to acc_report.md\r\n"]
[657.611404, "o", "\u001b[?2004hroot@bfb65fae2dcc:~# "]
[669.869693, "i", "cat acc_report.md\n"]
[669.869852, "o", "cat acc_report.md\r\n\u001b[?2004l\r"]
[669.870709, "o", "# ACC Simulation Report\r\n\r\n## System Design\r\n\r\n### ACC Architecture\r\n\r\nThe ACC system implements a hierarchical control architecture with three modes:\r\n\r\n- **Cruise Mode**: No lead vehicle detected - maintains set speed (30 m/s)\r\n- **Follow Mode**: Lead vehicle present with TTC >= threshold - maintains safe following distance\r\n- **Emergency Mode**: TTC < 3.0s - applies maximum deceleration\r\n\r\n### Safety Features\r\n- Time Headway: 1.5s\r\n- Minimum Gap: 10.0m\r\n- Emergency TTC: 3.0s\r\n- Accel Limits: [-8.0, 3.0] m/s2\r\n\r\n## PID Tuning Methodology\r\n\r\nParameters tuned using iterative simulation to meet performance targets.\r\n\r\n### Final Gains\r\n\r\n**Speed Controller:** kp=1.5, ki=0.3, kd=0.5\r\n\r\n**Distance Controller:** kp=0.3, ki=0.02, kd=0.05\r\n\r\n## Simulation Results\r\n\r\n### Performance Metrics\r\n\r\n| Metric | Target | Achieved | Status |\r\n|--------|--------|----------|--------|\r\n| Rise Time | <10s | 9.10s | PASS |\r\n| Overshoot | <5% | 0.01% | PASS |\r\n| Speed SS Error | <0.5m/s | 0.000m/s | PASS |\r\n| Dist SS Error | <2m | 18.31m | FAIL |\r\n| Min Distance | >5m | 33.60m | PASS |\r\n\r\n### Simulation Summary\r\n\r\n- Duration: 150s, Timestep: 0.1s\r\n- Rows in output: 1501\r\n- Max speed: 30.00 m/s\r\n- Modes: cruise=501, follow=959, emergency=41\r\n"]
[669.870919, "o", "\u001b[?2004hroot@bfb65fae2dcc:~# "]
[670.169669, "i", "grep -E '^[0-9]+\\.?[0-9]*,3[0-9]' simulation_results.csv | head -3\n"]
[670.169897, "o", "grep -E '^[0-9]+\\.?[0-9]*,3[0-9]' simulation_results.csv | head -3\r\n\u001b[?2004l\r"]
[670.17153, "o", "100.7,30.004377548794547,0.2,follow,49.65343367680818,104.63,\r\n100.8,30.004377548794547,0.0,follow,43.593433676808175,98.6,43.73712826084656\r\n100.9,30.004377548794547,0.0,follow,41.083433676808184,96.09,\r\n"]
[670.171764, "o", "\u001b[?2004hroot@bfb65fae2dcc:~# "]
[670.473089, "i", "grep -E '^[0-9]+\\.?[0-9]*,3[12]' simulation_results.csv | head -3\n"]
[670.473323, "o", "grep -E '^[0-9]+\\.?[0-9]*,3[12]' simulation_results.csv | head -3\r\n\u001b[?2004l\r"]
