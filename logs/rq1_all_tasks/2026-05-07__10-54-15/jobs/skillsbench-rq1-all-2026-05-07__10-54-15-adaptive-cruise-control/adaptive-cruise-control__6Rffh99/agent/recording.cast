[292.204441, "o", "> "]
[292.204501, "o", "                self.pid_distance.integral = -self.integral_limit\r\n\u001b[?2004l\r"]
[292.20458, "o", "\u001b[?2004h> "]
[292.204654, "o", "            \r\n\u001b[?2004l\r\u001b[?2004h> "]
[292.204715, "o", "            acceleration_cmd = self.pid_distance.compute(distance_error, dt)\r\n\u001b[?2004l\r"]
[292.204744, "o", "\u001b[?2004h> "]
[292.20483, "o", "            \r\n\u001b[?2004l\r"]
[292.204868, "o", "\u001b[?2004h> "]
[292.204947, "o", "            # Limit speed to set_speed in follow mode\r\n\u001b[?2004l\r\u001b[?2004h> "]
[292.205024, "o", "            if ego_speed > self.set_speed:\r\n\u001b[?2004l\r"]
[292.205062, "o", "\u001b[?2004h> "]
[292.205149, "o", "                speed_correction = -2.0 * (ego_speed - self.set_speed)\r\n\u001b[?2004l\r\u001b[?2004h"]
[292.205217, "o", "> "]
[292.2053, "o", "                acceleration_cmd = min(acceleration_cmd, speed_correction)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[292.205378, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h> "]
[292.205442, "o", "        # Clamp final output\r\n\u001b[?2004l\r"]
[292.205483, "o", "\u001b[?2004h> "]
[292.205608, "o", "        acceleration_cmd = max(self.max_deceleration, min(self.max_acceleration, acceleration_cmd))\r\n\u001b[?2004l\r\u001b[?2004h> "]
[292.205671, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h> "]
[292.205761, "o", "        return acceleration_cmd, mode, distance_error\r\n\u001b[?2004l\r\u001b[?2004h"]
[292.20582, "o", ">     \r\n\u001b[?2004l\r\u001b[?2004h"]
[292.205876, "o", ">     def reset(self):\r\n\u001b[?2004l\r"]
[292.205958, "o", "\u001b[?2004h> "]
[292.205996, "o", "        self.pid_speed.reset()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[292.206072, "o", "        self.pid_distance.reset()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[292.206103, "o", "        self.prev_mode = 'cruise'\r\n\u001b[?2004l\r"]
[292.206188, "o", "\u001b[?2004h> "]
[292.206263, "o", "        self.mode = 'cruise'\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
[292.207247, "o", "\u001b[?2004hroot@bfb65fae2dcc:~# "]
