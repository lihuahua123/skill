[928.099349, "o", "drwx------ 1 root root  4096 May  7 03:10 \u001b[0m\u001b[01;34m.\u001b[0m\r\ndrwxr-xr-x 1 root root  4096 May  7 03:09 \u001b[01;34m..\u001b[0m\r\ndrwxr-xr-x 3 root root  4096 May  5 04:58 \u001b[01;34m.agents\u001b[0m\r\n-rw-r--r-- 1 root root  3106 Apr 22  2024 .bashrc\r\ndrwxr-xr-x 1 root root  4096 May  5 04:58 \u001b[01;34m.cache\u001b[0m\r\ndrwxr-xr-x 3 root root  4096 May  5 04:58 \u001b[01;34m.claude\u001b[0m\r\ndrwxr-xr-x 3 root root  4096 May  5 04:58 \u001b[01;34m.codex\u001b[0m\r\ndrwxr-xr-x 3 root root  4096 May  7 02:54 \u001b[01;34m.config\u001b[0m\r\ndrwxr-xr-x 3 root root  4096 May  5 04:58 \u001b[01;34m.factory\u001b[0m\r\ndrwxr-xr-x 3 root root  4096 May  5 04:58 \u001b[01;34m.gemini\u001b[0m\r\ndrwxr-xr-x 3 root root  4096 May  5 04:58 \u001b[01;34m.goose\u001b[0m\r\ndrwxr-xr-x 3 root root  4096 May  5 04:58 \u001b[01;34m.opencode\u001b[0m\r\n-rw-r--r-- 1 root root   161 Apr 22  2024 .profile\r\ndrwxr-xr-x 2 root root  4096 May  7 03:08 \u001b[01;34m__pycache__\u001b[0m\r\n"]
