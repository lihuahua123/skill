[617.147025, "o", "        ego_speed = max(0, ego_speed)  # No negative speed\r\n\u001b[?2004l\r"]
[617.147075, "o", "\u001b[?2004h> "]
[617.147241, "o", "        ego_speed = min(50, ego_speed)  # Cap reasonable max\r\n\u001b[?2004l\r\u001b[?2004h"]
[617.14729, "o", "> "]
[617.147337, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h> "]
[617.147403, "o", "        # Calculate TTC\r\n\u001b[?2004l\r|\u001b[?2004h"]
[617.147448, "o", "> "]
[617.147655, "o", "        ttc = calculate_ttc(distance, ego_speed, lead_speed)\r\n\u001b[?2004l\r5"]
[617.147682, "o", "\u001b[?2004h> "]
[617.147749, "o", "        \r\n\u001b[?2004l\rF\u001b[?2004h> "]
[617.147809, "o", "        result = {\r\n\u001b[?2004l\r"]
[617.147848, "o", "\u001b[?2004h> "]
[617.147931, "o", "            'time': time,\r\n\u001b[?2004l\r"]
[617.147971, "o", "\u001b[?2004h> "]
[617.148133, "o", "            'ego_speed': ego_speed,\r\n\u001b[?2004l\r"]
[617.148187, "o", "\u001b[?2004h> "]
[617.148273, "o", "            'acceleration_cmd': acc_cmd,\r\n\u001b[?2004l\r"]
[617.148323, "o", "\u001b[?2004h> "]
[617.148416, "o", "            'mode': mode,\r\n\u001b[?2004l\r"]
[617.148476, "o", "\u001b[?2004h> "]
[617.148759, "o", "            'distance_error': dist_error if dist_error is not None else '',\r\n\u001b[?2004l\r"]
[617.148795, "o", "\u001b[?2004h> "]
[617.149052, "o", "            'distance': distance if distance is not None else '',\r\n\u001b[?2004l\r\u001b[?2004h> "]
[617.149285, "o", "            'ttc': ttc if ttc is not None else ''\r\n\u001b[?2004l\r"]
[617.149344, "o", "\u001b[?2004h> "]
[617.149395, "o", "        }\r\n\u001b[?2004l\rs\u001b[?2004h> "]
[617.149469, "o", "        results.append(result)\r\n\u001b[?2004l\r"]
[617.149569, "o", "\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h"]
[617.149649, "o", "> "]
[617.149705, "o", "    results_df = pd.DataFrame(results)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[617.149912, "o", "    results_df.to_csv('simulation_results.csv', index=False)\r\n\u001b[?2004l\r\u001b[?2004h"]
[617.149967, "o", "> "]
[617.150124, "o", "    print(f\"Saved {len(results)} rows to simulation_results.csv\")\r\n\u001b[?2004l\r"]
[617.150163, "o", "\u001b[?2004h> "]
[617.150234, "o", "    generate_report(results_df, config, tuning)\r\n\u001b[?2004l\r\u001b[?2004h"]
[617.150273, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
[617.150317, "o", "> "]
[617.150371, "o", "def generate_report(df, config, tuning):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[617.150455, "o", "    set_speed = config['acc_settings']['set_speed']\r\n\u001b[?2004l\r\u001b[?2004h"]
[617.150517, "o", "> "]
[617.150592, "o", "    speeds = pd.to_numeric(df['ego_speed'], errors='coerce').fillna(0)\r\n\u001b[?2004l\r\u001b[?2004h"]
[617.150631, "o", ">     \r\n\u001b[?2004l\r\u001b[?2004h"]
[617.150703, "o", "> "]
[617.150743, "o", "    # Rise time: time to reach 90% of set_speed\r\n\u001b[?2004l\r\u001b[?2004h"]
[617.150828, "o", "> "]
[617.150883, "o", "    rise_end = None\r\n\u001b[?2004l\r\u001b[?2004h>     for i, s in enumerate(speeds):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[617.150947, "o", "        if s >= 0.9 * set_speed:\r\n\u001b[?2004l\r\u001b[?2004h"]
[617.150986, "o", "> "]
[617.151024, "o", "            rise_end = i\r\n\u001b[?2004l\r\u001b[?2004h"]
[617.151062, "o", "> "]
[617.151104, "o", "            break\r\n\u001b[?2004l\r\u001b[?2004h> "]
[617.151224, "o", "    rise_time = (rise_end * 0.1) if rise_end else None\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r"]
[617.151297, "o", "\u001b[?2004h> "]
[617.151353, "o", "    max_speed = speeds.max()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[617.151419, "o", "    overshoot = max(0, ((max_speed - set_speed) / set_speed) * 100)\r\n\u001b[?2004l\r\u001b[?2004h"]
[617.151447, "o", ">     \r\n\u001b[?2004l\r"]
[617.151524, "o", "\u001b[?2004h> "]
[617.151625, "o", "    # SS error: use last 10% where in cruise mode (t > 147)\r\n\u001b[?2004l\r\u001b[?2004h"]
[617.151683, "o", "> "]
[617.151743, "o", "    cruise_df = df[(df['mode'] == 'cruise') & (df['time'] >= 147)]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[617.151805, "o", "    if len(cruise_df) > 0:\r\n\u001b[?2004l\r\u001b[?2004h"]
[617.151869, "o", "> "]
[617.151929, "o", "        ss_error = abs(cruise_df['ego_speed'].mean() - set_speed)\r\n\u001b[?2004l\r"]
[617.151991, "o", "\u001b[?2004h> "]
[617.152028, "o", "    else:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[617.152095, "o", "        ss_error = abs(speeds.iloc[-150:].mean() - set_speed)\r\n\u001b[?2004l\r"]
[617.152129, "o", "\u001b[?2004h>     \r\n"]
[617.1522, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[617.152262, "o", "    # Distance metrics in follow mode\r\n\u001b[?2004l\r\u001b[?2004h> "]
[617.152323, "o", "    follow_df = df[df['mode'] == 'follow']\r\n\u001b[?2004l\r\u001b[?2004h"]
[617.152389, "o", "> "]
[617.152491, "o", "    dist_errs = pd.to_numeric(follow_df['distance_error'], errors='coerce').dropna()\r\n\u001b[?2004l\r\u001b[?2004h"]
[617.152563, "o", "> "]
[617.152615, "o", "    dist_ss_err = dist_errs.abs().mean() if len(dist_errs) > 0 else 0\r\n\u001b[?2004l\r\u001b[?2004h"]
[617.152678, "o", "> "]
[617.152748, "o", "    dists = pd.to_numeric(follow_df['distance'], errors='coerce').dropna()\r\n\u001b[?2004l\r\u001b[?2004h"]
[617.152811, "o", "> "]
[617.152859, "o", "    min_dist = dists.min() if len(dists) > 0 else None\r\n\u001b[?2004l\r"]
[617.152926, "o", "\u001b[?2004h>     "]
[617.152958, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[617.15303, "o", "    with open('acc_report.md', 'w') as f:\r\n\u001b[?2004l\r\u001b[?2004h"]
[617.153105, "o", "> "]
[617.153161, "o", "        f.write(\"# ACC Simulation Report\\n\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[617.15322, "o", "        f.write(\"## System Design\\n\\n\")\r\n\u001b[?2004l\r"]
[617.153259, "o", "\u001b[?2004h> "]
[617.153339, "o", "        f.write(\"### ACC Architecture\\n\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[617.153506, "o", "        f.write(\"The ACC system implements a hierarchical control architecture with three modes:\\n\\n\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[617.15358, "o", "> "]
[617.153672, "o", "        f.write(\"- **Cruise Mode**: No lead vehicle detected - maintains set speed (30 m/s)\\n\")\r\n\u001b[?2004l\r"]
[617.153738, "o", "\u001b[?2004h> "]
[617.153876, "o", "        f.write(\"- **Follow Mode**: Lead vehicle present with TTC >= threshold - maintains safe following distance\\n\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[617.153941, "o", "> "]
[617.154019, "o", "        f.write(\"- **Emergency Mode**: TTC < 3.0s - applies maximum deceleration\\n\\n\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[617.154059, "o", "> "]
[617.154099, "o", "        f.write(\"### Safety Features\\n\")\r\n\u001b[?2004l\r"]
[617.154139, "o", "\u001b[?2004h> "]
[617.154256, "o", "        f.write(f\"- Time Headway: {config['acc_settings']['time_headway']}s\\n\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[617.154321, "o", "> "]
[617.154393, "o", "        f.write(f\"- Minimum Gap: {config['acc_settings']['min_distance']}m\\n\")\r\n\u001b[?2004l\r"]
[617.154463, "o", "\u001b[?2004h> "]
[617.154562, "o", "        f.write(f\"- Emergency TTC: {config['acc_settings']['emergency_ttc_threshold']}s\\n\")\r\n\u001b[?2004l\r"]
[617.154634, "o", "\u001b[?2004h> "]
[617.154776, "o", "        f.write(f\"- Accel Limits: [{config['vehicle']['max_deceleration']}, {config['vehicle']['max_acceleration']}] m/s2\\n\\n\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[617.15485, "o", "> "]
[617.154902, "o", "        f.write(\"## PID Tuning Methodology\\n\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[617.155018, "o", "        f.write(\"Parameters tuned using iterative simulation to meet performance targets.\\n\\n\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[617.155092, "o", "> "]
[617.155127, "o", "        f.write(\"### Final Gains\\n\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[617.155315, "o", "        f.write(f\"**Speed Controller:** kp={tuning['pid_speed']['kp']}, ki={tuning['pid_speed']['ki']}, kd={tuning['pid_speed']['kd']}\\n\\n\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[617.155384, "o", "> "]
[617.15558, "o", "        f.write(f\"**Distance Controller:** kp={tuning['pid_distance']['kp']}, ki={tuning['pid_distance']['ki']}, kd={tuning['pid_distance']['kd']}\\n\\n\")\r\n\u001b[?2004l\r"]
[617.155658, "o", "\u001b[?2004h> "]
[617.155712, "o", "        f.write(\"## Simulation Results\\n\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[617.155769, "o", "        f.write(\"### Performance Metrics\\n\\n\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[617.155842, "o", "> "]
[617.155888, "o", "        f.write(\"| Metric | Target | Achieved | Status |\\n\")\r\n\u001b[?2004l\r"]
[617.155941, "o", "\u001b[?2004h> "]
[617.156017, "o", "        f.write(\"|--------|--------|----------|--------|\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[617.156136, "o", "        rt_status = 'PASS' if (rise_time and rise_time < 10) else 'FAIL'\r\n\u001b[?2004l\r\u001b[?2004h> "]
[617.156272, "o", "        f.write(f\"| Rise Time | <10s | {rise_time:.2f}s | {rt_status} |\\n\")\r\n\u001b[?2004l\r"]
[617.156331, "o", "\u001b[?2004h> "]
[617.156388, "o", "        os_status = 'PASS' if overshoot < 5 else 'FAIL'\r\n\u001b[?2004l\r\u001b[?2004h> "]
[617.156523, "o", "        f.write(f\"| Overshoot | <5% | {overshoot:.2f}% | {os_status} |\\n\")\r\n\u001b[?2004l\r"]
[617.156569, "o", "\u001b[?2004h> "]
[617.156642, "o", "        ss_status = 'PASS' if ss_error < 0.5 else 'FAIL'\r\n\u001b[?2004l\r\u001b[?2004h"]
[617.156681, "o", "> "]
[617.156786, "o", "        f.write(f\"| Speed SS Error | <0.5m/s | {ss_error:.3f}m/s | {ss_status} |\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[617.15689, "o", "        ds_status = 'PASS' if dist_ss_err < 2 else 'FAIL'\r\n\u001b[?2004l\r"]
[617.15695, "o", "\u001b[?2004h> "]
[617.157041, "o", "        f.write(f\"| Dist SS Error | <2m | {dist_ss_err:.2f}m | {ds_status} |\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[617.157156, "o", "        md_status = 'PASS' if (min_dist and min_dist > 5) else 'FAIL'\r\n\u001b[?2004l\r\u001b[?2004h"]
[617.157219, "o", "> "]
[617.157289, "o", "        f.write(f\"| Min Distance | >5m | {min_dist:.2f}m | {md_status} |\\n\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[617.15736, "o", "> "]
[617.15743, "o", "        f.write(\"\\n### Simulation Summary\\n\\n\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[617.157495, "o", "> "]
[617.157535, "o", "        f.write(f\"- Duration: 150s, Timestep: 0.1s\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[617.157622, "o", "        f.write(f\"- Rows in output: {len(df)}\\n\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[617.157676, "o", "> "]
[617.157736, "o", "        f.write(f\"- Max speed: {max_speed:.2f} m/s\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[617.157961, "o", "        f.write(f\"- Modes: cruise={len(df[df['mode']=='cruise'])}, follow={len(follow_df)}, emergency={len(df[df['mode']=='emergency'])}\\n\")\r\n\u001b[?2004l\r"]
[617.158023, "o", "\u001b[?2004h> "]
[617.15807, "o", "    print(\"Report saved to acc_report.md\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[617.158128, "o", "\u001b[?2004h> "]
[617.158184, "o", "if __name__ == '__main__':\r\n\u001b[?2004l\r\u001b[?2004h> "]
[617.158242, "o", "    run_simulation()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[617.158307, "o", "SIMEOF\r\n\u001b[?2004l\r"]
[617.159275, "o", "\u001b[?2004hroot@bfb65fae2dcc:~# "]
[617.640234, "i", "cat > acc_system.py << 'EOF'\n\"\"\"Adaptive Cruise Control System Implementation\"\"\"\n\nfrom pid_controller import PIDController\n\nclass AdaptiveCruiseControl:\n    \"\"\"ACC system with proper cruise and follow control.\"\"\"\n    \n    def __init__(self, config):\n        self.mass = config['vehicle']['mass']\n        self.max_acceleration = config['vehicle']['max_acceleration']\n        self.max_deceleration = config['vehicle']['max_deceleration']\n        self.set_speed = config['acc_settings']['set_speed']\n        self.time_headway = config['acc_settings']['time_headway']\n        self.min_distance = config['acc_settings']['min_distance']\n        self.emergency_ttc_threshold = config['acc_settings']['emergency_ttc_threshold']\n        \n        pid_speed_cfg = config.get('pid_speed', {'kp': 0.5, 'ki': 0.05, 'kd': 0.1})\n        pid_dist_cfg = config.get('pid_distance', {'kp': 0.5, 'ki': 0.05, 'kd': 0.1})\n        \n        self.pid_speed = PIDController(pid_speed_cfg['kp'], pid_speed_cfg['ki'], pid_speed_cfg['kd'])\n        self.pid_distance = PIDController(pid_dist_cfg['kp'], pid_dist_cfg['ki'], pid_dist_cfg['kd'])\n        self.prev_mode = 'cruise'\n        self.mode = 'cruise'\n    \n    def safe_following_distance(self, ego_speed):\n        return ego_speed * self.time_headway + self.min_distance\n    \n    def time_to_collision(self, distance, ego_speed, lead_speed):\n        relative_speed = ego_speed - lead_speed\n        if relative_speed <= 0:\n            return None\n        return distance / relative_speed\n    \n    def determine_mode(self, lead_speed, distance):\n        if lead_speed is None or distance is None:\n            return 'cruise'\n        ttc = self.time_to_collision(distance, self.set_speed, lead_speed)\n        if ttc is not None and ttc < self.emergency_ttc_threshold:\n            return 'emergency'\n        return 'follow'\n    \n    def compute(self, ego_speed, lead_speed, distance, dt):\n        mode = self.determine_mode(lead_speed, distance)\n        \n        if mode != self.prev_mode:\n            self.pid_speed.reset()\n            self.pid_distance.reset()\n            self.prev_mode = mode\n        self.mode = mode\n        \n        if mode == 'cruise':\n            self.pid_distance.reset()\n            speed_error = self.set_speed - ego_speed\n            acceleration_cmd = self.pid_speed.compute(speed_error, dt)\n            \n            # Dampen when near target\n            if abs(speed_error) < 3.0:\n                acceleration_cmd *= 0.3\n            elif ego_speed > self.set_speed:\n                acceleration_cmd = min(acceleration_cmd, -1.0)\n            \n            distance_error = None\n            \n        elif mode == 'emergency':\n            self.pid_speed.reset()\n            self.pid_distance.reset()\n            acceleration_cmd = self.max_deceleration\n            distance_error = 0.0\n            \n        else:  # 'follow' mode\n            self.pid_speed.reset()\n            desired_distance = self.safe_following_distance(ego_speed)\n            # distance_error = actual - desired (positive = too far = accelerate)\n            distance_error = distance - desired_distance\n            \n            acceleration_cmd = self.pid_distance.compute(distance_error, dt)\n            \n            # Speed limiting in follow mode\n            if ego_speed >= self.set_speed:\n                acceleration_cmd = min(acceleration_cmd, 0.0)\n            elif ego_speed > self.set_speed - 5:\n                acceleration_cmd = min(acceleration_cmd, 0.5)\n            \n            # Emergency braking if too close\n            if distance < self.min_distance + 5:\n                acceleration_cmd = min(acceleration_cmd, -4.0)\n        \n        acceleration_cmd = max(self.max_deceleration, min(self.max_acceleration, acceleration_cmd))\n        return acceleration_cmd, mode, distance_error\n    \n    def reset(self):\n        self.pid_speed.reset()\n        self.pid_distance.reset()\n        self.prev_mode = 'cruise'\n        self.mode = 'cruise'\nEOF\n"]
[617.640525, "o", "cat > acc_system.py << 'EOF'\r\n\u001b[?2004l\r"]
[617.640631, "o", "\u001b[?2004h> "]
[617.64067, "o", "\"\"\"Adaptive Cruise Control System Implementation\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[617.64075, "o", "\u001b[?2004h> "]
[617.64082, "o", "from pid_controller import PIDController\r\n\u001b[?2004l\r"]
[617.640934, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> class AdaptiveCruiseControl:\r\n\u001b[?2004l\r\u001b[?2004h"]
[617.640971, "o", "> "]
[617.641125, "o", "    \"\"\"ACC system with proper cruise and follow control.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h"]
[617.641275, "o", "> "]
[617.641361, "o", "    def __init__(self, config):\r\n\u001b[?2004l\r\u001b[?2004h>         self.mass = config['vehicle']['mass']\r\n\u001b[?2004l\r"]
[617.641396, "o", "\u001b[?2004h> "]
[617.641581, "o", "        self.max_acceleration = config['vehicle']['max_acceleration']\r\n\u001b[?2004l\r\u001b[?2004h> "]
[617.641719, "o", "        self.max_deceleration = config['vehicle']['max_deceleration']\r\n\u001b[?2004l\r\u001b[?2004h> "]
[617.641896, "o", "        self.set_speed = config['acc_settings']['set_speed']\r\n\u001b[?2004l\r\u001b[?2004h> "]
[617.642042, "o", "        self.time_headway = config['acc_settings']['time_headway']\r\n\u001b[?2004l\r\u001b[?2004h> "]
[617.642204, "o", "        self.min_distance = config['acc_settings']['min_distance']\r\n\u001b[?2004l\r\u001b[?2004h> "]
[617.642384, "o", "        self.emergency_ttc_threshold = config['acc_settings']['emergency_ttc_threshold']\r\n\u001b[?2004l\r\u001b[?2004h> "]
[617.642427, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h> "]
[617.642624, "o", "        pid_speed_cfg = config.get('pid_speed', {'kp': 0.5, 'ki': 0.05, 'kd': 0.1})\r\n\u001b[?2004l\r\u001b[?2004h> "]
[617.642752, "o", "        pid_dist_cfg = config.get('pid_distance', {'kp': 0.5, 'ki': 0.05, 'kd': 0.1})\r\n\u001b[?2004l\r\u001b[?2004h"]
[617.642795, "o", ">         \r\n\u001b[?2004l\r\u001b[?2004h"]
[617.642872, "o", "> "]
[617.642994, "o", "        self.pid_speed = PIDController(pid_speed_cfg['kp'], pid_speed_cfg['ki'], pid_speed_cfg['kd'])\r\n\u001b[?2004l\r\u001b[?2004h> "]
[617.643166, "o", "        self.pid_distance = PIDController(pid_dist_cfg['kp'], pid_dist_cfg['ki'], pid_dist_cfg['kd'])\r\n\u001b[?2004l\r"]
[617.643218, "o", "\u001b[?2004h> "]
[617.643268, "o", "        self.prev_mode = 'cruise'\r\n\u001b[?2004l\r\u001b[?2004h"]
[617.643329, "o", "> "]
[617.643396, "o", "        self.mode = 'cruise'\r\n\u001b[?2004l\r\u001b[?2004h> "]
[617.64346, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[617.643579, "o", "    def safe_following_distance(self, ego_speed):\r\n\u001b[?2004l\r\u001b[?2004h"]
[617.643621, "o", "> "]
[617.643761, "o", "        return ego_speed * self.time_headway + self.min_distance\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[617.643833, "o", "    def time_to_collision(self, distance, ego_speed, lead_speed):\r\n\u001b[?2004l\r"]
[617.643879, "o", "\u001b[?2004h> "]
[617.64391, "o", "        relative_speed = ego_speed - lead_speed\r\n\u001b[?2004l\r\u001b[?2004h> "]
[617.643992, "o", "        if relative_speed <= 0:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[617.64405, "o", "            return None\r\n\u001b[?2004l\r\u001b[?2004h> "]
[617.644112, "o", "        return distance / relative_speed\r\n\u001b[?2004l\r\u001b[?2004h> "]
[617.644148, "o", "    \r\n\u001b[?2004l\r"]
[617.644228, "o", "\u001b[?2004h> "]
[617.644287, "o", "    def determine_mode(self, lead_speed, distance):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[617.644355, "o", "        if lead_speed is None or distance is None:\r\n\u001b[?2004l\r\u001b[?2004h"]
[617.644408, "o", "> "]
[617.644452, "o", "            return 'cruise'\r\n\u001b[?2004l\r\u001b[?2004h> "]
[617.644572, "o", "        ttc = self.time_to_collision(distance, self.set_speed, lead_speed)\r\n\u001b[?2004l\r\u001b[?2004h"]
[617.644644, "o", "> "]
[617.644708, "o", "        if ttc is not None and ttc < self.emergency_ttc_threshold:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[617.644782, "o", "            return 'emergency'\r\n\u001b[?2004l\r\u001b[?2004h"]
[617.644843, "o", "> "]
[617.644907, "o", "        return 'follow'\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[617.644993, "o", "    def compute(self, ego_speed, lead_speed, distance, dt):\r\n\u001b[?2004l\r\u001b[?2004h"]
[617.645052, "o", "> "]
[617.64511, "o", "        mode = self.determine_mode(lead_speed, distance)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[617.645145, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h> "]
[617.64522, "o", "        if mode != self.prev_mode:\r\n\u001b[?2004l\r\u001b[?2004h"]
[617.645286, "o", "> "]
[617.645342, "o", "            self.pid_speed.reset()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[617.645394, "o", "            self.pid_distance.reset()\r\n\u001b[?2004l\r\u001b[?2004h"]
[617.645459, "o", "> "]
[617.645518, "o", "            self.prev_mode = mode\r\n\u001b[?2004l\r\u001b[?2004h> "]
[617.645589, "o", "        self.mode = mode\r\n\u001b[?2004l\r\u001b[?2004h>         \r\n\u001b[?2004l\r"]
[617.645669, "o", "\u001b[?2004h> "]
[617.645723, "o", "        if mode == 'cruise':\r\n\u001b[?2004l\r\u001b[?2004h> "]
[617.645759, "o", "            self.pid_distance.reset()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[617.645852, "o", "            speed_error = self.set_speed - ego_speed\r\n\u001b[?2004l\r\u001b[?2004h"]
[617.645886, "o", "> "]
[617.645988, "o", "            acceleration_cmd = self.pid_speed.compute(speed_error, dt)\r\n\u001b[?2004l\r\u001b[?2004h"]
[617.646052, "o", "> "]
[617.646099, "o", "            \r\n\u001b[?2004l\r\u001b[?2004h> "]
[617.64613, "o", "            # Dampen when near target\r\n\u001b[?2004l\r\u001b[?2004h> "]
[617.646213, "o", "            if abs(speed_error) < 3.0:\r\n\u001b[?2004l\r\u001b[?2004h"]
[617.646282, "o", "> "]
[617.646341, "o", "                acceleration_cmd *= 0.3\r\n\u001b[?2004l\r\u001b[?2004h> "]
[617.646413, "o", "            elif ego_speed > self.set_speed:\r\n\u001b[?2004l\r\u001b[?2004h"]
[617.646445, "o", "> "]
[617.64655, "o", "                acceleration_cmd = min(acceleration_cmd, -1.0)\r\n\u001b[?2004l\r\u001b[?2004h"]
[617.646604, "o", ">             \r\n\u001b[?2004l\r\u001b[?2004h> "]
[617.646675, "o", "            distance_error = None\r\n\u001b[?2004l\r\u001b[?2004h> "]
[617.646739, "o", "            \r\n\u001b[?2004l\r\u001b[?2004h> "]
[617.646791, "o", "        elif mode == 'emergency':\r\n\u001b[?2004l\r\u001b[?2004h> "]
[617.646869, "o", "            self.pid_speed.reset()\r\n\u001b[?2004l\r\u001b[?2004h"]
[617.646927, "o", "> "]
[617.646991, "o", "            self.pid_distance.reset()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[617.647064, "o", "            acceleration_cmd = self.max_deceleration\r\n\u001b[?2004l\r\u001b[?2004h> "]
[617.647132, "o", "            distance_error = 0.0\r\n\u001b[?2004l\r\u001b[?2004h"]
[617.647195, "o", ">             \r\n\u001b[?2004l\r\u001b[?2004h> "]
[617.647257, "o", "        else:  # 'follow' mode\r\n\u001b[?2004l\r\u001b[?2004h> "]
[617.647336, "o", "            self.pid_speed.reset()\r\n\u001b[?2004l\r\u001b[?2004h"]
[617.647367, "o", "> "]
[617.647502, "o", "            desired_distance = self.safe_following_distance(ego_speed)\r\n\u001b[?2004l\r\u001b[?2004h"]
[617.647572, "o", "> "]
[617.64768, "o", "            # distance_error = actual - desired (positive = too far = accelerate)\r\n\u001b[?2004l\r"]
[617.647736, "o", "\u001b[?2004h> "]
[617.647824, "o", "            distance_error = distance - desired_distance\r\n\u001b[?2004l\r\u001b[?2004h"]
[617.647851, "o", "> "]
[617.647943, "o", "            \r\n\u001b[?2004l\r\u001b[?2004h"]
[617.648003, "o", "> "]
[617.648064, "o", "            acceleration_cmd = self.pid_distance.compute(distance_error, dt)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[617.648129, "o", "            \r\n\u001b[?2004l\r\u001b[?2004h> "]
[617.648216, "o", "            # Speed limiting in follow mode\r\n\u001b[?2004l\r\u001b[?2004h"]
[617.648291, "o", "> "]
[617.648341, "o", "            if ego_speed >= self.set_speed:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[617.648481, "o", "                acceleration_cmd = min(acceleration_cmd, 0.0)\r\n\u001b[?2004l\r\u001b[?2004h"]
[617.648525, "o", "> "]
[617.648595, "o", "            elif ego_speed > self.set_speed - 5:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[617.648743, "o", "                acceleration_cmd = min(acceleration_cmd, 0.5)\r\n\u001b[?2004l\r\u001b[?2004h"]
[617.648777, "o", "> "]
[617.648821, "o", "            \r\n\u001b[?2004l\r\u001b[?2004h> "]
[617.648923, "o", "            # Emergency braking if too close\r\n\u001b[?2004l\r\u001b[?2004h"]
[617.648965, "o", "> "]
[617.649049, "o", "            if distance < self.min_distance + 5:\r\n\u001b[?2004l\r\u001b[?2004h"]
[617.649129, "o", "> "]
[617.649205, "o", "                acceleration_cmd = min(acceleration_cmd, -4.0)\r\n\u001b[?2004l\r\u001b[?2004h"]
[617.649273, "o", ">         \r\n\u001b[?2004l\r"]
[617.649329, "o", "\u001b[?2004h> "]
[617.649501, "o", "        acceleration_cmd = max(self.max_deceleration, min(self.max_acceleration, acceleration_cmd))\r\n\u001b[?2004l\r\u001b[?2004h> "]
[617.649707, "o", "        return acceleration_cmd, mode, distance_error\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h>     def reset(self):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[617.649794, "o", "        self.pid_speed.reset()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[617.649846, "o", "        self.pid_distance.reset()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[617.649913, "o", "        self.prev_mode = 'cruise'\r\n\u001b[?2004l\r"]
[617.649939, "o", "\u001b[?2004h> "]
[617.650018, "o", "        self.mode = 'cruise'\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
[617.651024, "o", "\u001b[?2004hroot@bfb65fae2dcc:~# "]
