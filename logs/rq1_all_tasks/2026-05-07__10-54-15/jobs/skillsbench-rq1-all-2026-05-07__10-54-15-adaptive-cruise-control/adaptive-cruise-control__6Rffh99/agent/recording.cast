[124.907471, "i", "cat > pid_controller.py << 'EOF'\n\"\"\"PID Controller Implementation\"\"\"\n\nclass PIDController:\n    \"\"\"Discrete-time PID Controller.\"\"\"\n    \n    def __init__(self, kp, ki, kd):\n        self.kp = kp\n        self.ki = ki\n        self.kd = kd\n        self.integral = 0.0\n        self.prev_error = 0.0\n    \n    def reset(self):\n        \"\"\"Clear controller state.\"\"\"\n        self.integral = 0.0\n        self.prev_error = 0.0\n    \n    def compute(self, error, dt):\n        \"\"\"Compute control output given error and timestep.\"\"\"\n        p_term = self.kp * error\n        self.integral += error * dt\n        i_term = self.ki * self.integral\n        derivative = (error - self.prev_error) / dt if dt > 0 else 0.0\n        d_term = self.kd * derivative\n        self.prev_error = error\n        return p_term + i_term + d_term\nEOF\n"]
[124.907741, "o", "cat > pid_controller.py << 'EOF'\r\n\u001b[?2004l\r"]
[124.909822, "o", "\u001b[?2004h> \"\"\"PID Controller Implementation\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> class PIDController:\r\n\u001b[?2004l\r\u001b[?2004h>     \"\"\"Discrete-time PID Controller.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h>     def __init__(self, kp, ki, kd):\r\n\u001b[?2004l\r\u001b[?2004h>         self.kp = kp\r\n\u001b[?2004l\r\u001b[?2004h>         self.ki = ki\r\n\u001b[?2004l\r\u001b[?2004h>         self.kd = kd\r\n\u001b[?2004l\r\u001b[?2004h>         self.integral = 0.0\r\n\u001b[?2004l\r\u001b[?2004h>         self.prev_error = 0.0\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h>     def reset(self):\r\n\u001b[?2004l\r\u001b[?2004h>         \"\"\"Clear controller state.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h>         self.integral = 0.0\r\n\u001b[?2004l\r\u001b[?2004h>         self.prev_error = 0.0\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h>     def compute(self, error, dt):\r\n\u001b[?2004l\r\u001b[?2004h>         \"\"\"Compute control output given error and timestep.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h>         p_term = self.kp * error\r\n\u001b[?2004l\r\u001b[?2004h>         self.integral += error * dt\r\n\u001b[?2004l\r\u001b[?2004h>         i_term = self.ki * self.integral\r\n\u001b[?2004l\r\u001b[?2004h>         derivative = (error - self.prev_error) / dt if dt > 0 else 0.0\r\n\u001b[?2004l\r\u001b[?2004h>         d_term = self.kd * derivative\r\n\u001b[?2004l\r\u001b[?2004h>         self.prev_error = error\r\n\u001b[?2004l\r\u001b[?2004h>         return p_term + i_term + d_term\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
[124.91063, "o", "\u001b[?2004hroot@bfb65fae2dcc:~# "]
[125.413575, "i", "cat > acc_system.py << 'EOF'\n\"\"\"Adaptive Cruise Control System Implementation\"\"\"\n\nfrom pid_controller import PIDController\n\nclass AdaptiveCruiseControl:\n    \"\"\"ACC system that maintains speed and safe following distance.\"\"\"\n    \n    def __init__(self, config):\n        self.mass = config['vehicle']['mass']\n        self.max_acceleration = config['vehicle']['max_acceleration']\n        self.max_deceleration = config['vehicle']['max_deceleration']\n        self.set_speed = config['acc_settings']['set_speed']\n        self.time_headway = config['acc_settings']['time_headway']\n        self.min_distance = config['acc_settings']['min_distance']\n        self.emergency_ttc_threshold = config['acc_settings']['emergency_ttc_threshold']\n        \n        pid_speed_cfg = config.get('pid_speed', {'kp': 0.5, 'ki': 0.05, 'kd': 0.1})\n        pid_dist_cfg = config.get('pid_distance', {'kp': 0.5, 'ki': 0.05, 'kd': 0.1})\n        \n        self.pid_speed = PIDController(pid_speed_cfg['kp'], pid_speed_cfg['ki'], pid_speed_cfg['kd'])\n        self.pid_distance = PIDController(pid_dist_cfg['kp'], pid_dist_cfg['ki'], pid_dist_cfg['kd'])\n        self.mode = 'cruise'\n    \n    def safe_following_distance(self, ego_speed):\n        return ego_speed * self.time_headway + self.min_distance\n    \n    def time_to_collision(self, distance, ego_speed, lead_speed):\n        relative_speed = ego_speed - lead_speed\n        if relative_speed <= 0:\n            return None\n        return distance / relative_speed\n    \n    def determine_mode(self, lead_speed, distance):\n        if lead_speed is None or distance is None:\n            return 'cruise'\n        ttc = self.time_to_collision(distance, self.set_speed, lead_speed)\n        if ttc is not None and ttc < self.emergency_ttc_threshold:\n            return 'emergency'\n        return 'follow'\n    \n    def compute(self, ego_speed, lead_speed, distance, dt):\n        mode = self.determine_mode(lead_speed, distance)\n        self.mode = mode\n        \n        if mode == 'cruise':\n            self.pid_distance.reset()\n            speed_error = self.set_speed - ego_speed\n            acceleration_cmd = self.pid_speed.compute(speed_error, dt)\n            distance_error = None\n        elif mode == 'emergency':\n            self.pid_speed.reset()\n            self.pid_distance.reset()\n            acceleration_cmd = self.max_deceleration\n            distance_error = 0.0\n        else:\n            self.pid_speed.reset()\n            desired_distance = self.safe_following_distance(ego_speed)\n            distance_error = desired_distance - distance\n            acceleration_cmd = self.pid_distance.compute(distance_error, dt)\n            speed_correction = 0.2 * (self.set_speed - ego_speed)\n            acceleration_cmd += speed_correction\n        \n        acceleration_cmd = max(self.max_deceleration, min(self.max_acceleration, acceleration_cmd))\n        return acceleration_cmd, mode, distance_error\n    \n    def reset(self):\n        self.pid_speed.reset()\n        self.pid_distance.reset()\n        self.mode = 'cruise'\nEOF\n"]
