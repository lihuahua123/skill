[485.174519, "o", "29.8,30.70000000000019,3.0,cruise,,,\r\n29.9,30.500000000000192,-2.0,cruise,,,\r\n30.0,30.207270000000168,-2.9273000000002267,follow,-3.650000000000283,52.1,10.77053792738429\r\n30.1,30.03287941900016,-1.7439058100000648,follow,-4.440905000000257,50.87,9.910616604726126\r\n30.2,29.776171093894455,-2.5670832510570674,follow,-5.9493191285002425,49.1,11.455445647034885\r\n30.3,29.503473622898262,-2.726974709961909,follow,-7.074256640841682,47.59,14.149062943740976\r\n30.4,29.303473622898263,-2.0,follow,-5.18521043434739,49.07,10.944638940081365\r\n30.5,29.092698329540234,-2.1077529335802967,follow,-5.795210434347396,48.16,11.27156571458259\r\n30.6,28.892698329540234,-2.0,follow,-5.219047494310345,48.42,17.84938615279294\r\n30.7,28.685916305385593,-2.067820241546422,follow,-5.739047494310348,47.6,15.325590041644903\r\n30.8,28.485916305385594,-2.0,follow,-5.288874458078389,47.74,12.44552701344746\r\n30.9,28.13045992253468,-3.5545638285091523,follow,-7.608874458078397,45.12,16.585430877423565\r\n31.0,28.103069167649114,-0.2739075488556495,follow,-4.945689883802018,47.25,13.683479161863497\r\n31.1,27.790039153885704,-3.1303001376341095,follow,-6.834603751473672,45.32,14.43294104913241\r\n31.2,27.777769423411318,-0.12269730474385043,follow,-4.2450587308285606,47.44,18.261820919311276\r\n31.3,27.30943347873458,-4.6833594467673745,follow,-8.306654135116979,43.36,11.595339306496497\r\n31.4,27.32662478758985,0.17191308855271936,follow,-4.764150218101868,46.2,12.774341468468476\r\n31.5,26.971991956095458,-3.5463283149439295,follow,-7.179937181384773,43.81,18.315278982590204\r\n31.6,26.66308481495771,-3.089071411377498,follow,-8.097987934143191,42.36,17.48184782410899\r\n31.7,26.425998142949926,-2.3708667200778577,follow,-7.754627222436561,42.24,35.61557010109364\r\n31.8,26.189090036554855,-2.369081063950688,follow,-7.518997214424893,42.12,22.53502997514044\r\n"]
