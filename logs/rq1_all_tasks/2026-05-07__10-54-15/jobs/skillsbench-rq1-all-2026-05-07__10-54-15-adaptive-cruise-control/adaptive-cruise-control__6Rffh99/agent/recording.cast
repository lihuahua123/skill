[1518.88506, "o", "> "]
[1518.885097, "o", "    for i, s in enumerate(speeds):\r\n\u001b[?2004l\r\u001b[?2004h"]
[1518.885168, "o", "> "]
[1518.885232, "o", "        if s >= 0.9 * set_speed:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1518.885276, "o", "            rise_end = i\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1518.885335, "o", "            break\r\n\u001b[?2004l\r\u001b[?2004h"]
[1518.885392, "o", "> "]
