[402.613973, "o", "129.0,35.95283937881888,3.0,follow,59.40074093177167,122.88,21.322822296877003\r\n129.1,36.25283937881888,3.0,follow,60.830740931771686,124.76,15.416097386849202\r\n129.2,36.552839378818874,3.0,follow,64.04074093177167,128.42,18.96102842799077\r\n129.3,36.85283937881887,3.0,follow,63.850740931771696,128.68,17.242766923970155\r\n129.4,37.15283937881887,3.0,follow,64.0707409317717,129.35,16.062657395132614\r\n129.5,37.452839378818865,3.0,follow,68.44074093177169,134.17,17.418252335487917\r\n129.6,37.75283937881886,3.0,follow,65.71074093177168,131.89,21.505536319035475\r\n129.7,38.05283937881886,3.0,follow,63.820740931771695,130.45,17.456550768339756\r\n129.8,38.35283937881886,3.0,follow,68.25074093177173,135.33,15.269372964540322\r\n129.9,38.652839378818854,3.0,follow,67.3907409317717,134.92,16.589532107493145\r\n"]
[402.614154, "o", "\u001b[?2004hroot@bfb65fae2dcc:~# "]
[433.008196, "i", "cat > acc_system.py << 'EOF'\n\"\"\"Adaptive Cruise Control System Implementation\"\"\"\n\nfrom pid_controller import PIDController\n\nclass AdaptiveCruiseControl:\n    \"\"\"ACC system with proper speed limiting.\"\"\"\n    \n    def __init__(self, config):\n        self.mass = config['vehicle']['mass']\n        self.max_acceleration = config['vehicle']['max_acceleration']\n        self.max_deceleration = config['vehicle']['max_deceleration']\n        self.set_speed = config['acc_settings']['set_speed']\n        self.time_headway = config['acc_settings']['time_headway']\n        self.min_distance = config['acc_settings']['min_distance']\n        self.emergency_ttc_threshold = config['acc_settings']['emergency_ttc_threshold']\n        \n        pid_speed_cfg = config.get('pid_speed', {'kp': 0.5, 'ki': 0.05, 'kd': 0.1})\n        pid_dist_cfg = config.get('pid_distance', {'kp': 0.5, 'ki': 0.05, 'kd': 0.1})\n        \n        self.pid_speed = PIDController(pid_speed_cfg['kp'], pid_speed_cfg['ki'], pid_speed_cfg['kd'])\n        self.pid_distance = PIDController(pid_dist_cfg['kp'], pid_dist_cfg['ki'], pid_dist_cfg['kd'])\n        self.prev_mode = 'cruise'\n        self.mode = 'cruise'\n    \n    def safe_following_distance(self, ego_speed):\n        return ego_speed * self.time_headway + self.min_distance\n    \n    def time_to_collision(self, distance, ego_speed, lead_speed):\n        relative_speed = ego_speed - lead_speed\n        if relative_speed <= 0:\n            return None\n        return distance / relative_speed\n    \n    def determine_mode(self, lead_speed, distance):\n        if lead_speed is None or distance is None:\n            return 'cruise'\n        ttc = self.time_to_collision(distance, self.set_speed, lead_speed)\n        if ttc is not None and ttc < self.emergency_ttc_threshold:\n            return 'emergency'\n        return 'follow'\n    \n    def compute(self, ego_speed, lead_speed, distance, dt):\n        mode = self.determine_mode(lead_speed, distance)\n        \n        if mode != self.prev_mode:\n            self.pid_speed.reset()\n            self.pid_distance.reset()\n            self.prev_mode = mode\n        self.mode = mode\n        \n        if mode == 'cruise':\n            self.pid_distance.reset()\n            speed_error = self.set_speed - ego_speed\n            acceleration_cmd = self.pid_speed.compute(speed_error, dt)\n            \n            if ego_speed > self.set_speed + 0.5:\n                acceleration_cmd = min(acceleration_cmd, -2.0)\n            elif abs(speed_error) < 2.0:\n                acceleration_cmd *= 0.15\n            \n            distance_error = None\n            \n        elif mode == 'emergency':\n            self.pid_speed.reset()\n            self.pid_distance.reset()\n            acceleration_cmd = self.max_deceleration\n            distance_error = 0.0\n            \n        else:  # 'follow' mode\n            self.pid_speed.reset()\n            desired_distance = self.safe_following_distance(ego_speed)\n            distance_error = distance - desired_distance\n            \n            acceleration_cmd = self.pid_distance.compute(distance_error, dt)\n            \n            # CRITICAL: Don't exceed set_speed in follow mode\n            if ego_speed >= self.set_speed:\n                acceleration_cmd = min(acceleration_cmd, 0.0)\n            else:\n                # Allow positive accel up to set_speed\n                max_accel_to_set = (self.set_speed - ego_speed) / dt\n                acceleration_cmd = min(acceleration_cmd, max_accel_to_set)\n            \n            # Also ensure we can decelerate if needed\n            if distance_error < -5:  # Too close\n                acceleration_cmd = min(acceleration_cmd, -2.0)\n        \n        acceleration_cmd = max(self.max_deceleration, min(self.max_acceleration, acceleration_cmd))\n        return acceleration_cmd, mode, distance_error\n    \n    def reset(self):\n        self.pid_speed.reset()\n        self.pid_distance.reset()\n        self.prev_mode = 'cruise'\n        self.mode = 'cruise'\nEOF\n"]
[433.008388, "o", "cat > acc_system.py << 'EOF'\r\n\u001b[?2004l\r"]
[433.008425, "o", "\u001b[?2004h> "]
[433.008609, "o", "\"\"\"Adaptive Cruise Control System Implementation\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[433.008733, "o", "\u001b[?2004h> from pid_controller import PIDController\r\n\u001b[?2004l\r\u001b[?2004h> "]
[433.008776, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[433.008915, "o", "class AdaptiveCruiseControl:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[433.009082, "o", "    \"\"\"ACC system with proper speed limiting.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h>     def __init__(self, config):\r\n\u001b[?2004l\r"]
[433.009174, "o", "\u001b[?2004h> "]
[433.009249, "o", "        self.mass = config['vehicle']['mass']\r\n\u001b[?2004l\r\u001b[?2004h"]
[433.009312, "o", "> "]
[433.009458, "o", "        self.max_acceleration = config['vehicle']['max_acceleration']\r\n\u001b[?2004l\r\u001b[?2004h> "]
[433.009619, "o", "        self.max_deceleration = config['vehicle']['max_deceleration']\r\n\u001b[?2004l\r\u001b[?2004h> "]
[433.009766, "o", "        self.set_speed = config['acc_settings']['set_speed']\r\n\u001b[?2004l\r\u001b[?2004h> "]
[433.009911, "o", "        self.time_headway = config['acc_settings']['time_headway']\r\n\u001b[?2004l\r\u001b[?2004h"]
[433.010052, "o", ">         self.min_distance = config['acc_settings']['min_distance']"]
[433.01156, "o", "\r\n\u001b[?2004l\r\u001b[?2004h"]
[433.011611, "o", "> "]
[433.01178, "o", "        self.emergency_ttc_threshold = config['acc_settings']['emergency_ttc_threshold']"]
[433.011891, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[433.011956, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h> "]
[433.012087, "o", "        pid_speed_cfg = config.get('pid_speed', {'kp': 0.5, 'ki': 0.05, 'kd': 0.1})\r\n\u001b[?2004l\r\u001b[?2004h> "]
[433.01224, "o", "        pid_dist_cfg = config.get('pid_distance', {'kp': 0.5, 'ki': 0.05, 'kd': 0.1})\r\n\u001b[?2004l\r\u001b[?2004h> "]
[433.012296, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h> "]
[433.012467, "o", "        self.pid_speed = PIDController(pid_speed_cfg['kp'], pid_speed_cfg['ki'], pid_speed_cfg['kd'])\r\n\u001b[?2004l\r\u001b[?2004h"]
[433.012536, "o", "> "]
[433.012672, "o", "        self.pid_distance = PIDController(pid_dist_cfg['kp'], pid_dist_cfg['ki'], pid_dist_cfg['kd'])\r\n\u001b[?2004l\r"]
[433.012705, "o", "\u001b[?2004h> "]
[433.013061, "o", "        self.prev_mode = 'cruise'\r\n\u001b[?2004l\r\u001b[?2004h> "]
[433.013153, "o", "        self.mode = 'cruise'\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h>     def safe_following_distance(self, ego_speed):\r\n\u001b[?2004l\r\u001b[?2004h>         return ego_speed * self.time_headway + self.min_distance\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r"]
[433.013235, "o", "\u001b[?2004h> "]
[433.01332, "o", "    def time_to_collision(self, distance, ego_speed, lead_speed):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[433.013414, "o", "        relative_speed = ego_speed - lead_speed\r\n\u001b[?2004l\r\u001b[?2004h> "]
[433.013504, "o", "        if relative_speed <= 0:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[433.013564, "o", "            return None\r\n\u001b[?2004l\r\u001b[?2004h"]
[433.013644, "o", "> "]
[433.013679, "o", "        return distance / relative_speed\r\n\u001b[?2004l\r"]
[433.013713, "o", "\u001b[?2004h>     \r\n\u001b[?2004l\r"]
[433.0138, "o", "\u001b[?2004h> "]
[433.013864, "o", "    def determine_mode(self, lead_speed, distance):\r\n\u001b[?2004l\r"]
[433.013925, "o", "\u001b[?2004h> "]
[433.013986, "o", "        if lead_speed is None or distance is None:\r\n\u001b[?2004l\r"]
[433.014026, "o", "\u001b[?2004h> "]
[433.014106, "o", "            return 'cruise'\r\n\u001b[?2004l\r\u001b[?2004h> "]
[433.014201, "o", "        ttc = self.time_to_collision(distance, self.set_speed, lead_speed)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[433.014329, "o", "        if ttc is not None and ttc < self.emergency_ttc_threshold:\r\n\u001b[?2004l\r\u001b[?2004h"]
[433.014365, "o", "> "]
[433.01441, "o", "            return 'emergency'\r\n\u001b[?2004l\r\u001b[?2004h> "]
[433.014515, "o", "        return 'follow'\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[433.014617, "o", "    def compute(self, ego_speed, lead_speed, distance, dt):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[433.014735, "o", "        mode = self.determine_mode(lead_speed, distance)\r\n\u001b[?2004l\r\u001b[?2004h"]
[433.014797, "o", ">         \r\n"]
[433.014859, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[433.0149, "o", "        if mode != self.prev_mode:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[433.014968, "o", "            self.pid_speed.reset()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[433.015061, "o", "            self.pid_distance.reset()\r\n\u001b[?2004l\r\u001b[?2004h"]
[433.015134, "o", "> "]
[433.0152, "o", "            self.prev_mode = mode\r\n\u001b[?2004l\r\u001b[?2004h> "]
[433.015237, "o", "        self.mode = mode\r\n\u001b[?2004l\r\u001b[?2004h>         \r\n\u001b[?2004l\r"]
[433.015321, "o", "\u001b[?2004h> "]
[433.015383, "o", "        if mode == 'cruise':\r\n\u001b[?2004l\r\u001b[?2004h> "]
[433.015426, "o", "            self.pid_distance.reset()\r\n\u001b[?2004l\r\u001b[?2004h"]
[433.015578, "o", "> "]
[433.015618, "o", "            speed_error = self.set_speed - ego_speed\r\n\u001b[?2004l\r\u001b[?2004h> "]
[433.015706, "o", "            acceleration_cmd = self.pid_speed.compute(speed_error, dt)\r\n\u001b[?2004l\r"]
[433.015745, "o", "\u001b[?2004h> "]
[433.01583, "o", "            \r\n\u001b[?2004l\r\u001b[?2004h> "]
[433.015882, "o", "            if ego_speed > self.set_speed + 0.5:\r\n\u001b[?2004l\r\u001b[?2004h"]
[433.015923, "o", "> "]
[433.015998, "o", "                acceleration_cmd = min(acceleration_cmd, -2.0)\r\n\u001b[?2004l\r"]
[433.016034, "o", "\u001b[?2004h> "]
[433.016111, "o", "            elif abs(speed_error) < 2.0:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[433.016209, "o", "                acceleration_cmd *= 0.15\r\n\u001b[?2004l\r\u001b[?2004h> "]
[433.016252, "o", "            \r\n\u001b[?2004l\r"]
[433.016324, "o", "\u001b[?2004h> "]
[433.016363, "o", "            distance_error = None\r\n\u001b[?2004l\r\u001b[?2004h> "]
[433.016426, "o", "            \r\n\u001b[?2004l\r\u001b[?2004h> "]
[433.016497, "o", "        elif mode == 'emergency':\r\n\u001b[?2004l\r\u001b[?2004h> "]
[433.016567, "o", "            self.pid_speed.reset()\r\n\u001b[?2004l\r\u001b[?2004h"]
[433.016641, "o", "> "]
[433.016678, "o", "            self.pid_distance.reset()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[433.01677, "o", "            acceleration_cmd = self.max_deceleration\r\n\u001b[?2004l\r"]
[433.016845, "o", "\u001b[?2004h> "]
[433.016921, "o", "            distance_error = 0.0\r\n\u001b[?2004l\r\u001b[?2004h"]
[433.016985, "o", ">             \r\n\u001b[?2004l\r\u001b[?2004h> "]
[433.017047, "o", "        else:  # 'follow' mode\r\n\u001b[?2004l\r\u001b[?2004h> "]
[433.017112, "o", "            self.pid_speed.reset()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[433.017188, "o", "            desired_distance = self.safe_following_distance(ego_speed)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[433.017281, "o", "            distance_error = distance - desired_distance\r\n\u001b[?2004l\r\u001b[?2004h> "]
[433.017347, "o", "            \r\n\u001b[?2004l\r\u001b[?2004h"]
[433.017371, "o", "> "]
[433.017477, "o", "            acceleration_cmd = self.pid_distance.compute(distance_error, dt)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[433.017566, "o", "            \r\n\u001b[?2004l\r"]
[433.01763, "o", "\u001b[?2004h> "]
[433.017664, "o", "            # CRITICAL: Don't exceed set_speed in follow mode\r\n\u001b[?2004l\r\u001b[?2004h> "]
[433.01774, "o", "            if ego_speed >= self.set_speed:\r\n\u001b[?2004l\r\u001b[?2004h"]
[433.017809, "o", "> "]
[433.017864, "o", "                acceleration_cmd = min(acceleration_cmd, 0.0)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[433.017923, "o", "            else:\r\n\u001b[?2004l\r\u001b[?2004h"]
[433.017986, "o", "> "]
[433.018052, "o", "                # Allow positive accel up to set_speed\r\n\u001b[?2004l\r\u001b[?2004h> "]
[433.018152, "o", "                max_accel_to_set = (self.set_speed - ego_speed) / dt\r\n\u001b[?2004l\r\u001b[?2004h> "]
[433.018281, "o", "                acceleration_cmd = min(acceleration_cmd, max_accel_to_set)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[433.018318, "o", "            \r\n\u001b[?2004l\r"]
[433.018345, "o", "\u001b[?2004h> "]
[433.018435, "o", "            # Also ensure we can decelerate if needed\r\n\u001b[?2004l\r\u001b[?2004h> "]
[433.018532, "o", "            if distance_error < -5:  # Too close\r\n\u001b[?2004l\r\u001b[?2004h> "]
[433.018647, "o", "                acceleration_cmd = min(acceleration_cmd, -2.0)\r\n\u001b[?2004l\r\u001b[?2004h"]
[433.018719, "o", ">         \r\n\u001b[?2004l\r"]
[433.018778, "o", "\u001b[?2004h> "]
[433.018864, "o", "        acceleration_cmd = max(self.max_deceleration, min(self.max_acceleration, acceleration_cmd))\r\n\u001b[?2004l\r\u001b[?2004h> "]
[433.018962, "o", "        return acceleration_cmd, mode, distance_error\r\n\u001b[?2004l\r\u001b[?2004h> "]
[433.018995, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[433.019082, "o", "> "]
[433.019114, "o", "    def reset(self):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[433.019142, "o", "        self.pid_speed.reset()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[433.01923, "o", "        self.pid_distance.reset()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[433.019296, "o", "        self.prev_mode = 'cruise'\r\n\u001b[?2004l\r\u001b[?2004h> "]
[433.019352, "o", "        self.mode = 'cruise'\r\n\u001b[?2004l\r"]
[433.019412, "o", "\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
[433.020387, "o", "\u001b[?2004hroot@bfb65fae2dcc:~# "]
[433.507955, "i", "cat > tuning_results.yaml << 'EOF'\npid_speed:\n  kp: 1.2\n  ki: 0.25\n  kd: 0.4\npid_distance:\n  kp: 0.3\n  ki: 0.02\n  kd: 0.05\nEOF\n"]
[433.508186, "o", "cat > tuning_results.yaml << 'EOF'\r\n\u001b[?2004l\r"]
[433.508228, "o", "\u001b[?2004h> "]
[433.50825, "o", "pid_speed:\r\n\u001b[?2004l\r"]
[433.508335, "o", "\u001b[?2004h>   kp: 1.2\r\n\u001b[?2004l\r\u001b[?2004h> "]
[433.508503, "o", "  ki: 0.25\r\n\u001b[?2004l\r\u001b[?2004h>   kd: 0.4\r\n\u001b[?2004l\r\u001b[?2004h> pid_distance:\r\n\u001b[?2004l\r"]
[433.508853, "o", "\u001b[?2004h>   kp: 0.3\r\n\u001b[?2004l\r\u001b[?2004h>   ki: 0.02\r\n\u001b[?2004l\r\u001b[?2004h>   kd: 0.05\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
[433.509803, "o", "\u001b[?2004hroot@bfb65fae2dcc:~# "]
[433.810874, "i", "python3 simulation.py\n"]
[433.811049, "o", "python3 simulation.py\r\n\u001b[?2004l\r"]
[434.200574, "o", "Speed PID: {'kp': 1.2, 'ki': 0.25, 'kd': 0.4}\r\nDistance PID: {'kp': 0.3, 'ki': 0.02, 'kd': 0.05}\r\n"]
[434.264995, "o", "Saved 1501 rows to simulation_results.csv\r\n"]
[434.267384, "o", "Report saved to acc_report.md\r\n"]
[434.316624, "o", "\u001b[?2004hroot@bfb65fae2dcc:~# "]
[444.900031, "i", "cat acc_report.md\n"]
[444.900251, "o", "cat acc_report.md\r\n\u001b[?2004l\r"]
[444.901077, "o", "# ACC Simulation Report\r\n\r\n## System Design\r\n\r\n### ACC Architecture\r\n\r\nThe ACC system implements a hierarchical control architecture with three modes:\r\n\r\n- **Cruise Mode**: No lead vehicle detected - maintains set speed (30 m/s)\r\n- **Follow Mode**: Lead vehicle present with TTC >= threshold - maintains safe following distance\r\n- **Emergency Mode**: TTC < 3.0s - applies maximum deceleration\r\n\r\n### Safety Features\r\n- Time Headway: 1.5s\r\n- Minimum Gap: 10.0m\r\n- Emergency TTC: 3.0s\r\n- Accel Limits: [-8.0, 3.0] m/s2\r\n\r\n## PID Tuning Methodology\r\n\r\nParameters tuned using iterative simulation to meet performance targets.\r\n\r\n### Final Gains\r\n\r\n**Speed Controller:** kp=1.2, ki=0.25, kd=0.4\r\n\r\n**Distance Controller:** kp=0.3, ki=0.02, kd=0.05\r\n\r\n## Simulation Results\r\n\r\n### Performance Metrics\r\n\r\n| Metric | Target | Achieved | Status |\r\n|--------|--------|----------|--------|\r\n| Rise Time | <10s | 8.90s | PASS |\r\n| Overshoot | <5% | 2.33% | PASS |\r\n| Speed SS Error | <0.5m/s | 4.681m/s | FAIL |\r\n| Dist SS Error | <2m | 18.01m | FAIL |\r\n| Min Distance | >5m | 33.60m | PASS |\r\n\r\n### Simulation Summary\r\n\r\n- Duration: 150s, Timestep: 0.1s\r\n- Rows in output: 1501\r\n- Max speed: 30.70 m/s\r\n- Modes: cruise=501, follow=959, emergency=41\r\n"]
[444.901272, "o", "\u001b[?2004hroot@bfb65fae2dcc:~# "]
[445.201005, "i", "tail -5 simulation_results.csv\n"]
[445.201179, "o", "tail -5 simulation_results.csv\r\n\u001b[?2004l\r"]
[445.202042, "o", "149.6,30.459115198527858,0.6453926605482092,cruise,,,\r\n149.7,30.523438725953916,0.6432352742605768,cruise,,,\r\n149.8,30.323438725953917,-2.0,cruise,,,\r\n149.9,30.40575920680513,0.8232048085121251,cruise,,,\r\n150.0,30.469506530447394,0.6374732364226606,cruise,,,\r\n"]
