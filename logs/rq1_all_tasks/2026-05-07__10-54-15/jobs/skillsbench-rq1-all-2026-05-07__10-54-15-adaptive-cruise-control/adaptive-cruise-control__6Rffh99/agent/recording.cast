[163.207926, "i", "cat > simulation.py << 'SIMEOF'\n\"\"\"ACC Simulation Runner\"\"\"\nimport yaml\nimport pandas as pd\nfrom pid_controller import PIDController\nfrom acc_system import AdaptiveCruiseControl\n\ndef load_tuning_results(filepath='tuning_results.yaml'):\n    with open(filepath, 'r') as f:\n        return yaml.safe_load(f)\n\ndef calculate_ttc(distance, ego_speed, lead_speed):\n    if lead_speed is None or distance is None:\n        return None\n    relative_speed = ego_speed - lead_speed\n    if relative_speed <= 0:\n        return None\n    return distance / relative_speed\n\ndef run_simulation():\n    with open('vehicle_params.yaml', 'r') as f:\n        config = yaml.safe_load(f)\n    \n    tuning = load_tuning_results()\n    config['pid_speed'] = tuning['pid_speed']\n    config['pid_distance'] = tuning['pid_distance']\n    \n    print(f\"Speed PID: {tuning['pid_speed']}\")\n    print(f\"Distance PID: {tuning['pid_distance']}\")\n    \n    df = pd.read_csv('sensor_data.csv')\n    dt = config['simulation']['dt']\n    acc = AdaptiveCruiseControl(config)\n    ego_speed = 0.0\n    results = []\n    \n    for idx, row in df.iterrows():\n        time = row['time']\n        lead_speed = row['lead_speed'] if pd.notna(row['lead_speed']) else None\n        distance = row['distance'] if pd.notna(row['distance']) else None\n        \n        acc_cmd, mode, dist_error = acc.compute(ego_speed, lead_speed, distance, dt)\n        ego_speed = max(0, ego_speed + acc_cmd * dt)\n        ttc = calculate_ttc(distance, ego_speed, lead_speed)\n        \n        result = {\n            'time': time,\n            'ego_speed': ego_speed,\n            'acceleration_cmd': acc_cmd,\n            'mode': mode,\n            'distance_error': dist_error if dist_error is not None else '',\n            'distance': distance if distance is not None else '',\n            'ttc': ttc if ttc is not None else ''\n        }\n        results.append(result)\n    \n    results_df = pd.DataFrame(results)\n    results_df.to_csv('simulation_results.csv', index=False)\n    print(f\"Saved {len(results)} rows to simulation_results.csv\")\n    generate_report(results_df, config, tuning)\n\ndef generate_report(df, config, tuning):\n    set_speed = config['acc_settings']['set_speed']\n    speeds = pd.to_numeric(df['ego_speed'], errors='coerce').fillna(0)\n    \n    # Rise time\n    rise_end = None\n    for i, s in enumerate(speeds):\n        if s >= 0.9 * set_speed:\n            rise_end = i\n            break\n    rise_time = (rise_end * 0.1) if rise_end else None\n    \n    max_speed = speeds.max()\n    overshoot = max(0, ((max_speed - set_speed) / set_speed) * 100)\n    \n    steady_start = int(len(speeds) * 0.7)\n    ss_error = abs(speeds.iloc[steady_start:].mean() - set_speed)\n    \n    follow_df = df[df['mode'] == 'follow']\n    dist_errs = pd.to_numeric(follow_df['distance_error'], errors='coerce').dropna()\n    dist_ss_err = dist_errs.abs().mean() if len(dist_errs) > 0 else 0\n    dists = pd.to_numeric(follow_df['distance'], errors='coerce').dropna()\n    min_dist = dists.min() if len(dists) > 0 else None\n    \n    # Save report\n    with open('acc_report.md', 'w') as f:\n        f.write(\"# ACC Simulation Report\\n\\n\")\n        f.write(\"## System Design\\n\\n\")\n        f.write(\"### ACC Architecture\\n\\n\")\n        f.write(\"The ACC system implements a hierarchical control architecture with three modes:\\n\\n\")\n        f.write(\"- **Cruise Mode**: No lead vehicle detected - maintains set speed (30 m/s)\\n\")\n        f.write(\"- **Follow Mode**: Lead vehicle present with TTC >= threshold - maintains safe following distance\\n\")\n        f.write(\"- **Emergency Mode**: TTC < 3.0s - applies maximum deceleration\\n\\n\")\n        f.write(\"### Safety Features\\n\")\n        f.write(f\"- Time Headway: {config['acc_settings']['time_headway']}s\\n\")\n        f.write(f\"- Minimum Gap: {config['acc_settings']['min_distance']}m\\n\")\n        f.write(f\"- Emergency TTC: {config['acc_settings']['emergency_ttc_threshold']}s\\n\")\n        f.write(f\"- Accel Limits: [{config['vehicle']['max_deceleration']}, {config['vehicle']['max_acceleration']}] m/s2\\n\\n\")\n        f.write(\"## PID Tuning Methodology\\n\\n\")\n       "]
[163.20807, "i", " f.write(\"Parameters tuned using iterative simulation to meet performance targets.\\n\\n\")\n        f.write(\"### Final Gains\\n\\n\")\n        f.write(f\"**Speed Controller:** kp={tuning['pid_speed']['kp']}, ki={tuning['pid_speed']['ki']}, kd={tuning['pid_speed']['kd']}\\n\\n\")\n        f.write(f\"**Distance Controller:** kp={tuning['pid_distance']['kp']}, ki={tuning['pid_distance']['ki']}, kd={tuning['pid_distance']['kd']}\\n\\n\")\n        f.write(\"## Simulation Results\\n\\n\")\n        f.write(\"### Performance Metrics\\n\\n\")\n        f.write(\"| Metric | Target | Achieved | Status |\\n\")\n        f.write(\"|--------|--------|----------|--------|\\n\")\n        rt_status = 'PASS' if (rise_time and rise_time < 10) else 'FAIL'\n        f.write(f\"| Rise Time | <10s | {rise_time:.2f}s | {rt_status} |\\n\")\n        os_status = 'PASS' if overshoot < 5 else 'FAIL'\n        f.write(f\"| Overshoot | <5% | {overshoot:.2f}% | {os_status} |\\n\")\n        ss_status = 'PASS' if ss_error < 0.5 else 'FAIL'\n        f.write(f\"| Speed SS Error | <0.5m/s | {ss_error:.3f}m/s | {ss_status} |\\n\")\n        ds_status = 'PASS' if dist_ss_err < 2 else 'FAIL'\n        f.write(f\"| Dist SS Error | <2m | {dist_ss_err:.2f}m | {ds_status} |\\n\")\n        md_status = 'PASS' if (min_dist and min_dist > 5) else 'FAIL'\n        f.write(f\"| Min Distance | >5m | {min_dist:.2f}m | {md_status} |\\n\")\n        f.write(\"\\n### Simulation Summary\\n\\n\")\n        f.write(f\"- Duration: 150s, Timestep: 0.1s\\n\")\n        f.write(f\"- Rows in output: {len(df)}\\n\")\n        f.write(f\"- Max speed: {max_speed:.2f} m/s\\n\")\n        f.write(f\"- Modes: cruise={len(df[df['mode']=='cruise'])}, follow={len(follow_df)}, emergency={len(df[df['mode']=='emergency'])}\\n\")\n    print(\"Report saved to acc_report.md\")\n\nif __name__ == '__main__':\n    run_simulation()\nSIMEOF\n"]
[163.208357, "o", "cat > simulation.py << 'SIMEOF'\r\n\u001b[?2004l\r\u001b[?2004h"]
[163.208499, "o", "> \"\"\"ACC Simulation Runner\"\"\"\r\n\u001b[?2004l\r"]
[163.208562, "o", "\u001b[?2004h> import yaml\r\n\u001b[?2004l\r"]
[163.208599, "o", "\u001b[?2004h> "]
[163.208745, "o", "import pandas as pd\r\n\u001b[?2004l\r\u001b[?2004h> "]
[163.208915, "o", "from pid_controller import PIDController\r\n\u001b[?2004l\r \u001b[?2004h> "]
[163.20907, "o", "from acc_system import AdaptiveCruiseControl\r\n\u001b[?2004l\rg\u001b[?2004h"]
[163.209203, "o", "> \r\n\u001b[?2004l\r[\u001b[?2004h> "]
[163.209337, "o", "def load_tuning_results(filepath='tuning_results.yaml'):\r\n\u001b[?2004l\r"]
[163.209441, "o", "\u001b[?2004h> "]
[163.209593, "o", "    with open(filepath, 'r') as f:\r\n\u001b[?2004l\r\u001b[?2004h"]
[163.209705, "o", ">         return yaml.safe_load(f)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[163.209925, "o", "def calculate_ttc(distance, ego_speed, lead_speed):\r\n\u001b[?2004l\rg\u001b[?2004h> "]
[163.210154, "o", "    if lead_speed is None or distance is None:\r\n\u001b[?2004l\r\u001b[?2004h"]
[163.21019, "o", "> "]
[163.210276, "o", "        return None\r\n\u001b[?2004l\r"]
[163.210355, "o", "\u001b[?2004h> "]
[163.210471, "o", "    relative_speed = ego_speed - lead_speed\r\n\u001b[?2004l\r"]
[163.210546, "o", "\u001b[?2004h> "]
[163.210615, "o", "    if relative_speed <= 0:\r\n\u001b[?2004l\r\u001b[?2004h"]
[163.210649, "o", "> "]
[163.210732, "o", "        return None\r\n\u001b[?2004l\r \u001b[?2004h> "]
[163.21088, "o", "    return distance / relative_speed\r\n\u001b[?2004l\r\u001b[?2004h"]
[163.210911, "o", "> \r\n\u001b[?2004l\rh\u001b[?2004h"]
[163.210997, "o", "> "]
[163.211058, "o", "def run_simulation():\r\n\u001b[?2004l\r\u001b[?2004h"]
[163.211108, "o", "> "]
[163.211267, "o", "    with open('vehicle_params.yaml', 'r') as f:\r\n\u001b[?2004l\r"]
[163.211339, "o", "\u001b[?2004h> "]
[163.211442, "o", "        config = yaml.safe_load(f)\r\n\u001b[?2004l\rA\u001b[?2004h"]
[163.211541, "o", ">     \r\n\u001b[?2004l\r"]
[163.211628, "o", "\u001b[?2004h> "]
[163.211698, "o", "    tuning = load_tuning_results()\r\n\u001b[?2004l\r\u001b[?2004h"]
[163.211767, "o", "> "]
[163.211899, "o", "    config['pid_speed'] = tuning['pid_speed']\r\n\u001b[?2004l\r"]
[163.211961, "o", "\u001b[?2004h> "]
[163.212166, "o", "    config['pid_distance'] = tuning['pid_distance']\r\n\u001b[?2004l\r"]
[163.212194, "o", "\u001b[?2004h> "]
[163.212219, "o", "    \r\n\u001b[?2004l\r"]
[163.212241, "o", "\u001b[?2004h> "]
[163.212441, "o", "    print(f\"Speed PID: {tuning['pid_speed']}\")"]
[163.212517, "o", "\r\n\u001b[?2004l\r"]
[163.212593, "o", "\u001b[?2004h> "]
[163.212691, "o", "    print(f\"Distance PID: {tuning['pid_distance']}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[163.212726, "o", "    \r\n\u001b[?2004l\r"]
[163.212761, "o", "\u001b[?2004h> "]
[163.212922, "o", "    df = pd.read_csv('sensor_data.csv')\r\n\u001b[?2004l\r\u001b[?2004h> "]
[163.213064, "o", "    dt = config['simulation']['dt']\r\n\u001b[?2004l\r\u001b[?2004h"]
[163.213103, "o", "> "]
[163.213214, "o", "    acc = AdaptiveCruiseControl(config)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[163.213302, "o", "    ego_speed = 0.0\r\n\u001b[?2004l\rs\u001b[?2004h> "]
[163.213379, "o", "    results = []\r\n\u001b[?2004l\r\u001b[?2004h> "]
[163.213415, "o", "    \r\n\u001b[?2004l\r"]
[163.213495, "o", "\u001b[?2004h> "]
[163.213575, "o", "    for idx, row in df.iterrows():\r\n\u001b[?2004l\rrr \u001b[?2004h> "]
[163.213679, "o", "        time = row['time']\r\n\u001b[?2004l\r\u001b[?2004h> "]
[163.214054, "o", "        lead_speed = row['lead_speed'] if pd.notna(row['lead_speed']) else None\r\n\u001b[?2004l\r\u001b[?2004h"]
[163.214145, "o", "> "]
[163.214354, "o", "        distance = row['distance'] if pd.notna(row['distance']) else None\r\n\u001b[?2004l\r\u001b[?2004h> "]
[163.214452, "o", "        \r\n\u001b[?2004l\r"]
[163.214508, "o", "\u001b[?2004h> "]
[163.214691, "o", "        acc_cmd, mode, dist_error = acc.compute(ego_speed, lead_speed, distance, dt)\r\n\u001b[?2004l\r\u001b[?2004h"]
[163.214781, "o", "> "]
[163.214924, "o", "        ego_speed = max(0, ego_speed + acc_cmd * dt)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[163.215232, "o", "        ttc = calculate_ttc(distance, ego_speed, lead_speed)\r\n\u001b[?2004l\r"]
[163.215276, "o", "\u001b[?2004h> "]
[163.215351, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h"]
[163.215389, "o", ">         result = {\r\n\u001b[?2004l\r \u001b[?2004h"]
[163.215472, "o", "> "]
[163.215525, "o", "            'time': time,\r\n\u001b[?2004l\r.2f}\u001b[?2004h"]
[163.215605, "o", "> "]
[163.215659, "o", "            'ego_speed': ego_speed,\r\n\u001b[?2004l\r \u001b[?2004h"]
[163.215684, "o", "> "]
[163.215833, "o", "            'acceleration_cmd': acc_cmd,\r\n\u001b[?2004l\rf\u001b[?2004h"]
[163.21586, "o", "> "]
[163.215962, "o", "            'mode': mode,\r\n\u001b[?2004l\r"]
[163.216017, "o", "\u001b[?2004h> "]
[163.216314, "o", "            'distance_error': dist_error if dist_error is not None else '',\r\n\u001b[?2004l\r\u001b[?2004h"]
[163.216339, "o", "> "]
[163.21659, "o", "            'distance': distance if distance is not None else '',\r\n\u001b[?2004l\r\u001b[?2004h"]
[163.216651, "o", "> "]
[163.216715, "o", "            'ttc': ttc if ttc is not None else ''\r\n\u001b[?2004l\r\u001b[?2004h> "]
[163.216781, "o", "        }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[163.216837, "o", "        results.append(result)\r\n\u001b[?2004l\r"]
[163.216897, "o", "\u001b[?2004h>     \r\n\u001b[?2004l\r"]
[163.216966, "o", "\u001b[?2004h> "]
[163.217039, "o", "    results_df = pd.DataFrame(results)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[163.217112, "o", "    results_df.to_csv('simulation_results.csv', index=False)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[163.217237, "o", "    print(f\"Saved {len(results)} rows to simulation_results.csv\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[163.217268, "o", "> "]
[163.217351, "o", "    generate_report(results_df, config, tuning)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[163.217409, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
