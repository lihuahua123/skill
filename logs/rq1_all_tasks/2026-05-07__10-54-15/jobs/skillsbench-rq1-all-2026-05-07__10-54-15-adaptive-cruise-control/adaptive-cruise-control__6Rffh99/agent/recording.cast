[1437.104715, "o", "\r\n\u001b[?2004l\rm\u001b[?2004h> "]
[1437.104874, "o", "def run_simulation():\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1437.104971, "o", "    with open('vehicle_params.yaml', 'r') as f:\r\n\u001b[?2004l\r"]
