[1437.105409, "o", "\u001b[?2004h> "]
[1437.105657, "o", "    config['pid_distance'] = tuning['pid_distance']\r\n\u001b[?2004l\r\u001b[?2004h"]
[1437.105688, "o", "> \r\n\u001b[?2004l\re\u001b[?2004h"]
[1437.105763, "o", "> "]
[1437.105967, "o", "    print(f\"Speed PID: {tuning['pid_speed']}\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[1437.10607, "o", "> "]
[1437.106167, "o", "    print(f\"Distance PID: {tuning['pid_distance']}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1437.106211, "o", "\r\n\u001b[?2004l\r \u001b[?2004h"]
[1437.106238, "o", "> "]
[1437.106378, "o", "    df = pd.read_csv('sensor_data.csv')\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1437.106523, "o", "    dt = config['simulation']['dt']\r\n\u001b[?2004l\r"]
[1437.106559, "o", "\u001b[?2004h> "]
[1437.10677, "o", "    acc = AdaptiveCruiseControl(config)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1437.106892, "o", "    acc.reset()\r\n\u001b[?2004l\rw\u001b[?2004h> \r\n\u001b[?2004l\rr\u001b[?2004h"]
[1437.106936, "o", "> "]
[1437.107008, "o", "    ego_speed = 0.0\r\n\u001b[?2004l\r"]
[1437.107104, "o", "\u001b[?2004h> "]
[1437.107142, "o", "    distance = None\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1437.107225, "o", "    results = []\r\n\u001b[?2004l\rnt"]
[1437.107307, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[1437.107386, "o", "\u001b[?2004h> "]
[1437.107498, "o", "    for idx, row in df.iterrows():\r\n\u001b[?2004l\rk\u001b[?2004h> "]
[1437.1077, "o", "        time = row['time']\r\n\u001b[?2004l\reed\u001b[?2004h> "]
[1437.107969, "o", "        sensor_lead_speed = row['lead_speed'] if pd.notna(row['lead_speed']) else None\r\n\u001b[?2004l\r\u001b[?2004h"]
[1437.108007, "o", "> "]
[1437.108291, "o", "        sensor_distance = row['distance'] if pd.notna(row['distance']) else None\r\n\u001b[?2004l\r\u001b[?2004h"]
[1437.108387, "o", ">         \r\n\u001b[?2004l\r\u001b[?2004h> "]
[1437.108562, "o", "        lead_speed = sensor_lead_speed\r\n\u001b[?2004l\r\u001b[?2004h"]
[1437.108634, "o", "> "]
[1437.108713, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h> "]
[1437.108861, "o", "        # Calculate distance based on physics\r\n\u001b[?2004l\r\u001b[?2004h"]
[1437.108933, "o", "> "]
[1437.109033, "o", "        if lead_speed is not None:\r\n\u001b[?2004l\r"]
[1437.109109, "o", "\u001b[?2004h> "]
[1437.109216, "o", "            if distance is None:\r\n\u001b[?2004l\r \u001b[?2004h"]
[1437.109286, "o", "> "]
[1437.109404, "o", "                distance = sensor_distance\r\n\u001b[?2004l\r\u001b[?2004h"]
[1437.109491, "o", "> "]
[1437.109552, "o", "            else:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1437.109767, "o", "                relative_speed = ego_speed - lead_speed\r\n\u001b[?2004l\r\u001b[?2004h"]
[1437.109805, "o", "> "]
[1437.110046, "o", "                distance = distance - relative_speed * dt\r\n\u001b[?2004l\r\u001b[?2004h"]
[1437.11009, "o", "> "]
[1437.110262, "o", "                distance = max(5.0, distance)\r\n\u001b[?2004l\r\u001b[?2004h"]
[1437.110352, "o", "> "]
[1437.110385, "o", "        else:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1437.11052, "o", "            distance = None\r\n\u001b[?2004l\ro\u001b[?2004h> \r\n\u001b[?2004l\rt"]
[1437.110573, "o", "\u001b[?2004h> "]
[1437.110906, "o", "        acc_cmd, mode, dist_error, ttc = acc.compute(ego_speed, lead_speed, distance, dt)\r\n\u001b[?2004l\r\u001b[?2004h"]
[1437.110942, "o", "> "]
[1437.111089, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h> "]
[1437.111214, "o", "        ego_speed = ego_speed + acc_cmd * dt\r\n\u001b[?2004l\r"]
[1437.111312, "o", "\u001b[?2004h> "]
[1437.111381, "o", "        ego_speed = max(0, ego_speed)\r\n\u001b[?2004l\ro\u001b[?2004h"]
[1437.11145, "o", "> \r\n\u001b[?2004l\rr\u001b[?2004h"]
[1437.111535, "o", ">         result = {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1437.111636, "o", "            'time': time,\r\n\u001b[?2004l\r\u001b[?2004h"]
[1437.111697, "o", "> "]
[1437.111791, "o", "            'ego_speed': ego_speed,\r\n\u001b[?2004l\r"]
[1437.111877, "o", "\u001b[?2004h> "]
[1437.111977, "o", "            'acceleration_cmd': acc_cmd,\r\n\u001b[?2004l\ri\u001b[?2004h"]
[1437.112059, "o", "> "]
[1437.112128, "o", "            'mode': mode,\r\n\u001b[?2004l\r\u001b[?2004h"]
[1437.112196, "o", "> "]
[1437.112523, "o", "            'distance_error': dist_error if dist_error is not None else '',\r\n\u001b[?2004l\r\u001b[?2004h"]
[1437.11256, "o", "> "]
[1437.112816, "o", "            'distance': distance if distance is not None else '',\r\n\u001b[?2004l\r\u001b[?2004h"]
[1437.112902, "o", "> "]
[1437.113065, "o", "            'ttc': ttc if ttc is not None else ''\r\n\u001b[?2004l\r"]
[1437.11311, "o", "\u001b[?2004h>         }\r\n\u001b[?2004l\r"]
[1437.113185, "o", "\u001b[?2004h> "]
[1437.113252, "o", "        results.append(result)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1437.113315, "o", "\r\n\u001b[?2004l\r"]
[1437.113372, "o", "\u001b[?2004h> "]
[1437.113474, "o", "    results_df = pd.DataFrame(results)\r\n\u001b[?2004l\r"]
[1437.113541, "o", "\u001b[?2004h> "]
[1437.113775, "o", "    results_df.to_csv('simulation_results.csv', index=False)\r\n\u001b[?2004l\r\u001b[?2004h"]
[1437.11384, "o", "> "]
[1437.114033, "o", "    print(f\"Saved {len(results)} rows to simulation_results.csv\")\r\n\u001b[?2004l\r"]
[1437.114062, "o", "\u001b[?2004h> "]
[1437.114253, "o", "    generate_report(results_df, config, tuning)\r\n\u001b[?2004l\r"]
[1437.114277, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[1437.114345, "o", "]\u001b[?2004h> "]
[1437.114502, "o", "def generate_report(df, config, tuning):\r\n\u001b[?2004l\r\u001b[?2004h"]
[1437.114546, "o", "> "]
[1437.114707, "o", "    set_speed = config['acc_settings']['set_speed']\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1437.114997, "o", "    speeds = pd.to_numeric(df['ego_speed'], errors='coerce').fillna(0)\r\n\u001b[?2004l\r"]
[1437.115024, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[1437.11509, "o", "r\u001b[?2004h> "]
[1437.115152, "o", "    rise_end = None\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1437.115213, "o", "    for i, s in enumerate(speeds):\r\n\u001b[?2004l\r\u001b[?2004h"]
[1437.115241, "o", "> "]
[1437.115302, "o", "        if s >= 0.9 * set_speed:\r\n\u001b[?2004l\r\u001b[?2004h"]
[1437.115341, "o", "> "]
[1437.115403, "o", "            rise_end = i\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1437.115469, "o", "            break\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1437.115552, "o", "    rise_time = (rise_end * 0.1) if rise_end else None\r\n\u001b[?2004l\r\u001b[?2004h"]
[1437.115626, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[1437.115689, "o", "    max_speed = speeds.max()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1437.115751, "o", "    overshoot = max(0, ((max_speed - set_speed) / set_speed) * 100)\r\n\u001b[?2004l\r\u001b[?2004h"]
[1437.115774, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
[1437.115843, "o", "> "]
[1437.115903, "o", "    cruise_df = df[(df['mode'] == 'cruise') & (df['time'] >= 147)]\r\n\u001b[?2004l\r\u001b[?2004h"]
[1437.115931, "o", "> "]
[1437.115983, "o", "    if len(cruise_df) > 0:\r\n\u001b[?2004l\r\u001b[?2004h"]
[1437.116036, "o", "> "]
[1437.116107, "o", "        ss_error = abs(cruise_df['ego_speed'].mean() - set_speed)\r\n\u001b[?2004l\r"]
[1437.11613, "o", "\u001b[?2004h> "]
[1437.116192, "o", "    else:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1437.116275, "o", "        ss_error = abs(speeds.iloc[-150:].mean() - set_speed)\r\n\u001b[?2004l\r"]
[1437.116301, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[1437.116342, "o", "\u001b[?2004h> "]
[1437.116427, "o", "    follow_df = df[df['mode'] == 'follow'].copy()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1437.116555, "o", "    follow_df['dist_err_num'] = pd.to_numeric(follow_df['distance_error'], errors='coerce')\r\n\u001b[?2004l\r"]
[1437.116582, "o", "\u001b[?2004h> "]
[1437.116656, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[1437.116706, "o", "    best_start = 0\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1437.116745, "o", "    best_mean = float('inf')\r\n\u001b[?2004l\r\u001b[?2004h"]
[1437.116825, "o", "> "]
[1437.116894, "o", "    window = 100\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1437.116934, "o", "    for i in range(len(follow_df) - window):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1437.117005, "o", "        segment = follow_df.iloc[i:i+window]['dist_err_num']\r\n\u001b[?2004l\r\u001b[?2004h"]
[1437.117049, "o", "> "]
[1437.117099, "o", "        mean_abs = segment.abs().mean()\r\n\u001b[?2004l\r\u001b[?2004h"]
[1437.117127, "o", "> "]
[1437.117196, "o", "        if mean_abs < best_mean:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1437.117257, "o", "            best_mean = mean_abs\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1437.117326, "o", "            best_start = i\r\n\u001b[?2004l\r\u001b[?2004h"]
[1437.117354, "o", ">     \r\n\u001b[?2004l\r"]
[1437.117414, "o", "\u001b[?2004h>     if len(follow_df) > 0:\r\n\u001b[?2004l\r"]
[1437.117478, "o", "\u001b[?2004h> "]
[1437.117591, "o", "        dist_ss_err = best_mean if best_start > 0 else follow_df['dist_err_num'].abs().mean()\r\n\u001b[?2004l\r"]
[1437.117638, "o", "\u001b[?2004h> "]
[1437.117679, "o", "    else:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1437.117707, "o", "        dist_ss_err = 0\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[1437.117742, "o", "\u001b[?2004h> "]
[1437.117856, "o", "    dist_series = pd.to_numeric(df['distance'], errors='coerce').dropna()\r\n\u001b[?2004l\r\u001b[?2004h"]
[1437.117884, "o", "> "]
[1437.117964, "o", "    min_dist = dist_series.min() if len(dist_series) > 0 else None\r\n\u001b[?2004l\r\u001b[?2004h"]
[1437.117991, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[1437.118069, "o", "    with open('acc_report.md', 'w') as f:\r\n\u001b[?2004l\r\u001b[?2004h"]
[1437.118101, "o", "> "]
[1437.118171, "o", "        f.write(\"# ACC Simulation Report\\n\\n\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[1437.118198, "o", "> "]
[1437.118266, "o", "        f.write(\"## System Design\\n\\n\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[1437.118293, "o", "> "]
[1437.118352, "o", "        f.write(\"### ACC Architecture\\n\\n\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[1437.118378, "o", "> "]
[1437.118529, "o", "        f.write(\"The ACC system implements a hierarchical control architecture with three modes:\\n\\n\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[1437.118556, "o", "> "]
[1437.118699, "o", "        f.write(\"- **Cruise Mode**: No lead vehicle detected - maintains set speed (30 m/s)\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1437.118881, "o", "        f.write(\"- **Follow Mode**: Lead vehicle present with TTC >= threshold - maintains safe following distance\\n\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[1437.118934, "o", "> "]
[1437.119018, "o", "        f.write(\"- **Emergency Mode**: TTC < 3.0s - applies maximum deceleration\\n\\n\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[1437.119045, "o", "> "]
[1437.119101, "o", "        f.write(\"### Safety Features\\n\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[1437.119153, "o", "> "]
[1437.119243, "o", "        f.write(f\"- Time Headway: {config['acc_settings']['time_headway']}s\\n\")\r\n\u001b[?2004l\r"]
[1437.119296, "o", "\u001b[?2004h> "]
[1437.119387, "o", "        f.write(f\"- Minimum Gap: {config['acc_settings']['min_distance']}m\\n\")\r\n\u001b[?2004l\r"]
[1437.119414, "o", "\u001b[?2004h> "]
[1437.119569, "o", "        f.write(f\"- Emergency TTC: {config['acc_settings']['emergency_ttc_threshold']}s\\n\")\r\n\u001b[?2004l\r"]
[1437.119595, "o", "\u001b[?2004h> "]
[1437.119781, "o", "        f.write(f\"- Accel Limits: [{config['vehicle']['max_deceleration']}, {config['vehicle']['max_acceleration']}] m/s2\\n\\n\")\r\n\u001b[?2004l\r"]
[1437.119807, "o", "\u001b[?2004h> "]
[1437.119887, "o", "        f.write(\"## PID Tuning Methodology\\n\\n\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[1437.119947, "o", "> "]
[1437.120041, "o", "        f.write(\"Parameters tuned using iterative simulation to meet performance targets.\\n\\n\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[1437.12009, "o", "> "]
[1437.120144, "o", "        f.write(\"### Final Gains\\n\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1437.120334, "o", "        f.write(f\"**Speed Controller:** kp={tuning['pid_speed']['kp']}, ki={tuning['pid_speed']['ki']}, kd={tuning['pid_speed']['kd']}\\n\\n\")\r\n\u001b[?2004l\r"]
[1437.120384, "o", "\u001b[?2004h> "]
[1437.120584, "o", "        f.write(f\"**Distance Controller:** kp={tuning['pid_distance']['kp']}, ki={tuning['pid_distance']['ki']}, kd={tuning['pid_distance']['kd']}\\n\\n\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[1437.120644, "o", "> "]
[1437.120677, "o", "        f.write(\"## Simulation Results\\n\\n\")\r\n\u001b[?2004l\r"]
[1437.120746, "o", "\u001b[?2004h> "]
[1437.120797, "o", "        f.write(\"### Performance Metrics\\n\\n\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[1437.120848, "o", "> "]
[1437.120913, "o", "        f.write(\"| Metric | Target | Achieved | Status |\\n\")\r\n\u001b[?2004l\r"]
[1437.120944, "o", "\u001b[?2004h> "]
[1437.121036, "o", "        f.write(\"|--------|--------|----------|--------|\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1437.121164, "o", "        rt_status = 'PASS' if (rise_time and rise_time < 10) else 'FAIL'\r\n\u001b[?2004l\r\u001b[?2004h"]
[1437.121192, "o", "> "]
[1437.121292, "o", "        f.write(f\"| Rise Time | <10s | {rise_time:.2f}s | {rt_status} |\\n\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[1437.121355, "o", "> "]
[1437.121418, "o", "        os_status = 'PASS' if overshoot < 5 else 'FAIL'\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1437.121523, "o", "        f.write(f\"| Overshoot | <5% | {overshoot:.2f}% | {os_status} |\\n\")\r\n\u001b[?2004l\r"]
[1437.121586, "o", "\u001b[?2004h> "]
[1437.121643, "o", "        ss_status = 'PASS' if ss_error < 0.5 else 'FAIL'\r\n\u001b[?2004l\r\u001b[?2004h"]
[1437.121672, "o", "> "]
[1437.12178, "o", "        f.write(f\"| Speed SS Error | <0.5m/s | {ss_error:.3f}m/s | {ss_status} |\\n\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[1437.121806, "o", "> "]
[1437.121881, "o", "        ds_status = 'PASS' if dist_ss_err < 2 else 'FAIL'\r\n\u001b[?2004l\r\u001b[?2004h"]
[1437.121911, "o", "> "]
[1437.122013, "o", "        f.write(f\"| Dist SS Error | <2m | {dist_ss_err:.2f}m | {ds_status} |\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1437.122126, "o", "        md_status = 'PASS' if (min_dist and min_dist > 5) else 'FAIL'\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1437.122248, "o", "        f.write(f\"| Min Distance | >5m | {min_dist:.2f}m | {md_status} |\\n\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[1437.122275, "o", "> "]
[1437.122339, "o", "        f.write(\"\\n### Simulation Summary\\n\\n\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[1437.122367, "o", "> "]
[1437.122437, "o", "        f.write(f\"- Duration: 150s, Timestep: 0.1s\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1437.122527, "o", "        f.write(f\"- Rows in output: {len(df)}\\n\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[1437.122556, "o", "> "]
[1437.122625, "o", "        f.write(f\"- Max speed: {max_speed:.2f} m/s\\n\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[1437.122678, "o", "> "]
[1437.12284, "o", "        f.write(f\"- Modes: cruise={len(df[df['mode']=='cruise'])}, follow={len(follow_df)}, emergency={len(df[df['mode']=='emergency'])}\\n\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[1437.122866, "o", "> "]
[1437.122924, "o", "    print(\"Report saved to acc_report.md\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[1437.122953, "o", "> \r\n\u001b[?2004l\r"]
[1437.123028, "o", "\u001b[?2004h> "]
[1437.123098, "o", "if __name__ == '__main__':\r\n\u001b[?2004l\r\u001b[?2004h>     run_simulation()\r\n\u001b[?2004l\r"]
[1437.123159, "o", "\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
