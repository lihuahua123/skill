[1040.728843, "o", "\r\n   294\t        # t < 30s mostly cruise (>90%)\r\n   295\t        period = simulation_data[simulation_data['time'] < 30.0]\r\n   296\t        assert (period['mode'] == 'cruise').mean() > 0.9\r\n   297\t\r\n   298\t        # t = 30-60s mostly follow (>50%)\r\n   299\t        period = simulation_data[(simulation_data['time'] >= 30.0) & (simulation_data['time'] <= 60.0)]\r\n   300\t        assert (period['mode'] == 'follow').mean() > 0.5\r\n   301\t\r\n   302\t        # t = 120-122s emergency mode should appear\r\n   303\t        period = simulation_data[(simulation_data['time'] >= 120.0) & (simulation_data['time'] <= 122.0)]\r\n   304\t        assert (period['mode'] == 'emergency').any()\r\n   305\t\r\n   306\t        # t = 130-150s back to cruise (>80%)\r\n   307\t        period = simulation_data[(simulation_data['time'] >= 130.0) & (simulation_data['time'] <= 150.0)]\r\n   308\t        assert (period['mode'] == 'cruise').mean() > 0.8\r\n   309\t\r\n   310\t        # All three modes should appear\r\n   311\t        modes = simulation_data['mode'].unique()\r\n   312\t        for mode in ['cruise', 'follow', 'emergency']:\r\n   313\t            assert mode in modes\r\n   314\t\r\n   315\t\r\n   316\tclass TestSimulationExecution:\r\n   317\t    \"\"\"Step 3: simulation.py can be run directly and uses tuning_results.yaml\"\"\"\r\n   318\t\r\n   319\t    def test_simulation_execution(self):\r\n   320\t        \"\"\"Step 3: simulation.py runs and tuning affects behavior.\"\"\"\r\n   321\t        import subprocess\r\n   322\t        import os\r\n   323\t        import shutil\r\n   324\t        import yaml\r\n   325\t        import pandas as pd\r\n   326\t\r\n   327\t        backup_t = '/root/tuning_backup.yaml'\r\n   328\t        backup_r = '/root/results_backup.csv'\r\n   329\t        original = '/root/simulation_results.csv'\r\n   330\t\r\n   331\t        try:\r\n   332\t            # Backup existing files\r\n   333\t            if os.path.exists('/root/tuning_results.yaml'):\r\n   334\t                shutil.copy('/root/tuning_results.yaml', backup_t)\r\n   335\t            if os.path.exists(original):\r\n   336\t                shutil.copy(original, backup_r)\r\n   337\t\r\n   338\t            # Test 1: simulation.py can be run directly\r\n   339\t            result = subprocess.run(\r\n   340\t                ['python3', 'simulation.py'],\r\n   341\t                capture_output=True, text=True, timeout=60, cwd='/root'\r\n   342\t            )\r\n   343\t            assert result.returncode == 0\r\n   344\t            assert os.path.exists(original)\r\n   345\t\r\n   346\t            # Test 2: behavior must change when gains change\r\n   347\t            modified = {\r\n   348\t                'pid_speed': {'kp': 0.001, 'ki': 0.0001, 'kd': 0.0},\r\n   349\t                'pid_distance': {'kp': 0.001, 'ki': 0.0001, 'kd': 0.0}\r\n   350\t            }\r\n   351\t\r\n   352\t            with open('/root/tuning_results.yaml', 'w') as f:\r\n   353\t                yaml.dump(modified, f)\r\n   354\t\r\n   355\t            subprocess.run(['python3', 'simulation.py'], cwd='/root', timeout=60)\r\n   356\t            weak_df = pd.read_csv('/root/simulation_results.csv')\r\n   357\t\r\n   358\t            shutil.copy(backup_t, '/root/tuning_results.yaml')\r\n   359\t            subprocess.run(['python3', 'simulation.py'], cwd='/root', timeout=60)\r\n   360\t            orig_df = pd.read_csv('/root/simulation_results.csv')\r\n   361\t\r\n   362\t            assert weak_df['acceleration_cmd'].std() != orig_df['acceleration_cmd'].std() or \\\r\n   363\t                   abs(weak_df['ego_speed'].iloc[100] - orig_df['ego_speed'].iloc[100]) > 0.1\r\n   364\t\r\n   365\t        finally:\r\n   366\t            if os.path.exists(backup_t):\r\n   367\t                shutil.copy(backup_t, '/root/tuning_results.yaml')\r\n   368\t                os.unlink(backup_t)\r\n   369\t            if os.path.exists(backup_r):\r\n   370\t                shutil.copy(backup_r, '/root/simulation_results.csv')\r\n   371\t                os.unlink(backup_r)\r\n   372\t\r\n   373\t\r\n   374\tclass TestAntiCheat:\r\n   375\t    \"\"\"Verify simulation uses sensor_data.csv correctly, not just fabricated outputs.\"\"\"\r\n   376\t\r\n   377\t    def test_anti_cheat(self):\r\n   378\t        \"\"\"Verify simulation uses sensor d"]
[1040.728973, "o", "ata: mode, distance, TTC, and physics.\"\"\"\r\n   379\t        import pandas as pd\r\n   380\t        import numpy as np\r\n   381\t\r\n   382\t        simulation_data = pd.read_csv('/root/simulation_results.csv')\r\n   383\t        sensor_data = pd.read_csv('/root/sensor_data.csv')\r\n   384\t\r\n   385\t        merged = simulation_data.merge(sensor_data, on='time', suffixes=('_sim', '_sensor'))\r\n   386\t\r\n   387\t        # Mode must be cruise when no lead, follow/emergency when lead present\r\n   388\t        no_lead = merged[merged['lead_speed'].isna()]\r\n   389\t        if len(no_lead) > 0:\r\n   390\t            cruise_when_no_lead = (no_lead['mode'] == 'cruise').mean()\r\n   391\t            assert cruise_when_no_lead > 0.95, \"Mode should be 'cruise' when no lead vehicle\"\r\n   392\t\r\n   393\t        with_lead = merged[merged['lead_speed'].notna()]\r\n   394\t        if len(with_lead) > 0:\r\n   395\t            not_cruise_when_lead = (with_lead['mode'] != 'cruise').mean()\r\n   396\t            assert not_cruise_when_lead > 0.9, \"Mode should be 'follow' or 'emergency' when lead present\"\r\n   397\t\r\n   398\t        # Distance column must be empty when sensor shows no lead, non-empty when lead present\r\n   399\t        if len(no_lead) > 0:\r\n   400\t            empty_dist = no_lead['distance_sim'].apply(lambda x: x == '' or pd.isna(x)).mean()\r\n   401\t            assert empty_dist > 0.95, \"Distance should be empty when no lead vehicle in sensor data\"\r\n   402\t\r\n   403\t        if len(with_lead) > 0:\r\n   404\t            has_dist = with_lead['distance_sim'].apply(lambda x: x != '' and pd.notna(x)).mean()\r\n   405\t            assert has_dist > 0.9, \"Distance should be present when lead vehicle in sensor data\"\r\n   406\t\r\n   407\t        # TTC should only be present when ego is faster than lead (approaching)\r\n   408\t        if len(with_lead) > 0:\r\n   409\t            for _, row in with_lead.head(50).iterrows():\r\n   410\t                ego_speed = row['ego_speed_sim']\r\n   411\t                lead_speed = row['lead_speed']\r\n   412\t                ttc_val = row['ttc']\r\n   413\t                if ego_speed <= lead_speed:\r\n   414\t                    assert ttc_val == '' or pd.isna(ttc_val), \\\r\n   415\t                        f\"TTC should be empty when not approaching at t={row['time']}\"\r\n   416\t\r\n   417\t        # Distance changes must be consistent with sensor lead_speed (physics check)\r\n   418\t        if len(with_lead) >= 10:\r\n   419\t            with_lead = with_lead.copy()\r\n   420\t            with_lead['sim_dist'] = pd.to_numeric(with_lead['distance_sim'], errors='coerce')\r\n   421\t            with_lead['dist_change'] = with_lead['sim_dist'].diff()\r\n   422\t            with_lead['relative_speed'] = with_lead['ego_speed_sim'] - with_lead['lead_speed']\r\n   423\t            with_lead['expected_change'] = -with_lead['relative_speed'] * 0.1  # dt = 0.1s\r\n   424\t\r\n   425\t            valid = with_lead.dropna()\r\n   426\t            if len(valid) > 10:\r\n   427\t                matches = abs(valid['dist_change'] - valid['expected_change']) < 2.0  # 2m tolerance\r\n   428\t                assert matches.mean() > 0.7, \"Distance changes must follow physics based on sensor lead_speed\"\r\n"]
