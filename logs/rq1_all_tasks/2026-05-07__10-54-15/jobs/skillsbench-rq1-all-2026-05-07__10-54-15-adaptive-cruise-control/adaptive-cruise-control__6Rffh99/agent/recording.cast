[783.528637, "o", "        self.pid_distance = PIDController(pid_dist_cfg['kp'], pid_dist_cfg['ki'], pid_dist_cfg['kd'])\r\n\u001b[?2004l\r\u001b[?2004h> "]
[783.528717, "o", "        self.prev_mode = 'cruise'\r\n\u001b[?2004l\r"]
[783.528755, "o", "\u001b[?2004h> "]
