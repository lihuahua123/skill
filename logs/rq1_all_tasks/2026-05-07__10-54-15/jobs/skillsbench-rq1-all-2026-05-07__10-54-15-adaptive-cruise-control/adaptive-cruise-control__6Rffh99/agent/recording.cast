[1024.525848, "o", "     1\t\"\"\"Adaptive Cruise Control System Implementation\"\"\"\r\n     2\t\r\n     3\tfrom pid_controller import PIDController\r\n     4\t\r\n     5\tclass AdaptiveCruiseControl:\r\n     6\t    \"\"\"ACC system with tuned cruise and follow control.\"\"\"\r\n     7\t    \r\n     8\t    def __init__(self, config):\r\n     9\t        self.mass = config['vehicle']['mass']\r\n    10\t        self.max_acceleration = config['vehicle']['max_acceleration']\r\n    11\t        self.max_deceleration = config['vehicle']['max_deceleration']\r\n    12\t        self.set_speed = config['acc_settings']['set_speed']\r\n    13\t        self.time_headway = config['acc_settings']['time_headway']\r\n    14\t        self.min_distance = config['acc_settings']['min_distance']\r\n    15\t        self.emergency_ttc_threshold = config['acc_settings']['emergency_ttc_threshold']\r\n    16\t        \r\n    17\t        pid_speed_cfg = config.get('pid_speed', {'kp': 0.5, 'ki': 0.05, 'kd': 0.1})\r\n    18\t        pid_dist_cfg = config.get('pid_distance', {'kp': 0.5, 'ki': 0.05, 'kd': 0.1})\r\n    19\t        \r\n    20\t        self.pid_speed = PIDController(pid_speed_cfg['kp'], pid_speed_cfg['ki'], pid_speed_cfg['kd'])\r\n    21\t        self.pid_distance = PIDController(pid_dist_cfg['kp'], pid_dist_cfg['ki'], pid_dist_cfg['kd'])\r\n    22\t        self.prev_mode = 'cruise'\r\n    23\t        self.mode = 'cruise'\r\n    24\t    \r\n    25\t    def safe_following_distance(self, ego_speed):\r\n    26\t        return ego_speed * self.time_headway + self.min_distance\r\n    27\t    \r\n    28\t    def time_to_collision(self, distance, ego_speed, lead_speed):\r\n    29\t        relative_speed = ego_speed - lead_speed\r\n    30\t        if relative_speed <= 0:\r\n    31\t            return None\r\n    32\t        return distance / relative_speed"]
[1024.525902, "o", "\r\n    33\t    \r\n    34\t    def determine_mode(self, lead_speed, distance):\r\n    35\t        if lead_speed is None or distance is None:\r\n    36\t            return 'cruise'\r\n    37\t        ttc = self.time_to_collision(distance, self.set_speed, lead_speed)\r\n    38\t        if ttc is not None and ttc < self.emergency_ttc_threshold:\r\n    39\t            return 'emergency'\r\n    40\t        return 'follow'\r\n    41\t    \r\n    42\t    def compute(self, ego_speed, lead_speed, distance, dt):\r\n    43\t        mode = self.determine_mode(lead_speed, distance)\r\n    44\t        \r\n    45\t        if mode != self.prev_mode:\r\n    46\t            self.pid_speed.reset()\r\n    47\t            self.pid_distance.reset()\r\n    48\t            self.prev_mode = mode\r\n    49\t        self.mode = mode\r\n    50\t        \r\n    51\t        if mode == 'cruise':\r\n    52\t            self.pid_distance.reset()\r\n    53\t            speed_error = self.set_speed - ego_speed\r\n    54\t            p_term = self.pid_speed.kp * speed_error\r\n    55"]
