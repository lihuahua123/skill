[485.478779, "o", "29.8,30.0,,\r\n29.9,30.0,,\r\n30.0,30.0,25.37,52.1\r\n30.1,29.9,24.9,50.87\r\n30.2,29.8,25.49,49.1\r\n30.3,29.7,26.14,47.59\r\n30.4,29.6,24.82,49.07\r\n30.5,29.5,24.82,48.16\r\n30.6,29.4,26.18,48.42\r\n30.7,29.3,25.58,47.6\r\n30.8,29.2,24.65,47.74\r\n30.9,29.1,25.41,45.12\r\n31.0,29.0,24.65,47.25\r\n31.1,28.9,24.65,45.32\r\n31.2,28.8,25.18,47.44\r\n31.3,28.7,23.57,43.36\r\n31.4,28.6,23.71,46.2\r\n31.5,28.5,24.58,43.81\r\n31.6,28.4,24.24,42.36\r\n31.7,28.3,25.24,42.24\r\n31.8,28.2,24.32,42.12\r\n"]
