[1295.737674, "o", "> \r\n\u001b[?2004l\rR\u001b[?2004h> "]
[1295.737834, "o", "from pid_controller import PIDController\r\n\u001b[?2004l\ri"]
[1295.737953, "o", "\u001b[?2004h> \r\n\u001b[?2004l\rd\u001b[?2004h> "]
[1295.738016, "o", "class AdaptiveCruiseControl:\r\n\u001b[?2004l\r\u001b[?2004h"]
[1295.738164, "o", "> "]
[1295.738315, "o", "    \"\"\"ACC system with proper mode determination and safety hysteresis.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[1295.738349, "o", "> \r\n\u001b[?2004l\rc\u001b[?2004h"]
[1295.738369, "o", "> "]
[1295.738528, "o", "    def __init__(self, config):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1295.738655, "o", "        self.mass = config['vehicle']['mass']\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1295.7388, "o", "        self.max_acceleration = config['vehicle']['max_acceleration']\r\n\u001b[?2004l\r"]
[1295.738841, "o", "\u001b[?2004h> "]
[1295.738968, "o", "        self.max_deceleration = config['vehicle']['max_deceleration']\r\n\u001b[?2004l\r"]
[1295.738997, "o", "\u001b[?2004h> "]
[1295.739131, "o", "        self.set_speed = config['acc_settings']['set_speed']\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1295.739261, "o", "        self.time_headway = config['acc_settings']['time_headway']\r\n\u001b[?2004l\r"]
[1295.739335, "o", "\u001b[?2004h> "]
[1295.739435, "o", "        self.min_distance = config['acc_settings']['min_distance']\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1295.739609, "o", "        self.emergency_ttc_threshold = config['acc_settings']['emergency_ttc_threshold']\r\n\u001b[?2004l\r"]
[1295.739692, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[1295.739796, "o", "        pid_speed_cfg = config.get('pid_speed', {'kp': 2.5, 'ki': 0.4, 'kd': 0.6})\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1295.739956, "o", "        pid_dist_cfg = config.get('pid_distance', {'kp': 1.2, 'ki': 0.15, 'kd': 0.3})\r\n\u001b[?2004l\r"]
[1295.740031, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[1295.740156, "o", "        self.pid_speed = PIDController(pid_speed_cfg['kp'], pid_speed_cfg['ki'], pid_speed_cfg['kd'])\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1295.740334, "o", "        self.pid_distance = PIDController(pid_dist_cfg['kp'], pid_dist_cfg['ki'], pid_dist_cfg['kd'])\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1295.740416, "o", "        self.prev_mode = 'cruise'\r\n\u001b[?2004l\r"]
[1295.740444, "o", "\u001b[?2004h> "]
[1295.740516, "o", "        self.mode = 'cruise'\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[1295.740539, "o", "\u001b[?2004h> "]
[1295.740654, "o", "    def safe_following_distance(self, ego_speed):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1295.740755, "o", "        \"\"\"Calculate desired following distance.\"\"\"\r\n\u001b[?2004l\r"]
[1295.740897, "o", "\u001b[?2004h> "]
[1295.741018, "o", "        return ego_speed * self.time_headway + self.min_distance\r\n\u001b[?2004l\r"]
[1295.741096, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[1295.741187, "o", "    def calculate_ttc(self, distance, ego_speed, lead_speed):\r\n\u001b[?2004l\r"]
[1295.741247, "o", "\u001b[?2004h> "]
[1295.741306, "o", "        \"\"\"Calculate Time to Collision.\"\"\"\r\n\u001b[?2004l\r"]
[1295.741355, "o", "\u001b[?2004h> "]
[1295.741427, "o", "        if distance is None or lead_speed is None:\r\n\u001b[?2004l\r"]
[1295.741503, "o", "\u001b[?2004h> "]
[1295.741539, "o", "            return None\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1295.741621, "o", "        relative_speed = ego_speed - lead_speed\r\n\u001b[?2004l\r"]
[1295.741682, "o", "\u001b[?2004h> "]
[1295.741742, "o", "        if relative_speed <= 0:\r\n\u001b[?2004l\r"]
[1295.7418, "o", "\u001b[?2004h> "]
[1295.741848, "o", "            return None\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1295.741897, "o", "        return distance / relative_speed\r\n\u001b[?2004l\r"]
[1295.741949, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[1295.741992, "o", "\u001b[?2004h> "]
[1295.742097, "o", "    def determine_mode(self, lead_speed, distance, ego_speed):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1295.742252, "o", "        \"\"\"Determine operating mode based on conditions with hysteresis for safety.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1295.742359, "o", "        if lead_speed is None or distance is None:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1295.742425, "o", "            return 'cruise'\r\n\u001b[?2004l\r"]
[1295.742525, "o", "\u001b[?2004h>         \r\n\u001b[?2004l\r"]
[1295.742596, "o", "\u001b[?2004h> "]
[1295.742651, "o", "        # Keep emergency mode until TTC > 4.0 (hysteresis) or distance is safe\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1295.742716, "o", "        if self.mode == 'emergency':\r\n\u001b[?2004l\r"]
[1295.742753, "o", "\u001b[?2004h> "]
[1295.742874, "o", "            ttc = self.calculate_ttc(distance, ego_speed, lead_speed)\r\n\u001b[?2004l\r"]
[1295.742932, "o", "\u001b[?2004h> "]
[1295.743027, "o", "            safe_dist = self.safe_following_distance(ego_speed)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1295.743184, "o", "            # Exit emergency only when TTC is well above threshold AND distance is safe\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1295.743318, "o", "            if ttc is not None and ttc > 4.0 and distance >= safe_dist:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1295.743393, "o", "                return 'follow'\r\n\u001b[?2004l\r"]
[1295.743448, "o", "\u001b[?2004h> "]
[1295.743547, "o", "            return 'emergency'\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1295.743611, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h> "]
[1295.743675, "o", "        # Normal mode determination\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1295.743798, "o", "        ttc = self.calculate_ttc(distance, ego_speed, lead_speed)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1295.743929, "o", "        if ttc is not None and ttc < self.emergency_ttc_threshold:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1295.744008, "o", "            return 'emergency'\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1295.74406, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h"]
[1295.744111, "o", ">         return 'follow'\r\n\u001b[?2004l\r"]
[1295.744161, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[1295.744216, "o", "\u001b[?2004h> "]
[1295.74429, "o", "    def compute(self, ego_speed, lead_speed, distance, dt):\r\n\u001b[?2004l\r\u001b[?2004h"]
[1295.744315, "o", "> "]
[1295.744432, "o", "        \"\"\"Compute acceleration command based on ACC logic.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[1295.744512, "o", "> "]
[1295.744587, "o", "        mode = self.determine_mode(lead_speed, distance, ego_speed)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1295.744623, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1295.744698, "o", "        if mode != self.prev_mode:\r\n\u001b[?2004l\r"]
[1295.744755, "o", "\u001b[?2004h> "]
[1295.744814, "o", "            self.pid_speed.reset()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1295.744891, "o", "            self.pid_distance.reset()\r\n\u001b[?2004l\r\u001b[?2004h"]
[1295.744948, "o", "> "]
[1295.744995, "o", "            self.prev_mode = mode\r\n\u001b[?2004l\r\u001b[?2004h"]
[1295.745029, "o", "> "]
[1295.745105, "o", "        self.mode = mode\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[1295.745168, "o", "> "]
[1295.745224, "o", "        if mode == 'cruise':\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1295.745284, "o", "            self.pid_distance.reset()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1295.745391, "o", "            speed_error = self.set_speed - ego_speed\r\n\u001b[?2004l\r\u001b[?2004h"]
[1295.745441, "o", "> "]
[1295.745546, "o", "            acceleration_cmd = self.pid_speed.compute(speed_error, dt)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1295.745641, "o", "            if ego_speed >= self.set_speed:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1295.745758, "o", "                acceleration_cmd = min(acceleration_cmd, 0)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1295.745839, "o", "            distance_error = None\r\n\u001b[?2004l\r\u001b[?2004h> \r\n"]
[1295.745908, "o", "\u001b[?2004l\r\u001b[?2004h"]
[1295.745955, "o", "> "]
[1295.746023, "o", "        elif mode == 'emergency':\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1295.746085, "o", "            self.pid_speed.reset()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1295.746165, "o", "            self.pid_distance.reset()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1295.746271, "o", "            acceleration_cmd = self.max_deceleration\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1295.746352, "o", "            distance_error = 0.0\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1295.746411, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1295.746479, "o", "        else:  # 'follow' mode\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1295.746556, "o", "            self.pid_speed.reset()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1295.746692, "o", "            desired_distance = self.safe_following_distance(ego_speed)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1295.746804, "o", "            distance_error = distance - desired_distance\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1295.746943, "o", "            acceleration_cmd = self.pid_distance.compute(distance_error, dt)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1295.747038, "o", "            if ego_speed >= self.set_speed:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1295.747155, "o", "                acceleration_cmd = min(acceleration_cmd, 0)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1295.747256, "o", "            elif ego_speed > self.set_speed - 5:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1295.747376, "o", "                acceleration_cmd = min(acceleration_cmd, 0.5)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1295.747426, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1295.747607, "o", "        acceleration_cmd = max(self.max_deceleration, min(self.max_acceleration, acceleration_cmd))\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1295.74772, "o", "        return acceleration_cmd, mode, distance_error\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1295.747778, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1295.747814, "o", "    def reset(self):\r\n\u001b[?2004l\r\u001b[?2004h"]
[1295.747905, "o", "> "]
[1295.747979, "o", "        \"\"\"Reset controller state.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1295.748023, "o", "        self.pid_speed.reset()\r\n\u001b[?2004l\r\u001b[?2004h"]
[1295.748061, "o", "> "]
[1295.74817, "o", "        self.pid_distance.reset()\r\n\u001b[?2004l\r\u001b[?2004h"]
[1295.748232, "o", "> "]
[1295.748308, "o", "        self.prev_mode = 'cruise'\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1295.748349, "o", "        self.mode = 'cruise'\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
