[1445.150227, "o", "    \r\n        with open('/root/vehicle_params.yaml', 'r') as f:\r\n            config = yaml.safe_load(f)\r\n    \r\n        # Class must exist\r\n        assert hasattr(module, 'AdaptiveCruiseControl')\r\n    \r\n        acc = module.AdaptiveCruiseControl(config)\r\n    \r\n        # Return format validation\r\n        result = acc.compute(ego_speed=20.0, lead_speed=None, distance=None, dt=0.1)\r\n        assert isinstance(result, tuple)\r\n>       assert len(result) == 3\r\nE       AssertionError: assert 4 == 3\r\nE        +  where 4 = len((1.01, 'cruise', None, None))\r\n\r\n/tests/test_outputs.py:100: AssertionError\r\n=========================== short test summary info ============================\r\nFAILED ../tests/test_outputs.py::TestACCSystem::test_acc_system - AssertionEr...\r\n========================= 1 failed, 11 passed in 2.28s =========================\r\n"]
[1445.150501, "o", "\u001b[?2004hroot@bfb65fae2dcc:~# "]
[1518.364921, "i", "cat > acc_system.py << 'EOF'\n\"\"\"Adaptive Cruise Control System Implementation\"\"\"\n\nfrom pid_controller import PIDController\n\nclass AdaptiveCruiseControl:\n    \"\"\"ACC system with proper mode determination.\"\"\"\n\n    def __init__(self, config):\n        self.mass = config['vehicle']['mass']\n        self.max_acceleration = config['vehicle']['max_acceleration']\n        self.max_deceleration = config['vehicle']['max_deceleration']\n        self.set_speed = config['acc_settings']['set_speed']\n        self.time_headway = config['acc_settings']['time_headway']\n        self.min_distance = config['acc_settings']['min_distance']\n        self.emergency_ttc_threshold = config['acc_settings']['emergency_ttc_threshold']\n\n        pid_speed_cfg = config.get('pid_speed', {'kp': 2.5, 'ki': 0.4, 'kd': 0.6})\n        pid_dist_cfg = config.get('pid_distance', {'kp': 1.2, 'ki': 0.15, 'kd': 0.3})\n\n        self.pid_speed = PIDController(pid_speed_cfg['kp'], pid_speed_cfg['ki'], pid_speed_cfg['kd'])\n        self.pid_distance = PIDController(pid_dist_cfg['kp'], pid_dist_cfg['ki'], pid_dist_cfg['kd'])\n        self.prev_mode = 'cruise'\n        self.mode = 'cruise'\n\n    def safe_following_distance(self, ego_speed):\n        return ego_speed * self.time_headway + self.min_distance\n\n    def calculate_ttc(self, distance, ego_speed, lead_speed):\n        if distance is None or lead_speed is None:\n            return None\n        relative_speed = ego_speed - lead_speed\n        if relative_speed <= 0:\n            return None\n        return distance / relative_speed\n\n    def determine_mode(self, lead_speed, distance, ego_speed):\n        if lead_speed is None or distance is None:\n            return 'cruise'\n        ttc = self.calculate_ttc(distance, ego_speed, lead_speed)\n        if ttc is not None and ttc < self.emergency_ttc_threshold:\n            return 'emergency'\n        return 'follow'\n\n    def compute(self, ego_speed, lead_speed, distance, dt):\n        mode = self.determine_mode(lead_speed, distance, ego_speed)\n\n        if mode != self.prev_mode:\n            self.pid_speed.reset()\n            self.pid_distance.reset()\n            self.prev_mode = mode\n        self.mode = mode\n\n        if mode == 'cruise':\n            self.pid_distance.reset()\n            speed_error = self.set_speed - ego_speed\n            acceleration_cmd = self.pid_speed.compute(speed_error, dt)\n            if ego_speed >= self.set_speed:\n                acceleration_cmd = min(acceleration_cmd, 0)\n            distance_error = None\n\n        elif mode == 'emergency':\n            self.pid_speed.reset()\n            self.pid_distance.reset()\n            acceleration_cmd = self.max_deceleration\n            distance_error = 0.0\n\n        else:  # 'follow' mode\n            self.pid_speed.reset()\n            desired_distance = self.safe_following_distance(ego_speed)\n            distance_error = distance - desired_distance\n            acceleration_cmd = self.pid_distance.compute(distance_error, dt)\n            if ego_speed >= self.set_speed:\n                acceleration_cmd = min(acceleration_cmd, 0)\n            elif ego_speed > self.set_speed - 5:\n                acceleration_cmd = min(acceleration_cmd, 0.5)\n\n        acceleration_cmd = max(self.max_deceleration, min(self.max_acceleration, acceleration_cmd))\n        return acceleration_cmd, mode, distance_error\n\n    def reset(self):\n        self.pid_speed.reset()\n        self.pid_distance.reset()\n        self.prev_mode = 'cruise'\n        self.mode = 'cruise'\nEOF\n"]
