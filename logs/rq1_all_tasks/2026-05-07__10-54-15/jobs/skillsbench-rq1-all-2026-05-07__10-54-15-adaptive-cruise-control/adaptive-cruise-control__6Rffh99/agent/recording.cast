[1040.727732, "o", "     1\t\"\"\"\r\n     2\tTest suite for Adaptive Cruise Control simulation task.\r\n     3\tTests only what is explicitly mentioned in instruction.md.\r\n     4\t\"\"\"\r\n     5\t\r\n     6\timport pytest\r\n     7\timport os\r\n     8\timport sys\r\n     9\timport importlib.util\r\n    10\t\r\n    11\tsys.path.insert(0, '/root')\r\n    12\t\r\n    13\t\r\n    14\tclass TestInputFilesIntegrity:\r\n    15\t    \"\"\"Instruction: sensor_data.csv has 1501 rows, don't modify vehicle_params.yaml\"\"\"\r\n    16\t\r\n    17\t    def test_input_files_integrity(self):\r\n    18\t        \"\"\"Validate sensor_data.csv format and vehicle_params.yaml unchanged.\"\"\"\r\n    19\t        import pandas as pd\r\n    20\t        import yaml\r\n    21\t\r\n    22\t        # sensor_data.csv validation\r\n    23\t        df = pd.read_csv('/root/sensor_data.csv')\r\n    24\t        assert len(df) == 1501, \"sensor_data.csv must have 1501 rows\"\r\n    25\t        assert list(df.columns) == ['time', 'ego_speed', 'lead_speed', 'distance']\r\n    26\t        assert df['time'].min() == 0.0\r\n    27\t        assert df['time'].max() == 150.0\r\n    28\t\r\n    29\t        # vehicle_params.yaml must be unchanged\r\n    30\t        with open('/root/vehicle_params.yaml', 'r') as f:\r\n    31\t            config = yaml.safe_load(f)\r\n    32\t        assert config['vehicle']['max_acceleration'] == 3.0"]
[1040.727905, "o", "\r\n    33\t        assert config['vehicle']['max_deceleration'] == -8.0\r\n    34\t        assert config['acc_settings']['set_speed'] == 30.0\r\n    35\t        assert config['acc_settings']['time_headway'] == 1.5\r\n    36\t        assert config['acc_settings']['min_distance'] == 10.0\r\n    37\t        assert config['acc_settings']['emergency_ttc_threshold'] == 3.0\r\n    38\t        assert config['simulation']['dt'] == 0.1\r\n    39\t\r\n    40\t\r\n    41\tclass TestPIDController:\r\n    42\t    \"\"\"Step 1: PIDController class with __init__, reset, compute methods.\"\"\"\r\n    43\t\r\n    44\t    def test_pid_controller(self):\r\n    45\t        \"\"\"Step 1: PIDController class exists with correct methods and behavior.\"\"\"\r\n    46\t        spec = importlib.util.spec_from_file_location('pid_controller', '/root/pid_controller.py')\r\n    47\t        module = importlib.util.module_from_spec(spec)\r\n    48\t        spec.loader.exec_module(module)\r\n    49\t\r\n    50\t        # Class must exist\r\n    51\t        assert hasattr(module, 'PIDController')\r\n    52\t\r\n    53\t        # Methods and basic functionality\r\n    54\t        ctrl = module.PIDController(kp=1.0, ki=0.1, kd=0.05)\r\n    55\t        assert hasattr(ctrl, 'reset')\r\n    56\t        assert hasattr(ctrl, 'compute')\r\n    57\t        ctrl.reset()\r\n    58\t        out = ctrl.compute(error=1.0, dt=0.1)\r\n    59\t        assert isinstance(out, (int, float))\r\n    60\t\r\n    61\t        # Proportional response: doubling error roughly doubles output when ki=kd=0\r\n    62\t        ctrl = module.PIDController(kp=2.0, ki=0.0, kd=0.0)\r\n    63\t        ctrl.reset()\r\n    64\t        out1 = ctrl.compute(error=1.0, dt=0.1)\r\n    65\t        ctrl.reset()\r\n    66\t        out2 = ctrl.compute(error=2.0, dt=0.1)\r\n    67\t        assert abs(out2 / out1 - 2.0) < 0.5 or abs(out2 - out1 * 2) < 1.0\r\n    68\t\r\n    69\t        # Integral accumulation over time\r\n    70\t        ctrl = module.PIDController(kp=0.0, ki=1.0, kd=0.0)\r\n    71\t        ctrl.reset()\r\n    72\t        out1 = ctrl.compute(error=1.0, dt=0.1)\r\n    73\t        out2 = ctrl.compute(error=1.0, dt=0.1)\r\n    74\t        out3 = ctrl.compute(error=1.0, dt=0.1)\r\n    75\t        assert out3 > out1\r\n    76\t\r\n    77\t\r\n    78\tclass TestACCSystem:\r\n    79\t    \"\"\"Step 2: AdaptiveCruiseControl class with compute returning (accel, mode, dist_err).\"\"\"\r\n    80\t\r\n    81\t    def test_acc_system(self):\r\n    82\t        \"\"\"Step 2: AdaptiveCruiseControl class with all modes and return format.\"\"\"\r\n    83\t        import yaml\r\n    84\t\r\n    85\t        spec = importlib.util.spec_from_file_location('acc_system', '/root/acc_system.py')\r\n    86\t        module = importlib.util.module_from_spec(spec)\r\n    87\t        spec.loader.exec_module(module)\r\n    88\t\r\n    89\t        with open('/root/vehicle_params.yaml', 'r') as f:\r\n    90\t            config = yaml.safe_load(f)\r\n    91\t\r\n    92\t        # Class must exist\r\n    93\t        assert hasattr(module, 'AdaptiveCruiseControl')\r\n    94\t\r\n    95\t        acc = module.AdaptiveCruiseControl(config)\r\n    96\t\r\n    97\t        # Return format validation\r\n    98\t        result = acc.compute(ego_speed=20.0, lead_speed=None, distance=None, dt=0.1)\r\n    99\t        assert isinstance(result, tuple)\r\n   100\t        assert len(result) == 3\r\n   101\t        accel, mode, dist_err = result\r\n   102\t        assert isinstance(accel, (int, float))\r\n   103\t        assert mode in ['cruise', 'follow', 'emergency']\r\n   104\t\r\n   105\t        # Cruise mode when no lead vehicle\r\n   106\t        accel, mode, dist_err = acc.compute(ego_speed=20.0, lead_speed=None, distance=None, dt=0.1)\r\n   107\t        assert mode == 'cruise'\r\n   108\t        assert dist_err is None\r\n   109\t        assert isinstance(accel, (int, float))\r\n   110\t\r\n   111\t        # Follow mode when lead vehicle present and safe\r\n   112\t        accel, mode, dist_err = acc.compute(ego_speed=20.0, lead_speed=20.0, distance=50.0, dt=0.1)\r\n   113\t"]
