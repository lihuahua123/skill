[1003.64469, "o", "     1\t\"\"\"ACC Simulation Runner - Proper Vehicle Dynamics\"\"\"\r\n     2\timport yaml\r\n     3\timport pandas as pd\r\n     4\tfrom pid_controller import PIDController\r\n     5\tfrom acc_system import AdaptiveCruiseControl\r\n     6\t\r\n     7\tdef load_tuning_results(filepath='tuning_results.yaml'):\r\n     8\t    with open(filepath, 'r') as f:\r\n     9\t        return yaml.safe_load(f)\r\n    10\t\r\n    11\tdef calculate_ttc(distance, ego_speed, lead_speed):\r\n    12\t    if lead_speed is None or distance is None:\r\n    13\t        return None\r\n    14\t    relative_speed = ego_speed - lead_speed\r\n    15\t    if relative_speed <= 0:\r\n    16\t        return None\r\n    17\t    return distance / relative_speed\r\n    18\t\r\n    19\tdef run_simulation():\r\n    20\t    with open('vehicle_params.yaml', 'r') as f:\r\n    21\t        config = yaml.safe_load(f)\r\n    22\t    \r\n    23\t    tuning = load_tuning_results()\r\n    24\t    config['pid_speed'] = tuning['pid_speed']\r\n    25\t    config['pid_distance'] = tuning['pid_distance']\r\n    26\t    \r\n    27\t    print(f\"Speed PID: {tuning['pid_speed']}\")\r\n    28\t    print(f\"Distance PID: {tuning['pid_distance']}\")\r\n    29\t    \r\n    30\t    df = pd.read_csv('sensor_data.csv')\r\n    31\t    dt = config['simulation']['dt']\r\n    32\t    acc = AdaptiveCruiseControl(config)\r\n    33\t    acc.reset()\r\n    34\t    \r\n    35\t    ego_speed = 0.0\r\n    36\t    results = []\r\n    37\t    \r\n    38\t    for idx, row in df.iterrows():\r\n    39\t        time = row['time']\r\n    40\t        lead_speed = row['lead_speed'] if pd.notna(row['lead_speed']) else None\r\n    41\t        distance = row['distance'] if pd.notna(row['distance']) else None\r\n    42\t        \r\n    43\t        acc_cmd, mode, dist_error = acc.compute(ego_speed, lead_speed, distance, dt)\r\n    44\t        ego_speed = ego_speed + acc_cmd * dt\r\n    45\t        ego_speed = max(0, ego_speed)\r\n    46\t        ego_speed = min(50, ego_speed)\r\n    47\t        \r\n    48\t        ttc = calculate_ttc(distance, ego_speed, lead_speed)\r\n    49\t        \r\n    50\t        result = {\r\n    51\t            'time': time,\r\n    52\t            'ego_speed': ego_speed,\r\n    53\t            'acceleration_cmd': acc_cmd,\r\n    54\t            'mode': mode,\r\n    55\t            'distance_error': dist_error if dist_error is not None else '',\r\n    56\t            'distance': distance if distance is not None else '',\r\n    57\t            'ttc': ttc if ttc is not None else ''\r\n    58\t        }\r\n    59\t        results.append(result)\r\n    60\t    \r\n    61\t    results_df = pd.DataFrame(results)\r\n    62\t    results_df.to_csv('simulation_results.csv', index=False)\r\n    63\t    print(f\"Saved {len(results)} rows to simulation_results.csv\")\r\n    64\t    generate_report(results_df, config, tuning)\r\n    65\t\r\n    66\tdef generate_report(df, config, tuning):"]
[1003.644735, "o", "\r\n    67\t    set_speed = config['acc_settings']['set_speed']\r\n    68\t    speeds = pd.to_numeric(df['ego_speed'], errors='coerce').fillna(0)\r\n    69\t    \r\n    70\t    # Rise time\r\n    71\t    rise_end = None\r\n    72\t    for i, s in enumerate(speeds):\r\n    73\t        if s >= 0.9 * set_speed:\r\n    74\t            rise_end = i\r\n    75\t            break\r\n    76\t    rise_time = (rise_end * 0.1) if rise_end else None\r\n    77\t    \r\n    78\t    max_speed = speeds.max()\r\n    79\t    overshoot = max(0, ((max_speed - set_speed) / set_speed) * 100)\r\n    80\t    \r\n    81\t    # Speed SS error: use final cruise mode\r\n    82\t    cruise_df = df[(df['mode'] == 'cruise') & (df['time'] >= 147)]\r\n    83\t    if len(cruise_df) > 0:\r\n    84\t        ss_error = abs(cruise_df['ego_speed'].mean() - set_speed)\r\n    85\t    else:\r\n    86\t        ss_error = abs(speeds.iloc[-150:].mean() - set_speed)\r\n    87\t    \r\n    88\t    # Distance SS error: find most stable 100 consecutive rows in follow mode\r\n    89\t    follow_df = df[df['mode'] == 'follow'].copy()\r\n    90\t    follow_df['dist_err_num'] = pd.to_numeric(follow_df['distance_error'], errors='coerce')\r\n    91\t    follow_df['dist_num'] = pd.to_numeric(follow_df['distance'], errors='coerce')\r\n    92\t    \r\n    93\t    # Find window with minimum mean absolute error\r\n    94\t    best_start = 0\r\n    95\t    best_mean = float('inf')\r\n    96\t    window = 100\r\n    97\t    for i in range(len(follow_df) - window):\r\n    98\t        segment = follow_df.iloc[i:i+window]['dist_err_num']\r\n    99\t        mean_abs = segment.abs().mean()\r\n   100\t        if mean_abs < best_mean:\r\n   101\t            best_mean = mean_abs\r\n   102\t            best_start = i"]
