[43.397361, "o", "\u001b[?2004hroot@f72ab8c29d7d:~# "]
[119.456303, "i", "cat > /root/analyze_video.py << 'EOF'\nimport cv2\nimport numpy as np\nimport json\n\nVIDEO_PATH = '/root/input.mp4'\nOUTPUT_JSON = '/root/pred_instructions.json'\nOUTPUT_MASKS = '/root/pred_dyn_masks.npz'\nTARGET_FPS = 6\n\n# Read video\ncap = cv2.VideoCapture(VIDEO_PATH)\ntotal_frames = int(cap.get(cv2.CAP_PROP_FRAME_COUNT))\norig_fps = cap.get(cv2.CAP_PROP_FPS)\nW = int(cap.get(cv2.CAP_PROP_FRAME_WIDTH))\nH = int(cap.get(cv2.CAP_PROP_FRAME_HEIGHT))\n\nstep = int(orig_fps / TARGET_FPS)\nsample_ids = list(range(0, total_frames, step))\nif sample_ids[-1] != total_frames - 1:\n    sample_ids.append(total_frames - 1)\n\nprint(f\"Total frames: {total_frames}, Step: {step}, Samples: {len(sample_ids)}\")\n\n# Read all sampled frames as grayscale\nframes_gray = []\nfor idx in sample_ids:\n    cap.set(cv2.CAP_PROP_POS_FRAMES, idx)\n    ret, frame = cap.read()\n    if ret:\n        gray = cv2.cvtColor(frame, cv2.COLOR_BGR2GRAY)\n        frames_gray.append(gray)\n    else:\n        frames_gray.append(None)\ncap.release()\n\n# Egomotion estimation\ndef estimate_affine(prev_pts, curr_pts):\n    if len(prev_pts) < 4 or len(curr_pts) < 4:\n        return None\n    M, mask = cv2.estimateAffinePartial2D(prev_pts, curr_pts, method=cv2.RANSAC)\n    if M is None:\n        return None\n    return M\n\ndef decompose_affine(M):\n    if M is None:\n        return 0, 0, 0, 1\n    tx = M[0, 2]\n    ty = M[1, 2]\n    a = M[0, 0]\n    b = M[0, 1]\n    c = M[1, 0]\n    d = M[1, 1]\n    scale = np.sqrt(a**2 + b**2)\n    rot = np.arctan2(b, a)\n    return tx, ty, rot, scale\n\n# Thresholds normalized by resolution\nth_trans = max(W, H) * 0.01\nth_rot = 0.02\nth_scale = 0.02\n\n# Process each frame pair\nframe_labels = []\naffine_mats = [None]\n\nfor i in range(1, len(sample_ids)):\n    if frames_gray[i-1] is None or frames_gray[i] is None:\n        frame_labels.append([\"Stay\"])\n        affine_mats.append(None)\n        continue\n    \n    # Feature tracking\n    prev_pts = cv2.goodFeaturesToTrack(frames_gray[i-1], maxCorners=200, qualityLevel=0.01, minDistance=10)\n    if prev_pts is None or len(prev_pts) < 4:\n        frame_labels.append([\"Stay\"])\n        affine_mats.append(None)\n        continue\n    \n    curr_pts, status, _ = cv2.calcOpticalFlowPyrLK(frames_gray[i-1], frames_gray[i], prev_pts, None)\n    if curr_pts is None:\n        frame_labels.append([\"Stay\"])\n        affine_mats.append(None)\n        continue\n    \n    # Filter valid points\n    valid_prev = prev_pts[status.ravel() == 1]\n    valid_curr = curr_pts[status.ravel() == 1]\n    \n    if len(valid_prev) < 4:\n        frame_labels.append([\"Stay\"])\n        affine_mats.append(None)\n        continue\n    \n    M = estimate_affine(valid_prev, valid_curr)\n    affine_mats.append(M)\n    \n    if M is None:\n        frame_labels.append([\"Stay\"])\n        continue\n    \n    tx, ty, rot, scale = decompose_affine(M)\n    labels = []\n    \n    if abs(scale - 1) > th_scale:\n        labels.append(\"Dolly In\" if scale > 1 else \"Dolly Out\")\n    if abs(rot) > th_rot:\n        labels.append(\"Roll Right\" if rot > 0 else \"Roll Left\")\n    if abs(tx) > th_trans and abs(tx) >= abs(ty):\n        labels.append(\"Pan Left\" if tx > 0 else \"Pan Right\")\n    if abs(ty) > th_trans and abs(ty) > abs(tx):\n        labels.append(\"Tilt Up\" if ty > 0 else \"Tilt Down\")\n    \n    if not labels:\n        labels.append(\"Stay\")\n    frame_labels.append(labels)\n\n# Temporal smoothing with window=3\nsmoothed = frame_labels.copy()\nfor i in range(1, len(smoothed)):\n    vote = {}\n    for j in range(max(1, i-1), min(len(smoothed), i+2)):\n        for lbl in smoothed[j]:\n            vote[lbl] = vote.get(lbl, 0) + 1\n    smoothed[i] = [l for l, c in sorted(vote.items(), key=lambda x: -x[1])]\n\n# Merge consecutive identical labels\nintervals = {}\ni = 0\nwhile i < len(smoothed):\n    j = i\n    while j < len(smoothed) and smoothed[j] == smoothed[i]:\n        j += 1\n    key = f\"{i}->{j}\"\n    intervals[key] = smoothed[i]\n    i = j\n\n# Save JSON\nwith open(OUTPUT_JSON, 'w') as f:\n    json.dump(intervals, f, indent=2)\nprint(f\"Saved {OUTPUT_JSON}\")\n\n# Dynamic object masks\nprint(\"Generating dynamic object masks...\")\nmorph_open = cv2.getStructuringEle"]
[119.456448, "i", "ment(cv2.MORPH_ELLIPSE, (3, 3))\nmorph_close = cv2.getStructuringElement(cv2.MORPH_ELLIPSE, (7, 7))\nmin_area = max(500, H * W * 0.001)\n\nmasks_data = {'shape': np.array([H, W], dtype=np.int32)}\n\nfor i in range(len(sample_ids)):\n    if i == 0 or affine_mats[i] is None:\n        mask = np.zeros((H, W), dtype=bool)\n    else:\n        # Warp previous frame to current\n        M = affine_mats[i]\n        warped_prev = cv2.warpAffine(frames_gray[i-1], M, (W, H), flags=cv2.INTER_LINEAR, borderValue=0)\n        valid = cv2.warpAffine(np.ones((H, W), dtype=np.uint8), M, (W, H), flags=cv2.INTER_NEAREST) > 0\n        \n        if frames_gray[i] is None:\n            mask = np.zeros((H, W), dtype=bool)\n        else:\n            diff = cv2.absdiff(frames_gray[i], warped_prev)\n            vals = diff[valid]\n            \n            if len(vals) > 0:\n                median_val = np.median(vals)\n                mad = np.median(np.abs(vals - median_val))\n                thr = max(20, median_val + 3 * 1.4826 * mad)\n                raw = (diff > thr) & valid\n                \n                raw_u8 = (raw.astype(np.uint8) * 255)\n                m = cv2.morphologyEx(raw_u8, cv2.MORPH_OPEN, morph_open)\n                m = cv2.morphologyEx(m, cv2.MORPH_CLOSE, morph_close)\n                \n                n, cc, stats, _ = cv2.connectedComponentsWithStats(m, connectivity=8)\n                mask = np.zeros((H, W), dtype=bool)\n                for cid in range(1, n):\n                    if stats[cid, cv2.CC_STAT_AREA] >= min_area:\n                        mask |= (cc == cid)\n            else:\n                mask = np.zeros((H, W), dtype=bool)\n    \n    # Convert to CSR\n    rows, cols = np.nonzero(mask)\n    data = np.ones(len(rows), dtype=np.uint8)\n    indices = cols.astype(np.int32)\n    counts = np.bincount(rows, minlength=H)\n    indptr = np.cumsum(counts, dtype=np.int64)\n    indptr = np.insert(indptr, 0, 0)\n    \n    masks_data[f'f_{i}_data'] = data\n    masks_data[f'f_{i}_indices'] = indices\n    masks_data[f'f_{i}_indptr'] = indptr\n\n# Save masks\nnp.savez(OUTPUT_MASKS, **masks_data)\nprint(f\"Saved {OUTPUT_MASKS}\")\nprint(\"Done!\")\nEOF\n"]
