[42.179921, "o", "> "]
[42.180076, "o", "        gray = cv2.cvtColor(frame, cv2.COLOR_BGR2GRAY)\r\n\u001b[?2004l\r"]
[42.180149, "o", "\u001b[?2004h> "]
[42.180338, "o", "        frames_gray.append(gray)\r\n\u001b[?2004l\r\u001b[?2004h>     else:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[42.180376, "o", "        frames_gray.append(None)\r\n\u001b[?2004l\r"]
[42.180531, "o", "\u001b[?2004h> cap.release()\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r8\u001b[?2004h> "]
[42.180856, "o", "# Egomotion estimation\r\n\u001b[?2004l\r \u001b[?2004h> def estimate_affine(prev_pts, curr_pts):\r\n\u001b[?2004l\r \u001b[?2004h> "]
[42.181005, "o", "    if len(prev_pts) < 4 or len(curr_pts) < 4:\r\n\u001b[?2004l\r"]
[42.181137, "o", "\u001b[?2004h> "]
[42.181194, "o", "        return None\r\n\u001b[?2004l\r\u001b[?2004h> "]
[42.181494, "o", "    M, mask = cv2.estimateAffinePartial2D(prev_pts, curr_pts, method=cv2.RANSAC)\r\n\u001b[?2004l\r\u001b[?2004h"]
[42.18154, "o", "> "]
[42.18178, "o", "    if M is None:\r\n\u001b[?2004l\r\u001b[?2004h>         return None\r\n\u001b[?2004l\r\u001b[?2004h> "]
[42.181812, "o", "    return M\r\n\u001b[?2004l\r"]
[42.181831, "o", "\u001b[?2004h> "]
[42.181851, "o", "\r\n\u001b[?2004l\r"]
[42.181868, "o", "\u001b[?2004h> "]
[42.18202, "o", "def decompose_affine(M):\r\n\u001b[?2004l\r\u001b[?2004h"]
[42.182057, "o", "> "]
[42.182172, "o", "    if M is None:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[42.182302, "o", "        return 0, 0, 0, 1\r\n\u001b[?2004l\rd"]
[42.182371, "o", "\u001b[?2004h>     tx = M[0, 2]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[42.182444, "o", "    ty = M[1, 2]\r\n\u001b[?2004l\rt\u001b[?2004h"]
[42.182519, "o", "> "]
[42.182558, "o", "    a = M[0, 0]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[42.182642, "o", "    b = M[0, 1]\r\n\u001b[?2004l\rp.z\u001b[?2004h> "]
[42.182709, "o", "    c = M[1, 0]\r\n\u001b[?2004l\ry\u001b[?2004h"]
[42.182745, "o", "> "]
[42.182816, "o", "    d = M[1, 1]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[42.182933, "o", "    scale = np.sqrt(a**2 + b**2)\r\n\u001b[?2004l\r\u001b[?2004h"]
[42.182996, "o", "> "]
[42.183059, "o", "    rot = np.arctan2(b, a)\r\n\u001b[?2004l\r\u001b[?2004h"]
[42.183138, "o", "> "]
[42.183258, "o", "    return tx, ty, rot, scale\r\n\u001b[?2004l\r\u001b[?2004h> "]
[42.183298, "o", "\r\n\u001b[?2004l\rn\u001b[?2004h> "]
[42.183417, "o", "# Thresholds normalized by resolution\r\n\u001b[?2004l\r=\u001b[?2004h"]
[42.183457, "o", "> "]
[42.183583, "o", "th_trans = max(W, H) * 0.01\r\n\u001b[?2004l\r\u001b[?2004h> "]
[42.18364, "o", "th_rot = 0.02\r\n\u001b[?2004l\r\u001b[?2004h"]
[42.183729, "o", "> "]
[42.183757, "o", "th_scale = 0.02\r\n\u001b[?2004l\r"]
[42.183784, "o", "\u001b[?2004h> \r\n\u001b[?2004l\re"]
[42.183899, "o", "\u001b[?2004h> "]
[42.18396, "o", "# Process each frame pair\r\n\u001b[?2004l\r\u001b[?2004h> "]
[42.184029, "o", "frame_labels = []\r\n\u001b[?2004l\rt\u001b[?2004h"]
[42.184097, "o", "> "]
[42.184194, "o", "affine_mats = [None]\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r=\u001b[?2004h> "]
[42.184312, "o", "for i in range(1, len(sample_ids)):\r\n\u001b[?2004l\r"]
[42.184391, "o", "\u001b[?2004h> "]
[42.184599, "o", "    if frames_gray[i-1] is None or frames_gray[i] is None:\r\n\u001b[?2004l\r\u001b[?2004h"]
[42.184665, "o", "> "]
[42.184772, "o", "        frame_labels.append([\"Stay\"])\r\n\u001b[?2004l\r\u001b[?2004h"]
[42.184806, "o", "> "]
[42.184927, "o", "        affine_mats.append(None)\r\n\u001b[?2004l\r\u001b[?2004h"]
[42.184995, "o", "> "]
[42.185039, "o", "        continue\r\n\u001b[?2004l\rnp\u001b[?2004h>     \r\n\u001b[?2004l\r"]
[42.185124, "o", "\u001b[?2004h>     # Feature tracking\r\n"]
[42.18519, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[42.185549, "o", "    prev_pts = cv2.goodFeaturesToTrack(frames_gray[i-1], maxCorners=200, qualityLevel=0.01, minDistance=10)\r\n\u001b[?2004l\r"]
[42.185625, "o", "\u001b[?2004h> "]
[42.185736, "o", "    if prev_pts is None or len(prev_pts) < 4:\r\n\u001b[?2004l\r\u001b[?2004h"]
[42.185769, "o", "> "]
[42.185882, "o", "        frame_labels.append([\"Stay\"])\r\n\u001b[?2004l\r\u001b[?2004h"]
[42.185944, "o", "> "]
[42.186024, "o", "        affine_mats.append(None)\r\n\u001b[?2004l\rt\u001b[?2004h"]
[42.18606, "o", "> "]
[42.186138, "o", "        continue\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r"]
[42.186211, "o", "\u001b[?2004h> "]
[42.186514, "o", "    curr_pts, status, _ = cv2.calcOpticalFlowPyrLK(frames_gray[i-1], frames_gray[i], prev_pts, None)\r\n\u001b[?2004l\r"]
[42.186544, "o", "\u001b[?2004h> "]
[42.186618, "o", "    if curr_pts is None:\r\n\u001b[?2004l\rz"]
[42.186685, "o", "\u001b[?2004h> "]
[42.18678, "o", "        frame_labels.append([\"Stay\"])\r\n\u001b[?2004l\r"]
[42.186853, "o", "\u001b[?2004h> "]
[42.186938, "o", "        affine_mats.append(None)\r\n\u001b[?2004l\r"]
[42.186977, "o", "\u001b[?2004h> "]
[42.18701, "o", "        continue\r\n\u001b[?2004l\r\u001b[?2004h"]
[42.187119, "o", ">     \r\n\u001b[?2004l\r"]
[42.187186, "o", "\u001b[?2004h>     # Filter valid points\r\n\u001b[?2004l\r\u001b[?2004h> "]
[42.187247, "o", "    valid_prev = prev_pts[status.ravel() == 1]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[42.187311, "o", "    valid_curr = curr_pts[status.ravel() == 1]\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r"]
[42.187378, "o", "\u001b[?2004h> "]
[42.187437, "o", "    if len(valid_prev) < 4:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[42.187492, "o", "        frame_labels.append([\"Stay\"])\r\n\u001b[?2004l\r\u001b[?2004h> "]
[42.187549, "o", "        affine_mats.append(None)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[42.187583, "o", "        continue\r\n\u001b[?2004l\r\u001b[?2004h"]
[42.18766, "o", ">     \r\n\u001b[?2004l\r"]
[42.187698, "o", "\u001b[?2004h> "]
[42.187773, "o", "    M = estimate_affine(valid_prev, valid_curr)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[42.187831, "o", "    affine_mats.append(M)\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r"]
[42.187863, "o", "\u001b[?2004h>     if M is None:\r\n\u001b[?2004l\r"]
[42.187927, "o", "\u001b[?2004h> "]
[42.187985, "o", "        frame_labels.append([\"Stay\"])\r\n\u001b[?2004l\r\u001b[?2004h"]
[42.188018, "o", ">         continue\r\n\u001b[?2004l\r\u001b[?2004h"]
[42.188084, "o", ">     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[42.188145, "o", "    tx, ty, rot, scale = decompose_affine(M)\r\n\u001b[?2004l\r"]
[42.188235, "o", "\u001b[?2004h> "]
[42.18827, "o", "    labels = []\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r"]
[42.188302, "o", "\u001b[?2004h> "]
[42.188379, "o", "    if abs(scale - 1) > th_scale:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[42.18848, "o", "        labels.append(\"Dolly In\" if scale > 1 else \"Dolly Out\")\r\n\u001b[?2004l\r"]
[42.188546, "o", "\u001b[?2004h> "]
[42.188605, "o", "    if abs(rot) > th_rot:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[42.18866, "o", "        labels.append(\"Roll Right\" if rot > 0 else \"Roll Left\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[42.188747, "o", "    if abs(tx) > th_trans and abs(tx) >= abs(ty):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[42.188857, "o", "        labels.append(\"Pan Left\" if tx > 0 else \"Pan Right\")\r\n\u001b[?2004l\r"]
[42.188892, "o", "\u001b[?2004h> "]
[42.188966, "o", "    if abs(ty) > th_trans and abs(ty) > abs(tx):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[42.189061, "o", "        labels.append(\"Tilt Up\" if ty > 0 else \"Tilt Down\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[42.189131, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[42.189194, "o", ">     if not labels:\r\n\u001b[?2004l\r\u001b[?2004h"]
[42.189249, "o", ">         labels.append(\"Stay\")\r\n\u001b[?2004l\r"]
[42.189313, "o", "\u001b[?2004h> "]
[42.189373, "o", "    frame_labels.append(labels)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[42.189431, "o", "> "]
[42.189457, "o", "# Temporal smoothing with window=3\r\n\u001b[?2004l\r\u001b[?2004h> "]
[42.189529, "o", "smoothed = frame_labels.copy()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[42.189591, "o", "for i in range(1, len(smoothed)):\r\n\u001b[?2004l\r"]
[42.189642, "o", "\u001b[?2004h> "]
[42.1897, "o", "    vote = {}\r\n\u001b[?2004l\r\u001b[?2004h> "]
[42.18975, "o", "    for j in range(max(1, i-1), min(len(smoothed), i+2)):\r\n\u001b[?2004l\r\u001b[?2004h"]
[42.189809, "o", "> "]
[42.189865, "o", "        for lbl in smoothed[j]:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[42.189927, "o", "            vote[lbl] = vote.get(lbl, 0) + 1\r\n\u001b[?2004l\r\u001b[?2004h"]
[42.18998, "o", "> "]
[42.19005, "o", "    smoothed[i] = [l for l, c in sorted(vote.items(), key=lambda x: -x[1])]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[42.190083, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[42.190145, "o", "# Merge consecutive identical labels\r\n\u001b[?2004l\r"]
[42.190208, "o", "\u001b[?2004h> "]
[42.190281, "o", "intervals = {}\r\n\u001b[?2004l\r\u001b[?2004h> i = 0\r\n\u001b[?2004l\r\u001b[?2004h"]
[42.190315, "o", "> while i < len(smoothed):\r\n\u001b[?2004l\r\u001b[?2004h"]
[42.190378, "o", ">     j = i\r\n\u001b[?2004l\r\u001b[?2004h> "]
[42.190467, "o", "    while j < len(smoothed) and smoothed[j] == smoothed[i]:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[42.19052, "o", "        j += 1\r\n\u001b[?2004l\r\u001b[?2004h> "]
[42.19057, "o", "    key = f\"{i}->{j}\"\r\n\u001b[?2004l\r"]
[42.190625, "o", "\u001b[?2004h> "]
[42.190683, "o", "    intervals[key] = smoothed[i]\r\n\u001b[?2004l\r\u001b[?2004h"]
[42.190745, "o", ">     i = j\r\n\u001b[?2004l\r\u001b[?2004h"]
[42.190794, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> # Save JSON\r\n\u001b[?2004l\r\u001b[?2004h"]
[42.190819, "o", "> "]
[42.190896, "o", "with open(OUTPUT_JSON, 'w') as f:\r\n\u001b[?2004l\r\u001b[?2004h"]
[42.190919, "o", ">     json.dump(intervals, f, indent=2)\r\n\u001b[?2004l\r"]
[42.190974, "o", "\u001b[?2004h> "]
[42.191014, "o", "print(f\"Saved {OUTPUT_JSON}\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n"]
[42.191049, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[42.191156, "o", "# Dynamic object masks\r\n\u001b[?2004l\r\u001b[?2004h> "]
[42.191225, "o", "print(\"Generating dynamic object masks...\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[42.191287, "o", "morph_open = cv2.getStructuringElement(cv2.MORPH_ELLIPSE, (3, 3))\r\n\u001b[?2004l\r"]
[42.191335, "o", "\u001b[?2004h> "]
[42.191411, "o", "morph_close = cv2.getStructuringElement(cv2.MORPH_ELLIPSE, (7, 7))\r\n\u001b[?2004l\r"]
[42.191475, "o", "\u001b[?2004h> "]
[42.191509, "o", "min_area = max(500, H * W * 0.001)\r\n\u001b[?2004l\r"]
[42.191542, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[42.191619, "o", "> "]
[42.191676, "o", "masks_data = {'shape': np.array([H, W], dtype=np.int32)}\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[42.19174, "o", "\u001b[?2004h> "]
[42.19179, "o", "for i in range(len(sample_ids)):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[42.191852, "o", "    if i == 0 or affine_mats[i] is None:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[42.191904, "o", "        mask = np.zeros((H, W), dtype=bool)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[42.191934, "o", "    else:\r\n\u001b[?2004l\r\u001b[?2004h"]
[42.192003, "o", "> "]
[42.192053, "o", "        # Warp previous frame to current\r\n\u001b[?2004l\r\u001b[?2004h"]
[42.192119, "o", ">         M = affine_mats[i]\r\n\u001b[?2004l\r"]
[42.192193, "o", "\u001b[?2004h> "]
[42.19229, "o", "        warped_prev = cv2.warpAffine(frames_gray[i-1], M, (W, H), flags=cv2.INTER_LINEAR, borderValue=0)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[42.192448, "o", "        valid = cv2.warpAffine(np.ones((H, W), dtype=np.uint8), M, (W, H), flags=cv2.INTER_NEAREST) > 0\r\n\u001b[?2004l\r\u001b[?2004h> "]
[42.192507, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h"]
[42.19254, "o", "> "]
[42.192596, "o", "        if frames_gray[i] is None:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[42.192673, "o", "            mask = np.zeros((H, W), dtype=bool)\r\n\u001b[?2004l\r\u001b[?2004h"]
[42.19273, "o", ">         else:\r\n\u001b[?2004l\r"]
[42.192787, "o", "\u001b[?2004h> "]
[42.192848, "o", "            diff = cv2.absdiff(frames_gray[i], warped_prev)\r\n\u001b[?2004l\r\u001b[?2004h"]
[42.192895, "o", "> "]
[42.192951, "o", "            vals = diff[valid]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[42.193015, "o", "            \r\n\u001b[?2004l\r\u001b[?2004h> "]
[42.193049, "o", "            if len(vals) > 0:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[42.19312, "o", "                median_val = np.median(vals)\r\n\u001b[?2004l\r"]
[42.193179, "o", "\u001b[?2004h> "]
[42.193244, "o", "                mad = np.median(np.abs(vals - median_val))\r\n\u001b[?2004l\r\u001b[?2004h> "]
[42.193344, "o", "                thr = max(20, median_val + 3 * 1.4826 * mad)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[42.193421, "o", "                raw = (diff > thr) & valid\r\n\u001b[?2004l\r\u001b[?2004h> "]
[42.193472, "o", "                \r\n\u001b[?2004l\r\u001b[?2004h> "]
[42.193566, "o", "                raw_u8 = (raw.astype(np.uint8) * 255)\r\n\u001b[?2004l\r"]
[42.193624, "o", "\u001b[?2004h> "]
[42.193707, "o", "                m = cv2.morphologyEx(raw_u8, cv2.MORPH_OPEN, nmorph_open)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[42.193821, "o", "                m = cv2.morphologyEx(m, cv2.MORPH_CLOSE, nmorph_close)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[42.193909, "o", "                \r\n\u001b[?2004l\r\u001b[?2004h> "]
[42.194002, "o", "                n, cc, stats, _ = cv2.connectedComponentsWithStats(m, connectivity=8)\r\n\u001b[?2004l\r\u001b[?2004h"]
[42.194065, "o", "> "]
[42.194142, "o", "                mask = np.zeros((H, W), dtype=bool)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[42.194235, "o", "                for cid in range(1, n):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[42.194312, "o", "                    if stats[cid, cv2.CC_STAT_AREA] >= min_area:\r\n\u001b[?2004l\r\u001b[?2004h"]
[42.194373, "o", "> "]
[42.194444, "o", "                        mask |= (cc == cid)\r\n\u001b[?2004l\r"]
[42.194504, "o", "\u001b[?2004h>             else:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[42.194583, "o", "                mask = np.zeros((H, W), dtype=bool)\r\n\u001b[?2004l\r\u001b[?2004h"]
[42.194644, "o", ">     \r\n\u001b[?2004l\r"]
[42.194715, "o", "\u001b[?2004h>     # Convert to CSR\r\n\u001b[?2004l\r\u001b[?2004h"]
[42.194771, "o", ">     rows, cols = np.nonzero(mask)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[42.194836, "o", "    data = np.ones(len(rows), dtype=np.uint8)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[42.194906, "o", "    indices = cols.astype(np.int32)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[42.194988, "o", "    counts = np.bincount(rows, minlength=H)\r\n\u001b[?2004l\r"]
[42.195052, "o", "\u001b[?2004h> "]
[42.195122, "o", "    indptr = np.cumsum(counts, dtype=np.int64)\r\n\u001b[?2004l\r\u001b[?2004h> "]
