[308.406948, "o", "\u001b[?2004hroot@f72ab8c29d7d:~# "]
[377.614844, "i", "cat > /root/analyze_video.py << 'EOF'\nimport cv2\nimport numpy as np\nimport json\nfrom scipy import sparse\n\nVIDEO_PATH = '/root/input.mp4'\nOUTPUT_JSON = '/root/pred_instructions.json'\nOUTPUT_NPZ = '/root/pred_dyn_masks.npz'\n\ncap = cv2.VideoCapture(VIDEO_PATH)\ntotal_frames = int(cap.get(cv2.CAP_PROP_FRAME_COUNT))\nfps = cap.get(cv2.CAP_PROP_FPS)\nW = int(cap.get(cv2.CAP_PROP_FRAME_WIDTH))\nH = int(cap.get(cv2.CAP_PROP_FRAME_HEIGHT))\n\nprint(f\"Video: {total_frames} frames, {fps} fps, {W}x{H}\")\n\n# Sample at fps=6: step = 60/6 = 10\nstep = int(round(fps / 6))\nsample_ids = list(range(0, total_frames, step))\nif sample_ids[-1] != total_frames - 1:\n    sample_ids.append(total_frames - 1)\nprint(f\"Sampled {len(sample_ids)} frames: {sample_ids}\")\n\n# Read sampled frames\nframes = []\nfor idx in sample_ids:\n    cap.set(cv2.CAP_PROP_POS_FRAMES, idx)\n    ret, frame = cap.read()\n    if ret:\n        frames.append(cv2.cvtColor(frame, cv2.COLOR_BGR2GRAY))\n    else:\n        print(f\"Warning: failed to read frame {idx}\")\ncap.release()\n\n# Egomotion estimation\ndef estimate_motion(prev_gray, curr_gray):\n    # Feature detection\n    prev_pts = cv2.goodFeaturesToTrack(prev_gray, maxCorners=200, qualityLevel=0.01, minDistance=10)\n    if prev_pts is None or len(prev_pts) < 4:\n        return np.eye(2, 3, dtype=np.float64)\n    \n    curr_pts, status, _ = cv2.calcOpticalFlowPyrLK(prev_gray, curr_gray, prev_pts, None)\n    \n    # Filter valid points\n    valid_prev = prev_pts[status.ravel() == 1]\n    valid_curr = curr_pts[status.ravel() == 1]\n    \n    if len(valid_prev) < 4:\n        return np.eye(2, 3, dtype=np.float64)\n    \n    M, _ = cv2.estimateAffinePartial2D(valid_prev, valid_curr, method=cv2.RANSAC)\n    if M is None:\n        return np.eye(2, 3, dtype=np.float64)\n    return M\n\n# Parameters for motion classification\nth_trans = 2.0  # pixels per frame threshold\nth_rot = 0.01   # radians threshold\nth_scale = 0.005 # scale ratio threshold\n\ndef classify_motion(M):\n    tx = M[0, 2]\n    ty = M[1, 2]\n    a = M[0, 0]\n    b = M[0, 1]\n    scale = np.sqrt(a*a + b*b)\n    rot = np.arctan2(b, a)\n    \n    labels = []\n    # Dolly (scale change)\n    if abs(scale - 1) > th_scale:\n        labels.append(\"Dolly In\" if scale > 1 else \"Dolly Out\")\n    # Roll\n    if abs(rot) > th_rot:\n        labels.append(\"Roll Right\" if rot > 0 else \"Roll Left\")\n    # Pan (horizontal translation)\n    if abs(tx) > th_trans and abs(tx) >= abs(ty):\n        labels.append(\"Pan Left\" if tx > 0 else \"Pan Right\")\n    # Tilt (vertical translation)\n    if abs(ty) > th_trans and abs(ty) > abs(tx):\n        labels.append(\"Tilt Up\" if ty < 0 else \"Tilt Down\")\n    \n    if not labels:\n        labels.append(\"Stay\")\n    return labels\n\n# Process egomotion\nmotions = []\nfor i in range(1, len(frames)):\n    M = estimate_motion(frames[i-1], frames[i])\n    labels = classify_motion(M)\n    motions.append(labels)\n    print(f\"Frame {sample_ids[i-1]}->{sample_ids[i]}: {labels}\")\n\n# Compress to intervals\nintervals = {}\nif len(motions) > 0:\n    start = sample_ids[0]\n    current_labels = motions[0]\n    for i in range(1, len(motions)):\n        if motions[i] != current_labels:\n            intervals[f\"{start}->{sample_ids[i]}\"] = current_labels\n            start = sample_ids[i]\n            current_labels = motions[i]\n    intervals[f\"{start}->{sample_ids[-1]}\"] = current_labels\n\nprint(f\"\\nIntervals: {intervals}\")\n\nwith open(OUTPUT_JSON, 'w') as f:\n    json.dump(intervals, f, indent=2)\nprint(f\"Saved {OUTPUT_JSON}\")\n\n# Dynamic object masks\ndef compute_mask(prev_gray, curr_gray, M, min_area=100):\n    # Warp previous frame to current coordinate system\n    warped_prev = cv2.warpAffine(prev_gray, M, (W, H), flags=cv2.INTER_LINEAR, borderValue=0)\n    \n    # Valid region mask\n    valid_mask = cv2.warpAffine(np.ones((H, W), dtype=np.uint8), M, (W, H), flags=cv2.INTER_NEAREST) > 0\n    \n    # Difference\n    diff = cv2.absdiff(curr_gray, warped_prev)\n    \n    # Adaptive threshold on valid region\n    vals = diff[valid_mask]\n    if len(vals) == 0:\n        return np.zeros((H, W), dtype=bool)\n    median_val = np.median(vals)\n    mad = np.median(np.abs"]
[377.615033, "i", "(vals - median_val))\n    thr = max(20, median_val + 3 * 1.4826 * mad)\n    \n    raw = (diff > thr) & valid_mask\n    \n    # Morphology\n    kernel3 = cv2.getStructuringElement(cv2.MORPH_ELLIPSE, (3, 3))\n    kernel7 = cv2.getStructuringElement(cv2.MORPH_ELLIPSE, (7, 7))\n    m = cv2.morphologyEx(raw.astype(np.uint8) * 255, cv2.MORPH_OPEN, kernel3)\n    m = cv2.morphologyEx(m, cv2.MORPH_CLOSE, kernel7)\n    \n    # Connected components\n    n, cc, stats, _ = cv2.connectedComponentsWithStats(m, connectivity=8)\n    mask = np.zeros((H, W), dtype=bool)\n    for cid in range(1, n):\n        if stats[cid, cv2.CC_STAT_AREA] >= min_area:\n            mask |= (cc == cid)\n    \n    return mask\n\n# Identity transform for first frame (no motion)\nidentity_M = np.eye(2, 3, dtype=np.float64)\nmask_data = {'shape': np.array([H, W], dtype=np.int32)}\n\nfor i in range(len(frames)):\n    if i == 0:\n        # First frame: no motion yet, empty mask or detect against next\n        mask = np.zeros((H, W), dtype=bool)\n    else:\n        M = estimate_motion(frames[i-1], frames[i])\n        mask = compute_mask(frames[i-1], frames[i], M)\n    \n    # CSR encoding\n    rows, cols = np.nonzero(mask)\n    data = np.ones(len(rows), dtype=np.uint8)\n    indices = cols.astype(np.int32)\n    counts = np.bincount(rows, minlength=H)\n    indptr = np.concatenate([[0], np.cumsum(counts)]).astype(np.int32)\n    \n    mask_data[f'f_{i}_data'] = data\n    mask_data[f'f_{i}_indices'] = indices\n    mask_data[f'f_{i}_indptr'] = indptr\n    print(f\"Frame {sample_ids[i]}: mask with {mask.sum()} pixels\")\n\nnp.savez(OUTPUT_NPZ, **mask_data)\nprint(f\"\\nSaved {OUTPUT_NPZ}\")\nprint(\"Done!\")\nEOF\n"]
