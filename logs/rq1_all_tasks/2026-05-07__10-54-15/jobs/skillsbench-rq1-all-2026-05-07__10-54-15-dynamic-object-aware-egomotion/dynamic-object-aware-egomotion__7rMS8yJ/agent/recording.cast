[172.539807, "i", "python3 -c \"\nimport json, numpy as np, cv2\n\nVIDEO_PATH = '/root/input.mp4'\nINSTRUCTIONS_PATH = '/root/pred_instructions.json'\nMASKS_PATH = '/root/pred_dyn_masks.npz'\n\ncap = cv2.VideoCapture(VIDEO_PATH)\nn = int(cap.get(cv2.CAP_PROP_FRAME_COUNT))\nH = int(cap.get(cv2.CAP_PROP_FRAME_HEIGHT))\nW = int(cap.get(cv2.CAP_PROP_FRAME_WIDTH))\ncap.release()\n\nprint(f'Video: {n} frames, {H}x{W}')\n\nj = json.load(open(INSTRUCTIONS_PATH))\nfor k, v in j.items():\n    s, e = k.split('->')\n    assert s.isdigit() and e.isdigit(), f'Invalid key format: {k}'\n    s, e = int(s), int(e)\n    assert 0 <= s <= e < n, f'Index out of range: {k}'\n    for lbl in v:\n        assert isinstance(lbl, str) and lbl in ['Stay', 'Dolly In', 'Dolly Out', 'Pan Left', 'Pan Right', 'Tilt Up', 'Tilt Down', 'Roll Left', 'Roll Right']\nprint('JSON validation passed!')\n\nnpz = np.load(MASKS_PATH)\nassert npz['shape'][0] == H and npz['shape'][1] == W\nframes = 0\nwhile f'f_{frames}_data' in npz.files:\n    data = npz[f'f_{frames}_data']\n    indices = npz[f'f_{frames}_indices']\n    indptr = npz[f'f_{frames}_indptr']\n    assert len(indptr) == H + 1, f'Frame {frames}: bad indptr length'\n    assert indptr[-1] == indices.size, f'Frame {frames}: indptr[-1] != indices.size'\n    if indices.size > 0:\n        assert indices.min() >= 0 and indices.max() < W, f'Frame {frames}: indices out of range'\n    frames += 1\nprint(f'NPZ validation passed! {frames} frames processed.')\nprint('All validations passed!')\n\"\n"]
