[157.473389, "o", "Frame 3: nnz=136127, indptr_len=721, H+1=721\r\n"]
[157.473831, "o", "Frame 4: nnz=177926, indptr_len=721, H+1=721\r\n"]
[157.474319, "o", "Frame 5: nnz=171205, indptr_len=721, H+1=721\r\n"]
[157.474767, "o", "Frame 6: nnz=177353, indptr_len=721, H+1=721\r\n"]
[157.475224, "o", "Frame 7: nnz=171111, indptr_len=721, H+1=721\r\n"]
[157.475623, "o", "Frame 8: nnz=167391, indptr_len=721, H+1=721\r\n"]
[157.476025, "o", "Frame 9: nnz=169841, indptr_len=721, H+1=721\r\n"]
[157.476453, "o", "Frame 10: nnz=169551, indptr_len=721, H+1=721\r\n"]
[157.476797, "o", "Frame 11: nnz=157860, indptr_len=721, H+1=721\r\n"]
[157.477219, "o", "Frame 12: nnz=149399, indptr_len=721, H+1=721\r\n"]
[157.477568, "o", "Frame 13: nnz=114542, indptr_len=721, H+1=721\r\n"]
