[119.46752, "o", "    valid_curr = curr_pts[status.ravel() == 1]\r\n\u001b[?2004l\r"]
[119.467553, "o", "\u001b[?2004h>     \r\n\u001b[?2004l\r"]
[119.467626, "o", "\u001b[?2004h> "]
[119.467678, "o", "    if len(valid_prev) < 4:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[119.467754, "o", "        frame_labels.append([\"Stay\"])\r\n\u001b[?2004l\r"]
[119.467821, "o", "\u001b[?2004h> "]
[119.467884, "o", "        affine_mats.append(None)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[119.467981, "o", "        continue\r\n\u001b[?2004l\r\u001b[?2004h> "]
[119.468059, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[119.468133, "o", "    M = estimate_affine(valid_prev, valid_curr)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[119.468217, "o", "    affine_mats.append(M)\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h"]
[119.468251, "o", "> "]
[119.468291, "o", "    if M is None:\r\n\u001b[?2004l\r"]
[119.468405, "o", "\u001b[?2004h> "]
[119.468447, "o", "        frame_labels.append([\"Stay\"])\r\n\u001b[?2004l\r\u001b[?2004h>         continue\r\n\u001b[?2004l\r"]
[119.468487, "o", "\u001b[?2004h>     \r\n"]
[119.468586, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[119.468648, "o", "    tx, ty, rot, scale = decompose_affine(M)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[119.468708, "o", "    labels = []\r\n\u001b[?2004l\r"]
[119.46878, "o", "\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[119.46885, "o", "    if abs(scale - 1) > th_scale:\r\n\u001b[?2004l\r"]
[119.468912, "o", "\u001b[?2004h> "]
[119.468979, "o", "        labels.append(\"Dolly In\" if scale > 1 else \"Dolly Out\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[119.46905, "o", "> "]
[119.469112, "o", "    if abs(rot) > th_rot:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[119.469211, "o", "        labels.append(\"Roll Right\" if rot > 0 else \"Roll Left\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[119.469316, "o", "    if abs(tx) > th_trans and abs(tx) >= abs(ty):\r\n\u001b[?2004l\r\u001b[?2004h"]
[119.469384, "o", "> "]
[119.469458, "o", "        labels.append(\"Pan Left\" if tx > 0 else \"Pan Right\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[119.46952, "o", "> "]
[119.469583, "o", "    if abs(ty) > th_trans and abs(ty) > abs(tx):\r\n\u001b[?2004l\r\u001b[?2004h"]
[119.46964, "o", "> "]
[119.469727, "o", "        labels.append(\"Tilt Up\" if ty > 0 else \"Tilt Down\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[119.469811, "o", ">     \r\n\u001b[?2004l\r"]
[119.469865, "o", "\u001b[?2004h>     if not labels:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[119.469926, "o", "        labels.append(\"Stay\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[119.469964, "o", "> "]
[119.470051, "o", "    frame_labels.append(labels)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n"]
[119.470113, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[119.470191, "o", "# Temporal smoothing with window=3\r\n\u001b[?2004l\r"]
[119.470234, "o", "\u001b[?2004h> smoothed = frame_labels.copy()\r\n\u001b[?2004l\r"]
[119.470276, "o", "\u001b[?2004h> "]
[119.470373, "o", "for i in range(1, len(smoothed)):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[119.470423, "o", "    vote = {}\r\n\u001b[?2004l\r\u001b[?2004h> "]
[119.470526, "o", "    for j in range(max(1, i-1), min(len(smoothed), i+2)):\r\n\u001b[?2004l\r\u001b[?2004h"]
[119.470563, "o", "> "]
[119.470635, "o", "        for lbl in smoothed[j]:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[119.47073, "o", "            vote[lbl] = vote.get(lbl, 0) + 1\r\n\u001b[?2004l\r\u001b[?2004h"]
[119.470787, "o", "> "]
[119.470886, "o", "    smoothed[i] = [l for l, c in sorted(vote.items(), key=lambda x: -x[1])]\r\n\u001b[?2004l\r\u001b[?2004h"]
[119.470952, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
[119.470989, "o", "> "]
[119.471052, "o", "# Merge consecutive identical labels\r\n\u001b[?2004l\r\u001b[?2004h> "]
[119.471115, "o", "intervals = {}\r\n\u001b[?2004l\r\u001b[?2004h"]
[119.471191, "o", "> i = 0\r\n\u001b[?2004l\r\u001b[?2004h> "]
[119.471255, "o", "while i < len(smoothed):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[119.47131, "o", "    j = i\r\n\u001b[?2004l\r\u001b[?2004h> "]
[119.471397, "o", "    while j < len(smoothed) and smoothed[j] == smoothed[i]:\r\n\u001b[?2004l\r"]
[119.471433, "o", "\u001b[?2004h> "]
[119.471504, "o", "        j += 1\r\n\u001b[?2004l\r\u001b[?2004h> "]
[119.471545, "o", "    key = f\"{i}->{j}\"\r\n\u001b[?2004l\r"]
[119.471623, "o", "\u001b[?2004h> "]
[119.471689, "o", "    intervals[key] = smoothed[i]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[119.471752, "o", "    i = j\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[119.47181, "o", "> # Save JSON\r\n\u001b[?2004l\r\u001b[?2004h> "]
[119.471881, "o", "with open(OUTPUT_JSON, 'w') as f:\r\n\u001b[?2004l\r\u001b[?2004h"]
[119.471936, "o", "> "]
[119.471981, "o", "    json.dump(intervals, f, indent=2)\r\n\u001b[?2004l\r"]
[119.47202, "o", "\u001b[?2004h> "]
[119.472081, "o", "print(f\"Saved {OUTPUT_JSON}\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[119.472121, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
[119.472315, "o", "> "]
[119.472363, "o", "# Dynamic object masks\r\n\u001b[?2004l\r\u001b[?2004h> print(\"Generating dynamic object masks...\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[119.472454, "o", "morph_open = cv2.getStructuringElement(cv2.MORPH_ELLIPSE, (3, 3))\r\n\u001b[?2004l\r\u001b[?2004h"]
[119.472531, "o", "> "]
[119.472603, "o", "morph_close = cv2.getStructuringElement(cv2.MORPH_ELLIPSE, (7, 7))\r\n\u001b[?2004l\r\u001b[?2004h"]
[119.472668, "o", "> "]
[119.472735, "o", "min_area = max(500, H * W * 0.001)\r\n\u001b[?2004l\r\u001b[?2004h"]
[119.472791, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[119.472875, "o", "masks_data = {'shape': np.array([H, W], dtype=np.int32)}\r\n\u001b[?2004l\r\u001b[?2004h"]
[119.472915, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
[119.472986, "o", "> "]
[119.473053, "o", "for i in range(len(sample_ids)):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[119.473122, "o", "    if i == 0 or affine_mats[i] is None:\r\n\u001b[?2004l\r\u001b[?2004h"]
[119.473209, "o", "> "]
[119.473281, "o", "        mask = np.zeros((H, W), dtype=bool)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[119.47332, "o", "    else:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[119.473406, "o", "        # Warp previous frame to current\r\n\u001b[?2004l\r\u001b[?2004h"]
[119.473471, "o", "> "]
[119.473539, "o", "        M = affine_mats[i]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[119.473685, "o", "        warped_prev = cv2.warpAffine(frames_gray[i-1], M, (W, H), flags=cv2.INTER_LINEAR, borderValue=0)\r\n\u001b[?2004l\r\u001b[?2004h"]
[119.473728, "o", "> "]
[119.473884, "o", "        valid = cv2.warpAffine(np.ones((H, W), dtype=np.uint8), M, (W, H), flags=cv2.INTER_NEAREST) > 0\r\n\u001b[?2004l\r\u001b[?2004h"]
[119.473932, "o", ">         \r\n\u001b[?2004l\r\u001b[?2004h"]
[119.474004, "o", "> "]
[119.474069, "o", "        if frames_gray[i] is None:\r\n\u001b[?2004l\r\u001b[?2004h"]
[119.474123, "o", "> "]
[119.474161, "o", "            mask = np.zeros((H, W), dtype=bool)\r\n\u001b[?2004l\r"]
[119.474239, "o", "\u001b[?2004h>         else:\r\n\u001b[?2004l\r\u001b[?2004h"]
[119.474296, "o", "> "]
[119.474389, "o", "            diff = cv2.absdiff(frames_gray[i], warped_prev)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[119.474464, "o", "            vals = diff[valid]\r\n\u001b[?2004l\r\u001b[?2004h"]
[119.474501, "o", "> "]
[119.474584, "o", "            \r\n\u001b[?2004l\r\u001b[?2004h> "]
[119.474653, "o", "            if len(vals) > 0:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[119.474729, "o", "                median_val = np.median(vals)\r\n\u001b[?2004l\r\u001b[?2004h"]
[119.474795, "o", "> "]
[119.47487, "o", "                mad = np.median(np.abs(vals - median_val))\r\n\u001b[?2004l\r\u001b[?2004h"]
[119.474912, "o", "> "]
[119.475008, "o", "                thr = max(20, median_val + 3 * 1.4826 * mad)\r\n\u001b[?2004l\r\u001b[?2004h"]
[119.475068, "o", "> "]
[119.475138, "o", "                raw = (diff > thr) & valid\r\n\u001b[?2004l\r\u001b[?2004h"]
[119.475201, "o", ">                 \r\n\u001b[?2004l\r"]
[119.475271, "o", "\u001b[?2004h> "]
[119.475331, "o", "                raw_u8 = (raw.astype(np.uint8) * 255)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[119.475463, "o", "                m = cv2.morphologyEx(raw_u8, cv2.MORPH_OPEN, morph_open)\r\n\u001b[?2004l\r\u001b[?2004h"]
[119.47553, "o", "> "]
[119.475619, "o", "                m = cv2.morphologyEx(m, cv2.MORPH_CLOSE, morph_close)\r\n\u001b[?2004l\r"]
[119.475686, "o", "\u001b[?2004h> "]
[119.475755, "o", "                \r\n\u001b[?2004l\r\u001b[?2004h> "]
[119.475866, "o", "                n, cc, stats, _ = cv2.connectedComponentsWithStats(m, connectivity=8)\r\n\u001b[?2004l\r\u001b[?2004h"]
[119.475927, "o", "> "]
[119.475996, "o", "                mask = np.zeros((H, W), dtype=bool)\r\n\u001b[?2004l\r\u001b[?2004h"]
[119.476055, "o", "> "]
[119.476129, "o", "                for cid in range(1, n):\r\n\u001b[?2004l\r\u001b[?2004h"]
[119.476211, "o", "> "]
[119.476278, "o", "                    if stats[cid, cv2.CC_STAT_AREA] >= min_area:\r\n\u001b[?2004l\r\u001b[?2004h"]
[119.47632, "o", "> "]
[119.476398, "o", "                        mask |= (cc == cid)\r\n\u001b[?2004l\r\u001b[?2004h"]
[119.476439, "o", "> "]
[119.47652, "o", "            else:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[119.47659, "o", "                mask = np.zeros((H, W), dtype=bool)\r\n\u001b[?2004l\r\u001b[?2004h"]
[119.476694, "o", ">     \r\n\u001b[?2004l\r"]
[119.476767, "o", "\u001b[?2004h>     # Convert to CSR\r\n\u001b[?2004l\r\u001b[?2004h> "]
[119.476831, "o", "    rows, cols = np.nonzero(mask)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[119.476909, "o", "    data = np.ones(len(rows), dtype=np.uint8)\r\n\u001b[?2004l\r\u001b[?2004h"]
[119.476979, "o", "> "]
[119.477061, "o", "    indices = cols.astype(np.int32)\r\n\u001b[?2004l\r\u001b[?2004h"]
[119.477132, "o", "> "]
[119.477216, "o", "    counts = np.bincount(rows, minlength=H)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[119.477298, "o", "    indptr = np.cumsum(counts, dtype=np.int64)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[119.477359, "o", "    indptr = np.insert(indptr, 0, 0)\r\n\u001b[?2004l\r"]
[119.47743, "o", "\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h"]
[119.477476, "o", "> "]
[119.477559, "o", "    masks_data[f'f_{i}_data'] = data\r\n\u001b[?2004l\r\u001b[?2004h> "]
[119.477622, "o", "    masks_data[f'f_{i}_indices'] = indices\r\n\u001b[?2004l\r\u001b[?2004h> "]
[119.477706, "o", "    masks_data[f'f_{i}_indptr'] = indptr\r\n\u001b[?2004l\r\u001b[?2004h"]
[119.477745, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
[119.477828, "o", "> "]
[119.477868, "o", "# Save masks\r\n\u001b[?2004l\r\u001b[?2004h> "]
[119.477954, "o", "np.savez(OUTPUT_MASKS, **masks_data)\r\n\u001b[?2004l\r\u001b[?2004h"]
[119.478019, "o", "> print(f\"Saved {OUTPUT_MASKS}\")\r\n\u001b[?2004l\r"]
[119.478086, "o", "\u001b[?2004h> print(\"Done!\")\r\n\u001b[?2004l\r"]
[119.478152, "o", "\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
[119.479178, "o", "\u001b[?2004hroot@f72ab8c29d7d:~# "]
[120.454581, "i", "python3 /root/analyze_video.py\n"]
[120.454764, "o", "python3 /root/analyze_video.py\r\n\u001b[?2004l\r"]
[120.680922, "o", "Total frames: 207, Step: 10, Samples: 22\r\n"]
[124.957465, "o", "Saved /root/pred_instructions.json\r\nGenerating dynamic object masks...\r\n"]
[125.713521, "o", "Saved /root/pred_dyn_masks.npz\r\nDone!\r\n"]
[125.738873, "o", "\u001b[?2004hroot@f72ab8c29d7d:~# "]
[156.778426, "i", "cat /root/pred_instructions.json\n"]
[156.778638, "o", "cat /root/pred_instructions.json\r\n\u001b[?2004l\r"]
[156.779517, "o", "{\r\n  \"0->1\": [\r\n    \"Dolly In\",\r\n    \"Pan Right\"\r\n  ],\r\n  \"1->4\": [\r\n    \"Stay\"\r\n  ],\r\n  \"4->5\": [\r\n    \"Stay\",\r\n    \"Pan Right\"\r\n  ],\r\n  \"5->18\": [\r\n    \"Pan Right\",\r\n    \"Stay\"\r\n  ],\r\n  \"18->20\": [\r\n    \"Pan Right\",\r\n    \"Stay\",\r\n    \"Dolly In\"\r\n  ],\r\n  \"20->21\": [\r\n    \"Stay\",\r\n    \"Pan Right\",\r\n    \"Dolly In\"\r\n  ]\r\n}"]
[156.779732, "o", "\u001b[?2004hroot@f72ab8c29d7d:~# "]
[157.284548, "i", "python3 -c \"\nimport numpy as np\nnpz = np.load('/root/pred_dyn_masks.npz')\nprint('Keys:', list(npz.keys())[:10], '...')\nprint('Shape:', npz['shape'])\nprint('Frame count keys:')\nframes = 0\nwhile f'f_{frames}_data' in npz.files:\n    d = npz[f'f_{frames}_data']\n    ind = npz[f'f_{frames}_indptr']\n    print(f'Frame {frames}: nnz={d.size}, indptr_len={len(ind)}, H+1={ind.shape[0]}')\n    frames += 1\nprint(f'Total frames: {frames}')\n\"\n"]
[157.284742, "o", "python3 -c \"\r\n\u001b[?2004l\r"]
[157.284803, "o", "\u001b[?2004h> "]
[157.284917, "o", "import numpy as np\r\n\u001b[?2004l\r\u001b[?2004h> npz = np.load('/root/pred_dyn_masks.npz')\r\n\u001b[?2004l\r"]
[157.284944, "o", "\u001b[?2004h"]
[157.28497, "o", "> "]
[157.285053, "o", "print('Keys:', list(npz.keys())[:10], '...')\r\n\u001b[?2004l\r"]
[157.285084, "o", "\u001b[?2004h> "]
[157.285255, "o", "print('Shape:', npz['shape'])\r\n\u001b[?2004l\r\u001b[?2004h> "]
[157.285367, "o", "print('Frame count keys:')\r\n\u001b[?2004l\r\u001b[?2004h> frames = 0\r\n\u001b[?2004l\r\u001b[?2004h> "]
[157.285556, "o", "while f'f_{frames}_data' in npz.files:\r\n\u001b[?2004l\r\u001b[?2004h>     d = npz[f'f_{frames}_data']\r\n\u001b[?2004l\r\u001b[?2004h> "]
[157.28565, "o", "    ind = npz[f'f_{frames}_indptr']\r\n\u001b[?2004l\r\u001b[?2004h> "]
[157.285849, "o", "    print(f'Frame {frames}: nnz={d.size}, indptr_len={len(ind)}, H+1={ind.shape[0]}')\r\n\u001b[?2004l\r"]
[157.285893, "o", "\u001b[?2004h>     frames += 1\r\n\u001b[?2004l\r\u001b[?2004h"]
[157.285926, "o", "> "]
[157.28623, "o", "print(f'Total frames: {frames}')\r\n\u001b[?2004l\r\u001b[?2004h> \"\r\n\u001b[?2004l\r"]
[157.471077, "o", "Keys: ['shape', 'f_0_data', 'f_0_indices', 'f_0_indptr', 'f_1_data', 'f_1_indices', 'f_1_indptr', 'f_2_data', 'f_2_indices', 'f_2_indptr'] ...\r\n"]
