[377.627426, "o", "print(f\"\\nIntervals: {intervals}\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[377.627494, "o", "with open(OUTPUT_JSON, 'w') as f:\r\n\u001b[?2004l\r\u001b[?2004h"]
[377.627535, "o", "> "]
[377.627604, "o", "    json.dump(intervals, f, indent=2)\r\n\u001b[?2004l\r\u001b[?2004h"]
[377.627685, "o", "> "]
[377.62774, "o", "print(f\"Saved {OUTPUT_JSON}\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[377.627801, "o", "# Dynamic object masks\r\n\u001b[?2004l\r\u001b[?2004h"]
[377.627882, "o", "> "]
[377.62796, "o", "def compute_mask(prev_gray, curr_gray, M, min_area=100):\r\n\u001b[?2004l\r\u001b[?2004h"]
[377.628045, "o", "> "]
[377.62811, "o", "    # Warp previous frame to current coordinate system\r\n\u001b[?2004l\r"]
[377.628153, "o", "\u001b[?2004h> "]
[377.628299, "o", "    warped_prev = cv2.warpAffine(prev_gray, M, (W, H), flags=cv2.INTER_LINEAR, borderValue=0)\r\n\u001b[?2004l\r\u001b[?2004h"]
[377.62834, "o", ">     \r\n\u001b[?2004l\r"]
[377.62845, "o", "\u001b[?2004h> "]
[377.628524, "o", "    # Valid region mask\r\n\u001b[?2004l\r\u001b[?2004h> "]
[377.628622, "o", "    valid_mask = cv2.warpAffine(np.ones((H, W), dtype=np.uint8), M, (W, H), flags=cv2.INTER_NEAREST) > 0\r\n\u001b[?2004l\r\u001b[?2004h"]
[377.628688, "o", ">     \r\n\u001b[?2004l\r"]
[377.628756, "o", "\u001b[?2004h>     # Difference\r\n\u001b[?2004l\r\u001b[?2004h"]
[377.628819, "o", "> "]
[377.628876, "o", "    diff = cv2.absdiff(curr_gray, warped_prev)\r\n\u001b[?2004l\r\u001b[?2004h"]
[377.628957, "o", ">     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[377.629014, "o", "    # Adaptive threshold on valid region\r\n\u001b[?2004l\r\u001b[?2004h"]
[377.629085, "o", "> "]
[377.629165, "o", "    vals = diff[valid_mask]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[377.629234, "o", "    if len(vals) == 0:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[377.629307, "o", "        return np.zeros((H, W), dtype=bool)\r\n\u001b[?2004l\r\u001b[?2004h"]
[377.629346, "o", "> "]
[377.629419, "o", "    median_val = np.median(vals)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[377.629515, "o", "    mad = np.median(np.abs(vals - median_val))\r\n\u001b[?2004l\r\u001b[?2004h"]
[377.629576, "o", "> "]
[377.62964, "o", "    thr = max(20, median_val + 3 * 1.4826 * mad)\r\n\u001b[?2004l\r\u001b[?2004h"]
[377.629712, "o", ">     \r\n\u001b[?2004l\r"]
[377.629747, "o", "\u001b[?2004h> "]
[377.629833, "o", "    raw = (diff > thr) & valid_mask\r\n\u001b[?2004l\r"]
[377.629874, "o", "\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h>     # Morphology\r\n\u001b[?2004l\r"]
[377.629961, "o", "\u001b[?2004h> "]
[377.630045, "o", "    kernel3 = cv2.getStructuringElement(cv2.MORPH_ELLIPSE, (3, 3))\r\n\u001b[?2004l\r\u001b[?2004h"]
[377.630114, "o", "> "]
[377.6302, "o", "    kernel7 = cv2.getStructuringElement(cv2.MORPH_ELLIPSE, (7, 7))\r\n\u001b[?2004l\r\u001b[?2004h"]
[377.630271, "o", "> "]
[377.630367, "o", "    m = cv2.morphologyEx(raw.astype(np.uint8) * 255, cv2.MORPH_OPEN, kernel3)\r\n\u001b[?2004l\r\u001b[?2004h"]
[377.630437, "o", "> "]
[377.630503, "o", "    m = cv2.morphologyEx(m, cv2.MORPH_CLOSE, kernel7)\r\n\u001b[?2004l\r\u001b[?2004h"]
[377.630569, "o", ">     \r\n\u001b[?2004l\r"]
[377.630636, "o", "\u001b[?2004h>     # Connected components\r\n\u001b[?2004l\r"]
[377.630679, "o", "\u001b[?2004h> "]
[377.630783, "o", "    n, cc, stats, _ = cv2.connectedComponentsWithStats(m, connectivity=8)\r\n\u001b[?2004l\r\u001b[?2004h"]
[377.630851, "o", "> "]
[377.630912, "o", "    mask = np.zeros((H, W), dtype=bool)\r\n\u001b[?2004l\r\u001b[?2004h"]
[377.63098, "o", "> "]
[377.631051, "o", "    for cid in range(1, n):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[377.631121, "o", "        if stats[cid, cv2.CC_STAT_AREA] >= min_area:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[377.631194, "o", "            mask |= (cc == cid)\r\n\u001b[?2004l\r\u001b[?2004h"]
[377.631233, "o", ">     \r\n\u001b[?2004l\r"]
[377.631268, "o", "\u001b[?2004h> "]
[377.63137, "o", "    return mask\r\n\u001b[?2004l\r\u001b[?2004h"]
[377.631444, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[377.631517, "o", "# Identity transform for first frame (no motion)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[377.631577, "o", "identity_M = np.eye(2, 3, dtype=np.float64)\r\n\u001b[?2004l\r"]
[377.631637, "o", "\u001b[?2004h> "]
[377.631697, "o", "mask_data = {'shape': np.array([H, W], dtype=np.int32)}\r\n\u001b[?2004l\r\u001b[?2004h"]
[377.631775, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
[377.631836, "o", "> for i in range(len(frames)):\r\n\u001b[?2004l\r"]
[377.631875, "o", "\u001b[?2004h>     if i == 0:\r\n\u001b[?2004l\r"]
[377.631956, "o", "\u001b[?2004h> "]
[377.632046, "o", "        # First frame: no motion yet, empty mask or detect against next\r\n\u001b[?2004l\r\u001b[?2004h"]
[377.632102, "o", "> "]
[377.632191, "o", "        mask = np.zeros((H, W), dtype=bool)\r\n\u001b[?2004l\r\u001b[?2004h"]
[377.632233, "o", ">     else:\r\n\u001b[?2004l\r\u001b[?2004h"]
[377.632275, "o", "> "]
[377.632361, "o", "        M = estimate_motion(frames[i-1], frames[i])\r\n\u001b[?2004l\r\u001b[?2004h"]
[377.632434, "o", "> "]
[377.632494, "o", "        mask = compute_mask(frames[i-1], frames[i], M)\r\n\u001b[?2004l\r\u001b[?2004h"]
[377.632562, "o", ">     \r\n\u001b[?2004l\r"]
[377.632601, "o", "\u001b[?2004h>     # CSR encoding\r\n\u001b[?2004l\r"]
[377.632686, "o", "\u001b[?2004h> "]
[377.63276, "o", "    rows, cols = np.nonzero(mask)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[377.632828, "o", "    data = np.ones(len(rows), dtype=np.uint8)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[377.632919, "o", "    indices = cols.astype(np.int32)\r\n\u001b[?2004l\r\u001b[?2004h"]
[377.632958, "o", "> "]
[377.633035, "o", "    counts = np.bincount(rows, minlength=H)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[377.633173, "o", "    indptr = np.concatenate([[0], np.cumsum(counts)]).astype(np.int32)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[377.633212, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[377.63325, "o", "> "]
[377.633332, "o", "    mask_data[f'f_{i}_data'] = data\r\n\u001b[?2004l\r\u001b[?2004h> "]
[377.633418, "o", "    mask_data[f'f_{i}_indices'] = indices\r\n\u001b[?2004l\r\u001b[?2004h"]
[377.633474, "o", "> "]
[377.633523, "o", "    mask_data[f'f_{i}_indptr'] = indptr\r\n\u001b[?2004l\r"]
[377.633587, "o", "\u001b[?2004h> "]
[377.633685, "o", "    print(f\"Frame {sample_ids[i]}: mask with {mask.sum()} pixels\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[377.633746, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
[377.633786, "o", "> "]
[377.633864, "o", "np.savez(OUTPUT_NPZ, **mask_data)\r\n\u001b[?2004l\r\u001b[?2004h"]
[377.633916, "o", "> print(f\"\\nSaved {OUTPUT_NPZ}\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[377.633954, "o", "> "]
[377.633991, "o", "print(\"Done!\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[377.634073, "o", "> EOF\r\n\u001b[?2004l\r"]
[377.63502, "o", "\u001b[?2004hroot@f72ab8c29d7d:~# "]
[378.113974, "i", "python3 /root/analyze_video.py\n"]
[378.114293, "o", "python3 /root/analyze_video.py\r\n\u001b[?2004l\r"]
[378.292584, "o", "Traceback (most recent call last):\r\n  File \"/root/analyze_video.py\", line 4, in <module>\r\n"]
[378.292749, "o", "    from scipy import sparse\r\nModuleNotFoundError: No module named 'scipy'\r\n"]
[378.30786, "o", "\u001b[?2004hroot@f72ab8c29d7d:~# "]
