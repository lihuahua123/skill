ion\": \"Defendant state\",\n    \"page\": 2,\n    \"value\": \"CA\"\n  },\n  {\n    \"field_id\": \"SC-100[0].Page2[0].List2[0].item2[0].DefendantZip1[0]\",\n    \"description\": \"Defendant zip\",\n    \"page\": 2,\n    \"value\": \"94086\"\n  },\n  {\n    \"field_id\": \"SC-100[0].Page2[0].List2[0].item2[0].DefendantPhone1[0]\",\n    \"description\": \"Defendant phone\",\n    \"page\": 2,\n    \"value\": \"5125658878\"\n  },\n  {\n    \"field_id\": \"SC-100[0].Page2[0].List3[0].PlaintiffClaimAmount1[0]\",\n    \"description\": \"Claim amount\",\n    \"page\": 2,\n    \"value\": \"$1,500.00\"\n  },\n  {\n    \"field_id\": \"SC-100[0].Page3[0].List3[0].Lib[0].Date1[0]\",\n    \"description\": \"Start date of incident\",\n    \"page\": 3,\n    \"value\": \"2025-09-30\"\n  },\n  {\n    \"field_id\": \"SC-100[0].Page3[0].List3[0].Lib[0].Date2[0]\",\n    \"description\": \"End date of incident\",\n    \"page\": 3,\n    \"value\": \"2026-01-19\"\n  },\n  {\n    \"field_id\": \"SC-100[0].Page3[0].List3[0].Lic[0].FillField1[0]\",\n    \"description\": \"Description of claim\",\n    \"page\": 3,\n    \"value\": \"Defendant failed to return my security deposit of $1500 based on the signed roommate sublease contract after moving out. I have asked him to return the money multiple times via text but he is not responding. The amount is listed on the signed roommate sublease contract.\"\n  },\n  {\n    \"field_id\": \"SC-100[0].Page4[0].Sign[0].Date1[0]\",\n    \"description\": \"Signature date\",\n    \"page\": 4,\n    \"value\": \"2026-01-19\"\n  },\n  {\n    \"field_id\": \"SC-100[0].Page4[0].Sign[0].PlaintiffName1[0]\",\n    \"description\": \"Plaintiff signature name\",\n    \"page\": 4,\n    \"value\": \"Joyce He\"\n  }\n]\nEOF\n"]
